{{define "services"}}
<div class="space-y-4">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <p class="t-eyebrow">Service inventory</p>
      <h2 class="text-lg font-semibold" style="color:rgb(var(--text))">Backends and port ranges</h2>
      <p class="mt-1 text-sm" style="color:rgb(var(--muted))">Each service defines the backend IP and ports available for route mappings.</p>
    </div>
    <a href="/app/routes/new" class="r-btn-primary inline-flex items-center justify-center px-3.5 py-2 rounded-lg text-sm font-medium shadow-sm">New route</a>
  </div>
{{range .Services}}
  <section class="r-card">
    {{if eq .Status "suspended"}}
    <div class="flex items-start gap-2 p-3 rounded-lg mb-3" style="background:rgb(var(--warning-weak)/.4);border:1px solid rgb(var(--warning)/.3)">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5" style="color:rgb(var(--warning))" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div>
        <p class="text-xs font-semibold" style="color:rgb(var(--warning))">Service suspended</p>
        <p class="text-xs mt-0.5" style="color:rgb(var(--warning))">All routes are offline until the suspension is lifted.</p>
      </div>
    </div>
    {{end}}
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <a href="/app/services/{{.ID}}" class="text-lg font-semibold truncate hover:opacity-80 transition cursor-pointer" style="color:rgb(var(--text))">{{.Name}}</a>
          {{if eq .Status "active"}}<span class="r-pill r-pill-success">active</span>{{else if eq .Status "suspended"}}<span class="r-pill r-pill-warning">suspended</span>{{else}}<span class="r-pill r-pill-danger">{{.Status}}</span>{{end}}
          {{if eq .PlanKind "npm"}}<span class="r-pill r-pill-info">editable backend</span>{{else}}<span class="r-pill r-pill-neutral">provider managed</span>{{end}}
        </div>
        <p class="mt-1 text-sm truncate" style="color:rgb(var(--muted))">{{.PlanName}} · {{.RouteCount}} mapped routes</p>
      </div>
      <a href="/app/routes/new?service_id={{.ID}}" class="r-btn-primary inline-flex items-center justify-center px-3.5 py-2 rounded-lg text-sm font-medium shadow-sm">Add route</a>
    </div>

    <dl class="grid grid-cols-2 lg:grid-cols-4 gap-3 mt-5 text-sm">
      <div class="rounded-xl p-3 ring-1" style="background:rgb(var(--surface-2));border-color:rgb(var(--border))">
        <dt class="t-eyebrow">Backend IP</dt>
        <dd class="mt-1 font-mono break-all" style="color:rgb(var(--text))">{{.BackendIP}}</dd>
      </div>
      <div class="rounded-xl p-3 ring-1" style="background:rgb(var(--surface-2));border-color:rgb(var(--border))">
        <dt class="t-eyebrow">Allowed ports</dt>
        <dd class="mt-1 font-mono" style="color:rgb(var(--text))">{{.PortStart}}-{{.PortEnd}}</dd>
      </div>
      <div class="rounded-xl p-3 ring-1" style="background:rgb(var(--surface-2));border-color:rgb(var(--border))">
        <dt class="t-eyebrow">Plan</dt>
        <dd class="mt-1" style="color:rgb(var(--text))">{{.PlanName}}</dd>
      </div>
      <div class="rounded-xl p-3 ring-1" style="background:rgb(var(--surface-2));border-color:rgb(var(--border))">
        <dt class="t-eyebrow">Routes</dt>
        <dd class="mt-1 tabular-nums" style="color:rgb(var(--text))">{{.RouteCount}}</dd>
      </div>
    </dl>

    {{if gt .MaxDomains 0}}
    <div class="mt-3">
      <div class="flex items-center justify-between text-xs mb-1" style="color:rgb(var(--muted))">
        <span>Routes used</span>
        <span class="font-medium" style="color:rgb(var(--text))">{{.RouteCount}} / {{.MaxDomains}}</span>
      </div>
      <div class="w-full h-1.5 rounded-full overflow-hidden" style="background:rgb(var(--surface-2))">
        <div class="h-full rounded-full {{if ge .RouteCount .MaxDomains}}bg-rose-500{{else if gt .RouteCountPct 50}}bg-amber-400{{else}}bg-emerald-500{{end}} transition-all"
             style="width: {{.RouteCountPct}}%"></div>
      </div>
    </div>
    {{end}}

    <div class="mt-2 flex flex-wrap gap-1.5">
      {{if .SSLEnabled}}<span class="r-pill r-pill-success">SSL</span>{{end}}
      {{if .WebsocketEnabled}}<span class="r-pill r-pill-info">WebSocket</span>{{end}}
      {{if .PathRouting}}<span class="r-pill r-pill-neutral">Path routing</span>{{end}}
      {{if gt .RateLimitRPM 0}}<span class="r-pill r-pill-warning">{{.RateLimitRPM}} req/min</span>{{end}}
    </div>

    {{if .Notes}}
    <div class="mt-2 p-3 rounded-lg text-xs ring-1" style="background:rgb(var(--warning-weak)/.4);color:rgb(var(--warning));border-color:rgb(var(--warning)/.3)">
      <span class="font-medium">Note:</span> {{.Notes}}
    </div>
    {{end}}

    {{if eq .PlanKind "npm"}}
    <details class="mt-4 rounded-xl p-4 ring-1" style="background:rgb(var(--surface-2));border-color:rgb(var(--border))">
      <summary class="cursor-pointer text-sm font-medium" style="color:rgb(var(--accent))">Edit backend IP</summary>
      <form method="POST" action="/app/services/{{.ID}}/edit" class="mt-4 grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-3 text-sm">
        <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
        <div>
          <label class="t-eyebrow block mb-1.5">Backend IP</label>
          <input name="backend_ip" value="{{.BackendIP}}" required class="w-full px-3 py-2 rounded-lg border-0 ring-1 focus:ring-2 focus:ring-[rgb(var(--accent))] outline-none" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
        </div>
        <div class="flex items-end">
          <button class="r-btn-primary w-full sm:w-auto px-4 py-2 rounded-lg text-sm font-medium">Save</button>
        </div>
      </form>
    </details>
    {{end}}
  </section>
{{else}}
  <section class="r-card py-12 text-center">
    <div class="mx-auto h-12 w-12 rounded-2xl grid place-items-center" style="background:rgb(var(--surface-2));color:rgb(var(--muted))">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
    </div>
    <h3 class="mt-4 font-semibold" style="color:rgb(var(--text))">No active services</h3>
    <p class="mx-auto mt-1 max-w-md text-sm leading-6" style="color:rgb(var(--muted))">A service must be active before routes can be created. Once your provider assigns one, its backend IP and allowed ports will appear here.</p>
  </section>
{{end}}
</div>
{{end}}
