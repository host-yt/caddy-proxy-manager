{{define "client_route_logs"}}
<div class="space-y-4 max-w-5xl">
  <div class="flex items-start justify-between gap-3">
    <div>
      <a href="/app/routes" class="text-xs transition-colors" style="color:rgb(var(--muted))">← routes</a>
      <h2 class="text-lg font-semibold mt-0.5" style="color:rgb(var(--text))">
        Access logs
        {{if .Domain}}<span class="text-sm font-normal font-mono ml-1" style="color:rgb(var(--muted))">{{.Domain}}</span>{{end}}
      </h2>
    </div>
    {{if .RouteID}}
    <a href="/app/routes/{{.RouteID}}/logs/export.csv" class="r-btn-secondary cursor-pointer">Download CSV</a>
    {{end}}
  </div>

  {{if .Error}}
  <div class="hpg-alert-err text-sm">{{.Error}}</div>
  {{end}}

  <!-- Stat cards -->
  <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    <!-- Requests / status buckets -->
    <div class="r-card">
      <p class="t-eyebrow">Requests, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        <span class="t-display">{{.AnalyticsTotal}}</span>
        <span class="text-xs" style="color:rgb(var(--muted))">total</span>
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .StatusBuckets}}
        <span class="r-pill {{if eq .Bucket "2xx"}}r-pill-success{{else if eq .Bucket "3xx"}}r-pill-warning{{else if or (eq .Bucket "4xx") (eq .Bucket "5xx")}}r-pill-danger{{else}}r-pill-neutral{{end}}">
          {{.Bucket}} {{.Count}}
        </span>
        {{else}}
        <span class="r-pill r-pill-neutral">no traffic</span>
        {{end}}
      </div>
    </div>

    <!-- Transfer -->
    <div class="r-card">
      <p class="t-eyebrow">Transfer, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        {{$tb := .BytesSummary.TotalBytes}}
        {{if ge $tb 1073741824}}
        <span class="t-display">{{printf "%.1f" (divf $tb 1073741824)}}</span>
        <span class="text-xs" style="color:rgb(var(--muted))">GB</span>
        {{else if ge $tb 1048576}}
        <span class="t-display">{{printf "%.1f" (divf $tb 1048576)}}</span>
        <span class="text-xs" style="color:rgb(var(--muted))">MB</span>
        {{else if ge $tb 1024}}
        <span class="t-display">{{printf "%.1f" (divf $tb 1024)}}</span>
        <span class="text-xs" style="color:rgb(var(--muted))">KB</span>
        {{else}}
        <span class="t-display">{{$tb}}</span>
        <span class="text-xs" style="color:rgb(var(--muted))">B</span>
        {{end}}
      </div>
      {{if gt .BytesSummary.AvgBytes 0}}
      <p class="mt-1 text-xs" style="color:rgb(var(--muted))">avg {{formatBytes .BytesSummary.AvgBytes}}/req</p>
      {{end}}
      {{if gt .BytesSummary.TotalBytesReq 0}}
      <p class="mt-0.5 text-xs" style="color:rgb(var(--muted))">&#8593; {{formatBytes .BytesSummary.TotalBytesReq}} upload</p>
      {{end}}
    </div>

    <!-- Protocol -->
    <div class="r-card">
      <p class="t-eyebrow">Protocol, 24h</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .ProtoBreakdown}}
        <span class="r-pill {{if eq .Proto "h2"}}r-pill-info{{else if eq .Proto "h3"}}r-pill-info{{else}}r-pill-neutral{{end}}">
          {{.Proto}} {{.Count}}
        </span>
        {{else}}
        <span class="r-pill r-pill-neutral">no data</span>
        {{end}}
      </div>
    </div>

    <!-- Top paths -->
    <div class="r-card">
      <p class="t-eyebrow">Top paths, 24h</p>
      <div class="mt-3 space-y-2">
        {{range .TopPaths}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono text-xs" style="color:rgb(var(--text))" title="{{.Path}}">{{.Path}}</span>
          <span class="r-pill r-pill-neutral tabular-nums flex-shrink-0">{{.Count}}</span>
        </div>
        {{else}}
        <p class="text-xs" style="color:rgb(var(--muted))">No path data yet.</p>
        {{end}}
      </div>
    </div>

    <!-- Top IPs -->
    {{if .TopRemoteIPs}}
    <div class="r-card">
      <p class="t-eyebrow">Top IPs, 24h</p>
      <ul class="mt-3 divide-y" style="border-color:rgb(var(--border))">
        {{range .TopRemoteIPs}}
        <li class="flex items-center justify-between gap-2 py-1.5">
          <span class="text-sm font-mono truncate min-w-0" style="color:rgb(var(--text))">{{.RemoteIP}}</span>
          <span class="text-xs shrink-0" style="color:rgb(var(--muted))">{{.Count}}</span>
        </li>
        {{end}}
      </ul>
    </div>
    {{end}}

    <!-- Top ASNs -->
    {{if .TopASNOrgs}}
    <div class="r-card">
      <p class="t-eyebrow">Top ASNs, 24h</p>
      <ul class="mt-3 divide-y" style="border-color:rgb(var(--border))">
        {{range .TopASNOrgs}}
        <li class="flex items-center justify-between gap-2 py-1.5">
          <span class="text-sm font-medium truncate min-w-0" style="color:rgb(var(--text))" title="{{.Org}}">{{.Org}}</span>
          <span class="text-xs shrink-0" style="color:rgb(var(--muted))">{{.Count}}</span>
        </li>
        {{end}}
      </ul>
    </div>
    {{end}}
  </section>

  {{if .BandwidthDays}}
  <section class="r-card p-4">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="t-eyebrow">Bandwidth · last 7 days</h3>
      <span class="text-sm font-semibold" style="color:rgb(var(--text))">{{formatBytes .BandwidthTotal7d}}</span>
    </div>
    <div class="flex items-end gap-1.5" style="height:48px">
      {{range .BandwidthDays}}
      {{$pct := divf .Bytes $.MaxDayBytes}}
      {{$h := mulf $pct 48.0}}
      <div class="flex-1 flex flex-col items-center gap-0.5 h-full justify-end" title="{{.Label}}: {{formatBytes .Bytes}}">
        <div class="w-full rounded-t transition-all cursor-default" style="background:rgb(var(--accent));height: {{printf "%.0f" $h}}px; min-height: 2px"></div>
        <span class="text-[9px] leading-none select-none" style="color:rgb(var(--muted))">{{.ShortLabel}}</span>
      </div>
      {{end}}
    </div>
  </section>
  {{end}}

  {{if gt .Bandwidth30dTotal 0}}
  <section class="r-card p-4">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="t-eyebrow">Bandwidth · last 30 days</h3>
      <span class="text-sm font-semibold" style="color:rgb(var(--text))">{{formatBytes .Bandwidth30dTotal}}</span>
    </div>
    <div class="flex items-end gap-0.5" style="height:48px">
      {{range .Bandwidth30dDays}}
      {{$pct := divf .Bytes $.MaxDay30dBytes}}
      {{$h := mulf $pct 48.0}}
      <div class="flex-1 flex flex-col items-center gap-0.5 h-full justify-end" title="{{.Label}}: {{formatBytes .Bytes}}">
        <div class="w-full rounded-t transition-all cursor-default" style="background:rgb(var(--accent-info,var(--accent)));height: {{printf "%.0f" $h}}px; min-height: 2px"></div>
      </div>
      {{end}}
    </div>
  </section>
  {{end}}

  {{if not .Entries}}
  <div class="r-card text-sm text-center py-12" style="color:rgb(var(--muted))">
    No log entries yet. Entries appear here once Caddy starts forwarding requests to this route.
  </div>
  {{end}}

  <!-- Log table -->
  <section class="r-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead class="text-left" style="border-bottom:1px solid rgb(var(--border))">
          <tr>
            <th class="px-4 py-2.5 font-medium text-xs whitespace-nowrap" style="color:rgb(var(--muted))">Time</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Method</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Proto</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Path</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Status</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Latency</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">↓ Resp</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Remote IP</th>
            <th class="px-4 py-2.5 font-medium text-xs" style="color:rgb(var(--muted))">Country</th>
          </tr>
        </thead>
        <tbody class="divide-y" style="border-color:rgb(var(--border))">
          {{range .Entries}}
          <tr class="hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors">
            <td class="px-4 py-2 text-xs whitespace-nowrap font-mono" style="color:rgb(var(--muted))">{{.TS.Format "2006-01-02 15:04:05"}}</td>
            <td class="px-4 py-2"><span class="hpg-method-badge text-xs font-mono font-semibold">{{.Method}}</span></td>
            <td class="px-4 py-2 text-xs font-mono" style="color:rgb(var(--muted))">{{if .Proto}}{{.Proto}}{{else}}-{{end}}</td>
            <td class="px-4 py-2 font-mono text-xs max-w-xs truncate" style="color:rgb(var(--text))" title="{{.URI}}">{{.URI}}</td>
            <td class="px-4 py-2">
              <span class="r-pill font-mono text-xs font-semibold
                {{if lt .Status 300}}r-pill-success
                {{else if lt .Status 400}}r-pill-warning
                {{else}}r-pill-danger{{end}}">
                {{.Status}}
              </span>
            </td>
            <td class="px-4 py-2 text-xs font-mono" style="color:rgb(var(--muted))">{{.LatencyMS}}ms</td>
            <td class="px-4 py-2 text-xs font-mono" style="color:rgb(var(--muted))">{{if .BytesResp}}{{formatBytes .BytesResp}}{{else}}-{{end}}</td>
            <td class="px-4 py-2 text-xs font-mono" style="color:rgb(var(--muted))">{{.RemoteIP}}</td>
            <td class="px-4 py-2 text-xs font-mono" style="color:rgb(var(--muted))">{{if .Country}}{{.Country}}{{else}}-{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{if .Entries}}
    <div class="px-4 py-2 text-xs" style="border-top:1px solid rgb(var(--border));color:rgb(var(--muted))">
      Showing {{len .Entries}} entries.
      <a href="?" class="ml-1" style="color:rgb(var(--accent))">Refresh</a>
    </div>
    {{end}}
  </section>
</div>
{{end}}
