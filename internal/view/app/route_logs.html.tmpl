{{define "client_route_logs"}}
<div class="space-y-4 max-w-5xl">
  <div class="flex items-start justify-between gap-3">
    <div>
      <a href="/app/routes" class="text-xs text-slate-500 hover:text-indigo-600 transition-colors">← routes</a>
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mt-0.5">
        Access logs
        {{if .Domain}}<span class="text-sm font-normal font-mono text-slate-500 dark:text-slate-400 ml-1">{{.Domain}}</span>{{end}}
      </h2>
    </div>
    {{if .RouteID}}
    <a href="/app/routes/{{.RouteID}}/logs/export.csv" class="hpg-btn-sm bg-slate-100 hover:bg-slate-200 dark:bg-zinc-700 dark:hover:bg-zinc-600 text-slate-700 dark:text-slate-200 transition-colors cursor-pointer">Download CSV</a>
    {{end}}
  </div>

  {{if .Error}}
  <div class="hpg-alert-err text-sm">{{.Error}}</div>
  {{end}}

  <!-- Stat cards -->
  <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    <!-- Requests / status buckets -->
    <div class="hpg-card">
      <p class="hpg-eyebrow">Requests, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        <span class="hpg-stat-num">{{.AnalyticsTotal}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">total</span>
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .StatusBuckets}}
        <span class="hpg-pill {{if eq .Bucket "2xx"}}hpg-pill-ok{{else if eq .Bucket "3xx"}}hpg-pill-warn{{else if or (eq .Bucket "4xx") (eq .Bucket "5xx")}}hpg-pill-err{{else}}hpg-pill-muted{{end}}">
          {{.Bucket}} {{.Count}}
        </span>
        {{else}}
        <span class="hpg-pill hpg-pill-muted">no traffic</span>
        {{end}}
      </div>
    </div>

    <!-- Transfer -->
    <div class="hpg-card">
      <p class="hpg-eyebrow">Transfer, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        {{$tb := .BytesSummary.TotalBytes}}
        {{if ge $tb 1073741824}}
        <span class="hpg-stat-num">{{printf "%.1f" (divf $tb 1073741824)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">GB</span>
        {{else if ge $tb 1048576}}
        <span class="hpg-stat-num">{{printf "%.1f" (divf $tb 1048576)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">MB</span>
        {{else if ge $tb 1024}}
        <span class="hpg-stat-num">{{printf "%.1f" (divf $tb 1024)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">KB</span>
        {{else}}
        <span class="hpg-stat-num">{{$tb}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">B</span>
        {{end}}
      </div>
      {{if gt .BytesSummary.AvgBytes 0}}
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">avg {{.BytesSummary.AvgBytes}} B/req</p>
      {{end}}
    </div>

    <!-- Protocol -->
    <div class="hpg-card">
      <p class="hpg-eyebrow">Protocol, 24h</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .ProtoBreakdown}}
        <span class="hpg-pill {{if eq .Proto "h2"}}hpg-pill-indigo{{else if eq .Proto "h3"}}hpg-pill-violet{{else}}hpg-pill-muted{{end}}">
          {{.Proto}} {{.Count}}
        </span>
        {{else}}
        <span class="hpg-pill hpg-pill-muted">no data</span>
        {{end}}
      </div>
    </div>

    <!-- Top paths -->
    <div class="hpg-card">
      <p class="hpg-eyebrow">Top paths, 24h</p>
      <div class="mt-3 space-y-2">
        {{range .TopPaths}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono text-xs text-slate-700 dark:text-slate-300" title="{{.Path}}">{{.Path}}</span>
          <span class="hpg-pill hpg-pill-muted tabular-nums flex-shrink-0">{{.Count}}</span>
        </div>
        {{else}}
        <p class="text-xs text-slate-500 dark:text-slate-400">No path data yet.</p>
        {{end}}
      </div>
    </div>
  </section>

  {{if .BandwidthDays}}
  <section class="hpg-card p-4">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="hpg-eyebrow">Bandwidth · last 7 days</h3>
      <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">{{formatBytes .BandwidthTotal7d}}</span>
    </div>
    <div class="flex items-end gap-1.5" style="height:48px">
      {{range .BandwidthDays}}
      {{$pct := divf .Bytes $.MaxDayBytes}}
      {{$h := mulf $pct 48.0}}
      <div class="flex-1 flex flex-col items-center gap-0.5 h-full justify-end" title="{{.Label}}: {{formatBytes .Bytes}}">
        <div class="w-full rounded-t bg-indigo-400 dark:bg-indigo-500 transition-all cursor-default"
             style="height: {{printf "%.0f" $h}}px; min-height: 2px"></div>
        <span class="text-[9px] text-slate-400 leading-none select-none">{{.ShortLabel}}</span>
      </div>
      {{end}}
    </div>
  </section>
  {{end}}

  {{if gt .Bandwidth30dTotal 0}}
  <section class="hpg-card p-4">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="hpg-eyebrow">Bandwidth · last 30 days</h3>
      <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">{{formatBytes .Bandwidth30dTotal}}</span>
    </div>
    <div class="flex items-end gap-0.5" style="height:48px">
      {{range .Bandwidth30dDays}}
      {{$pct := divf .Bytes $.MaxDay30dBytes}}
      {{$h := mulf $pct 48.0}}
      <div class="flex-1 flex flex-col items-center gap-0.5 h-full justify-end" title="{{.Label}}: {{formatBytes .Bytes}}">
        <div class="w-full rounded-t bg-sky-400 dark:bg-sky-500 transition-all cursor-default"
             style="height: {{printf "%.0f" $h}}px; min-height: 2px"></div>
      </div>
      {{end}}
    </div>
  </section>
  {{end}}

  {{if not .Entries}}
  <div class="hpg-card text-sm text-slate-500 dark:text-slate-400 text-center py-12">
    No log entries yet. Entries appear here once Caddy starts forwarding requests to this route.
  </div>
  {{end}}

  <!-- Log table -->
  <section class="hpg-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-slate-100 dark:border-zinc-800 text-left">
          <tr>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs whitespace-nowrap">Time</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Method</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Proto</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Path</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Status</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Latency</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Remote IP</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Country</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
          {{range .Entries}}
          <tr class="hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors">
            <td class="px-4 py-2 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap font-mono">{{.TS.Format "2006-01-02 15:04:05"}}</td>
            <td class="px-4 py-2"><span class="hpg-method-badge text-xs font-mono font-semibold">{{.Method}}</span></td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{if .Proto}}{{.Proto}}{{else}}-{{end}}</td>
            <td class="px-4 py-2 font-mono text-xs text-slate-700 dark:text-slate-300 max-w-xs truncate" title="{{.URI}}">{{.URI}}</td>
            <td class="px-4 py-2">
              <span class="inline-block px-1.5 py-0.5 rounded text-xs font-semibold font-mono
                {{if lt .Status 300}}text-emerald-700 bg-emerald-50 dark:text-emerald-400 dark:bg-emerald-500/10
                {{else if lt .Status 400}}text-amber-700 bg-amber-50 dark:text-amber-400 dark:bg-amber-500/10
                {{else}}text-rose-700 bg-rose-50 dark:text-rose-400 dark:bg-rose-500/10{{end}}">
                {{.Status}}
              </span>
            </td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{.LatencyMS}}ms</td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{.RemoteIP}}</td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{if .Country}}{{.Country}}{{else}}-{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{if .Entries}}
    <div class="px-4 py-2 border-t border-slate-100 dark:border-zinc-800 text-xs text-slate-400">
      Showing {{len .Entries}} entries.
      <a href="?" class="text-indigo-500 hover:underline ml-1">Refresh</a>
    </div>
    {{end}}
  </section>
</div>
{{end}}
