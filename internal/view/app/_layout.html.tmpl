{{define "layout.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full" data-theme="{{.Data.Theme}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="csrf-token" content="{{.Data.CSRF}}">
<title>{{.Data.Title}} - Hostyt Proxy</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<link rel="stylesheet" href="/static/css/enhance.css">
<script nonce="{{.Data.CSPNonce}}">(function(){var t=localStorage.getItem('theme');if(!t)t='dark';if(t==='dark')document.documentElement.classList.add('dark');else document.documentElement.classList.remove('dark');})();</script>
<!-- Palette theme bootstrap: client-side pick applies before paint, even before the ui_theme cookie round-trips. Allowlist-guarded so a tampered key cannot inject an arbitrary slug. -->
<script nonce="{{.Data.CSPNonce}}">(function(){try{var ok={default:1,midnight:1,ocean:1,forest:1,violet:1,sunset:1,nord:1,mono:1};var p=localStorage.getItem('ui_theme');if(p&&ok[p]&&p!==document.documentElement.dataset.theme)document.documentElement.dataset.theme=p;}catch(e){}})();</script>
{{if .Data.Brand.FaviconURL}}<link rel="icon" href="{{.Data.Brand.FaviconURL}}">{{end}}
<script src="/static/js/sheet.js" nonce="{{.Data.CSPNonce}}" defer></script>
<script src="/static/js/rowactions.js" nonce="{{.Data.CSPNonce}}" defer></script>
<style>
  /* Global form-control dark-mode safety net (see install/_layout for context). */
  input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  select, textarea { color: rgb(var(--c-slate-900)); }
  .dark input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  .dark select, .dark textarea {
    background-color: rgb(var(--c-zinc-800));
    border-color: rgb(var(--c-zinc-700));
    color: rgb(var(--c-zinc-100));
  }
  .dark input::placeholder, .dark textarea::placeholder { color: rgb(var(--c-zinc-500)); }
</style>
</head>
<body class="h-full" style="background:rgb(var(--bg));color:rgb(var(--text))">

<!-- Mobile overlay -->
<div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/40 backdrop-blur-sm hidden" data-action="close-sidebar"></div>

<!-- Sidebar -->
<aside id="sidebar" class="fixed inset-y-0 left-0 z-40 flex flex-col w-64 backdrop-blur border-r -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-in-out" style="background:rgb(var(--surface)/.95);border-color:rgb(var(--border))">

  <!-- Brand -->
  <div class="flex items-center gap-2.5 px-4 py-4 border-b shrink-0" style="border-color:rgb(var(--border))">
    {{if .Data.Brand.LogoURLLight}}<img src="{{.Data.Brand.LogoURLLight}}" alt="" class="h-5 dark:hidden">{{end}}
    {{if .Data.Brand.LogoURLDark}}<img src="{{.Data.Brand.LogoURLDark}}" alt="" class="h-5 hidden dark:inline-block">{{end}}
    {{if not .Data.Brand.LogoURLLight}}<span class="w-8 h-8 rounded-xl bg-[rgb(var(--accent))] shrink-0 flex items-center justify-center shadow-sm shadow-[rgb(var(--accent)/.18)]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </span>{{end}}
    <span class="font-semibold text-sm tracking-tight truncate" style="color:rgb(var(--text))">{{if .Data.Brand.BrandName}}{{.Data.Brand.BrandName}}{{else}}Hostyt Proxy{{end}}</span>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto py-3 px-2 space-y-0.5">

    <div data-nav-group="ops">
    <button type="button" class="nav-group-btn mb-1 px-2"><span class="nav-eyebrow text-[10px]">Operations</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
    <div class="nav-group-body space-y-0.5 pb-1">

    <a href="/app" class="nav-link {{if eq .Page "dashboard"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Dashboard
    </a>

    <a href="/app/services" class="nav-link {{if eq .Page "services"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
      Services
    </a>

    <a href="/app/routes" class="nav-link {{if or (eq .Page "routes_list") (eq .Page "route_new")}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      Routes
    </a>

    {{if $.Data.Features.Tunnels}}<a href="/app/tunnels" class="nav-link {{if eq .Page "tunnels"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Tunnels
    </a>{{end}}

    <a href="/app/worldmap" class="nav-link {{if eq .Page "worldmap"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      Traffic map
    </a>

    </div></div>

    <div data-nav-group="account">
    <button type="button" class="nav-group-btn mb-1 px-2"><span class="nav-eyebrow text-[10px]">Account</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
    <div class="nav-group-body space-y-0.5 pb-1">

    <a href="/app/account" class="nav-link {{if eq .Page "account"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Account
    </a>

    <a href="/app/2fa" class="nav-link {{if eq .Page "twofa"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
      Security
    </a>

    {{if $.Data.Features.APITokens}}<a href="/app/api-keys" class="nav-link {{if eq .Page "api_keys"}}is-active{{end}}">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
      API Keys
    </a>{{end}}

    </div></div>
  </nav>

  <!-- Sidebar footer -->
  <div class="border-t px-3 py-3 shrink-0" style="border-color:rgb(var(--border))">
    <div class="flex items-center gap-2 mb-3 min-w-0">
      <div class="w-7 h-7 rounded-full text-[11px] font-semibold flex items-center justify-center shrink-0 uppercase select-none" style="background:rgb(var(--accent)/.15);color:rgb(var(--accent))">
        {{printf "%.1s" .Data.Email}}
      </div>
      <span class="text-xs truncate min-w-0" style="color:rgb(var(--text))">{{.Data.Email}}</span>
    </div>
    <div class="flex items-center justify-between">
      <button type="button" data-theme-toggle title="Toggle theme"
        class="r-btn-ghost h-8 w-8 p-0">
        <span id="icon-moon">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
        <span id="icon-sun" class="hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
      </button>
      <form method="POST" action="/auth/logout">
        <input type="hidden" name="csrf_token" value="{{.Data.CSRF}}">
        <button class="text-xs text-slate-500 dark:text-slate-400 hover:text-rose-600 dark:hover:text-rose-400 transition-colors duration-150 cursor-pointer">Sign out</button>
      </form>
    </div>
    <p class="text-[10px] text-slate-400 dark:text-slate-600 text-center mt-2">Made with ❤️ in 🇺🇦 &amp; 🇵🇱</p>
  </div>
</aside>

<!-- Main content column -->
<div class="min-h-full flex flex-col lg:pl-64">

  {{if .Data.ImpersonatorEmail}}
  <div class="bg-amber-100 dark:bg-amber-900/40 border-b border-amber-300 dark:border-amber-700 text-amber-900 dark:text-amber-200 text-xs shrink-0">
    <div class="px-6 py-2 flex items-center justify-between gap-3">
      <span>Viewing as <strong>{{.Data.Email}}</strong> (admin: {{.Data.ImpersonatorEmail}}). All actions are audit-attributed to the admin.</span>
      <form method="POST" action="/auth/end-impersonation">
        <input type="hidden" name="csrf_token" value="{{.Data.CSRF}}">
        <button class="px-2 py-0.5 rounded bg-amber-600 text-white hover:bg-amber-700 text-xs font-medium cursor-pointer">Back to admin</button>
      </form>
    </div>
  </div>
  {{end}}

  <!-- Mobile top bar (hamburger) -->
  <header class="sticky top-0 z-20 border-b px-4 py-3 flex items-center gap-3 lg:hidden shrink-0" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
    <button data-action="open-sidebar" class="cursor-pointer" style="color:rgb(var(--muted))" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <span class="font-semibold text-sm truncate" style="color:rgb(var(--text))">{{.Data.Title}}</span>
  </header>

  <!-- Desktop top bar -->
  <header class="hidden lg:flex sticky top-0 z-20 border-b shrink-0 items-center justify-between gap-4 px-6 h-14" style="background:rgb(var(--surface)/.95);border-color:rgb(var(--border));backdrop-filter:blur(8px)">
    <div class="flex items-center gap-3 min-w-0">
      <div class="min-w-0">
        <div class="t-eyebrow leading-none">Client portal</div>
        <div data-greeting class="text-xs font-medium leading-tight" style="color:rgb(var(--accent))"></div>
      </div>
      <svg class="w-4 h-4 shrink-0" style="color:rgb(var(--border))" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="1.5"><path d="M6 4l4 4-4 4"/></svg>
      <span class="text-sm font-medium truncate" style="color:rgb(var(--text))">{{.Data.Title}}</span>
    </div>
    <div class="flex items-center gap-1 shrink-0">
      <!-- ⌘K trigger -->
      <button type="button" id="cmd-palette-btn" class="r-btn-ghost h-8 px-2.5 gap-1.5 text-xs" style="color:rgb(var(--muted))" title="Command palette (⌘K)">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span class="hidden sm:inline">⌘K</span>
      </button>
      <!-- Theme toggle -->
      <button type="button" data-theme-toggle title="Toggle theme" class="r-btn-ghost h-8 w-8 p-0">
        <span id="icon-moon-top">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
        <span id="icon-sun-top" class="hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
      </button>
      <!-- Palette picker -->
      <div class="relative" id="palette-menu-wrap">
        <button type="button" id="palette-menu-btn" class="r-btn-ghost h-8 w-8 p-0" title="Switch palette">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 0 20"/><path d="M2 12h20"/></svg>
        </button>
        <div id="palette-dropdown" class="hidden absolute right-0 top-full mt-1 rounded-[12px] border p-2 z-50 min-w-[10rem] shadow-lg" style="background:rgb(var(--surface-2));border-color:rgb(var(--border))">
          <div class="t-eyebrow px-2 mb-2">Palette</div>
          <div class="grid grid-cols-2 gap-1">
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="default" style="color:rgb(var(--text))">default</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="midnight" style="color:rgb(var(--text))">midnight</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="ocean" style="color:rgb(var(--text))">ocean</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="forest" style="color:rgb(var(--text))">forest</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="violet" style="color:rgb(var(--text))">violet</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="sunset" style="color:rgb(var(--text))">sunset</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="nord" style="color:rgb(var(--text))">nord</button>
            <button type="button" class="palette-pick text-xs px-2 py-1.5 rounded-lg text-left transition-colors" data-palette="mono" style="color:rgb(var(--text))">mono</button>
          </div>
        </div>
      </div>
      <!-- Account -->
      <a href="/app/account" class="r-btn-ghost h-8 w-8 p-0" title="Account ({{.Data.Email}})">
        <div class="w-6 h-6 rounded-full text-[10px] font-semibold flex items-center justify-center uppercase select-none" style="background:rgb(var(--accent)/.15);color:rgb(var(--accent))">{{printf "%.1s" .Data.Email}}</div>
      </a>
    </div>
  </header>

  <main class="flex-1 px-4 sm:px-6 lg:px-8 py-6 max-w-7xl w-full">
    {{if .Data.Flash}}<div class="mb-4 p-3 rounded-md bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30 text-emerald-800 dark:text-emerald-300 text-sm">{{.Data.Flash}}</div>{{end}}
    {{if .Data.Error}}<div class="mb-4 p-3 rounded-md bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/30 text-rose-800 dark:text-rose-300 text-sm">{{.Data.Error}}</div>{{end}}
    {{if .Data.SystemBanner}}
    <div id="hpg-sys-banner" data-banner-text="{{.Data.SystemBanner}}" class="mb-4 {{if eq .Data.SystemBannerType "error"}}bg-rose-50 border-rose-400 text-rose-800 dark:bg-rose-900/30 dark:border-rose-600 dark:text-rose-200{{else if eq .Data.SystemBannerType "warning"}}bg-amber-50 border-amber-400 text-amber-800 dark:bg-amber-900/30 dark:border-amber-600 dark:text-amber-200{{else}}bg-sky-50 border-sky-400 text-sky-800 dark:bg-sky-900/30 dark:border-sky-600 dark:text-sky-200{{end}} border-l-4 px-4 py-2 text-sm flex items-center gap-2">
      <span class="flex-1">{{.Data.SystemBanner}}</span>
      {{if .Data.SystemBannerLink}}<a href="{{.Data.SystemBannerLink}}" target="_blank" rel="noopener" class="ml-2 underline font-medium whitespace-nowrap cursor-pointer">{{if .Data.SystemBannerLinkLabel}}{{.Data.SystemBannerLinkLabel}}{{else}}Learn more{{end}}</a>{{end}}
      <button id="hpg-sys-banner-x" type="button" class="ml-3 shrink-0 opacity-60 hover:opacity-100 cursor-pointer transition-opacity leading-none" aria-label="Dismiss">&times;</button>
    </div>
    <script nonce="{{.Data.CSPNonce}}">(function(){var b=document.getElementById('hpg-sys-banner');if(!b)return;function key(s){var h=0,i;for(i=0;i<s.length;i++)h=((h<<5)-h+s.charCodeAt(i))|0;return 'hpg-banner-'+h;}var k=key(b.dataset.bannerText||'');try{if(localStorage.getItem(k)){b.style.display='none';return;}}catch(e){}var x=document.getElementById('hpg-sys-banner-x');if(x)x.addEventListener('click',function(){try{localStorage.setItem(k,'1');}catch(e){}b.style.display='none';});})();</script>
    {{end}}

    {{if eq .Page "dashboard"}}{{template "dashboard" .Data}}{{end}}
    {{if eq .Page "services"}}{{template "services" .Data}}{{end}}
    {{if eq .Page "routes_list"}}{{template "routes_list" .Data}}{{end}}
    {{if eq .Page "route_new"}}{{template "route_new" .Data}}{{end}}
    {{if eq .Page "twofa"}}{{template "twofa" .Data}}{{end}}
    {{if eq .Page "api_keys"}}{{template "api_keys" .Data}}{{end}}
    {{if eq .Page "tunnels"}}{{template "client_tunnels" .Data}}{{end}}
    {{if eq .Page "account"}}{{template "account" .Data}}{{end}}
    {{if eq .Page "worldmap"}}{{template "worldmap_app" .Data}}{{end}}
  </main>
</div>

<!-- AI chat bubble (floating, fixed bottom-right, z-[70] above toasts). -->
{{template "ai_bubble" .}}

<!-- Toasts -->
<div id="hpg-toasts" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none w-80 max-w-[calc(100vw-2rem)]"></div>

<!-- Confirm modal -->
<div id="hpg-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
  <div class="rounded-[var(--r-lg,16px)] border shadow-[var(--shadow-soft)] max-w-md w-full p-5 space-y-4" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
    <p id="hpg-modal-msg" class="text-sm whitespace-pre-wrap" style="color:rgb(var(--text))"></p>
    <div class="flex justify-end gap-2">
      <button id="hpg-modal-cancel" type="button" class="r-btn-ghost text-sm h-8 px-3">Cancel</button>
      <button id="hpg-modal-ok" type="button" class="px-3 py-1.5 rounded-[var(--r-sm,8px)] bg-rose-600 text-white text-sm font-semibold hover:bg-rose-700 cursor-pointer transition-colors">Confirm</button>
    </div>
  </div>
</div>

<!-- Prompt modal -->
<div id="hpg-prompt" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
  <div class="rounded-[var(--r-lg,16px)] border shadow-[var(--shadow-soft)] max-w-md w-full p-5 space-y-4" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
    <p id="hpg-prompt-msg" class="text-sm whitespace-pre-wrap" style="color:rgb(var(--text))"></p>
    <input id="hpg-prompt-input" type="text" class="r-input">
    <div class="flex justify-end gap-2">
      <button id="hpg-prompt-cancel" type="button" class="r-btn-ghost text-sm h-8 px-3">Cancel</button>
      <button id="hpg-prompt-ok" type="button" class="r-btn-primary text-sm h-8 px-3">OK</button>
    </div>
  </div>
</div>

<script nonce="{{.Data.CSPNonce}}">
window.hpgToast = function(msg, kind){
  if (!msg) return;
  var wrap = document.getElementById('hpg-toasts'); if (!wrap) return;
  var el = document.createElement('div');
  var palette = kind === 'error'
    ? 'bg-rose-600 text-white'
    : kind === 'warn' ? 'bg-amber-500 text-white'
    : 'bg-emerald-600 text-white';
  el.className = 'pointer-events-auto rounded-lg shadow-lg px-4 py-3 text-sm ' + palette + ' opacity-0 transition-opacity duration-200';
  el.textContent = msg;
  wrap.appendChild(el);
  requestAnimationFrame(function(){ el.classList.remove('opacity-0'); });
  setTimeout(function(){
    el.classList.add('opacity-0');
    setTimeout(function(){ el.remove(); }, 250);
  }, 4000);
};
window.hpgConfirm = function(msg){
  return new Promise(function(resolve){
    var m = document.getElementById('hpg-modal');
    document.getElementById('hpg-modal-msg').textContent = msg || 'Are you sure?';
    m.classList.remove('hidden'); m.classList.add('flex');
    function done(ok){
      m.classList.add('hidden'); m.classList.remove('flex');
      document.getElementById('hpg-modal-ok').onclick = null;
      document.getElementById('hpg-modal-cancel').onclick = null;
      m.onclick = null;
      resolve(ok);
    }
    document.getElementById('hpg-modal-ok').onclick = function(){ done(true); };
    document.getElementById('hpg-modal-cancel').onclick = function(){ done(false); };
    m.onclick = function(e){ if (e.target === m) done(false); };
  });
};
window.hpgPrompt = function(msg, defaultValue){
  return new Promise(function(resolve){
    var m = document.getElementById('hpg-prompt');
    var inp = document.getElementById('hpg-prompt-input');
    document.getElementById('hpg-prompt-msg').textContent = msg || '';
    inp.value = defaultValue || '';
    m.classList.remove('hidden'); m.classList.add('flex');
    setTimeout(function(){ inp.focus(); inp.select(); }, 30);
    function done(val){
      m.classList.add('hidden'); m.classList.remove('flex');
      document.getElementById('hpg-prompt-ok').onclick = null;
      document.getElementById('hpg-prompt-cancel').onclick = null;
      inp.onkeydown = null;
      m.onclick = null;
      resolve(val);
    }
    document.getElementById('hpg-prompt-ok').onclick = function(){ done(inp.value); };
    document.getElementById('hpg-prompt-cancel').onclick = function(){ done(null); };
    m.onclick = function(e){ if (e.target === m) done(null); };
    inp.onkeydown = function(e){
      if (e.key === 'Enter') { e.preventDefault(); done(inp.value); }
      else if (e.key === 'Escape') { e.preventDefault(); done(null); }
    };
  });
};
</script>
<script nonce="{{.Data.CSPNonce}}">
function updateThemeIcons(dark) {
  var ids = [['icon-moon','icon-sun'],['icon-moon-top','icon-sun-top']];
  ids.forEach(function(pair){
    var moon = document.getElementById(pair[0]);
    var sun  = document.getElementById(pair[1]);
    if (moon) moon.classList.toggle('hidden', dark);
    if (sun)  sun.classList.toggle('hidden', !dark);
  });
}
function toggleTheme(){
  var dark = document.documentElement.classList.toggle('dark');
  localStorage.setItem('theme', dark ? 'dark' : 'light');
  updateThemeIcons(dark);
}
(function(){ updateThemeIcons(document.documentElement.classList.contains('dark')); })();

document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('[data-theme-toggle]').forEach(function(el){
    el.addEventListener('click', toggleTheme);
  });

  // Palette picker dropdown
  var paletteBtn = document.getElementById('palette-menu-btn');
  var paletteDrop = document.getElementById('palette-dropdown');
  if (paletteBtn && paletteDrop) {
    paletteBtn.addEventListener('click', function(e){
      e.stopPropagation();
      paletteDrop.classList.toggle('hidden');
    });
    document.addEventListener('click', function(){ paletteDrop.classList.add('hidden'); });
    paletteDrop.addEventListener('click', function(e){ e.stopPropagation(); });
    paletteDrop.querySelectorAll('.palette-pick').forEach(function(btn){
      btn.addEventListener('click', function(){
        var p = btn.dataset.palette;
        var ok={default:1,midnight:1,ocean:1,forest:1,violet:1,sunset:1,nord:1,mono:1};
        if (!ok[p]) return;
        document.documentElement.dataset.theme = p;
        try { localStorage.setItem('ui_theme', p); } catch(e){}
        paletteDrop.classList.add('hidden');
        fetch('/app/settings/theme', {method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded','X-CSRF-Token':document.querySelector('meta[name=csrf-token]').content}, body:'theme='+encodeURIComponent(p)}).catch(function(){});
      });
    });
  }

  document.querySelectorAll('form[data-confirm]').forEach(function(f){
    var armed = false;
    f.addEventListener('submit', function(e){
      if (armed) return;
      e.preventDefault();
      window.hpgConfirm(f.dataset.confirm).then(function(ok){
        if (ok) { armed = true; f.submit(); }
      });
    });
  });
});

// Delegated handler - CSP blocks inline on* attributes, nonce only covers <script>.
document.addEventListener('click', function(e) {
  var el = e.target.closest('[data-action]');
  if (!el) return;
  switch (el.getAttribute('data-action')) {
    case 'open-sidebar':  openSidebar();  break;
    case 'close-sidebar': closeSidebar(); break;
  }
});

function openSidebar() {
  document.getElementById('sidebar').classList.remove('-translate-x-full');
  document.getElementById('sidebar-overlay').classList.remove('hidden');
  document.body.classList.add('overflow-hidden');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.add('-translate-x-full');
  document.getElementById('sidebar-overlay').classList.add('hidden');
  document.body.classList.remove('overflow-hidden');
}
</script>
