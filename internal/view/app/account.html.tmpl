{{define "account"}}
<div class="space-y-4 max-w-2xl">
  <form method="POST" action="/app/account" class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 space-y-4 text-sm">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
      <input value="{{.Email}}" disabled class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 bg-slate-50 dark:bg-zinc-800 text-slate-500">
      <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Email changes go through the operator.</p>
    </div>

    {{if .PhoneEnabled}}
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Phone (E.164)</label>
      <input name="phone_e164" value="{{.Phone}}" placeholder="+48555111222" pattern="^\+[1-9]\d{1,14}$" class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 font-mono">
      <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Used for SMS alerts on outages and (optionally) 2FA fallback. Leave blank to remove.</p>
    </div>
    <div class="flex justify-end pt-2">
      <button class="px-3 py-1.5 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Save</button>
    </div>
    {{end}}
  </form>

  <!-- Public status page toggle -->
  <section class="bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 rounded-xl p-5 space-y-3 text-sm">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100">Public status page</h2>
    {{if .StatusPageURL}}
    <p class="text-slate-600 dark:text-slate-300">Your status page is <strong class="text-green-700 dark:text-green-400">enabled</strong>.</p>
    <p class="font-mono text-xs text-slate-500 break-all">{{.StatusPageURL}}</p>
    <div class="flex gap-2">
      <a href="{{.StatusPageURL}}" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-md border border-slate-300 dark:border-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800">Preview</a>
      <form method="POST" action="/app/status-page/toggle">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="px-3 py-1.5 rounded-md text-rose-700 border border-rose-200 bg-rose-50 hover:bg-rose-100">Disable</button>
      </form>
    </div>
    {{else}}
    <p class="text-slate-500 dark:text-slate-400">Share a public status page for your services. Enable it here.</p>
    <form method="POST" action="/app/status-page/toggle">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="px-3 py-2 rounded-md bg-indigo-600 text-white font-medium hover:bg-indigo-700">Enable status page</button>
    </form>
    {{end}}
  </section>
</div>
{{end}}
