{{define "account"}}
<div class="space-y-4 max-w-2xl">
  <form method="POST" action="/app/account" class="r-card space-y-4 text-sm">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <div>
      <label class="block text-xs font-medium mb-1" style="color:rgb(var(--text))">Email</label>
      <input value="{{.Email}}" disabled class="r-input w-full" style="color:rgb(var(--muted))">
      <p class="text-[11px] mt-1" style="color:rgb(var(--muted))">Email changes go through the operator.</p>
    </div>

    {{if .PhoneEnabled}}
    <div>
      <label class="block text-xs font-medium mb-1" style="color:rgb(var(--text))">Phone (E.164)</label>
      <input name="phone_e164" value="{{.Phone}}" placeholder="+48555111222" pattern="^\+[1-9]\d{1,14}$" class="r-input w-full font-mono">
      <p class="text-[11px] mt-1" style="color:rgb(var(--muted))">Used for SMS alerts on outages and (optionally) 2FA fallback. Leave blank to remove.</p>
    </div>
    <div class="flex justify-end pt-2">
      <button class="r-btn-primary">Save</button>
    </div>
    {{end}}
  </form>

  <!-- Linked OAuth providers -->
  <section class="r-card space-y-3 text-sm">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <h2 class="t-h2">Linked login providers</h2>
      <div class="flex items-center gap-2 flex-wrap">
        {{if .OIDCEnabled}}
        <form method="POST" action="/app/oauth-identities/link/oidc">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="r-btn-ghost text-xs cursor-pointer">
            + Link OIDC provider
          </button>
        </form>
        {{end}}
        {{if .GitHubEnabled}}
        <form method="POST" action="/app/oauth-identities/link/github">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="r-btn-ghost inline-flex items-center gap-1.5 text-xs cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            Link GitHub
          </button>
        </form>
        {{end}}
        {{if .GoogleEnabled}}
        <form method="POST" action="/app/oauth-identities/link/google">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="r-btn-ghost inline-flex items-center gap-1.5 text-xs cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Link Google
          </button>
        </form>
        {{end}}
      </div>
    </div>

    {{if .OAuthIdentities}}
    <ul class="divide-y" style="border-color:rgb(var(--border))">
      {{range .OAuthIdentities}}
      <li class="flex items-center justify-between py-2.5 gap-3">
        <div class="flex items-center gap-2.5 min-w-0">
          <!-- Provider icon chip -->
          <span class="r-avatar flex-shrink-0">
            {{if eq .Provider "github"}}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            {{else if eq .Provider "google"}}
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            {{else if eq .Provider "microsoft"}}
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true"><path fill="#f25022" d="M1 1h10v10H1z"/><path fill="#00a4ef" d="M13 1h10v10H13z"/><path fill="#7fba00" d="M1 13h10v10H1z"/><path fill="#ffb900" d="M13 13h10v10H13z"/></svg>
            {{else}}
            <svg class="w-4 h-4" style="color:rgb(var(--muted))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {{end}}
          </span>
          <div class="min-w-0">
            <p class="font-medium truncate" style="color:rgb(var(--text))">{{.Label}}</p>
            {{if .Email}}<p class="text-[11px] truncate" style="color:rgb(var(--muted))">{{.Email}}</p>{{end}}
          </div>
        </div>
        <form method="POST" action="/app/oauth-identities/{{.ID}}/unlink" class="flex-shrink-0">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button class="r-btn-ghost text-xs text-rose-700 dark:text-rose-400 cursor-pointer">
            Unlink
          </button>
        </form>
      </li>
      {{end}}
    </ul>
    {{else}}
    <p class="text-xs" style="color:rgb(var(--muted))">No OAuth providers linked yet.</p>
    {{end}}
  </section>

  <!-- Public status page toggle -->
  <section class="r-card space-y-3 text-sm">
    <h2 class="t-h2">Public status page</h2>
    {{if .StatusPageURL}}
    <p style="color:rgb(var(--muted))">Your status page is <strong class="text-green-700 dark:text-green-400">enabled</strong>.</p>
    <p class="font-mono text-xs break-all" style="color:rgb(var(--muted))">{{.StatusPageURL}}</p>
    <div class="flex gap-2">
      <a href="{{.StatusPageURL}}" target="_blank" rel="noopener" class="r-btn-secondary">Preview</a>
      <form method="POST" action="/app/status-page/toggle">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-ghost text-rose-700 dark:text-rose-400">Disable</button>
      </form>
    </div>
    {{else}}
    <p style="color:rgb(var(--muted))">Share a public status page for your services. Enable it here.</p>
    <form method="POST" action="/app/status-page/toggle">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-primary">Enable status page</button>
    </form>
    {{end}}
  </section>
</div>
{{end}}
