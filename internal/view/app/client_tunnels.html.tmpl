{{define "client_tunnels"}}
<div class="space-y-5">
  <section class="hpg-card overflow-hidden relative">
    <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-sky-500 to-emerald-500"></div>
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 pt-2">
      <div class="min-w-0">
        <p class="hpg-eyebrow">WireGuard</p>
        <h2 class="text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Private network tunnels</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300 max-w-2xl">Give Caddy a private path to a backend when public inbound ports are closed or the service should stay internal.</p>
      </div>
      {{if .Nodes}}
      <button type="button" data-open-client-tunnel class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 shadow-sm">New tunnel</button>
      {{end}}
    </div>
  </section>

  {{if .NewTunnel}}
  <section class="hpg-card ring-emerald-300 dark:ring-emerald-700 space-y-3">
    <div class="flex items-center gap-3">
      <span class="hpg-chip bg-emerald-50 text-emerald-600 dark:bg-emerald-500/15 dark:text-emerald-300">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
      <div class="min-w-0">
        <h3 class="font-semibold text-slate-950 dark:text-white">Tunnel ready</h3>
        <p class="text-xs text-slate-500 dark:text-slate-400">Single-use installer, expires in 24h.</p>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row gap-2 items-stretch">
      <code id="hpg-cln-cmd" class="flex-1 block bg-slate-950 text-emerald-200 font-mono text-xs p-3 rounded-lg break-all">{{.NewTunnel.InstallCommand}}</code>
      <button type="button" data-copy-target="hpg-cln-cmd" class="px-3 rounded-lg bg-slate-200 dark:bg-zinc-700 text-slate-700 dark:text-slate-200 text-xs font-medium hover:bg-slate-300 dark:hover:bg-zinc-600">Copy</button>
    </div>
    <p class="text-xs text-slate-500 dark:text-slate-400">Or download <a href="{{.NewTunnel.ConfURL}}" class="text-indigo-600 dark:text-indigo-400 underline">WireGuard .conf</a>.</p>
  </section>
  {{end}}

  <section class="hpg-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 dark:bg-zinc-800/60 text-left hpg-eyebrow">
          <tr>
            <th class="px-4 py-3">Tunnel</th>
            <th class="px-4 py-3">Node</th>
            <th class="px-4 py-3">Private IP</th>
            <th class="px-4 py-3">State</th>
            <th class="px-4 py-3">Handshake</th>
            <th class="px-4 py-3">Traffic</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .Tunnels}}
          <tr class="hover:bg-slate-50/70 dark:hover:bg-zinc-800/40 transition-colors">
            <td class="px-4 py-3">
              <div class="font-medium text-slate-900 dark:text-white break-all">{{.Name}}</div>
              {{if .PeerGroupID}}<span class="mt-1 hpg-pill bg-indigo-50 text-indigo-700 dark:bg-indigo-500/15 dark:text-indigo-300 font-mono">HA</span>{{end}}
            </td>
            <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><span class="block max-w-[12rem] truncate" title="{{.NodeName}}">{{.NodeName}}</span></td>
            <td class="px-4 py-3"><span class="hpg-pill hpg-pill-muted font-mono">{{.AssignedIP}}</span></td>
            <td class="px-4 py-3">
              <div class="flex flex-wrap gap-1.5">
                {{if eq .Status "active"}}<span class="hpg-pill hpg-pill-ok">active</span>{{end}}
                {{if eq .Status "pending"}}<span class="hpg-pill hpg-pill-warn">pending install</span>{{end}}
                {{if eq .Status "revoked"}}<span class="hpg-pill hpg-pill-muted">revoked</span>{{end}}
                {{if .Healthy}}<span class="hpg-pill hpg-pill-ok">connected</span>{{else if eq .Status "active"}}<span class="hpg-pill hpg-pill-warn">stale</span>{{end}}
              </div>
            </td>
            <td class="px-4 py-3 text-xs font-mono text-slate-500 dark:text-slate-400">{{.LastHandshake}}</td>
            <td class="px-4 py-3 text-xs font-mono text-slate-500 dark:text-slate-400">
              <span class="flex flex-col gap-0.5 tabular-nums">
                <span><span class="text-emerald-500">↓</span> {{.RxHuman}}</span>
                <span><span class="text-sky-500">↑</span> {{.TxHuman}}</span>
              </span>
            </td>
            <td class="px-4 py-3 text-right">
              {{if ne .Status "revoked"}}
              <button type="button" class="px-2.5 py-1.5 rounded-lg text-xs font-medium text-violet-700 dark:text-violet-300 ring-1 ring-violet-200 dark:ring-violet-500/30 hover:bg-violet-50 dark:hover:bg-violet-500/10 cursor-pointer" data-cln-bw-toggle="{{.ID}}">Charts</button>
              <form method="POST" action="/app/tunnels/{{.ID}}/revoke" class="inline" data-confirm="Revoke {{.Name}}? Your tunnel will stop within about 30 seconds.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="px-2.5 py-1.5 rounded-lg text-xs font-medium text-rose-700 dark:text-rose-300 ring-1 ring-rose-200 dark:ring-rose-500/30 hover:bg-rose-50 dark:hover:bg-rose-500/10">Revoke</button>
              </form>
              {{end}}
            </td>
          </tr>
          <tr id="hpg-cln-bw-row-{{.ID}}" class="hidden">
            <td colspan="7" class="px-4 py-4 bg-slate-50/60 dark:bg-zinc-900/50">
              <div class="flex items-center justify-between mb-3 gap-3">
                <span class="text-xs font-medium text-slate-700 dark:text-slate-200">Bandwidth &middot; <span class="font-mono">{{.Name}}</span></span>
                <div class="flex gap-1" data-cln-bw-periods="{{.ID}}">
                  <button type="button" data-period="24h" class="hpg-cln-bw-btn px-2.5 py-1 rounded-md text-xs bg-indigo-600 text-white cursor-pointer transition">24h</button>
                  <button type="button" data-period="7d"  class="hpg-cln-bw-btn px-2.5 py-1 rounded-md text-xs bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-700 cursor-pointer transition">7d</button>
                  <button type="button" data-period="30d" class="hpg-cln-bw-btn px-2.5 py-1 rounded-md text-xs bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-700 cursor-pointer transition">30d</button>
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <div class="text-[11px] text-emerald-600 dark:text-emerald-400 font-medium mb-1">RX (received)</div>
                  <canvas id="hpg-cln-bw-rx-{{.ID}}" height="100"></canvas>
                </div>
                <div>
                  <div class="text-[11px] text-sky-600 dark:text-sky-400 font-medium mb-1">TX (transmitted)</div>
                  <canvas id="hpg-cln-bw-tx-{{.ID}}" height="100"></canvas>
                </div>
              </div>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="7" class="px-4 py-14 text-center">
              <div class="mx-auto h-12 w-12 rounded-2xl bg-slate-100 dark:bg-zinc-800 grid place-items-center text-slate-400">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">No private tunnels</h3>
              <p class="mx-auto mt-1 max-w-md text-sm leading-6 text-slate-500 dark:text-slate-400">Create a tunnel for a backend that should stay private, then use the installer command on the server that needs to connect.</p>
              {{if $.Nodes}}<button type="button" data-open-client-tunnel class="mt-4 inline-flex items-center justify-center px-3.5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 shadow-sm">Create tunnel</button>{{end}}
            </td>
          </tr>
        {{end}}
        </tbody>
      </table>
    </div>
  </section>
</div>

<div id="hpg-cln-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
  <form method="POST" action="/app/tunnels" class="hpg-card max-w-md w-full space-y-4">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <div>
      <p class="hpg-eyebrow">WireGuard</p>
      <h3 class="font-semibold text-slate-950 dark:text-white text-lg">New private tunnel</h3>
    </div>
    <div>
      <label class="hpg-eyebrow block mb-1.5">Name</label>
      <input name="name" placeholder="prod-backend" required class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none">
    </div>
    <div>
      <label class="hpg-eyebrow block mb-1.5">Region / node</label>
      <select name="node_id" required class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none">
        <option value="">Select node</option>
        {{range .Nodes}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
      </select>
    </div>
    <div class="flex justify-end gap-2 pt-2">
      <button type="button" data-close-client-tunnel class="px-3.5 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 ring-1 ring-slate-200 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800">Cancel</button>
      <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Create</button>
    </div>
  </form>
</div>

<script src="/static/js/chart.umd.min.js" nonce="{{.CSPNonce}}"></script>
<script nonce="{{.CSPNonce}}">
(function(){
  if (!window.Chart) return;
  var dark = document.documentElement.classList.contains('dark');
  Chart.defaults.color = dark ? '#94a3b8' : '#475569';
  Chart.defaults.borderColor = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';

  var clnCharts = {};

  function fmtBytes(n) {
    if (n >= 1073741824) return (n/1073741824).toFixed(1)+' GB';
    if (n >= 1048576)    return (n/1048576).toFixed(1)+' MB';
    if (n >= 1024)       return (n/1024).toFixed(1)+' KB';
    return n+' B';
  }

  function makeChart(id, label, color, labels, data) {
    var el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{ label: label, data: data,
          borderColor: color,
          backgroundColor: color.replace(')',',0.12)').replace('rgb','rgba'),
          fill: true, tension: 0.3, pointRadius: data.length > 30 ? 0 : 2 }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { callback: function(v){ return fmtBytes(v); } } } }
      }
    });
  }

  function loadBW(peerId, period) {
    if (clnCharts[peerId]) {
      clnCharts[peerId].forEach(function(c){ if(c) c.destroy(); });
    }
    fetch('/app/tunnels/' + peerId + '/bandwidth.json?period=' + period)
      .then(function(r){ return r.json(); })
      .then(function(d){
        clnCharts[peerId] = [
          makeChart('hpg-cln-bw-rx-'+peerId, 'RX', 'rgb(16,185,129)', d.labels, d.rx),
          makeChart('hpg-cln-bw-tx-'+peerId, 'TX', 'rgb(14,165,233)', d.labels, d.tx)
        ];
      })
      .catch(function(e){ console.warn('bandwidth fetch', e); });
  }

  document.querySelectorAll('[data-cln-bw-toggle]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var id = btn.getAttribute('data-cln-bw-toggle');
      var row = document.getElementById('hpg-cln-bw-row-' + id);
      if (!row) return;
      var wasHidden = row.classList.contains('hidden');
      row.classList.toggle('hidden', !wasHidden);
      if (wasHidden && !clnCharts[id]) loadBW(id, '24h');
    });
  });

  document.querySelectorAll('[data-cln-bw-periods]').forEach(function(bar){
    var id = bar.getAttribute('data-cln-bw-periods');
    bar.querySelectorAll('.hpg-cln-bw-btn').forEach(function(b){
      b.addEventListener('click', function(){
        var period = b.getAttribute('data-period');
        bar.querySelectorAll('.hpg-cln-bw-btn').forEach(function(x){
          var active = x === b;
          x.classList.toggle('bg-indigo-600', active);
          x.classList.toggle('text-white', active);
          x.classList.toggle('bg-white', !active);
          x.classList.toggle('dark:bg-zinc-800', !active);
          x.classList.toggle('ring-1', !active);
          x.classList.toggle('ring-slate-200', !active);
          x.classList.toggle('dark:ring-zinc-700', !active);
          x.classList.toggle('text-slate-600', !active);
          x.classList.toggle('dark:text-slate-300', !active);
        });
        loadBW(id, period);
      });
    });
  });
})();
</script>
<script nonce="{{.CSPNonce}}">
(function(){
  var m = document.getElementById('hpg-cln-modal');
  document.querySelectorAll('[data-open-client-tunnel]').forEach(function(b){ b.addEventListener('click', function(){ m.classList.remove('hidden'); m.classList.add('flex'); }); });
  document.querySelectorAll('[data-close-client-tunnel]').forEach(function(b){ b.addEventListener('click', function(){ m.classList.add('hidden'); m.classList.remove('flex'); }); });
  m && m.addEventListener('click', function(e){ if (e.target === m) { m.classList.add('hidden'); m.classList.remove('flex'); } });
  document.querySelectorAll('[data-copy-target]').forEach(function(b){
    b.addEventListener('click', function(){
      var t = document.getElementById(b.dataset.copyTarget);
      navigator.clipboard.writeText(t.textContent.trim()).then(function(){
        b.textContent = 'Copied'; setTimeout(function(){ b.textContent = 'Copy'; }, 1500);
      });
    });
  });
})();
</script>
{{end}}
