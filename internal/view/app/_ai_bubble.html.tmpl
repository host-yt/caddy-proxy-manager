{{define "ai_bubble"}}
{{if .Data.CSPNonce}}
<script nonce="{{.Data.CSPNonce}}">window.HPG_AI_BASE = "/app/ai/chat";</script>
{{end}}

<!-- AI chat bubble: fixed bottom-right toggle button -->
<button id="hpg-ai-btn" type="button" aria-label="AI assistant" title="AI assistant"
  class="fixed bottom-6 right-6 z-[70] w-14 h-14 rounded-full bg-indigo-600 text-white shadow-lg shadow-indigo-900/30 flex items-center justify-center cursor-pointer hover:bg-indigo-700 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
  <svg id="hpg-ai-icon-chat" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
    <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
  </svg>
  <svg id="hpg-ai-icon-close" class="h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
</button>

<!-- AI chat panel (slide-out card) -->
<div id="hpg-ai-panel"
  class="fixed bottom-24 right-6 z-[70] w-[380px] max-w-[calc(100vw-1.5rem)] max-h-[70vh] hidden flex-col rounded-2xl bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-800 shadow-2xl shadow-slate-900/15 overflow-hidden">

  <!-- Panel header -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100 dark:border-zinc-800 shrink-0">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
        </svg>
      </div>
      <span class="text-sm font-medium text-slate-800 dark:text-slate-100">AI assistant</span>
    </div>
    <div class="flex items-center gap-1">
      <button id="hpg-ai-new" type="button" title="New conversation"
        class="p-1.5 rounded-md text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-zinc-800 transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m8-8H4"/></svg>
      </button>
      <button id="hpg-ai-sessions-toggle" type="button" title="Switch conversation"
        class="p-1.5 rounded-md text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Session list drawer (hidden by default, shown via toggle) -->
  <div id="hpg-ai-sessions-drawer" class="hidden border-b border-slate-100 dark:border-zinc-800 max-h-40 overflow-y-auto shrink-0">
    <div id="hpg-ai-session-list" class="divide-y divide-slate-50 dark:divide-zinc-800/50">
      <p id="hpg-ai-sessions-empty" class="px-4 py-3 text-xs text-slate-400 dark:text-slate-500 text-center">No conversations yet.</p>
    </div>
  </div>

  <!-- Not configured state -->
  <div id="hpg-ai-unconfigured" class="hidden flex-col items-center justify-center gap-3 px-6 py-8 text-center flex-1">
    <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
      </svg>
    </div>
    <div>
      <p class="text-sm font-medium text-slate-700 dark:text-slate-200">AI assistant not configured</p>
      <p class="mt-0.5 text-xs text-slate-400 dark:text-slate-500">The AI assistant is not available right now.</p>
    </div>
  </div>

  <!-- Thread -->
  <div id="hpg-ai-thread" class="flex-1 overflow-y-auto px-4 py-3 space-y-3 min-h-0">
    <div id="hpg-ai-thread-empty" class="flex flex-col items-center justify-center h-full gap-2 py-6 text-center">
      <p class="text-xs text-slate-400 dark:text-slate-500">Start a new conversation or pick one above.</p>
    </div>
  </div>

  <!-- Stream error -->
  <div id="hpg-ai-err" class="hidden px-4 py-2 text-xs text-rose-600 dark:text-rose-400 bg-rose-50 dark:bg-rose-500/10 border-t border-rose-200 dark:border-rose-500/20 shrink-0"></div>

  <!-- Composer -->
  <div class="border-t border-slate-100 dark:border-zinc-800 px-3 py-3 shrink-0">
    <div class="flex gap-2 items-end">
      <textarea id="hpg-ai-composer" rows="2" placeholder="Send a message..."
        class="flex-1 resize-none rounded-lg px-3 py-2 text-sm border border-slate-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-shadow placeholder-slate-400 dark:placeholder-zinc-500"
        disabled></textarea>
      <button id="hpg-ai-send" type="button" disabled
        class="shrink-0 flex items-center justify-center w-9 h-9 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script nonce="{{.Data.CSPNonce}}">
(function(){
  'use strict';

  var BASE = window.HPG_AI_BASE || '/app/ai/chat';
  var IS_ADMIN = false; // client portal: no settings link shown

  var panelEl   = document.getElementById('hpg-ai-panel');
  var btnEl     = document.getElementById('hpg-ai-btn');
  var iconChat  = document.getElementById('hpg-ai-icon-chat');
  var iconClose = document.getElementById('hpg-ai-icon-close');
  var newBtn    = document.getElementById('hpg-ai-new');
  var sessToggle= document.getElementById('hpg-ai-sessions-toggle');
  var drawer    = document.getElementById('hpg-ai-sessions-drawer');
  var sessList  = document.getElementById('hpg-ai-session-list');
  var sessEmpty = document.getElementById('hpg-ai-sessions-empty');
  var unconfigEl= document.getElementById('hpg-ai-unconfigured');
  var threadEl  = document.getElementById('hpg-ai-thread');
  var threadEmp = document.getElementById('hpg-ai-thread-empty');
  var errEl     = document.getElementById('hpg-ai-err');
  var composer  = document.getElementById('hpg-ai-composer');
  var sendBtn   = document.getElementById('hpg-ai-send');

  var panelOpen = false;
  var activeID  = null;
  var streaming = false;

  // ---- Panel toggle ----
  function setPanel(open) {
    panelOpen = open;
    panelEl.classList.toggle('hidden', !open);
    panelEl.classList.toggle('flex', open);
    iconChat.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    if (open) loadSessions();
  }

  btnEl.addEventListener('click', function(){ setPanel(!panelOpen); });

  // ---- Session drawer toggle ----
  sessToggle.addEventListener('click', function(){
    drawer.classList.toggle('hidden');
  });

  // ---- CSRF token ----
  function csrf(){
    var m = document.querySelector('meta[name="csrf-token"]');
    return m ? m.getAttribute('content') : '';
  }

  // ---- Composer enable/disable ----
  function setComposer(on){
    composer.disabled = !on;
    sendBtn.disabled  = !on;
  }

  // ---- Error banner ----
  function showErr(msg){
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
  }
  function clearErr(){
    errEl.classList.add('hidden');
    errEl.textContent = '';
  }

  // ---- Scroll to bottom ----
  function scrollThread(){ threadEl.scrollTop = threadEl.scrollHeight; }

  // ---- Load sessions ----
  function loadSessions(){
    fetch(BASE + '/sessions', {credentials:'same-origin', headers:{Accept:'application/json'}})
      .then(function(r){ return r.ok ? r.json() : {sessions:[]}; })
      .then(function(d){ renderSessions(d.sessions || []); })
      .catch(function(){ renderSessions([]); });
  }

  function renderSessions(list){
    Array.from(sessList.querySelectorAll('[data-sid]')).forEach(function(el){ el.remove(); });

    if (!list.length){
      if (sessEmpty) sessEmpty.classList.remove('hidden');
      return;
    }
    if (sessEmpty) sessEmpty.classList.add('hidden');

    list.forEach(function(s){
      var item = document.createElement('div');
      item.setAttribute('data-sid', s.id);
      item.className = 'group flex items-center justify-between gap-2 px-3 py-2 cursor-pointer transition-colors hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm';
      if (s.id === activeID) item.classList.add('bg-indigo-50', 'dark:bg-indigo-500/10');

      var label = document.createElement('span');
      label.className = 'flex-1 min-w-0 truncate text-slate-700 dark:text-slate-200 text-xs';
      label.textContent = s.title || 'Untitled';
      item.appendChild(label);

      var del = document.createElement('button');
      del.type = 'button';
      del.title = 'Delete';
      del.className = 'shrink-0 opacity-0 group-hover:opacity-100 transition-opacity p-0.5 rounded text-slate-400 hover:text-rose-500 cursor-pointer';
      del.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>';
      del.addEventListener('click', function(e){
        e.stopPropagation();
        deleteSession(s.id);
      });
      item.appendChild(del);

      item.addEventListener('click', function(){ openSession(s.id); });
      sessList.appendChild(item);
    });
  }

  function highlightSession(id){
    sessList.querySelectorAll('[data-sid]').forEach(function(el){
      var sid = parseInt(el.getAttribute('data-sid'), 10);
      el.classList.toggle('bg-indigo-50', sid === id);
      el.classList.toggle('dark:bg-indigo-500/10', sid === id);
    });
  }

  // ---- Create session ----
  function newSession(){
    if (streaming) return;
    fetch(BASE + '/sessions', {
      method:'POST', credentials:'same-origin',
      headers:{'Content-Type':'application/json', Accept:'application/json', 'X-CSRF-Token':csrf()},
      body: JSON.stringify({title:'', provider:''})
    })
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(data){
      if (!data || !data.id) return;
      loadSessions();
      openSession(data.id);
      drawer.classList.add('hidden');
    })
    .catch(function(){});
  }

  newBtn.addEventListener('click', newSession);

  // ---- Open session ----
  function openSession(id){
    if (streaming) return;
    activeID = id;
    highlightSession(id);
    setComposer(false);
    clearErr();
    hideUnconfigured();

    Array.from(threadEl.querySelectorAll('[data-msg]')).forEach(function(el){ el.remove(); });
    if (threadEmp) threadEmp.classList.remove('hidden');

    fetch(BASE + '/sessions/' + id, {credentials:'same-origin', headers:{Accept:'application/json'}})
      .then(function(r){
        if (!r.ok) throw new Error('status ' + r.status);
        return r.json();
      })
      .then(function(data){
        renderThread(data.messages || []);
        setComposer(true);
        composer.focus();
      })
      .catch(function(e){ showErr('Could not load session: ' + e.message); });
  }

  // ---- Delete session ----
  function deleteSession(id){
    window.hpgConfirm('Delete this conversation?').then(function(ok){
      if (!ok) return;
      fetch(BASE + '/sessions/' + id, {
        method:'DELETE', credentials:'same-origin',
        headers:{'X-CSRF-Token':csrf()}
      })
      .then(function(r){
        if (r.ok || r.status === 204){
          if (activeID === id){
            activeID = null;
            Array.from(threadEl.querySelectorAll('[data-msg]')).forEach(function(el){ el.remove(); });
            if (threadEmp) threadEmp.classList.remove('hidden');
            setComposer(false);
          }
          loadSessions();
        }
      })
      .catch(function(){});
    });
  }

  // ---- Thread rendering ----
  function renderThread(messages){
    Array.from(threadEl.querySelectorAll('[data-msg]')).forEach(function(el){ el.remove(); });
    clearErr();
    if (!messages.length){
      if (threadEmp) threadEmp.classList.remove('hidden');
      return;
    }
    if (threadEmp) threadEmp.classList.add('hidden');
    messages.forEach(function(m){ appendBubble(m.role, m.content, false); });
    scrollThread();
  }

  function appendBubble(role, content, live){
    if (threadEmp) threadEmp.classList.add('hidden');
    var wrap = document.createElement('div');
    wrap.setAttribute('data-msg', '1');
    wrap.className = role === 'user' ? 'flex justify-end' : 'flex justify-start';
    var bubble = document.createElement('div');
    bubble.className = role === 'user'
      ? 'max-w-[80%] rounded-2xl rounded-br-sm bg-indigo-600 text-white px-3 py-2 text-xs leading-relaxed whitespace-pre-wrap break-words'
      : 'max-w-[85%] rounded-2xl rounded-bl-sm bg-slate-100 dark:bg-zinc-800 text-slate-800 dark:text-slate-100 px-3 py-2 text-xs leading-relaxed whitespace-pre-wrap break-words';
    // textContent prevents XSS from model output
    bubble.textContent = content;
    if (live) bubble.setAttribute('data-live', '1');
    wrap.appendChild(bubble);
    threadEl.appendChild(wrap);
    return bubble;
  }

  // ---- Unconfigured state ----
  function showUnconfigured(){
    unconfigEl.classList.remove('hidden');
    unconfigEl.classList.add('flex');
    threadEl.classList.add('hidden');
    errEl.classList.add('hidden');
    composer.closest('.border-t').classList.add('hidden');
  }

  function hideUnconfigured(){
    unconfigEl.classList.add('hidden');
    unconfigEl.classList.remove('flex');
    threadEl.classList.remove('hidden');
    composer.closest('.border-t').classList.remove('hidden');
  }

  // ---- Send + SSE ----
  function sendMessage(){
    if (streaming || !activeID) return;
    var content = composer.value.trim();
    if (!content) return;

    clearErr();
    composer.value = '';
    setComposer(false);
    streaming = true;

    appendBubble('user', content, false);
    scrollThread();

    var aiBubble = appendBubble('assistant', '', true);
    scrollThread();

    fetch(BASE + '/sessions/' + activeID + '/message', {
      method:'POST', credentials:'same-origin',
      headers:{'Content-Type':'application/json', Accept:'text/event-stream', 'X-CSRF-Token':csrf()},
      body: JSON.stringify({content: content})
    })
    .then(function(r){
      if (r.status === 409){
        return r.json().then(function(body){
          throw {type:'not_configured', msg: body.error || 'AI provider not configured.'};
        });
      }
      if (!r.ok) throw {type:'http', msg:'HTTP ' + r.status};
      return readSSE(r.body, aiBubble);
    })
    .then(function(){
      streaming = false;
      setComposer(true);
      composer.focus();
      loadSessions();
    })
    .catch(function(e){
      streaming = false;
      if (e && e.type === 'not_configured'){
        if (aiBubble && !aiBubble.textContent){
          var p = aiBubble.parentElement; if (p) p.remove();
        }
        var msgs = threadEl.querySelectorAll('[data-msg]');
        if (msgs.length){ msgs[msgs.length-1].remove(); }
        showUnconfigured();
        return;
      }
      var msg = (e && e.msg) ? e.msg : (e && e.message) ? e.message : 'Streaming error.';
      showErr(msg);
      if (aiBubble && !aiBubble.textContent){
        var pa = aiBubble.parentElement; if (pa) pa.remove();
      }
      setComposer(true);
    });
  }

  function readSSE(body, bubble){
    return new Promise(function(resolve, reject){
      var reader = body.getReader();
      var decoder = new TextDecoder();
      var buf = '';
      var currentEvent = '';

      function pump(){
        reader.read().then(function(result){
          if (result.done){ resolve(); return; }
          buf += decoder.decode(result.value, {stream:true});
          var lines = buf.split('\n');
          buf = lines.pop();
          lines.forEach(function(line){
            if (line.startsWith('event: ')){
              currentEvent = line.slice(7).trim();
            } else if (line.startsWith('data: ')){
              var raw = line.slice(6);
              try {
                var obj = JSON.parse(raw);
                if (currentEvent === 'done'){ resolve(); return; }
                if (currentEvent === 'error'){ reject({msg: obj.error || 'Stream error.'}); return; }
                if (obj.text){
                  bubble.textContent += obj.text;
                  scrollThread();
                }
              } catch(ex){}
              currentEvent = '';
            }
          });
          pump();
        }).catch(function(e){ reject({msg: e.message || 'Read error.'}); });
      }
      pump();
    });
  }

  // ---- Event wiring ----
  sendBtn.addEventListener('click', sendMessage);
  composer.addEventListener('keydown', function(e){
    if (e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); sendMessage(); }
  });
})();
</script>
{{end}}
