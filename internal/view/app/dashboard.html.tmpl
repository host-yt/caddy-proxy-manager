{{define "dashboard"}}
<div class="space-y-6">
  <section class="r-card overflow-hidden">
    <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-center">
      <div class="min-w-0">
        <p class="t-eyebrow">Workspace status</p>
        <h1 class="t-h1">Routes, services, and tunnels at a glance</h1>
        <p class="mt-2 text-sm leading-6 max-w-3xl" style="color:rgb(var(--muted))">Use this dashboard to see whether public domains are live, DNS or SSL still needs attention, and which service boundaries are ready for new mappings.</p>
      </div>
      <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
        <a href="/app/routes/new" class="r-btn-primary">New route</a>
        <a href="/app/routes" class="r-btn-secondary">Review DNS</a>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
    <a href="/app/services" class="r-card flex items-center gap-4 hover:ring-[rgb(var(--accent)/.45)] transition-shadow">
      <span class="icon-chip">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
      </span>
      <div class="min-w-0">
        <div class="t-eyebrow">Services</div>
        <div class="t-display">{{.ServiceCount}}</div>
        <p class="text-xs truncate" style="color:rgb(var(--muted))">Backend targets available</p>
      </div>
    </a>
    <a href="/app/routes" class="r-card flex items-center gap-4 hover:ring-emerald-300 dark:hover:ring-emerald-500/50 transition-shadow">
      <span class="icon-chip">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
      <div class="min-w-0">
        <div class="t-eyebrow">Active routes</div>
        <div class="t-display">{{.ActiveRoutes}}</div>
        {{if .FailedRoutes}}<p class="text-xs text-rose-600 dark:text-rose-400 truncate font-medium">{{.FailedRoutes}} failed</p>{{else}}<p class="text-xs truncate" style="color:rgb(var(--muted))">Domains serving traffic</p>{{end}}
      </div>
    </a>
    <a href="/app/routes" class="r-card flex items-center gap-4 hover:ring-amber-300 dark:hover:ring-amber-500/50 transition-shadow">
      <span class="icon-chip">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </span>
      <div class="min-w-0">
        <div class="t-eyebrow">Pending DNS/SSL</div>
        <div class="t-display {{if .PendingRoutes}}text-amber-600 dark:text-amber-400{{end}}">{{.PendingRoutes}}</div>
        <p class="text-xs truncate" style="color:rgb(var(--muted))">{{if .PendingRoutes}}Needs verification{{else}}No route checks waiting{{end}}</p>
      </div>
    </a>
    <div class="r-card flex items-center gap-4">
      <span class="icon-chip">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </span>
      <div class="min-w-0">
        <div class="t-eyebrow">Traffic · 7d</div>
        <div class="t-display">{{.TotalBandwidth7d}}</div>
        <p class="text-xs truncate" style="color:rgb(var(--muted))">Bytes served this week</p>
      </div>
    </div>
    <div class="r-card flex items-center gap-4">
      <span class="icon-chip">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h4l3-9 4 18 3-9h4"/></svg>
      </span>
      <div class="min-w-0">
        <div class="t-eyebrow">Requests · 24h</div>
        <div class="t-display">{{.Requests24h}}</div>
        {{if .Errors24h}}<p class="text-xs text-rose-600 dark:text-rose-400 truncate">{{.Errors24h}} errors (4xx/5xx)</p>{{else}}<p class="text-xs truncate" style="color:rgb(var(--muted))">All requests last 24 hours</p>{{end}}
      </div>
    </div>
  </div>

  {{if gt .Bandwidth30dTotal 0}}
  <section class="r-card p-4">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="t-eyebrow">Bandwidth · last 30 days</h3>
      <span class="text-sm font-semibold" style="color:rgb(var(--text))">{{formatBytes .Bandwidth30dTotal}}</span>
    </div>
    <div class="flex items-end gap-0.5" style="height:48px">
      {{range .Bandwidth30dDays}}
      {{$pct := divf .Bytes $.MaxDay30dBytes}}
      {{$h := mulf $pct 48.0}}
      <div class="flex-1 flex flex-col items-center gap-0.5 h-full justify-end" title="{{.Label}}: {{formatBytes .Bytes}}">
        <div class="w-full rounded-t bg-sky-400 dark:bg-sky-500 transition-all cursor-default"
             style="height: {{printf "%.0f" $h}}px; min-height: 2px"></div>
      </div>
      {{end}}
    </div>
  </section>
  {{end}}

  <section class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-4">
    <div class="r-card">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="t-eyebrow">Operating path</p>
          <h3 class="mt-1 font-semibold" style="color:rgb(var(--text))">Route setup checklist</h3>
        </div>
        <span class="r-pill r-pill-neutral">public traffic</span>
      </div>
      <div class="mt-4 grid gap-3">
        <a href="/app/services" class="group rounded-xl p-3 ring-1 transition hover:ring-[rgb(var(--accent)/.45)]" style="background:rgb(var(--surface-raised,var(--surface)));border-color:rgb(var(--border))">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 r-pill r-pill-neutral">1</span>
            <div class="min-w-0">
              <h4 class="font-medium text-sm" style="color:rgb(var(--text))">Confirm service boundary</h4>
              <p class="mt-1 text-xs leading-5" style="color:rgb(var(--muted))">Backend IP and allowed port range decide where routes can send requests.</p>
            </div>
          </div>
        </a>
        <a href="/app/routes/new" class="group rounded-xl p-3 ring-1 transition hover:ring-[rgb(var(--accent)/.45)]" style="background:rgb(var(--surface-raised,var(--surface)));border-color:rgb(var(--border))">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 r-pill r-pill-neutral">2</span>
            <div class="min-w-0">
              <h4 class="font-medium text-sm" style="color:rgb(var(--text))">Create the route</h4>
              <p class="mt-1 text-xs leading-5" style="color:rgb(var(--muted))">Choose a service, domain, path prefix, and upstream port in one form.</p>
            </div>
          </div>
        </a>
        <a href="/app/routes" class="group rounded-xl p-3 ring-1 transition hover:ring-[rgb(var(--accent)/.45)]" style="background:rgb(var(--surface-raised,var(--surface)));border-color:rgb(var(--border))">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 r-pill r-pill-neutral">3</span>
            <div class="min-w-0">
              <h4 class="font-medium text-sm" style="color:rgb(var(--text))">Watch DNS and certificate state</h4>
              <p class="mt-1 text-xs leading-5" style="color:rgb(var(--muted))">Re-check pending routes after DNS points at the assigned gateway.</p>
            </div>
          </div>
        </a>
      </div>
    </div>
    <a href="/app/tunnels" class="r-card block hover:ring-sky-300 dark:hover:ring-sky-500/50 transition-shadow">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="t-eyebrow">Private backends</p>
          <h3 class="mt-1 font-semibold" style="color:rgb(var(--text))">Use tunnels for closed inbound ports</h3>
        </div>
        <span class="icon-chip">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
      </div>
      <p class="mt-3 text-sm leading-6" style="color:rgb(var(--muted))">Create a WireGuard tunnel when the backend should remain private or cannot expose the target port directly.</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="r-pill r-pill-neutral">node selected</span>
        <span class="r-pill r-pill-neutral">private IP assigned</span>
        <span class="r-pill r-pill-neutral">handshake tracked</span>
      </div>
    </a>
  </section>
</div>
{{end}}
