{{define "dashboard"}}
<div class="space-y-6">
  <section class="hpg-card overflow-hidden relative">
    <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-slate-900 via-indigo-500 to-emerald-500 dark:from-slate-200"></div>
    <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-center pt-2">
      <div class="min-w-0">
        <p class="hpg-eyebrow">Workspace status</p>
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Routes, services, and tunnels at a glance</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300 max-w-3xl">Use this dashboard to see whether public domains are live, DNS or SSL still needs attention, and which service boundaries are ready for new mappings.</p>
      </div>
      <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
        <a href="/app/routes/new" class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 shadow-sm">New route</a>
        <a href="/app/routes" class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-white dark:bg-zinc-900 text-slate-700 dark:text-slate-200 ring-1 ring-slate-200 dark:ring-zinc-700 text-sm font-medium hover:bg-slate-50 dark:hover:bg-zinc-800">Review DNS</a>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
    <a href="/app/services" class="hpg-card flex items-center gap-4 hover:ring-indigo-300 dark:hover:ring-indigo-500/50 transition">
      <span class="hpg-chip bg-indigo-50 text-indigo-600 dark:bg-indigo-500/15 dark:text-indigo-300">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
      </span>
      <div class="min-w-0">
        <div class="hpg-eyebrow">Services</div>
        <div class="hpg-stat-num text-slate-950 dark:text-white">{{.ServiceCount}}</div>
        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Backend targets available</p>
      </div>
    </a>
    <a href="/app/routes" class="hpg-card flex items-center gap-4 hover:ring-emerald-300 dark:hover:ring-emerald-500/50 transition">
      <span class="hpg-chip bg-emerald-50 text-emerald-600 dark:bg-emerald-500/15 dark:text-emerald-300">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
      <div class="min-w-0">
        <div class="hpg-eyebrow">Active routes</div>
        <div class="hpg-stat-num text-slate-950 dark:text-white">{{.ActiveRoutes}}</div>
        {{if .FailedRoutes}}<p class="text-xs text-rose-600 dark:text-rose-400 truncate font-medium">{{.FailedRoutes}} failed</p>{{else}}<p class="text-xs text-slate-500 dark:text-slate-400 truncate">Domains serving traffic</p>{{end}}
      </div>
    </a>
    <a href="/app/routes" class="hpg-card flex items-center gap-4 hover:ring-amber-300 dark:hover:ring-amber-500/50 transition">
      <span class="hpg-chip bg-amber-50 text-amber-600 dark:bg-amber-500/15 dark:text-amber-300">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </span>
      <div class="min-w-0">
        <div class="hpg-eyebrow">Pending DNS/SSL</div>
        <div class="hpg-stat-num {{if .PendingRoutes}}text-amber-600 dark:text-amber-400{{else}}text-slate-950 dark:text-white{{end}}">{{.PendingRoutes}}</div>
        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">{{if .PendingRoutes}}Needs verification{{else}}No route checks waiting{{end}}</p>
      </div>
    </a>
    <div class="hpg-card flex items-center gap-4">
      <span class="hpg-chip bg-sky-50 text-sky-600 dark:bg-sky-500/15 dark:text-sky-300">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </span>
      <div class="min-w-0">
        <div class="hpg-eyebrow">Traffic · 7d</div>
        <div class="hpg-stat-num text-slate-950 dark:text-white">{{.TotalBandwidth7d}}</div>
        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Bytes served this week</p>
      </div>
    </div>
  </div>

  <section class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-4">
    <div class="hpg-card">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="hpg-eyebrow">Operating path</p>
          <h3 class="mt-1 font-semibold text-slate-950 dark:text-white">Route setup checklist</h3>
        </div>
        <span class="hpg-pill hpg-pill-muted">public traffic</span>
      </div>
      <div class="mt-4 grid gap-3">
        <a href="/app/services" class="group rounded-xl bg-slate-50 dark:bg-zinc-800/50 p-3 ring-1 ring-slate-200/70 dark:ring-zinc-700 hover:ring-indigo-300 dark:hover:ring-indigo-500/50 transition">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 hpg-pill hpg-pill-muted">1</span>
            <div class="min-w-0">
              <h4 class="font-medium text-sm text-slate-900 dark:text-white">Confirm service boundary</h4>
              <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">Backend IP and allowed port range decide where routes can send requests.</p>
            </div>
          </div>
        </a>
        <a href="/app/routes/new" class="group rounded-xl bg-slate-50 dark:bg-zinc-800/50 p-3 ring-1 ring-slate-200/70 dark:ring-zinc-700 hover:ring-indigo-300 dark:hover:ring-indigo-500/50 transition">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 hpg-pill hpg-pill-muted">2</span>
            <div class="min-w-0">
              <h4 class="font-medium text-sm text-slate-900 dark:text-white">Create the route</h4>
              <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">Choose a service, domain, path prefix, and upstream port in one form.</p>
            </div>
          </div>
        </a>
        <a href="/app/routes" class="group rounded-xl bg-slate-50 dark:bg-zinc-800/50 p-3 ring-1 ring-slate-200/70 dark:ring-zinc-700 hover:ring-indigo-300 dark:hover:ring-indigo-500/50 transition">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 hpg-pill hpg-pill-muted">3</span>
            <div class="min-w-0">
              <h4 class="font-medium text-sm text-slate-900 dark:text-white">Watch DNS and certificate state</h4>
              <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">Re-check pending routes after DNS points at the assigned gateway.</p>
            </div>
          </div>
        </a>
      </div>
    </div>
    <a href="/app/tunnels" class="hpg-card block hover:ring-sky-300 dark:hover:ring-sky-500/50 transition">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="hpg-eyebrow">Private backends</p>
          <h3 class="mt-1 font-semibold text-slate-950 dark:text-white">Use tunnels for closed inbound ports</h3>
        </div>
        <span class="hpg-chip bg-sky-50 text-sky-600 dark:bg-sky-500/15 dark:text-sky-300">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">Create a WireGuard tunnel when the backend should remain private or cannot expose the target port directly.</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="hpg-pill hpg-pill-muted">node selected</span>
        <span class="hpg-pill hpg-pill-muted">private IP assigned</span>
        <span class="hpg-pill hpg-pill-muted">handshake tracked</span>
      </div>
    </a>
  </section>
</div>
{{end}}
