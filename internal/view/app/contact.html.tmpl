{{define "contact"}}
<div class="max-w-lg space-y-5">
  <section class="r-card">
    <h2 class="font-semibold text-text mb-4">Contact support</h2>
    {{if .MailerReady}}
    <form method="POST" action="/app/contact" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-sm font-medium text-muted mb-1">Subject</label>
        <input type="text" name="subject" required maxlength="128" class="r-input w-full">
      </div>
      <div>
        <label class="block text-sm font-medium text-muted mb-1">Message</label>
        <textarea name="message" required maxlength="2000" rows="6" class="r-input w-full resize-y"></textarea>
      </div>
      <button type="submit" class="r-btn-primary">Send message</button>
    </form>
    {{else}}
    <p class="text-sm text-muted">Email support is not configured. Please contact support directly.</p>
    {{end}}
  </section>
</div>
{{end}}
