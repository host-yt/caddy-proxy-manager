{{define "contact"}}
<div class="max-w-lg space-y-5">
  <section class="hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-4">Contact support</h2>
    {{if .MailerReady}}
    <form method="POST" action="/app/contact" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Subject</label>
        <input type="text" name="subject" required maxlength="128"
          class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Message</label>
        <textarea name="message" required maxlength="2000" rows="6"
          class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none text-sm resize-y"></textarea>
      </div>
      <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer">Send message</button>
    </form>
    {{else}}
    <p class="text-sm text-slate-500">Email support is not configured. Please contact support directly.</p>
    {{end}}
  </section>
</div>
{{end}}
