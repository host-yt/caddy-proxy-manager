{{define "reset.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Set new password - Hostyt Proxy</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<script nonce="{{.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
</head>
<body style="background:rgb(var(--bg));color:rgb(var(--text))" class="min-h-screen flex items-center justify-center p-4">
<div class="w-full max-w-sm mx-auto">

  <header class="text-center mb-6">
    <h1 class="t-h2">Choose a new password</h1>
    <p class="t-small mt-1" style="color:rgb(var(--muted))">Must be at least 12 characters.</p>
  </header>

  <div class="r-card">
    {{if .Error}}
    <div class="mb-4 p-3 rounded-lg t-small" style="background:rgb(var(--danger)/.12);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))">{{.Error}}</div>
    {{end}}

    <form method="POST" action="/auth/reset" class="space-y-4">
      <input type="hidden" name="token" value="{{.Token}}">
      <div>
        <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">New password</label>
        <input name="password" type="password" minlength="12" required autofocus class="r-input w-full">
      </div>
      <div>
        <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Confirm password</label>
        <input name="password_confirm" type="password" minlength="12" required class="r-input w-full">
      </div>
      <button class="r-btn-primary w-full cursor-pointer">Set password</button>
    </form>
  </div>

</div>
</body>
</html>
{{end}}
