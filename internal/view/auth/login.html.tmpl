{{define "login.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Sign in - {{if .Brand.BrandName}}{{.Brand.BrandName}}{{else}}Hostyt Proxy Gateway{{end}}</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<script nonce="{{.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
{{if .Brand.FaviconURL}}<link rel="icon" href="{{.Brand.FaviconURL}}">{{end}}
<style>
  /* Global form-control dark-mode safety net (see install/_layout for context). */
  input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  select, textarea { color: rgb(15 23 42); }
  .dark input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  .dark select, .dark textarea {
    background-color: rgb(39 39 42);
    border-color: rgb(63 63 70);
    color: rgb(241 245 249);
  }
  .dark input::placeholder, .dark textarea::placeholder { color: rgb(100 116 139); }
</style>
{{if .CaptchaEnabled}}<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer nonce="{{.CSPNonce}}"></script>{{end}}
</head>
<body class="h-full bg-slate-50 dark:bg-zinc-950 text-slate-900 dark:text-slate-100 flex items-center justify-center p-4">
<div class="w-full max-w-sm">
  <header class="text-center mb-6">
    {{if .Brand.LogoURLLight}}<img src="{{.Brand.LogoURLLight}}" alt="" class="h-12 mx-auto mb-3 dark:hidden">{{end}}
    {{if .Brand.LogoURLDark}}<img src="{{.Brand.LogoURLDark}}" alt="" class="h-12 mx-auto mb-3 hidden dark:inline-block">{{end}}
    <h1 class="text-xl font-semibold tracking-tight">{{if .Brand.BrandName}}{{.Brand.BrandName}}{{else}}Hostyt Proxy Gateway{{end}}</h1>
    {{if .Brand.Tagline}}<p class="text-slate-500 dark:text-slate-400 text-xs mt-1">{{.Brand.Tagline}}</p>{{end}}
    <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Sign in</p>
  </header>

  <main class="bg-white dark:bg-zinc-900 rounded-xl shadow-sm border border-slate-200 dark:border-zinc-800 p-6">
    {{if .Flash}}<div class="mb-4 p-3 rounded-md bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30 text-emerald-800 dark:text-emerald-300 text-sm">{{.Flash}}</div>{{end}}
    {{if .Error}}<div class="mb-4 p-3 rounded-md bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/30 text-rose-800 dark:text-rose-300 text-sm">{{.Error}}</div>{{end}}

    {{if .PasswordLoginDisabled}}
    <p class="text-sm text-slate-600 dark:text-slate-300 mb-4">Password login is disabled. Please use SSO to sign in.</p>
    {{else}}
    <!-- Two-step layout: stage 1 = email, stage 2 = password.
         JS reveals the password block once the email field is non-empty.
         Falls back to a single-shot form when JS is off (both fields
         submitted together). The actual POST handler is unchanged. -->
    <form method="POST" action="/auth/login" id="login-form" class="space-y-4">
      <div id="stage-email">
        <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
        <input name="email" id="login-email" value="{{.Email}}" type="email" required autofocus autocomplete="username"
               class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <button type="button" id="stage-email-next"
                class="mt-3 w-full px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2">
          Next
        </button>
      </div>

      <div id="stage-password" class="hidden space-y-3">
        <div class="flex items-center justify-between text-xs text-slate-500 dark:text-slate-400">
          <span id="login-email-display" class="truncate"></span>
          <button type="button" id="stage-email-back" class="text-indigo-600 dark:text-indigo-400 hover:underline">change</button>
        </div>
        <div>
          <label class="flex items-center justify-between text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">
            <span>Password</span>
            <a href="/auth/forgot" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">Forgot?</a>
          </label>
          <input name="password" id="login-password" type="password" required autocomplete="current-password"
                 class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        {{if .CaptchaEnabled}}<div class="cf-turnstile" data-sitekey="{{.CaptchaSiteKey}}"></div>{{end}}
        <button class="w-full px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2">
          Sign in
        </button>
      </div>
    </form>
    {{end}}

    {{if or .OIDCEnabled .PasskeyEnabled .GitHubEnabled .GoogleEnabled}}
    {{if not .PasswordLoginDisabled}}<div class="my-4 flex items-center gap-2 text-xs text-slate-400 dark:text-slate-500">
      <span class="flex-1 border-t border-slate-200 dark:border-zinc-800 dark:border-zinc-700"></span>
      <span>or</span>
      <span class="flex-1 border-t border-slate-200 dark:border-zinc-800 dark:border-zinc-700"></span>
    </div>{{end}}
    {{end}}

    {{if .PasskeyEnabled}}
    <button type="button" id="passkey-login-btn"
      class="block w-full text-center px-4 py-2 rounded-md border border-slate-300 dark:border-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm font-medium mb-3">
      <span class="inline-flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a3 3 0 11-6 0 3 3 0 016 0zM12 14c-3 0-5 1.5-5 3.5V20h10v-2.5C17 15.5 15 14 12 14z"/></svg>
        Sign in with a passkey
      </span>
    </button>
    <p id="passkey-err" class="text-xs text-rose-600 dark:text-rose-400 mb-3 hidden"></p>
    {{end}}

    {{if .OIDCEnabled}}
    <a href="/auth/oidc/start" class="block w-full text-center px-4 py-2 rounded-md border border-slate-300 dark:border-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm font-medium">
      Sign in with {{.OIDCProviderName}}
    </a>
    {{end}}
    {{if .GitHubEnabled}}
    <a href="/auth/github/start" class="mt-3 flex w-full items-center justify-center gap-2 px-4 py-2 rounded-md border border-slate-300 dark:border-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm font-medium">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      Sign in with GitHub
    </a>
    {{end}}
    {{if .GoogleEnabled}}
    <a href="/auth/google/start" class="mt-3 flex w-full items-center justify-center gap-2 px-4 py-2 rounded-md border border-slate-300 dark:border-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm font-medium">
      <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      Sign in with Google
    </a>
    {{end}}
  </main>
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  var emailInput = document.getElementById('login-email');
  var passInput  = document.getElementById('login-password');
  var stageEmail = document.getElementById('stage-email');
  var stagePass  = document.getElementById('stage-password');
  var nextBtn    = document.getElementById('stage-email-next');
  var backBtn    = document.getElementById('stage-email-back');
  var display    = document.getElementById('login-email-display');
  var form       = document.getElementById('login-form');

  // If the server bounced us back with an error and the email is
  // pre-filled, jump straight to the password stage so the user
  // doesn't see their email field disappear.
  if (emailInput && emailInput.value.trim() !== '') {
    reveal();
  }

  function reveal(){
    if (!emailInput.value.trim() || !emailInput.checkValidity()) {
      emailInput.reportValidity();
      return;
    }
    display.textContent = emailInput.value.trim();
    stageEmail.classList.add('hidden');
    stagePass.classList.remove('hidden');
    setTimeout(function(){ passInput.focus(); }, 30);
  }
  if (nextBtn) nextBtn.addEventListener('click', reveal);
  if (backBtn) backBtn.addEventListener('click', function(){
    stagePass.classList.add('hidden');
    stageEmail.classList.remove('hidden');
    emailInput.focus();
  });
  // Enter inside the email field acts as "Next" instead of submitting
  // a half-filled form.
  if (emailInput) emailInput.addEventListener('keydown', function(e){
    if (e.key === 'Enter' && stagePass.classList.contains('hidden')) {
      e.preventDefault();
      reveal();
    }
  });
})();
</script>
{{if .PasskeyEnabled}}
<script nonce="{{.CSPNonce}}">
(function(){
  var btn = document.getElementById('passkey-login-btn');
  var err = document.getElementById('passkey-err');
  if (!btn || !window.PublicKeyCredential) { if (btn) btn.style.display='none'; return; }
  function showErr(m){ if (err) { err.textContent=m; err.classList.remove('hidden'); } }
  function b64uToBuf(s){
    s = (s||'').replace(/-/g,'+').replace(/_/g,'/');
    while (s.length % 4) s += '=';
    var bin = atob(s);
    var b = new Uint8Array(bin.length);
    for (var i=0;i<bin.length;i++) b[i] = bin.charCodeAt(i);
    return b.buffer;
  }
  function bufToB64u(buf){
    var b = new Uint8Array(buf), s='';
    for (var i=0;i<b.length;i++) s += String.fromCharCode(b[i]);
    return btoa(s).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
  }
  function reviveOpts(o){
    o = o.publicKey || o;
    o.challenge = b64uToBuf(o.challenge);
    if (o.allowCredentials) o.allowCredentials.forEach(function(c){ c.id = b64uToBuf(c.id); });
    return o;
  }
  function encodeAssertion(cred){
    return {
      id: cred.id,
      rawId: bufToB64u(cred.rawId),
      type: cred.type,
      response: {
        authenticatorData: bufToB64u(cred.response.authenticatorData),
        clientDataJSON:    bufToB64u(cred.response.clientDataJSON),
        signature:         bufToB64u(cred.response.signature),
        userHandle:        cred.response.userHandle ? bufToB64u(cred.response.userHandle) : null
      },
      clientExtensionResults: cred.getClientExtensionResults ? cred.getClientExtensionResults() : {}
    };
  }
  btn.addEventListener('click', function(){
    err && err.classList.add('hidden');
    fetch('/auth/passkey/login/begin', { method: 'POST', credentials: 'same-origin' })
      .then(function(r){ if (!r.ok) throw new Error('begin failed'); return r.json(); })
      .then(function(opts){
        return navigator.credentials.get({ publicKey: reviveOpts(opts) });
      })
      .then(function(cred){
        return fetch('/auth/passkey/login/finish', {
          method:'POST', credentials:'same-origin',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify(encodeAssertion(cred))
        });
      })
      .then(function(r){
        if (!r.ok) return r.text().then(function(t){ throw new Error(t || 'verification failed'); });
        return r.json();
      })
      .then(function(j){ window.location.href = j.redirect || '/'; })
      .catch(function(e){ showErr('Passkey login failed: ' + (e.message || e)); });
  });
})();
</script>
{{end}}
</body>
</html>
{{end}}
