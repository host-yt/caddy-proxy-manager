{{define "email_otp_challenge.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Email verification - Hostyt Proxy</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<script nonce="{{.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
</head>
<body style="background:rgb(var(--bg));color:rgb(var(--text))" class="min-h-screen flex items-center justify-center p-4">
<div class="w-full max-w-sm mx-auto">

  <header class="text-center mb-6">
    <div class="icon-chip mx-auto mb-3" style="background:rgb(var(--accent)/.12)">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:rgb(var(--accent))" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </div>
    <h1 class="t-h2">Email verification</h1>
    <p class="t-small mt-1" style="color:rgb(var(--muted))">Enter the 6-digit code sent to your email.</p>
  </header>

  <div class="r-card">
    {{if .Error}}
    <div class="mb-4 p-3 rounded-lg t-small" style="background:rgb(var(--danger)/.12);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))">{{.Error}}</div>
    {{end}}

    <form method="POST" action="/auth/email-otp" class="space-y-4">
      <div>
        <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Verification code</label>
        <input name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus autocomplete="one-time-code"
               placeholder="123456"
               class="r-input w-full text-center text-2xl tracking-widest tabular-nums font-mono">
      </div>
      <button class="r-btn-primary w-full cursor-pointer">Verify code</button>
    </form>

    <p class="text-center t-caption mt-4" style="color:rgb(var(--muted))">Code expires in 10 minutes.</p>
  </div>

</div>
</body>
</html>
{{end}}
