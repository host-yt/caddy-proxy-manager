{{define "forgot.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Forgot password - Hostyt Proxy</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<script nonce="{{.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
</head>
<body style="background:rgb(var(--bg));color:rgb(var(--text))" class="min-h-screen flex items-center justify-center p-4">
<div class="w-full max-w-sm mx-auto">

  <header class="text-center mb-6">
    <h1 class="t-h2">Reset password</h1>
    <p class="t-small mt-1" style="color:rgb(var(--muted))">Enter your account email.</p>
  </header>

  <div class="r-card">
    {{if .Flash}}
    <div class="mb-4 p-3 rounded-lg t-small" style="background:rgb(var(--success)/.12);border:1px solid rgb(var(--success)/.3);color:rgb(var(--success))">{{.Flash}}</div>
    {{end}}
    {{if .Error}}
    <div class="mb-4 p-3 rounded-lg t-small" style="background:rgb(var(--danger)/.12);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))">{{.Error}}</div>
    {{end}}

    <form method="POST" action="/auth/forgot" class="space-y-4">
      <div>
        <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Email</label>
        <input name="email" type="email" required autofocus value="{{.Email}}" class="r-input w-full">
      </div>
      <button class="r-btn-primary w-full cursor-pointer">Send reset link</button>
    </form>

    <p class="text-center t-small mt-4">
      <a href="/auth/login" class="hover:underline" style="color:rgb(var(--accent))">
        <svg xmlns="http://www.w3.org/2000/svg" class="inline h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to sign in
      </a>
    </p>
  </div>

</div>
</body>
</html>
{{end}}
