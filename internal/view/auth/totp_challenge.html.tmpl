{{define "totp_challenge.html.tmpl"}}<!doctype html>
<html lang="{{.Lang}}" class="h-full">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>2FA - Hostyt Proxy</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<script nonce="{{.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
<style nonce="{{.CSPNonce}}">
  .method-tab { transition: background .15s, color .15s; }
  .method-tab.active { background: rgb(var(--accent)); color: rgb(var(--accent-text-on)); }
  .method-tab:not(.active) { background: rgb(var(--surface-2)); color: rgb(var(--muted)); }
  .method-tab[disabled] { opacity: .4; cursor: not-allowed; }
</style>
</head>
<body style="background:rgb(var(--bg));color:rgb(var(--text))" class="min-h-screen flex items-center justify-center p-4">
<div class="w-full max-w-md mx-auto">

  <header class="text-center mb-6">
    <div class="icon-chip mx-auto mb-3" style="background:rgb(var(--accent)/.12)">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:rgb(var(--accent))" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
    </div>
    <h1 class="t-h2">Two-factor authentication</h1>
    <p class="t-small mt-1" style="color:rgb(var(--muted))">Verify your identity to continue.</p>
  </header>

  <div class="r-card">
    {{if .Error}}
    <div class="mb-4 p-3 rounded-lg t-small" style="background:rgb(var(--danger)/.12);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))">{{.Error}}</div>
    {{end}}

    <div class="flex flex-wrap gap-2 mb-5 pb-4" style="border-bottom:1px solid rgb(var(--border))" id="methodTabs">
      {{if .HasTOTP}}<button type="button" data-method="totp" class="method-tab px-3 py-1.5 rounded-lg t-small font-medium cursor-pointer">Authenticator app</button>{{end}}
      {{if .HasEmail}}<button type="button" data-method="email" class="method-tab px-3 py-1.5 rounded-lg t-small font-medium cursor-pointer">Email</button>{{end}}
      {{if .HasSMS}}<button type="button" data-method="sms" class="method-tab px-3 py-1.5 rounded-lg t-small font-medium cursor-pointer">SMS</button>{{end}}
      {{if .HasRecovery}}<button type="button" data-method="recovery" class="method-tab px-3 py-1.5 rounded-lg t-small font-medium cursor-pointer">Recovery code</button>{{end}}
    </div>

    <form method="POST" action="/auth/2fa" class="space-y-4">
      <input type="hidden" name="method" id="methodField" value="{{.DefaultMethod}}">

      <div id="sendRow" class="hidden space-y-2">
        <button type="button" id="sendBtn" class="r-btn-secondary w-full cursor-pointer">Send code</button>
        <p id="sendStatus" class="t-caption" style="color:rgb(var(--muted))"></p>
      </div>

      <div>
        <label class="block t-caption font-medium mb-1" id="codeLabel" style="color:rgb(var(--text))">Code</label>
        <input name="code" id="codeInput" inputmode="numeric" autocomplete="one-time-code" required autofocus
               placeholder="123456"
               class="r-input w-full text-center text-2xl tracking-widest tabular-nums font-mono">
      </div>

      <label class="flex items-center gap-2 t-small select-none cursor-pointer">
        <input type="checkbox" name="trust_device" class="rounded" style="border-color:rgb(var(--border))">
        <span style="color:rgb(var(--muted))">Remember this browser for 30 days</span>
      </label>

      <button class="r-btn-primary w-full cursor-pointer">Verify</button>
    </form>

    <p class="text-center t-small mt-4">
      <a href="/auth/login" class="hover:underline" style="color:rgb(var(--muted))">Cancel and return to sign in</a>
    </p>
  </div>

</div>

<script nonce="{{.CSPNonce}}">
(function(){
  var tabs = document.querySelectorAll('#methodTabs .method-tab');
  var methodField = document.getElementById('methodField');
  var sendRow = document.getElementById('sendRow');
  var sendBtn = document.getElementById('sendBtn');
  var sendStatus = document.getElementById('sendStatus');
  var codeInput = document.getElementById('codeInput');
  var codeLabel = document.getElementById('codeLabel');

  function setActive(m) {
    methodField.value = m;
    tabs.forEach(function(t){
      t.classList.toggle('active', t.dataset.method === m);
    });
    if (m === 'sms' || m === 'email') {
      sendRow.classList.remove('hidden');
      codeInput.placeholder = '••••••';
      codeInput.setAttribute('pattern', '[0-9]*');
      codeLabel.textContent = (m === 'email' ? 'Email' : 'SMS') + ' code';
      sendStatus.textContent = '';
    } else if (m === 'recovery') {
      sendRow.classList.add('hidden');
      codeInput.placeholder = 'recovery-code';
      codeInput.removeAttribute('pattern');
      codeLabel.textContent = 'Recovery code';
    } else {
      sendRow.classList.add('hidden');
      codeInput.placeholder = '123456';
      codeInput.setAttribute('pattern', '[0-9]*');
      codeLabel.textContent = 'Authenticator code';
    }
    codeInput.value = '';
  }
  tabs.forEach(function(t){ t.addEventListener('click', function(){ setActive(t.dataset.method); }); });

  var sendBtnLabel = sendBtn ? sendBtn.textContent : 'Send code';
  var cooldownTimer = null;
  function startCooldown(sec) {
    if (cooldownTimer) clearInterval(cooldownTimer);
    var left = sec;
    sendBtn.disabled = true;
    sendBtn.textContent = 'Resend in ' + left + 's';
    cooldownTimer = setInterval(function(){
      left -= 1;
      if (left <= 0) {
        clearInterval(cooldownTimer);
        cooldownTimer = null;
        sendBtn.disabled = false;
        sendBtn.textContent = sendBtnLabel;
        return;
      }
      sendBtn.textContent = 'Resend in ' + left + 's';
    }, 1000);
  }

  if (sendBtn) {
    sendBtn.addEventListener('click', function(){
      sendBtn.disabled = true;
      sendStatus.textContent = 'Sending…';
      var body = new URLSearchParams();
      body.append('method', methodField.value);
      fetch('/auth/2fa/send', {
        method: 'POST',
        body: body,
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        credentials: 'same-origin'
      })
        .then(function(r){
          if (r.status === 204) {
            sendStatus.textContent = 'Code sent. Check your ' + (methodField.value === 'email' ? 'inbox.' : 'phone.');
            codeInput.focus();
            var after = parseInt(r.headers.get('X-Resend-After') || '60', 10);
            startCooldown(after);
            return;
          }
          if (r.status === 429) {
            var retry = parseInt(r.headers.get('Retry-After') || '60', 10);
            return r.text().then(function(t){
              sendStatus.textContent = t || ('Wait ' + retry + 's before resending.');
              startCooldown(retry);
            });
          }
          return r.text().then(function(t){ throw new Error(t || ('HTTP '+r.status)); });
        })
        .catch(function(e){
          sendStatus.textContent = 'Send failed: ' + (e.message || e);
          sendBtn.disabled = false;
        });
    });
  }

  if (methodField.value) setActive(methodField.value);
})();
</script>
</body>
</html>
{{end}}
