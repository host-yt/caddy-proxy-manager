{{define "admin"}}
<h2 class="text-xl font-semibold mb-1">Admin account</h2>
<p class="text-sm text-slate-500 mb-5">
  This account gets the <code>super_admin</code> role. Password is
  Argon2id-hashed at rest. Enable 2FA after first login.
</p>
<form method="POST" action="/install/admin" class="space-y-4">
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Full name</label>
    <input name="full_name" value="{{.Form.FullName}}" required
           class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Email</label>
    <input name="email" value="{{.Form.Email}}" type="email" required
           class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Password</label>
      <input name="password" type="password" minlength="12" required
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Confirm password</label>
      <input name="password_confirm" type="password" minlength="12" required
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <p class="text-xs text-slate-500">Min 12 characters.</p>
  <div class="flex justify-end pt-2">
    <button class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
      Create admin →
    </button>
  </div>
</form>
{{end}}
