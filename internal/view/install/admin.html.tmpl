{{define "admin"}}
<p class="t-eyebrow" style="margin-bottom:0.25rem;">Step 4</p>
<h2 class="t-h2" style="margin-bottom:0.375rem;">Admin account</h2>
<p class="t-small" style="color:rgb(var(--muted));margin-bottom:1.25rem;">
  This account gets the <code>super_admin</code> role. Password is
  Argon2id-hashed at rest. Enable 2FA after first login.
</p>
<form method="POST" action="/install/admin" style="display:flex;flex-direction:column;gap:0.875rem;">
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Full name</label>
    <input name="full_name" value="{{.Form.FullName}}" required class="r-input">
  </div>
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Email</label>
    <input name="email" value="{{.Form.Email}}" type="email" required class="r-input">
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Password</label>
      <input name="password" type="password" minlength="12" required class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Confirm password</label>
      <input name="password_confirm" type="password" minlength="12" required class="r-input">
    </div>
  </div>
  <p class="t-caption" style="color:rgb(var(--muted));">Min 12 characters.</p>
  <div style="display:flex;justify-content:flex-end;padding-top:0.375rem;">
    <button class="r-btn-primary" type="submit">Create admin &rarr;</button>
  </div>
</form>
{{end}}
