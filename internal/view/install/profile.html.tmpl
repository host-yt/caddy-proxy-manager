{{define "profile"}}
<p class="t-eyebrow" style="margin-bottom:0.25rem;">Step 2</p>
<h2 class="t-h2" style="margin-bottom:0.375rem;">Deployment profile</h2>
<p class="t-small" style="color:rgb(var(--muted));margin-bottom:1.25rem;">
  Choose the profile that best describes your use-case. Controls visible modules
  and menu items after install. Changeable later in Settings.
</p>
<form method="POST" action="/install/profile" style="display:flex;flex-direction:column;gap:0.625rem;">
  {{range .Form.Options}}
  <label style="display:flex;align-items:flex-start;gap:0.875rem;padding:1rem;border-radius:0.75rem;border:1px solid {{if eq $.Form.Selected .Value}}rgb(var(--accent)){{else}}rgb(var(--border)){{end}};background:{{if eq $.Form.Selected .Value}}rgb(var(--accent) / .06){{else}}transparent{{end}};cursor:pointer;transition:border-color .15s,background .15s;">
    <input type="radio" name="profile" value="{{.Value}}"
           {{if eq $.Form.Selected .Value}}checked{{end}}
           style="margin-top:0.125rem;accent-color:rgb(var(--accent));cursor:pointer;flex-shrink:0;">
    <div style="flex:1;min-width:0;">
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.25rem;">
        <span class="t-small" style="font-weight:600;">{{.Label}}</span>
        <span class="r-pill r-pill-neutral" style="font-size:0.7rem;">DB: {{.RecommendDB}}</span>
      </div>
      <p class="t-caption" style="color:rgb(var(--muted));">{{.Description}}</p>
    </div>
  </label>
  {{end}}
  <div style="display:flex;justify-content:flex-end;padding-top:0.5rem;">
    <button class="r-btn-primary" type="submit" style="cursor:pointer;">Continue &rarr;</button>
  </div>
</form>
{{end}}
