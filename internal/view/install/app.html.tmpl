{{define "app"}}
<h2 class="text-xl font-semibold mb-1">Panel URL</h2>
<p class="text-sm text-slate-500 mb-5">
  Public URL where this panel is reachable. Used for email links and OIDC
  redirects. Include the scheme.
</p>
<form method="POST" action="/install/app" class="space-y-4">
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Panel URL</label>
    <input name="url" value="{{.Form.URL}}" type="url" required placeholder="https://panel.example.com"
           class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    <p class="text-xs text-slate-500 mt-1">e.g. <code>https://panel.example.com</code> or <code>http://localhost:8080</code></p>
  </div>
  <div class="flex justify-end pt-2">
    <button class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
      Save →
    </button>
  </div>
</form>
{{end}}
