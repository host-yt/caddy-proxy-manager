{{define "app"}}
<p class="t-eyebrow" style="margin-bottom:0.25rem;">Step 5</p>
<h2 class="t-h2" style="margin-bottom:0.375rem;">Panel URL</h2>
<p class="t-small" style="color:rgb(var(--muted));margin-bottom:1.25rem;">
  Public URL where this panel is reachable. Used for email links and OIDC
  redirects. Include the scheme.
</p>
<form method="POST" action="/install/app" style="display:flex;flex-direction:column;gap:0.875rem;">
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Panel URL</label>
    <input name="url" value="{{.Form.URL}}" type="url" required placeholder="https://panel.example.com" class="r-input" style="font-family:monospace;">
    <p class="t-caption" style="color:rgb(var(--muted));margin-top:0.375rem;">e.g. <code>https://panel.example.com</code> or <code>http://localhost:8080</code></p>
  </div>
  <div style="display:flex;justify-content:flex-end;padding-top:0.375rem;">
    <button class="r-btn-primary" type="submit">Save &rarr;</button>
  </div>
</form>
{{end}}
