{{define "caddy"}}
<h2 class="text-xl font-semibold mb-1">First Caddy node</h2>
<p class="text-sm text-slate-500 mb-5">
  Register the proxy node this panel will manage. Admin API URL must be
  reachable from this container; <strong>do not expose :2019 publicly</strong>.
</p>
<form method="POST" action="/install/caddy" class="space-y-4">
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Node name</label>
    <input name="name" value="{{.Form.Name}}" required placeholder="node-1"
           class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Admin API URL</label>
    <input name="api_url" value="{{.Form.APIURL}}" required placeholder="http://caddy:2019"
           class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Public hostname</label>
      <input name="public_hostname" value="{{.Form.PublicHostname}}" required placeholder="proxy.node.yt"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Public IP (optional)</label>
      <input name="public_ip" value="{{.Form.PublicIP}}" placeholder="203.0.113.10"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <div class="flex justify-end pt-2">
    <button class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
      Register & finish →
    </button>
  </div>
</form>
{{end}}
