{{define "caddy"}}
<p class="t-eyebrow" style="margin-bottom:0.25rem;">Step 7</p>
<h2 class="t-h2" style="margin-bottom:0.375rem;">First Caddy node</h2>
<p class="t-small" style="color:rgb(var(--muted));margin-bottom:1.25rem;">
  Register the proxy node this panel will manage. Admin API URL must be
  reachable from this container; <strong>do not expose :2019 publicly</strong>.
</p>
<form method="POST" action="/install/caddy" style="display:flex;flex-direction:column;gap:0.875rem;">
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Node name</label>
    <input name="name" value="{{.Form.Name}}" required placeholder="node-1" class="r-input">
  </div>
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Admin API URL</label>
    <input name="api_url" value="{{.Form.APIURL}}" required placeholder="http://caddy:2019" class="r-input" style="font-family:monospace;">
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Public hostname</label>
      <input name="public_hostname" value="{{.Form.PublicHostname}}" required placeholder="proxy.node.example.com" class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Public IP <span style="font-weight:400;color:rgb(var(--muted));">(optional)</span></label>
      <input name="public_ip" value="{{.Form.PublicIP}}" placeholder="203.0.113.10" class="r-input" style="font-variant-numeric:tabular-nums;">
    </div>
  </div>
  <div style="display:flex;justify-content:flex-end;padding-top:0.375rem;">
    <button class="r-btn-primary" type="submit">Register &amp; finish &rarr;</button>
  </div>
</form>
{{end}}
