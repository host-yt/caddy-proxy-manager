{{define "layout.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hostyt Proxy Gateway - Install</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<script nonce="{{.Data.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
<style nonce="{{.Data.CSPNonce}}">
  .step-dot {
    width:8px;height:8px;border-radius:9999px;
    background-color:rgb(var(--border));
    transition:background-color .2s,box-shadow .2s;
  }
  .step-dot.done { background-color:rgb(var(--success)); }
  .step-dot.active {
    background-color:rgb(var(--accent));
    box-shadow:0 0 0 3px rgb(var(--accent) / .25);
  }
  input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  select,textarea { color:rgb(var(--text)); }
</style>
</head>
<body style="min-height:100vh;background:rgb(var(--bg));color:rgb(var(--text));display:flex;align-items:center;justify-content:center;padding:1rem;">
<div style="width:100%;max-width:38rem;">

  <header style="text-align:center;margin-bottom:2rem;">
    <div style="display:inline-flex;align-items:center;justify-content:center;width:3rem;height:3rem;border-radius:0.875rem;background:rgb(var(--accent) / .12);margin-bottom:0.75rem;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgb(var(--accent))" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
      </svg>
    </div>
    <h1 class="t-h2" style="margin-bottom:0.125rem;">Hostyt Proxy Gateway</h1>
    <p class="t-caption" style="color:rgb(var(--muted));">Install wizard</p>
  </header>

  <nav style="display:flex;justify-content:center;gap:0.5rem;margin-bottom:1.5rem;" aria-label="Setup progress">
    {{range $i, $s := .Data.Steps}}
      <span class="step-dot {{if eq $s $.Step}}active{{else if $.Data.IsDone $s}}done{{end}}" title="{{$s}}"></span>
    {{end}}
  </nav>

  <main class="r-card" style="padding:1.75rem;">
    {{if .Data.Error}}
      <div style="margin-bottom:1rem;padding:0.75rem 1rem;border-radius:0.5rem;background:rgb(var(--danger) / .08);border:1px solid rgb(var(--danger) / .25);color:rgb(var(--danger));font-size:0.875rem;">
        {{.Data.Error}}
      </div>
    {{end}}
    {{if eq .Step "welcome"}}{{template "welcome" .Data}}{{end}}
    {{if eq .Step "profile"}}{{template "profile" .Data}}{{end}}
    {{if eq .Step "db"}}{{template "db" .Data}}{{end}}
    {{if eq .Step "admin"}}{{template "admin" .Data}}{{end}}
    {{if eq .Step "app"}}{{template "app" .Data}}{{end}}
    {{if eq .Step "smtp"}}{{template "smtp" .Data}}{{end}}
    {{if eq .Step "caddy"}}{{template "caddy" .Data}}{{end}}
    {{if eq .Step "done"}}{{template "done" .Data}}{{end}}
  </main>

  <footer style="text-align:center;margin-top:1.25rem;display:flex;align-items:center;justify-content:center;gap:0.75rem;">
    <button type="button" data-theme-toggle class="r-btn-ghost" style="padding:0.25rem 0.5rem;display:inline-flex;align-items:center;gap:0.375rem;" title="Toggle theme">
      <svg id="theme-icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg id="theme-icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <span class="t-caption" style="color:rgb(var(--muted));">Step <strong style="color:rgb(var(--text));">{{.Step}}</strong> &middot; Wizard self-locks after install.</span>
  </footer>
</div>
<script nonce="{{.Data.CSPNonce}}">
function toggleTheme(){
  var d=document.documentElement;
  var dark=d.classList.toggle('dark');
  localStorage.setItem('theme',dark?'dark':'light');
  document.getElementById('theme-icon-sun').style.display=dark?'block':'none';
  document.getElementById('theme-icon-moon').style.display=dark?'none':'block';
}
(function(){
  var d=document.documentElement.classList.contains('dark');
  document.getElementById('theme-icon-sun').style.display=d?'block':'none';
  document.getElementById('theme-icon-moon').style.display=d?'none':'block';
})();
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('[data-theme-toggle]').forEach(function(el){
    el.addEventListener('click',toggleTheme);
  });
});
</script>
</body>
</html>
{{end}}
