{{define "smtp"}}
<p class="t-eyebrow" style="margin-bottom:0.25rem;">Step 6</p>
<h2 class="t-h2" style="margin-bottom:0.375rem;">SMTP <span class="t-small" style="color:rgb(var(--muted));font-weight:400;">(optional)</span></h2>
<p class="t-small" style="color:rgb(var(--muted));margin-bottom:1.25rem;">
  Used for password resets and notifications. Leave blank and click Skip to
  configure later from the admin panel.
</p>
<form method="POST" action="/install/smtp" style="display:flex;flex-direction:column;gap:0.875rem;">
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">SMTP host</label>
      <input name="host" value="{{.Form.Host}}" placeholder="smtp.example.com" class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Port</label>
      <input name="port" value="{{.Form.Port}}" type="number" min="1" max="65535" placeholder="587" class="r-input" style="font-variant-numeric:tabular-nums;">
    </div>
  </div>
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Encryption</label>
    <select name="encryption" class="r-select">
      <option value="tls" {{if eq .Form.Encryption "tls"}}selected{{end}}>STARTTLS</option>
      <option value="ssl" {{if eq .Form.Encryption "ssl"}}selected{{end}}>SSL/TLS</option>
      <option value="none" {{if eq .Form.Encryption "none"}}selected{{end}}>None</option>
    </select>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Username</label>
      <input name="username" value="{{.Form.Username}}" class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Password</label>
      <input name="password" type="password" class="r-input">
    </div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">From email</label>
      <input name="from_email" value="{{.Form.FromEmail}}" type="email" class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">From name</label>
      <input name="from_name" value="{{.Form.FromName}}" class="r-input">
    </div>
  </div>
  <div style="display:flex;justify-content:space-between;padding-top:0.375rem;">
    <button name="skip" value="1" class="r-btn-secondary" type="submit">Skip for now</button>
    <button class="r-btn-primary" type="submit">Save &rarr;</button>
  </div>
</form>
{{end}}
