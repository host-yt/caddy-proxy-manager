{{define "smtp"}}
<h2 class="text-xl font-semibold mb-1">SMTP <span class="text-xs font-normal text-slate-500">(optional)</span></h2>
<p class="text-sm text-slate-500 mb-5">
  Used for password resets and notifications. Leave blank and click Skip to
  configure later from the admin panel.
</p>
<form method="POST" action="/install/smtp" class="space-y-4">
  <div class="grid grid-cols-3 gap-3">
    <div class="col-span-2">
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">SMTP host</label>
      <input name="host" value="{{.Form.Host}}" placeholder="smtp.example.com"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Port</label>
      <input name="port" value="{{.Form.Port}}" type="number" min="1" max="65535" placeholder="587"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Encryption</label>
    <select name="encryption" class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
      <option value="tls" {{if eq .Form.Encryption "tls"}}selected{{end}}>STARTTLS</option>
      <option value="ssl" {{if eq .Form.Encryption "ssl"}}selected{{end}}>SSL/TLS</option>
      <option value="none" {{if eq .Form.Encryption "none"}}selected{{end}}>None</option>
    </select>
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Username</label>
      <input name="username" value="{{.Form.Username}}"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Password</label>
      <input name="password" type="password"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">From email</label>
      <input name="from_email" value="{{.Form.FromEmail}}" type="email"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">From name</label>
      <input name="from_name" value="{{.Form.FromName}}"
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <div class="flex justify-between pt-2">
    <button name="skip" value="1" class="px-4 py-2 rounded-md bg-slate-100 text-slate-700 dark:text-slate-200 text-sm font-medium hover:bg-slate-200">
      Skip
    </button>
    <button class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
      Save →
    </button>
  </div>
</form>
{{end}}
