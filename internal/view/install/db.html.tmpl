{{define "db"}}
<p class="t-eyebrow" style="margin-bottom:0.25rem;">Step 3</p>
<h2 class="t-h2" style="margin-bottom:0.375rem;">Database</h2>
<p class="t-small" style="color:rgb(var(--muted));margin-bottom:1rem;">
  Local bundled <code>mariadb</code> or any external MariaDB/MySQL. We'll test
  the connection and run migrations.
</p>

{{if .Form.ProfileName}}
<div style="margin-bottom:1rem;padding:0.625rem 0.875rem;border-radius:0.5rem;background:rgb(var(--surface-2));border:1px solid rgb(var(--border));" class="t-small">
  <span style="font-weight:600;">Profile:</span>
  <span style="color:rgb(var(--muted));margin-left:0.25rem;text-transform:capitalize;">{{.Form.ProfileName}}</span>
  <span style="margin:0 0.5rem;color:rgb(var(--border));">&middot;</span>
  <span style="font-weight:600;">Recommended DB:</span>
  <span style="color:rgb(var(--muted));margin-left:0.25rem;">{{.Form.RecommendDB}}</span>
</div>
{{end}}

{{if .Form.RequireMySQL}}
<div style="margin-bottom:1rem;padding:0.625rem 0.875rem;border-radius:0.5rem;background:rgb(var(--warning) / .08);border:1px solid rgb(var(--warning) / .3);color:rgb(var(--warning));" class="t-small">
  Provider mode requires MySQL/MariaDB. SQLite is not available for this profile.
</div>
{{end}}

<div style="margin-bottom:1rem;">
  <p class="t-caption" style="font-weight:600;margin-bottom:0.5rem;">Driver</p>
  <div style="display:flex;flex-direction:column;gap:0.375rem;">
    <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;" class="t-small">
      <input type="radio" name="db_driver" value="mysql" checked
             style="accent-color:rgb(var(--accent));cursor:pointer;">
      MySQL / MariaDB
    </label>
    <label style="display:flex;align-items:center;gap:0.5rem;cursor:not-allowed;opacity:.5;" class="t-small" title="SQLite support is not yet available">
      <input type="radio" name="db_driver" value="sqlite" disabled
             style="cursor:not-allowed;">
      SQLite <span style="margin-left:0.25rem;font-style:italic;">(planned - not yet available)</span>
    </label>
  </div>
</div>

<form method="POST" action="/install/db" style="display:flex;flex-direction:column;gap:0.875rem;">
  <input type="hidden" name="db_driver" value="mysql">
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Host</label>
      <input name="host" value="{{.Form.Host}}" required class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Port</label>
      <input name="port" value="{{.Form.Port}}" type="number" min="1" max="65535" required class="r-input" style="font-variant-numeric:tabular-nums;">
    </div>
  </div>
  <div>
    <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Database name</label>
    <input name="name" value="{{.Form.Name}}" required class="r-input">
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">User</label>
      <input name="user" value="{{.Form.User}}" required class="r-input">
    </div>
    <div>
      <label class="t-caption" style="display:block;font-weight:600;margin-bottom:0.375rem;">Password</label>
      <input name="password" type="password" required class="r-input">
    </div>
  </div>
  <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;" class="t-small">
    <input name="tls" type="checkbox" value="1" {{if .Form.TLS}}checked{{end}}
           style="accent-color:rgb(var(--accent));">
    Use TLS to connect (for managed DBs)
  </label>
  <div style="display:flex;justify-content:flex-end;padding-top:0.375rem;">
    <button class="r-btn-primary" type="submit" style="cursor:pointer;">
      Test &amp; run migrations &rarr;
    </button>
  </div>
</form>
{{end}}
