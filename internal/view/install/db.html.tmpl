{{define "db"}}
<h2 class="text-xl font-semibold mb-1">Database</h2>
<p class="text-sm text-slate-500 mb-5">
  Local bundled <code>mariadb</code> or any external MariaDB/MySQL. We'll test
  the connection and run migrations.
</p>
<form method="POST" action="/install/db" class="space-y-4">
  <div class="grid grid-cols-3 gap-3">
    <div class="col-span-2">
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Host</label>
      <input name="host" value="{{.Form.Host}}" required
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Port</label>
      <input name="port" value="{{.Form.Port}}" type="number" min="1" max="65535" required
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Database name</label>
    <input name="name" value="{{.Form.Name}}" required
           class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">User</label>
      <input name="user" value="{{.Form.User}}" required
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-200 mb-1">Password</label>
      <input name="password" type="password" required
             class="w-full px-3 py-2 rounded-md border border-slate-300 dark:border-zinc-700 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    </div>
  </div>
  <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
    <input name="tls" type="checkbox" value="1" {{if .Form.TLS}}checked{{end}}
           class="rounded border-slate-300 dark:border-zinc-700 text-indigo-600">
    Use TLS to connect (for managed DBs)
  </label>
  <div class="flex justify-end pt-2">
    <button class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
      Test connection & run migrations →
    </button>
  </div>
</form>
{{end}}
