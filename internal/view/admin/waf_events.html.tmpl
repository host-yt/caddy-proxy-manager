{{define "waf_events"}}
<div class="space-y-4">
  <div class="flex items-center justify-between gap-4">
    <div>
      <p class="t-eyebrow">Security</p>
      <h2 class="t-h2 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color:rgb(var(--danger))" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        WAF events
      </h2>
      <p class="t-caption mt-0.5">Firewall rule matches and blocked requests across all hosts</p>
    </div>
    <div class="flex items-center gap-2">
      {{if .CanClear}}
      <form method="POST" action="/admin/waf/events/clear" class="inline" data-confirm="Permanently delete {{if gt .Filter.RouteID 0}}this route's{{else}}ALL{{end}} WAF events? This cannot be undone.">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        {{if gt .Filter.RouteID 0}}<input type="hidden" name="route_id" value="{{.Filter.RouteID}}">{{end}}
        <button type="submit" class="r-btn-danger text-xs inline-flex items-center gap-1 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
          </svg>
          Clear events
        </button>
      </form>
      {{end}}
      <a href="/admin/waf.json" target="_blank" class="r-btn-secondary text-xs">JSON</a>
      <div class="relative" id="waf-export-wrap">
        <button type="button" id="waf-btn-export" class="r-btn-secondary text-xs inline-flex items-center gap-1 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          Export
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </button>
        <div id="waf-export-menu" class="hidden absolute right-0 mt-1 w-36 rounded-xl shadow-lg r-card z-20 py-1 !p-1">
          <a id="waf-export-csv" href="#" class="block px-3 py-1.5 rounded-lg text-xs t-body hover:bg-[rgb(var(--surface-2))] transition-colors">Export CSV</a>
          <a id="waf-export-json" href="#" class="block px-3 py-1.5 rounded-lg text-xs t-body hover:bg-[rgb(var(--surface-2))] transition-colors">Export JSON</a>
        </div>
      </div>
    </div>
  </div>

  {{if .Error}}
  <div class="r-card text-sm" style="border-color:rgb(var(--danger));color:rgb(var(--danger))">{{.Error}}</div>
  {{end}}
  {{if .Flash}}
  <div class="r-card text-sm" style="border-color:rgb(var(--success));color:rgb(var(--success))">{{.Flash}}</div>
  {{end}}

  {{if .Entries}}
  <div class="flex flex-wrap gap-2">
    <span id="waf-chip-total" class="r-pill r-pill-neutral">{{.Total}} total{{if gt .TotalPgs 1}} · {{len .Entries}} shown{{end}}</span>
    {{if .Suppressions}}
    <span class="r-pill r-pill-neutral">{{len .Suppressions}} active suppression{{if gt (len .Suppressions) 1}}s{{end}}</span>
    {{end}}
  </div>
  {{end}}

  {{if and .RouteDomain (gt .Filter.RouteID 0)}}
  <div class="flex items-center gap-2 text-xs">
    <span class="r-pill r-pill-info inline-flex items-center gap-1.5 font-mono">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
      </svg>
      Filtered to: {{.RouteDomain}}
    </span>
    <a href="/admin/waf" class="t-muted hover:text-[rgb(var(--danger))] transition-colors">clear ×</a>
  </div>
  {{end}}

  <!-- Filter form -->
  <form method="GET" action="/admin/waf" id="waf-filter-form" class="r-card flex flex-wrap gap-3 items-end">
    <div class="flex flex-col gap-1">
      <label class="t-caption">Severity</label>
      <select name="severity" class="r-select text-xs cursor-pointer">
        <option value="">All</option>
        {{range $s := (slice "low" "medium" "high" "critical")}}
        <option value="{{$s}}" {{if eq $.Filter.Severity $s}}selected{{end}}>{{$s}}</option>
        {{end}}
      </select>
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">Action</label>
      <select name="action" class="r-select text-xs cursor-pointer">
        <option value="">All</option>
        {{range $a := (slice "blocked" "detected")}}
        <option value="{{$a}}" {{if eq $.Filter.Action $a}}selected{{end}}>{{$a}}</option>
        {{end}}
      </select>
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">Host</label>
      <input type="text" name="host" placeholder="example.com" value="{{.Filter.Host}}" class="r-input w-36 text-xs font-mono">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">Remote IP</label>
      <input type="text" name="remote_ip" placeholder="1.2.3.4" value="{{.Filter.RemoteIP}}" class="r-input w-32 text-xs font-mono">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">Rule ID contains</label>
      <input type="text" name="rule_id" placeholder="rule-001" value="{{.Filter.RuleID}}" class="r-input w-36 text-xs font-mono">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">From</label>
      <input type="date" name="from" value="{{if not .Filter.From.IsZero}}{{.Filter.From.Format "2006-01-02"}}{{end}}" class="r-input text-xs">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">To</label>
      <input type="date" name="to" value="{{if not .Filter.To.IsZero}}{{.Filter.To.Format "2006-01-02"}}{{end}}" class="r-input text-xs">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">Route ID</label>
      <input type="number" name="route_id" placeholder="0" min="0" value="{{if gt .Filter.RouteID 0}}{{.Filter.RouteID}}{{end}}" class="r-input w-24 text-xs font-mono">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption">Per page</label>
      <select name="limit" class="r-select text-xs cursor-pointer">
        {{range $n := (slice 25 50 100 200 500)}}
        <option value="{{$n}}" {{if eq $.Filter.Limit $n}}selected{{end}}>{{$n}}</option>
        {{end}}
      </select>
    </div>
    <div class="flex items-center gap-2 ml-auto">
      <button type="submit" class="r-btn-primary text-xs cursor-pointer">Filter</button>
      <a href="/admin/waf" class="r-btn-secondary text-xs">Clear</a>
    </div>
  </form>

  {{if not .Entries}}
  <div class="r-empty">
    <div class="r-empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <h3 class="t-h3">No WAF events yet</h3>
    <p class="t-small">Events appear once the WAF module emits them.</p>
  </div>
  {{end}}

  <!-- Events table -->
  <section class="r-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Severity</th>
            <th>Action</th>
            <th>Rule ID</th>
            <th>Remote IP</th>
            <th>Host</th>
            <th>URI</th>
            <th>Message</th>
            <th>Status</th>
            <th class="text-right"></th>
          </tr>
        </thead>
        <tbody>
          {{range .Entries}}
          <tr class="{{if .Suppressed}}opacity-50{{end}}">
            <td class="font-mono text-xs tabular-nums whitespace-nowrap">{{.TS.Format "2006-01-02 15:04:05"}}</td>
            <td>
              {{if eq .Severity "critical"}}<span class="r-pill r-pill-danger">{{.Severity}}</span>
              {{else if eq .Severity "high"}}<span class="r-pill r-pill-danger">{{.Severity}}</span>
              {{else if eq .Severity "medium"}}<span class="r-pill r-pill-warning">{{.Severity}}</span>
              {{else}}<span class="r-pill r-pill-info">{{.Severity}}</span>
              {{end}}
            </td>
            <td>
              {{if eq .Action "blocked"}}<span class="r-pill r-pill-danger">{{.Action}}</span>
              {{else}}<span class="r-pill r-pill-info">{{.Action}}</span>
              {{end}}
            </td>
            <td class="font-mono text-xs max-w-[10rem] truncate" title="{{.RuleID}}">{{.RuleID}}</td>
            <td class="font-mono text-xs whitespace-nowrap">
              {{.RemoteIP}}
              {{with index $.ASNS .RemoteIP}}<br><span class="t-caption">{{.}}</span>{{end}}
            </td>
            <td class="font-mono text-xs max-w-[10rem] truncate" title="{{.Host}}">{{.Host}}</td>
            <td class="font-mono text-xs max-w-xs truncate" title="{{.URI}}">{{.URI}}</td>
            <td class="text-xs max-w-xs truncate" title="{{.Message}}">{{.Message}}</td>
            <td class="whitespace-nowrap">
              {{if .Suppressed}}<span class="r-pill r-pill-neutral">suppressed</span>
              {{else if .AcknowledgedAt.Valid}}<span class="r-pill r-pill-neutral">acked</span>
              {{end}}
            </td>
            <td class="text-right whitespace-nowrap">
              <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="waf-act-{{.ID}}">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
              </button>
              <div id="waf-act-{{.ID}}" class="hpg-act-menu" role="menu">
                {{if not .AcknowledgedAt.Valid}}
                <form method="POST" action="/admin/waf/events/{{.ID}}/ack" class="contents">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item" role="menuitem">Acknowledge</button>
                </form>
                {{end}}
                {{if not .Suppressed}}
                <button type="button"
                  data-action="waf-show-suppress"
                  data-rule-id="{{.RuleID}}"
                  data-route-id="{{if .RouteID.Valid}}{{.RouteID.Int64}}{{else}}0{{end}}"
                  class="hpg-act-item" role="menuitem">Suppress</button>
                {{end}}
              </div>
            </td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{if .Entries}}
    <div class="px-4 py-2 border-t" style="border-color:rgb(var(--border))">
      {{template "pagination" (dict "Total" .Total "TotalPgs" .TotalPgs "Page" .Page "PrevURL" .PrevURL "NextURL" .NextURL "Size" .Size)}}
    </div>
    {{end}}
  </section>

  <!-- Active suppressions -->
  {{if .Suppressions}}
  <section class="r-card space-y-3">
    <h3 class="t-h3 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color:rgb(var(--warning))" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
      </svg>
      Active rule suppressions
    </h3>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Rule ID</th>
            <th>Scope</th>
            <th>Reason</th>
            <th>Expires</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{range .Suppressions}}
          <tr>
            <td class="font-mono text-xs max-w-[12rem] truncate" title="{{.RuleID}}">{{.RuleID}}</td>
            <td>
              {{if .RouteID.Valid}}route {{.RouteID.Int64}}{{else}}<span class="r-pill r-pill-neutral">global</span>{{end}}
            </td>
            <td class="max-w-xs truncate" title="{{.Reason}}">{{if .Reason}}{{.Reason}}{{else}}-{{end}}</td>
            <td class="whitespace-nowrap tabular-nums">{{if .ExpiresAt.Valid}}{{.ExpiresAt.Time.Format "2006-01-02"}}{{else}}permanent{{end}}</td>
            <td class="font-mono text-xs tabular-nums whitespace-nowrap">{{.CreatedAt.Format "2006-01-02 15:04"}}</td>
            <td>
              <form method="POST" action="/admin/waf/suppressions/{{.ID}}/delete" class="inline" data-confirm="Delete this suppression?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                {{if .RouteID.Valid}}<input type="hidden" name="route_id" value="{{.RouteID.Int64}}">{{end}}
                <button type="submit" class="r-btn-danger text-xs inline-flex items-center gap-1 cursor-pointer">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
                  </svg>
                  Delete
                </button>
              </form>
            </td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>
  {{end}}

  <!-- Suppress rule modal -->
  <div id="waf-suppress-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.45)">
    <div class="r-card rounded-2xl shadow-xl w-full max-w-md space-y-4 !p-6">
      <h3 class="t-h3 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color:rgb(var(--warning))" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
        </svg>
        Suppress WAF rule
      </h3>
      <form method="POST" action="/admin/waf/suppress" class="space-y-3">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div class="flex flex-col gap-1">
          <label class="t-caption">Rule ID</label>
          <input type="text" name="rule_id" id="waf-suppress-rule-id" required class="r-input text-xs font-mono">
        </div>
        <div class="flex flex-col gap-1">
          <label class="t-caption">Route ID (leave blank for global)</label>
          <input type="number" name="route_id" id="waf-suppress-route-id" min="0" class="r-input text-xs font-mono">
        </div>
        <div class="flex flex-col gap-1">
          <label class="t-caption">Reason</label>
          <input type="text" name="reason" maxlength="255" placeholder="False positive - internal scanner" class="r-input text-xs">
        </div>
        <div class="flex flex-col gap-1">
          <label class="t-caption">Expires (blank = permanent)</label>
          <input type="date" name="expires_at" class="r-input text-xs">
        </div>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" data-action="waf-hide-suppress" class="r-btn-secondary text-xs cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary text-xs cursor-pointer" style="background:rgb(var(--warning))">Suppress rule</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  var wrap = document.getElementById('waf-export-wrap');
  var btn  = document.getElementById('waf-btn-export');
  var menu = document.getElementById('waf-export-menu');
  var csvLink  = document.getElementById('waf-export-csv');
  var jsonLink = document.getElementById('waf-export-json');

  function buildExportURL(fmt){
    var q = new URLSearchParams(window.location.search);
    q.set('format', fmt);
    return '/admin/waf/export?' + q.toString();
  }

  btn.addEventListener('click', function(e){
    e.stopPropagation();
    menu.classList.toggle('hidden');
    csvLink.href  = buildExportURL('csv');
    jsonLink.href = buildExportURL('json');
  });
  document.addEventListener('click', function(){ menu.classList.add('hidden'); });
})();

function wafShowSuppress(ruleID, routeID) {
  document.getElementById('waf-suppress-rule-id').value = ruleID;
  var rid = document.getElementById('waf-suppress-route-id');
  rid.value = routeID > 0 ? routeID : '';
  document.getElementById('waf-suppress-modal').classList.remove('hidden');
}
function wafHideSuppress() {
  document.getElementById('waf-suppress-modal').classList.add('hidden');
}
document.addEventListener('click', function(e) {
  var el = e.target.closest('[data-action]');
  if (!el) return;
  switch (el.getAttribute('data-action')) {
    case 'waf-show-suppress':
      wafShowSuppress(el.getAttribute('data-rule-id'), parseInt(el.getAttribute('data-route-id'), 10));
      break;
    case 'waf-hide-suppress':
      wafHideSuppress();
      break;
  }
});
document.getElementById('waf-suppress-modal').addEventListener('click', function(e){
  if (e.target === this) { wafHideSuppress(); }
});
</script>
{{end}}
