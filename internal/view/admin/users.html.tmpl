{{define "users"}}
<div class="space-y-5">
  <section class="r-card overflow-hidden relative">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
      <div class="max-w-3xl">
        <p class="t-eyebrow">Access control</p>
        <h2 class="t-h2 mt-1">Users, roles and client scope</h2>
        <p class="t-body mt-2">Super admins see the whole installation. Admin and support accounts can be narrowed to selected clients; those limits are enforced on tunnels and host logs.</p>
      </div>
      <button type="button" id="usr-new-btn"
        class="r-btn-primary inline-flex items-center justify-center gap-2 shrink-0 cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        New staff user
      </button>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mt-5 text-sm">
      <div class="rounded-xl bg-[rgb(var(--surface-2))] p-4 ring-1 ring-[rgb(var(--border))]">
        <div class="t-eyebrow">Super admin</div>
        <div class="t-body mt-2">Global owner, billing, settings, security.</div>
      </div>
      <div class="rounded-xl bg-[rgb(var(--surface-2))] p-4 ring-1 ring-[rgb(var(--border))]">
        <div class="t-eyebrow">Admin</div>
        <div class="t-body mt-2">Operates assigned customers and infrastructure tasks.</div>
      </div>
      <div class="rounded-xl bg-[rgb(var(--surface-2))] p-4 ring-1 ring-[rgb(var(--border))]">
        <div class="t-eyebrow">Support</div>
        <div class="t-body mt-2">Reserved role; use admin with scope for panel access today.</div>
      </div>
      <div class="rounded-xl bg-[rgb(var(--surface-2))] p-4 ring-1 ring-[rgb(var(--border))]">
        <div class="t-eyebrow">Client</div>
        <div class="t-body mt-2">Self-service portal account managed under Clients.</div>
      </div>
    </div>
  </section>

  <form method="GET" action="/admin/users" class="flex items-center gap-2 flex-wrap">
    <input type="search" name="q" value="{{.Q}}"
           placeholder="Email or name…"
           class="r-input w-48">
    <select name="role" class="r-select">
      <option value="" {{if eq .Filter ""}}selected{{end}}>All roles</option>
      <option value="super_admin" {{if eq .Filter "super_admin"}}selected{{end}}>Super admin</option>
      <option value="admin" {{if eq .Filter "admin"}}selected{{end}}>Admin</option>
      <option value="client" {{if eq .Filter "client"}}selected{{end}}>Client</option>
      <option value="support" {{if eq .Filter "support"}}selected{{end}}>Support</option>
    </select>
    <button type="submit" class="r-btn-primary cursor-pointer">Filter</button>
    {{if or .Q .Filter}}<a href="/admin/users" class="t-small text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] transition-colors">Clear</a>{{end}}
  </form>

  <section class="r-card !p-0 overflow-hidden">
    <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-[rgb(var(--border))]">
      <div>
        <p class="t-eyebrow">Accounts</p>
        <h2 class="t-h3 mt-0.5">Panel users</h2>
      </div>
      <span class="r-pill r-pill-neutral">{{len .Users}} users</span>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead>
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>Scope</th>
            <th>Security</th>
            <th>Last login</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          {{range .Users}}
          <tr>
            <td>
              <div class="flex items-center gap-3 min-w-[15rem]">
                <div class="r-avatar">{{printf "%.1s" .Email}}</div>
                <div class="min-w-0">
                  <div class="font-medium text-[rgb(var(--text))] truncate">{{if .FullName}}{{.FullName}}{{else}}{{.Email}}{{end}}</div>
                  <div class="t-caption text-[rgb(var(--muted))] truncate">{{.Email}}</div>
                </div>
              </div>
            </td>
            <td>
              <span class="r-pill
                {{if eq .Role "super_admin"}}r-pill-info
                {{else if eq .Role "admin"}}r-pill-info
                {{else if eq .Role "support"}}r-pill-warning
                {{else if eq .Role "client"}}r-pill-success
                {{else}}r-pill-neutral{{end}}">{{.Role}}</span>
            </td>
            <td>
              {{if eq .Role "super_admin"}}
                <span class="r-pill r-pill-success">all clients</span>
              {{else if eq .Role "client"}}
                <span class="r-pill r-pill-neutral">own portal</span>
              {{else if gt .ScopeCount 0}}
                <span class="r-pill r-pill-info">{{.ScopeCount}} clients</span>
              {{else}}
                <span class="r-pill r-pill-warning">no clients</span>
              {{end}}
            </td>
            <td>
              <div class="flex flex-wrap gap-1.5">
                {{if .IsActive}}<span class="r-pill r-pill-success">active</span>{{else}}<span class="r-pill r-pill-danger">disabled</span>{{end}}
                {{if .TOTPEnabled}}<span class="r-pill r-pill-success">2FA</span>{{else}}<span class="r-pill r-pill-neutral">2FA off</span>{{end}}
              </div>
            </td>
            <td class="tabular-nums text-[rgb(var(--muted))] whitespace-nowrap">{{if .LastLoginAt}}{{.LastLoginAt}}{{else}}never{{end}}</td>
            <td class="text-right">
              <div class="flex flex-wrap justify-end gap-2 whitespace-nowrap">
                {{if ne .Role "client"}}
                <button type="button"
                  class="usr-edit-btn r-btn-ghost text-xs cursor-pointer"
                  data-id="{{.ID}}" data-fullname="{{.FullName}}" data-email="{{.Email}}" data-role="{{.Role}}" data-active="{{if .IsActive}}1{{else}}0{{end}}">Edit</button>
                {{end}}
                {{if and $.CanManageScopes (ne .Role "client") (ne .Role "super_admin")}}
                <button type="button"
                  class="usr-scope-btn r-btn-ghost text-xs cursor-pointer"
                  data-id="{{.ID}}" data-email="{{.Email}}" data-scope="{{.ScopeIDs}}">Scope</button>
                {{end}}
                {{if and (eq .Role "client") .IsActive}}
                <form class="inline" method="POST" action="/admin/users/{{.ID}}/impersonate">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="r-btn-ghost text-xs cursor-pointer">Impersonate</button>
                </form>
                {{end}}
                {{if .CanToggle}}
                <form class="inline" method="POST" action="/admin/users/{{.ID}}/toggle">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="r-btn-secondary text-xs cursor-pointer">{{if .IsActive}}Disable{{else}}Enable{{end}}</button>
                </form>
                {{end}}
                {{if and $.CanManageScopes .TOTPEnabled .CanToggle}}
                <form class="inline" method="POST" action="/admin/users/{{.ID}}/reset-2fa" data-confirm="Reset 2FA for {{.Email}}? This clears TOTP, SMS, and email OTP.">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="r-btn-ghost text-xs cursor-pointer">Reset 2FA</button>
                </form>
                {{end}}
                {{if .CanDelete}}
                <form class="inline" method="POST" action="/admin/users/{{.ID}}/delete" data-confirm="Delete {{.Email}}? This is permanent.">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="r-btn-danger text-xs cursor-pointer">Delete</button>
                </form>
                {{end}}
              </div>
            </td>
          </tr>
          {{else}}
          <tr><td colspan="6" class="px-4 py-14 text-center text-[rgb(var(--muted))]">No users.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>
</div>

<div id="usr-modal" class="fixed inset-0 z-50 hidden">
  <div id="usr-modal-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-center justify-center overflow-y-auto p-4 sm:p-6">
    <div class="r-card w-full max-w-lg max-h-[90vh] overflow-y-auto relative shadow-xl" role="dialog" aria-modal="true">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="t-eyebrow">Staff account</p>
          <h2 id="usr-modal-title" class="t-h3 mt-0.5">New staff user</h2>
        </div>
        <button type="button" id="usr-modal-close" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] text-xl leading-none cursor-pointer">&times;</button>
      </div>
      <form id="usr-form" method="POST" action="/admin/users" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="t-eyebrow block mb-1.5">Full name</label>
          <input name="full_name" required class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Email</label>
          <input name="email" type="email" required class="r-input w-full">
        </div>
        <div>
          <label id="usr-pw-label" class="t-eyebrow block mb-1.5">Initial password</label>
          <input id="usr-pw-input" name="password" type="password" minlength="12" required class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Role</label>
          <select name="role" required class="r-select w-full">
            <option value="support">Support (reserved)</option>
            <option value="admin">Admin</option>
            {{if .CanCreateSuperAdmin}}<option value="super_admin">Super admin</option>{{end}}
          </select>
        </div>
        <label class="flex items-center gap-2 text-xs text-[rgb(var(--text))] cursor-pointer">
          <input type="checkbox" name="is_active" value="1" checked class="rounded cursor-pointer">
          Active
        </label>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="usr-modal-cancel" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save user</button>
        </div>
      </form>
    </div>
  </div>
</div>

{{if .CanManageScopes}}
<div id="usr-scope-modal" class="fixed inset-0 z-50 hidden">
  <div id="usr-scope-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-center justify-center overflow-y-auto p-4 sm:p-6">
    <div class="r-card w-full max-w-2xl max-h-[90vh] overflow-y-auto relative shadow-xl" role="dialog" aria-modal="true">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="t-eyebrow">Client scope</p>
          <h2 id="usr-scope-title" class="t-h3 mt-0.5">Assign clients</h2>
        </div>
        <button type="button" id="usr-scope-close" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] text-xl leading-none cursor-pointer">&times;</button>
      </div>
      <form id="usr-scope-form" method="POST" action="/admin/users/0/scope" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div class="rounded-xl bg-[rgb(var(--surface-2))] ring-1 ring-[rgb(var(--border))] p-3 max-h-80 overflow-y-auto grid grid-cols-1 sm:grid-cols-2 gap-2">
          {{range .ScopeClients}}
          <label class="scope-client flex items-start gap-2 rounded-lg bg-[rgb(var(--surface))] ring-1 ring-[rgb(var(--border))] p-3 cursor-pointer hover:ring-[rgb(var(--accent))]">
            <input type="checkbox" name="client_ids" value="{{.ID}}" class="mt-1 rounded cursor-pointer">
            <span class="min-w-0">
              <span class="block font-medium text-[rgb(var(--text))] truncate">{{.DisplayName}}</span>
              <span class="block t-caption text-[rgb(var(--muted))] truncate">{{.Email}}</span>
            </span>
          </label>
          {{else}}
          <div class="sm:col-span-2 py-8 text-center text-[rgb(var(--muted))]">No clients yet.</div>
          {{end}}
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="usr-scope-cancel" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save scope</button>
        </div>
      </form>
    </div>
  </div>
</div>
{{end}}

<script nonce="{{.CSPNonce}}">
(function () {
  var modal = document.getElementById("usr-modal");
  var form = document.getElementById("usr-form");
  var title = document.getElementById("usr-modal-title");
  var pwLabel = document.getElementById("usr-pw-label");
  var pwInput = document.getElementById("usr-pw-input");
  if (!modal || !form) return;

  function setVal(name, value) { var el = form.elements[name]; if (el) el.value = (value == null ? "" : value); }
  function setChecked(name, on) { var el = form.elements[name]; if (el) el.checked = !!on; }
  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  document.getElementById("usr-new-btn").addEventListener("click", function () {
    form.reset();
    form.action = "/admin/users";
    if (title) title.textContent = "New staff user";
    if (pwLabel) pwLabel.textContent = "Initial password";
    if (pwInput) { pwInput.required = true; pwInput.placeholder = ""; }
    setChecked("is_active", true);
    open();
  });

  document.querySelectorAll(".usr-edit-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var d = this.dataset;
      form.reset();
      form.action = "/admin/users/" + d.id + "/edit";
      if (title) title.textContent = "Edit staff user";
      if (pwLabel) pwLabel.textContent = "New password";
      if (pwInput) { pwInput.required = false; pwInput.placeholder = "Leave blank to keep current"; }
      setVal("full_name", d.fullname);
      setVal("email", d.email);
      setVal("role", d.role);
      setVal("password", "");
      setChecked("is_active", d.active === "1");
      open();
    });
  });

  ["usr-modal-close","usr-modal-cancel","usr-modal-overlay"].forEach(function(id){
    var el = document.getElementById(id); if (el) el.addEventListener("click", close);
  });
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });
})();

(function () {
  var modal = document.getElementById("usr-scope-modal");
  var form = document.getElementById("usr-scope-form");
  if (!modal || !form) return;
  function close(){ modal.classList.add("hidden"); }
  document.querySelectorAll(".usr-scope-btn").forEach(function(btn){
    btn.addEventListener("click", function(){
      var selected = {};
      (btn.dataset.scope || "").split(",").forEach(function(id){ if (id) selected[id] = true; });
      form.action = "/admin/users/" + btn.dataset.id + "/scope";
      var title = document.getElementById("usr-scope-title");
      if (title) title.textContent = "Assign clients to " + btn.dataset.email;
      form.querySelectorAll('input[name="client_ids"]').forEach(function(cb){ cb.checked = !!selected[cb.value]; });
      modal.classList.remove("hidden");
    });
  });
  ["usr-scope-close","usr-scope-cancel","usr-scope-overlay"].forEach(function(id){
    var el = document.getElementById(id); if (el) el.addEventListener("click", close);
  });
})();
</script>
{{end}}
