{{define "users"}}
<p class="mb-4 text-xs text-slate-500">Users are panel login accounts with roles. Customer accounts that own services/hosts are <a href="/admin/clients" class="underline">Clients</a>.</p>
<div class="mb-5 flex flex-wrap gap-2 text-sm">
  <a href="/admin/users" class="px-3 py-1.5 rounded-full {{if eq .Filter ""}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800{{end}}">All</a>
  <a href="/admin/users?role=super_admin" class="px-3 py-1.5 rounded-full {{if eq .Filter "super_admin"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800{{end}}">Super admin</a>
  <a href="/admin/users?role=admin" class="px-3 py-1.5 rounded-full {{if eq .Filter "admin"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800{{end}}">Admin</a>
  <a href="/admin/users?role=support" class="px-3 py-1.5 rounded-full {{if eq .Filter "support"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800{{end}}">Support</a>
  <a href="/admin/users?role=client" class="px-3 py-1.5 rounded-full {{if eq .Filter "client"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800{{end}}">Client</a>
</div>

<section class="hpg-card !p-0 overflow-hidden">
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-100 dark:border-zinc-800">
    <div class="flex items-center gap-3">
      <div>
        <p class="hpg-eyebrow">Access</p>
        <h2 class="font-semibold text-slate-800 dark:text-slate-100">Users</h2>
      </div>
      <span class="hpg-chip">{{len .Users}}</span>
    </div>
    <button type="button" id="usr-new-btn"
      class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      New user
    </button>
  </div>
  <div class="overflow-x-auto"><table class="w-full text-sm">
    <thead class="bg-slate-50 dark:bg-zinc-800/60 text-left text-xs uppercase tracking-wide text-slate-500">
      <tr>
        <th class="px-4 py-3 font-medium">Name</th>
        <th class="px-4 py-3 font-medium">Email</th>
        <th class="px-4 py-3 font-medium">Role</th>
        <th class="px-4 py-3 font-medium">Active</th>
        <th class="px-4 py-3 font-medium">2FA</th>
        <th class="px-4 py-3 font-medium">Last login</th>
        <th class="px-4 py-3 text-right font-medium">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
      {{range .Users}}
      <tr class="hover:bg-slate-50/70 dark:hover:bg-zinc-800/40 transition-colors">
        <td class="px-4 py-3 font-medium text-slate-800 dark:text-slate-100">{{.FullName}}</td>
        <td class="px-4 py-3 text-slate-600 dark:text-slate-300">{{.Email}}</td>
        <td class="px-4 py-3">
          <span class="inline-block px-2 py-0.5 rounded-full text-xs
            {{if eq .Role "super_admin"}}bg-purple-50 text-purple-600
            {{else if eq .Role "admin"}}bg-indigo-50 text-indigo-600
            {{else if eq .Role "support"}}bg-sky-50 text-sky-600
            {{else if eq .Role "client"}}bg-emerald-50 text-emerald-600
            {{else}}bg-slate-100 text-slate-600{{end}}">{{.Role}}</span>
        </td>
        <td class="px-4 py-3">{{if .IsActive}}<span class="hpg-pill hpg-pill-ok">yes</span>{{else}}<span class="hpg-pill hpg-pill-err">disabled</span>{{end}}</td>
        <td class="px-4 py-3">{{if .TOTPEnabled}}<span class="hpg-pill hpg-pill-ok">on</span>{{else}}<span class="hpg-pill hpg-pill-muted">off</span>{{end}}</td>
        <td class="px-4 py-3 text-xs text-slate-500">{{.LastLoginAt}}</td>
        <td class="px-4 py-3 text-right space-x-2 whitespace-nowrap">
          {{if ne .Role "client"}}
          <button type="button"
            class="usr-edit-btn text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline cursor-pointer"
            data-id="{{.ID}}"
            data-fullname="{{.FullName}}"
            data-email="{{.Email}}"
            data-role="{{.Role}}"
            data-active="{{if .IsActive}}1{{else}}0{{end}}">edit</button>
          {{end}}
          {{if and (eq .Role "client") .IsActive}}
          <form class="inline" method="POST" action="/admin/users/{{.ID}}/impersonate">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <button class="text-xs text-indigo-600 hover:underline cursor-pointer" title="Sign in as this client. All actions you take are audit-attributed to you.">impersonate</button>
          </form>
          {{end}}
          {{if .CanToggle}}
          <form class="inline" method="POST" action="/admin/users/{{.ID}}/toggle">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <button class="text-xs text-slate-700 dark:text-slate-200 hover:underline cursor-pointer">{{if .IsActive}}disable{{else}}enable{{end}}</button>
          </form>
          {{end}}
          {{if .CanDelete}}
          <form class="inline" method="POST" action="/admin/users/{{.ID}}/delete" data-confirm="Delete {{.Email}}? This is permanent.">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <button class="text-xs text-rose-600 hover:underline cursor-pointer">delete</button>
          </form>
          {{end}}
          <form class="inline" method="POST" action="/admin/users/{{.ID}}/gdpr-export">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <button class="text-xs text-sky-700 hover:underline cursor-pointer" title="Download a JSON export of every PII row for this user (GDPR Article 15).">export</button>
          </form>
          {{if .CanDelete}}
          <form class="inline" method="POST" action="/admin/users/{{.ID}}/gdpr-delete" data-confirm="GDPR-erase {{.Email}}? Account is masked, PII removed. Cannot be undone.">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <button class="text-xs text-rose-700 hover:underline cursor-pointer" title="Mask account + remove PII (GDPR Article 17). Routes/audit links survive.">erase</button>
          </form>
          {{end}}
        </td>
      </tr>
      {{else}}
      <tr><td colspan="7" class="px-4 py-12 text-center text-slate-500">No users.</td></tr>
      {{end}}
    </tbody>
  </table></div>
</section>

<!-- Create/Edit modal -->
<div id="usr-modal" class="fixed inset-0 z-50 hidden">
  <div id="usr-modal-overlay" class="absolute inset-0 bg-slate-900/50 dark:bg-black/60 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-start justify-center overflow-y-auto p-4 sm:p-6">
    <div class="hpg-card w-full max-w-lg my-8 relative rounded-2xl shadow-xl" role="dialog" aria-modal="true">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="hpg-eyebrow">Access</p>
          <h2 id="usr-modal-title" class="font-semibold text-slate-800 dark:text-slate-100">New user</h2>
        </div>
        <button type="button" id="usr-modal-close"
          class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 text-xl leading-none cursor-pointer">&times;</button>
      </div>

      <p class="text-xs text-slate-500 mb-4">Creates an admin or support panel account. Use <a href="/admin/clients" class="underline">Clients</a> for customer accounts.</p>

      <form id="usr-form" method="POST" action="/admin/users" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="hpg-eyebrow block mb-1.5">Full name</label>
          <input name="full_name" required class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none">
        </div>
        <div>
          <label class="hpg-eyebrow block mb-1.5">Email</label>
          <input name="email" type="email" required class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none">
        </div>
        <div>
          <label id="usr-pw-label" class="hpg-eyebrow block mb-1.5">Initial password</label>
          <input id="usr-pw-input" name="password" type="password" minlength="12" required class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none">
        </div>
        <div>
          <label class="hpg-eyebrow block mb-1.5">Role</label>
          <select name="role" required class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none">
            <option value="support">Support (read-only access)</option>
            <option value="admin">Admin</option>
            {{if .CanCreateSuperAdmin}}<option value="super_admin">Super admin</option>{{end}}
          </select>
        </div>
        <label class="flex items-center gap-2 text-xs text-slate-600 dark:text-slate-300">
          <input type="checkbox" name="is_active" value="1" checked class="rounded border-0 ring-1 ring-slate-200 dark:ring-zinc-700 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 cursor-pointer">
          Active
        </label>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="usr-modal-cancel"
            class="px-3.5 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 ring-1 ring-slate-200 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors cursor-pointer">Cancel</button>
          <button type="submit"
            class="px-4 py-2.5 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors cursor-pointer">Save user</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  var modal = document.getElementById("usr-modal");
  var form = document.getElementById("usr-form");
  var title = document.getElementById("usr-modal-title");
  var pwLabel = document.getElementById("usr-pw-label");
  var pwInput = document.getElementById("usr-pw-input");
  if (!modal || !form) return;

  function setVal(name, value) {
    var el = form.elements[name];
    if (el) el.value = (value == null ? "" : value);
  }
  function setChecked(name, on) {
    var el = form.elements[name];
    if (el) el.checked = !!on;
  }
  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  // Create mode: reset form, password required, post to collection endpoint.
  document.getElementById("usr-new-btn").addEventListener("click", function () {
    form.reset();
    form.action = "/admin/users";
    if (title) title.textContent = "New user";
    if (pwLabel) pwLabel.textContent = "Initial password";
    if (pwInput) { pwInput.required = true; pwInput.placeholder = ""; }
    setChecked("is_active", true);
    open();
  });

  // Edit mode: prefill from data-* attrs, password optional, post to /{id}/edit.
  var editBtns = document.querySelectorAll(".usr-edit-btn");
  for (var i = 0; i < editBtns.length; i++) {
    editBtns[i].addEventListener("click", function () {
      var d = this.dataset;
      form.reset();
      form.action = "/admin/users/" + d.id + "/edit";
      if (title) title.textContent = "Edit user";
      if (pwLabel) pwLabel.textContent = "New password (leave blank to keep)";
      if (pwInput) { pwInput.required = false; pwInput.placeholder = "Leave blank to keep current"; }
      setVal("full_name", d.fullname);
      setVal("email", d.email);
      setVal("role", d.role);
      setVal("password", "");
      setChecked("is_active", d.active === "1");
      open();
    });
  }

  var closeBtn = document.getElementById("usr-modal-close");
  var cancelBtn = document.getElementById("usr-modal-cancel");
  var overlay = document.getElementById("usr-modal-overlay");
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });
})();
</script>
{{end}}
