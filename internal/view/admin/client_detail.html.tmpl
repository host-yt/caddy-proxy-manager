{{define "client_detail"}}
<div class="max-w-xl space-y-6">

  {{if .Flash}}
  <div class="r-card px-4 py-2 ring-[rgb(var(--success)/.4)] t-small" style="background:rgb(var(--success)/.1);color:rgb(var(--success))">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="r-card px-4 py-2 ring-[rgb(var(--danger)/.4)] t-small" style="background:rgb(var(--danger)/.1);color:rgb(var(--danger))">{{.Error}}</div>
  {{end}}

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-3">
    <div class="r-card text-center">
      <p class="t-display">{{.TotalRoutes}}</p>
      <p class="t-caption mt-0.5">Total routes</p>
    </div>
    <div class="r-card text-center">
      <p class="t-display" style="color:rgb(var(--success))">{{.ActiveRoutes}}</p>
      <p class="t-caption mt-0.5">Active</p>
    </div>
    <div class="r-card text-center">
      <p class="t-display" style="color:rgb(56 189 248)">{{formatBytes .BandwidthBytes7d}}</p>
      <p class="t-caption mt-0.5">7-day traffic</p>
    </div>
  </div>

  <!-- Services table -->
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-4 py-3 border-b border-[rgb(var(--border))]">
      <h3 class="t-h3">Services</h3>
    </div>
    <table class="r-table">
      <thead>
        <tr><th class="px-4 py-2">Name</th><th>Plan</th><th>Status</th><th>Routes</th></tr>
      </thead>
      <tbody>
        {{range .Services}}
        <tr>
          <td class="px-4 py-2.5 font-medium">{{.Name}}</td>
          <td class="px-4 py-2.5 text-xs">{{.PlanName}}</td>
          <td class="px-4 py-2.5"><span class="r-pill {{if eq .Status "active"}}r-pill-success{{else if eq .Status "suspended"}}r-pill-warning{{else}}r-pill-neutral{{end}}">{{.Status}}</span></td>
          <td class="px-4 py-2.5">{{.ActiveRoutes}}/{{.RouteCount}}</td>
        </tr>
        {{else}}
        <tr><td colspan="4" class="px-4 py-4 text-center t-small">No services.</td></tr>
        {{end}}
      </tbody>
    </table>
  </section>

  <!-- Routes table -->
  {{if .Routes}}
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-4 py-3 border-b border-[rgb(var(--border))]">
      <h3 class="t-h3">Routes ({{len .Routes}})</h3>
    </div>
    <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th class="px-4 py-2">Domain</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2">SSL</th>
          <th class="px-4 py-2">Node</th>
          <th class="px-4 py-2">Tag</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody>
      {{range .Routes}}
      <tr>
        <td class="px-4 py-2.5 font-mono text-xs">{{.Domain}}{{if .PathPrefix}}<span style="color:rgb(var(--muted))">{{.PathPrefix}}</span>{{end}}</td>
        <td class="px-4 py-2.5"><span class="r-pill {{if eq .Status "active"}}r-pill-success{{else if eq .Status "failed"}}r-pill-danger{{else}}r-pill-neutral{{end}}">{{.Status}}</span></td>
        <td class="px-4 py-2.5">{{if .SSL}}<span style="color:rgb(var(--success))">&#10003;</span>{{else}}<span style="color:rgb(var(--muted))">-</span>{{end}}</td>
        <td class="px-4 py-2.5 text-xs">{{.NodeName}}</td>
        <td class="px-4 py-2.5">{{if .Tag}}<span class="r-pill r-pill-info">{{.Tag}}</span>{{end}}</td>
        <td class="px-4 py-2.5"><a href="/admin/hosts/{{.RouteID}}/edit" class="t-caption cursor-pointer hover:underline" style="color:rgb(var(--accent))">edit</a></td>
      </tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </section>
  {{end}}

  <!-- Client summary -->
  <section class="r-card space-y-1">
    <div class="flex items-start justify-between gap-3">
      <div class="space-y-1">
        <h2 class="t-h3">{{.DisplayName}}</h2>
        <p class="t-small">{{.Email}}</p>
        <p class="t-caption">ID: {{.ID}}</p>
      </div>
      {{if .UserID}}
      <form method="POST" action="/admin/users/{{.UserID}}/impersonate">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button type="submit"
          class="r-btn-secondary inline-flex items-center gap-1.5 text-xs cursor-pointer"
          title="Opens client portal as this user">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Log in as client
        </button>
      </form>
      {{end}}
    </div>
  </section>

  <!-- Change plan -->
  {{if .AllPlans}}
  <section class="r-card">
    <p class="t-eyebrow mb-3">Change plan</p>
    <form method="POST" action="/admin/clients/{{.ID}}/change-plan" class="flex items-center gap-3">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <select name="plan_id" class="r-select flex-1 cursor-pointer">
        {{range .AllPlans}}
        <option value="{{.ID}}"{{if eq .ID $.CurrentPlanID}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
      <button type="submit" class="r-btn-primary cursor-pointer">Apply</button>
    </form>
  </section>
  {{end}}

  <!-- Status page controls -->
  <section class="r-card">
    <p class="t-eyebrow mb-3">Public status page</p>
    {{if .StatusSlug}}
    <div class="mb-3 t-small space-y-2">
      <p>Status page is <span class="r-pill r-pill-success">enabled</span></p>
      <p class="font-mono text-xs break-all" style="color:rgb(var(--muted))">{{.StatusURL}}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="{{.StatusURL}}" target="_blank" class="r-btn-secondary">Preview</a>
      <form method="POST" action="/admin/clients/{{.ID}}/status-slug/generate">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-secondary cursor-pointer">Regenerate slug</button>
      </form>
      <form method="POST" action="/admin/clients/{{.ID}}/status-slug/revoke"
            data-confirm="Disable status page for {{.DisplayName}}?">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-danger cursor-pointer">Disable</button>
      </form>
    </div>
    <div class="mt-3 flex items-center gap-3">
      <form method="POST" action="/admin/clients/{{.ID}}/status-slug/toggle-traffic">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-secondary t-small cursor-pointer">
          {{if .ShowTraffic}}Hide traffic bytes{{else}}Show traffic bytes{{end}}
        </button>
      </form>
      <span class="t-caption">
        Traffic visible to visitors:
        {{if .ShowTraffic}}<span class="r-pill r-pill-success">yes</span>{{else}}<span class="r-pill r-pill-neutral">no</span>{{end}}
      </span>
    </div>
    {{else}}
    <p class="t-small mb-3">Status page is <span class="r-pill r-pill-neutral">disabled</span> for this client.</p>
    <form method="POST" action="/admin/clients/{{.ID}}/status-slug/generate">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-primary cursor-pointer">Enable status page</button>
    </form>
    {{end}}
  </section>

  <!-- Internal admin notes -->
  <section class="r-card">
    <p class="t-eyebrow mb-2">Internal notes</p>
    <form method="POST" action="/admin/clients/{{.ID}}/notes">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <textarea name="notes" rows="4" placeholder="Internal notes (visible to admins only)..."
                class="r-input w-full resize-y">{{.Notes}}</textarea>
      <div class="mt-2 flex justify-end">
        <button type="submit" class="r-btn-primary cursor-pointer">Save notes</button>
      </div>
    </form>
  </section>

  {{if .ClientAudit}}
  <!-- Recent activity audit section -->
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-4 py-3 border-b border-[rgb(var(--border))] flex items-center gap-2">
      <svg class="w-4 h-4 flex-shrink-0" style="color:rgb(var(--muted))" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="10" cy="10" r="8"/><path stroke-linecap="round" d="M10 6v4l2.5 2.5"/>
      </svg>
      <h3 class="t-h3">Recent activity</h3>
    </div>
    <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th class="px-4 py-2">Time</th>
          <th class="px-4 py-2">Action</th>
          <th class="px-4 py-2">Entity</th>
          <th class="px-4 py-2">Actor</th>
        </tr>
      </thead>
      <tbody>
      {{range .ClientAudit}}
      <tr>
        <td class="px-4 py-2 font-mono text-[11px] whitespace-nowrap">{{.FiredAt}}</td>
        <td class="px-4 py-2">
          {{$a := .Action}}
          {{if hasPrefix $a "admin.host."}}
            <span class="r-pill r-pill-warning">{{$a}}</span>
          {{else if hasPrefix $a "admin.service."}}
            <span class="r-pill r-pill-info">{{$a}}</span>
          {{else if hasPrefix $a "admin.client."}}
            <span class="r-pill" style="background:rgb(139 92 246/.12);color:rgb(139 92 246)">{{$a}}</span>
          {{else if hasPrefix $a "client."}}
            <span class="r-pill r-pill-success">{{$a}}</span>
          {{else}}
            <span class="r-pill r-pill-neutral">{{$a}}</span>
          {{end}}
        </td>
        <td class="px-4 py-2 text-xs">{{.Entity}}</td>
        <td class="px-4 py-2 text-xs">{{.Email}}</td>
      </tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </section>
  {{end}}

  <a href="/admin/clients" class="t-small cursor-pointer hover:underline" style="color:rgb(var(--accent))">&larr; Back to clients</a>
</div>
{{end}}
