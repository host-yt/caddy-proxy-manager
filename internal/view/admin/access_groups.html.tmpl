{{define "access_groups"}}
<div class="space-y-6">

  {{if .Flash}}
  <div class="rounded-xl bg-[rgb(var(--success)/.12)] ring-1 ring-[rgb(var(--success)/.4)] p-3 t-small text-[rgb(var(--success))]">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="rounded-xl bg-[rgb(var(--danger)/.12)] ring-1 ring-[rgb(var(--danger)/.4)] p-3 t-small text-[rgb(var(--danger))]">{{.Error}}</div>
  {{end}}

  <section class="r-card">
    <h2 class="t-h3">Built-in access portal</h2>
    <p class="t-small text-[rgb(var(--muted))] mt-1">Create local access groups, add existing users as members, then grant a group access to a host on the host editor's <strong>Portal</strong> tab. Members sign in with their normal email + password at the protected app's login gate.</p>
  </section>

  <!-- Create group -->
  <section class="r-card">
    <h3 class="t-eyebrow mb-3">New access group</h3>
    <form method="POST" action="/admin/access-groups" class="grid grid-cols-1 sm:grid-cols-4 gap-3 items-end text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-1">
        <label class="t-eyebrow block mb-1">Name</label>
        <input name="name" required maxlength="128" placeholder="e.g. ops-team" class="r-input w-full">
      </div>
      <div class="sm:col-span-2">
        <label class="t-eyebrow block mb-1">Description (optional)</label>
        <input name="description" maxlength="255" placeholder="Who is in this group" class="r-input w-full">
      </div>
      <div class="sm:col-span-1">
        {{if .IsSuperAdmin}}
        <label class="t-eyebrow block mb-1">Owning client</label>
        <select name="client_id" class="r-select w-full">
          <option value="0">Global (super-admin only)</option>
          {{range .Clients}}<option value="{{.ID}}">{{.Email}}</option>{{end}}
        </select>
        {{end}}
        <button type="submit" class="r-btn-primary mt-2 w-full cursor-pointer">Create group</button>
      </div>
    </form>
  </section>

  <!-- Groups -->
  {{range .Groups}}
  {{$gid := .ID}}
  <section class="r-card">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="t-h3">{{.Name}}
          <span class="t-caption text-[rgb(var(--muted))] font-normal">#{{.ID}}</span>
        </h3>
        {{if .Description}}<p class="t-small text-[rgb(var(--muted))] mt-0.5">{{.Description}}</p>{{end}}
        <p class="t-caption text-[rgb(var(--muted))] mt-0.5">
          {{if .ClientID.Valid}}Client: {{if .ClientName}}{{.ClientName}}{{else}}#{{.ClientID.Int64}}{{end}}{{else}}Global{{end}}
          &middot; {{len .Members}} member(s)
        </p>
      </div>
      <form method="POST" action="/admin/access-groups/{{.ID}}/delete" data-confirm="Delete group {{.Name}}? This removes all its members and route grants.">
        <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
        <button class="r-btn-danger text-xs cursor-pointer">Delete group</button>
      </form>
    </div>

    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <p class="t-eyebrow mb-2">Members</p>
        <ul class="space-y-1">
          {{range .Members}}
          <li class="flex items-center justify-between t-small bg-[rgb(var(--surface-2))] rounded-lg px-3 py-1.5">
            <span class="text-[rgb(var(--text))]">{{.Email}}{{if .Name}} <span class="text-[rgb(var(--muted))]">({{.Name}})</span>{{end}}</span>
            <form method="POST" action="/admin/access-groups/{{$gid}}/members/{{.UserID}}/delete" data-no-confirm>
              <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
              <button class="text-[rgb(var(--danger))] hover:underline cursor-pointer">remove</button>
            </form>
          </li>
          {{else}}
          <li class="t-caption text-[rgb(var(--muted))]">No members yet.</li>
          {{end}}
        </ul>
      </div>
      <div>
        <p class="t-eyebrow mb-2">Add member (existing user email)</p>
        <form method="POST" action="/admin/access-groups/{{.ID}}/members" class="flex gap-2 text-sm">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <input name="email" type="email" required placeholder="user@example.com" class="r-input flex-1">
          <button type="submit" class="r-btn-primary cursor-pointer">Add</button>
        </form>
        <p class="t-caption text-[rgb(var(--muted))] mt-1">Only existing, active users can be added. The portal reuses their normal credentials.</p>
      </div>
    </div>
  </section>
  {{else}}
  <section class="r-card">
    <div class="r-empty">
      <div class="r-empty-icon">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
      </div>
      <p class="font-medium text-[rgb(var(--text))]">No access groups yet</p>
      <p class="t-small text-[rgb(var(--muted))]">Create one above to restrict host access to specific users.</p>
    </div>
  </section>
  {{end}}

</div>
{{end}}
