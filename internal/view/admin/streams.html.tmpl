{{define "streams"}}
<div class="space-y-6">
  <div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <div class="icon-chip">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/>
        </svg>
      </div>
      <div>
        <p class="t-eyebrow">Layer-4</p>
        <p class="t-small text-[rgb(var(--muted))]">Layer-4 port forwards via the <code class="text-xs">caddy-l4</code> module. Use for game servers, database tunnels, mail relays - anything not HTTP.</p>
      </div>
    </div>
    <span class="r-pill {{if .ModuleAvailable}}r-pill-success{{else}}r-pill-danger{{end}} flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full {{if .ModuleAvailable}}bg-emerald-500{{else}}bg-rose-500{{end}}"></span>
      L4 module {{if .ModuleAvailable}}enabled{{else}}disabled (LAYER4_AVAILABLE=0){{end}}
    </span>
  </div>

  <section class="r-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Proto</th>
            <th>Listen</th>
            <th>Backend</th>
            <th>Match</th>
            <th>LB</th>
            <th>Node</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{range .Streams}}
          <tr>
            <td class="font-mono uppercase font-medium">{{.Protocol}}</td>
            <td class="font-mono">:{{.ListenPort}}</td>
            <td class="font-mono text-[rgb(var(--muted))]">{{.BackendIP}}:{{.UpstreamPort}}</td>
            <td class="t-small">
              {{if .MatchMode}}{{.MatchMode}}{{else}}any{{end}}
            </td>
            <td class="t-small text-[rgb(var(--muted))]">{{if .LBPolicy}}{{.LBPolicy}}{{else}}round_robin{{end}}</td>
            <td>{{.NodeName}}</td>
            <td>
              <span class="r-pill {{if eq .Status "active"}}r-pill-success{{else}}r-pill-neutral{{end}}">{{.Status}}</span>
            </td>
            <td class="text-right whitespace-nowrap">
              <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="stream-act-{{.ID}}">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
              </button>
              <div id="stream-act-{{.ID}}" class="hpg-act-menu" role="menu">
                <a href="/admin/streams/{{.ID}}/edit" class="hpg-act-item" role="menuitem">Edit</a>
                <form method="POST" action="/admin/streams/{{.ID}}/delete" class="contents" data-confirm="Delete stream {{.Protocol}} :{{.ListenPort}} → {{.BackendIP}}:{{.UpstreamPort}}?">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item is-danger" role="menuitem">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          {{else}}
          <tr><td colspan="8" class="px-4 py-10 text-center text-[rgb(var(--muted))]">No stream forwards configured yet.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

  <section class="r-card">
    <h3 class="t-h3 mb-4">Add stream forward</h3>

    <!-- Module requirement notice -->
    <div class="flex items-start gap-2.5 r-card border border-[rgb(var(--border))] bg-[rgb(var(--surface-2)/.5)] px-3.5 py-3 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5 text-[rgb(var(--muted))]" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
      </svg>
      <span class="t-small text-[rgb(var(--muted))]">Plain TCP/UDP forwarding plus the advanced options (SNI / HTTP-host matching, load balancing, PROXY protocol, CIDR access control) all run on the <code class="font-mono">caddy-l4</code> module bundled in the Caddy image. Generated configs are validated against caddy-l4 on every release.</span>
    </div>

    <!-- Tab strip for create form -->
    <nav class="flex flex-wrap gap-1 border-b border-[rgb(var(--border))] mb-4" id="hpg-create-tabs">
      <button type="button" data-ctab="listener"  class="hpg-ctab px-3 py-1.5 -mb-px border-b-2 border-[rgb(var(--accent))] text-[rgb(var(--accent))] font-medium t-small cursor-pointer">Listener</button>
      <button type="button" data-ctab="match"     class="hpg-ctab px-3 py-1.5 -mb-px border-b-2 border-transparent text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] t-small cursor-pointer">Match</button>
      <button type="button" data-ctab="upstreams" class="hpg-ctab px-3 py-1.5 -mb-px border-b-2 border-transparent text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] t-small cursor-pointer">Upstreams &amp; LB</button>
      <button type="button" data-ctab="security"  class="hpg-ctab px-3 py-1.5 -mb-px border-b-2 border-transparent text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] t-small cursor-pointer">Security</button>
    </nav>

    <form method="POST" action="/admin/streams/new" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">

      <!-- Listener pane -->
      <div data-cpane="listener" class="hpg-cpane grid grid-cols-1 sm:grid-cols-6 gap-3">
        <div>
          <label class="t-eyebrow block mb-1">Protocol</label>
          <select name="protocol" class="r-select w-full cursor-pointer">
            <option value="tcp"  {{if eq .Form.Protocol "tcp"}}selected{{end}}>TCP</option>
            <option value="udp"  {{if eq .Form.Protocol "udp"}}selected{{end}}>UDP</option>
            <option value="both" {{if eq .Form.Protocol "both"}}selected{{end}}>TCP + UDP</option>
          </select>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Listen port (public)</label>
          <input name="listen_port" type="number" min="1" max="65535" value="{{.Form.ListenPort}}" required class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Backend IP (primary upstream)</label>
          <input name="backend_ip" value="{{.Form.BackendIP}}" placeholder="10.0.0.5" required class="r-input w-full font-mono">
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Backend port</label>
          <input name="upstream_port" type="number" min="1" max="65535" value="{{.Form.UpstreamPort}}" required class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Caddy node</label>
          <select name="node_id" required class="r-select w-full cursor-pointer">
            <option value="">-- pick --</option>
            {{range .Nodes}}<option value="{{.ID}}" {{if eq (printf "%d" .ID) $.Form.NodeID}}selected{{end}}>{{.Name}} ({{.Hostname}})</option>{{end}}
          </select>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Tag (optional)</label>
          <input name="tag" value="{{.Form.Tag}}" maxlength="64" placeholder="game-1" class="r-input w-full">
        </div>
      </div>

      <!-- Match pane -->
      <div data-cpane="match" class="hpg-cpane hidden grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="t-eyebrow block mb-1">Match mode</label>
          <select name="match_mode" id="hpg-create-match-mode" class="r-select w-full cursor-pointer">
            <option value="any"       {{if eq .Form.MatchMode "any"}}selected{{end}}>Any (plain forward) [stable]</option>
            <option value="sni"       {{if eq .Form.MatchMode "sni"}}selected{{end}}>SNI (TLS server name)</option>
            <option value="http_host" {{if eq .Form.MatchMode "http_host"}}selected{{end}}>HTTP Host header</option>
          </select>
        </div>
        <div id="hpg-create-match-values-wrap" class="{{if eq .Form.MatchMode "any"}}hidden{{end}}">
          <label class="t-eyebrow block mb-1">Match values (comma/newline)</label>
          <textarea name="match_values" rows="3" placeholder="db.example.com"
                    class="r-input w-full font-mono text-xs">{{.Form.MatchValues}}</textarea>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">
            PROXY protocol in          </label>
          <select name="proxy_proto_in" class="r-select w-full cursor-pointer">
            <option value="none" {{if eq .Form.ProxyProtoIn "none"}}selected{{end}}>None</option>
            <option value="v1"   {{if eq .Form.ProxyProtoIn "v1"}}selected{{end}}>PROXY v1</option>
            <option value="v2"   {{if eq .Form.ProxyProtoIn "v2"}}selected{{end}}>PROXY v2</option>
          </select>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">
            PROXY protocol out          </label>
          <select name="proxy_proto_out" class="r-select w-full cursor-pointer">
            <option value="none" {{if eq .Form.ProxyProtoOut "none"}}selected{{end}}>None</option>
            <option value="v1"   {{if eq .Form.ProxyProtoOut "v1"}}selected{{end}}>PROXY v1</option>
            <option value="v2"   {{if eq .Form.ProxyProtoOut "v2"}}selected{{end}}>PROXY v2</option>
          </select>
        </div>
      </div>

      <!-- Upstreams pane -->
      <div data-cpane="upstreams" class="hpg-cpane hidden space-y-3">
        <div>
          <label class="t-eyebrow block mb-1">
            Additional upstreams (one per line: host:port or host:port weight)          </label>
          <textarea name="upstreams_raw" rows="4" placeholder="10.0.0.2:3306 2&#10;10.0.0.3:3306 1"
                    class="r-input w-full font-mono text-xs">{{.Form.UpstreamsRaw}}</textarea>
          <p class="t-caption text-[rgb(var(--muted))] mt-1">Leave blank to use only the primary backend above.</p>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">
            LB policy          </label>
          <select name="lb_policy" class="r-select w-full sm:w-56 cursor-pointer">
            <option value="round_robin" {{if eq .Form.LBPolicy "round_robin"}}selected{{end}}>Round robin</option>
            <option value="random"      {{if eq .Form.LBPolicy "random"}}selected{{end}}>Random</option>
            <option value="least_conn"  {{if eq .Form.LBPolicy "least_conn"}}selected{{end}}>Least connections</option>
            <option value="first"       {{if eq .Form.LBPolicy "first"}}selected{{end}}>First (failover)</option>
          </select>
        </div>
      </div>

      <!-- Security pane -->
      <div data-cpane="security" class="hpg-cpane hidden grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="t-eyebrow block mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline h-3.5 w-3.5 text-rose-500 mr-1" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524L13.477 14.89zm1.414-1.414L6.524 5.11A6 6 0 0114.89 13.476zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"/>
            </svg>
            Deny CIDRs (comma or newline)          </label>
          <textarea name="cidr_deny" rows="3" placeholder="10.99.0.0/16"
                    class="r-input w-full font-mono text-xs">{{.Form.CIDRDeny}}</textarea>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline h-3.5 w-3.5 text-emerald-500 mr-1" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Allow CIDRs (empty = allow all)          </label>
          <textarea name="cidr_allow" rows="3" placeholder="10.0.0.0/8"
                    class="r-input w-full font-mono text-xs">{{.Form.CIDRAllow}}</textarea>
        </div>
      </div>

      <div class="flex justify-end pt-1">
        <button class="r-btn-primary cursor-pointer">Add stream</button>
      </div>
    </form>

    <!-- Port conflict / reservation notice -->
    <div class="flex items-start gap-2 mt-4 r-card border border-[rgb(var(--border))] bg-[rgb(var(--surface-2)/.5)] px-3.5 py-3">
      <svg class="w-4 h-4 flex-shrink-0 mt-0.5 text-[rgb(var(--muted))]" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/>
      </svg>
      <p class="t-caption text-[rgb(var(--muted))]">Ports 80, 443, 2019 are reserved (HTTPS + admin). The Caddy container must publish the listen port on the host (edit <code class="text-xs">deploy/docker-compose.yml</code> and add the port mapping before saving). SNI/http_host matchers, LB, proxy-protocol, and CIDR access control require the bundled <code class="text-xs">caddy-l4</code> module.</p>
    </div>
  </section>
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  // Create-form tab switching.
  var ctabs = document.querySelectorAll('[data-ctab]');
  var cpanes = document.querySelectorAll('[data-cpane]');
  function showCTab(name){
    ctabs.forEach(function(t){
      var on = t.dataset.ctab === name;
      t.classList.toggle('border-[rgb(var(--accent))]', on);
      t.classList.toggle('text-[rgb(var(--accent))]', on);
      t.classList.toggle('font-medium', on);
      t.classList.toggle('border-transparent', !on);
      t.classList.toggle('text-[rgb(var(--muted))]', !on);
    });
    cpanes.forEach(function(p){p.classList.toggle('hidden', p.dataset.cpane !== name);});
  }
  ctabs.forEach(function(t){t.addEventListener('click', function(){showCTab(t.dataset.ctab);});});

  // Match values visibility for the create form.
  var cMode = document.getElementById('hpg-create-match-mode');
  var cValWrap = document.getElementById('hpg-create-match-values-wrap');
  function syncCreate(){
    if(cMode && cValWrap) cValWrap.classList.toggle('hidden', cMode.value === 'any');
  }
  if(cMode) cMode.addEventListener('change', syncCreate);
})();
</script>
{{end}}
