{{define "node_groups"}}
<div class="space-y-6">

  {{if .Flash}}
  <div class="r-card" style="background:rgb(var(--success)/0.08);border-color:rgb(var(--success)/0.3);color:rgb(var(--success))">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="r-card" style="background:rgb(var(--danger)/0.08);border-color:rgb(var(--danger)/0.3);color:rgb(var(--danger))">{{.Error}}</div>
  {{end}}

  <!-- Create form -->
  <section class="r-card">
    <h3 class="t-eyebrow mb-3">New node group</h3>
    <form method="POST" action="/admin/node-groups" class="flex flex-wrap gap-3 items-end">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="flex-1 min-w-[180px]">
        <label class="t-caption font-medium block mb-1">Name</label>
        <input name="name" required maxlength="128" placeholder="e.g. eu-west" class="r-input w-full">
      </div>
      <div class="w-44">
        <label class="t-caption font-medium block mb-1">Mode</label>
        <select name="mode" class="r-select w-full cursor-pointer">
          <option value="single">single</option>
          <option value="active_active">active-active</option>
          <option value="failover">failover</option>
        </select>
      </div>
      <button type="submit" class="r-btn-primary cursor-pointer">
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v10M3 8h10"/></svg>
        Create
      </button>
    </form>
  </section>

  <!-- List -->
  <section class="r-card p-0 overflow-hidden">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-[rgb(var(--border))]">
      <div>
        <p class="t-eyebrow">Fleet / Edge</p>
        <h2 class="t-h3 mt-0.5">Node groups</h2>
      </div>
      <span class="icon-chip text-sm font-semibold" style="min-width:2rem;height:2rem;border-radius:9999px">{{len .Groups}}</span>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Mode</th>
            <th>Nodes</th>
            <th>Plans</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          {{range .Groups}}
          <tr>
            <td class="font-medium">{{.Name}}</td>
            <td>
              {{if eq .Mode "failover"}}
              <span class="r-pill r-pill-info">failover</span>
              {{else if eq .Mode "active_active"}}
              <span class="r-pill r-pill-warning">active-active</span>
              {{else}}
              <span class="r-pill r-pill-neutral">single</span>
              {{end}}
            </td>
            <td class="tabular-nums">{{.NodeCount}}</td>
            <td class="tabular-nums">{{.PlanCount}}</td>
            <td class="text-right">
              <button type="button"
                class="ng-edit-btn r-btn-ghost text-xs cursor-pointer"
                style="color:rgb(var(--accent))"
                data-id="{{.ID}}" data-name="{{.Name}}" data-mode="{{.Mode}}">
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11.5 2.5a1.5 1.5 0 0 1 2.12 2.12L5 13.25l-3 .75.75-3L11.5 2.5z"/></svg>
                Edit
              </button>
            </td>
          </tr>
          <!-- Inline edit row, hidden by default -->
          <tr id="ng-edit-row-{{.ID}}" class="hidden" style="background:rgb(var(--surface-2)/0.5)">
            <td colspan="5" class="px-4 py-3">
              <form method="POST" action="/admin/node-groups/{{.ID}}/update" class="flex flex-wrap gap-3 items-end">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <div class="flex-1 min-w-[180px]">
                  <label class="t-caption font-medium block mb-1">Name</label>
                  <input name="name" required maxlength="128" value="{{.Name}}" class="r-input w-full">
                </div>
                <div class="w-44">
                  <label class="t-caption font-medium block mb-1">Mode</label>
                  <select name="mode" class="r-select w-full cursor-pointer">
                    <option value="single"{{if eq .Mode "single"}} selected{{end}}>single</option>
                    <option value="active_active"{{if eq .Mode "active_active"}} selected{{end}}>active-active</option>
                    <option value="failover"{{if eq .Mode "failover"}} selected{{end}}>failover</option>
                  </select>
                </div>
                <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
                <button type="button" class="ng-cancel-btn r-btn-secondary cursor-pointer" data-id="{{.ID}}">Cancel</button>
              </form>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="5" class="px-4 py-8 text-center t-caption">No node groups yet.</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

</div>
<script nonce="{{.CSPNonce}}">
(function () {
  // toggle inline edit row
  document.querySelectorAll('.ng-edit-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.dataset.id;
      var row = document.getElementById('ng-edit-row-' + id);
      if (row) row.classList.toggle('hidden');
    });
  });
  document.querySelectorAll('.ng-cancel-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.dataset.id;
      var row = document.getElementById('ng-edit-row-' + id);
      if (row) row.classList.add('hidden');
    });
  });
})();
</script>
{{end}}
