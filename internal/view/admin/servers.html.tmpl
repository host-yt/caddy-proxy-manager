{{define "servers"}}
<section class="r-card !p-0 overflow-hidden">
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-[rgb(var(--border))]">
    <div class="flex items-center gap-3">
      <div class="icon-chip">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>
        </svg>
      </div>
      <div>
        <p class="t-eyebrow">Infrastructure</p>
        <h2 class="t-h3">Backend servers</h2>
      </div>
      <span class="r-pill r-pill-neutral">{{len .Servers}}</span>
    </div>
    {{if .CanManage}}<button type="button" id="srv-new-btn" class="r-btn-primary cursor-pointer">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      New server
    </button>{{end}}
  </div>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>IP</th>
          <th>External ref</th>
          <th>Owner</th>
          <th>Notes</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range .Servers}}
        <tr>
          <td class="font-medium whitespace-nowrap">{{.Name}}</td>
          <td><code class="font-mono text-xs bg-[rgb(var(--surface-2))] rounded px-1.5 py-0.5">{{.IP}}</code></td>
          <td class="whitespace-nowrap">{{if .ExternalRef}}{{.ExternalRef}}{{else}}<span class="text-[rgb(var(--muted))]">-</span>{{end}}</td>
          <td class="whitespace-nowrap">{{if .ResellerID}}{{.ResellerName}}{{else}}<span class="r-pill r-pill-neutral">global</span>{{end}}</td>
          <td class="max-w-xs truncate" title="{{.Notes}}">{{.Notes}}</td>
          <td class="text-right whitespace-nowrap">
            {{if not .Owned}}<span class="r-pill r-pill-neutral">read-only</span>{{else}}
            <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="srv-act-{{.ID}}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
            </button>
            <div id="srv-act-{{.ID}}" class="hpg-act-menu" role="menu">
              <button type="button"
                class="srv-edit-btn hpg-act-item" role="menuitem"
                data-id="{{.ID}}"
                data-name="{{.Name}}"
                data-ip="{{.IP}}"
                data-extref="{{.ExternalRef}}"
                data-notes="{{.Notes}}">Edit</button>
              <form method="POST" action="/admin/servers/{{.ID}}/delete" class="contents" data-confirm="Delete server {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Delete</button>
              </form>
            </div>
            {{end}}
          </td>
        </tr>
        {{else}}
        <tr><td colspan="6" class="px-5 py-12 text-center text-[rgb(var(--muted))]">No backend servers yet.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

<!-- Create/Edit modal -->
<div id="srv-modal" class="fixed inset-0 z-50 hidden">
  <div id="srv-modal-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-center justify-center overflow-y-auto p-4 sm:p-6">
    <div class="r-card w-full max-w-lg max-h-[90vh] overflow-y-auto relative" role="dialog" aria-modal="true">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="t-eyebrow">Infrastructure</p>
          <h2 id="srv-modal-title" class="t-h3">New server</h2>
        </div>
        <button type="button" id="srv-modal-close"
          class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] transition-colors cursor-pointer" aria-label="Close">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <form id="srv-form" method="POST" action="/admin/servers" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="t-eyebrow block mb-1.5">Name</label>
          <input name="name" required placeholder="vps-fra-01" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">IP</label>
          <input name="ip" required placeholder="10.0.0.5" class="r-input w-full font-mono">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">External reference</label>
          <input name="external_ref" placeholder="hosting panel server id" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Notes</label>
          <textarea name="notes" rows="3" class="r-input w-full resize-y"></textarea>
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="srv-modal-cancel" class="r-btn-ghost cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save server</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  var modal = document.getElementById("srv-modal");
  var form = document.getElementById("srv-form");
  var title = document.getElementById("srv-modal-title");
  if (!modal || !form) return;

  function setVal(name, value) {
    var el = form.elements[name];
    if (el) el.value = (value == null ? "" : value);
  }

  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  var newBtn = document.getElementById("srv-new-btn");
  if (newBtn) newBtn.addEventListener("click", function () {
    form.reset();
    form.action = "/admin/servers";
    if (title) title.textContent = "New server";
    open();
  });

  var editBtns = document.querySelectorAll(".srv-edit-btn");
  for (var i = 0; i < editBtns.length; i++) {
    editBtns[i].addEventListener("click", function () {
      var d = this.dataset;
      form.action = "/admin/servers/" + d.id + "/edit";
      if (title) title.textContent = "Edit server";
      setVal("name", d.name);
      setVal("ip", d.ip);
      setVal("external_ref", d.extref);
      setVal("notes", d.notes);
      open();
    });
  }

  var closeBtn = document.getElementById("srv-modal-close");
  var cancelBtn = document.getElementById("srv-modal-cancel");
  var overlay = document.getElementById("srv-modal-overlay");
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });
})();
</script>
{{end}}
