{{define "admin_account"}}
<div class="space-y-4 max-w-2xl">
  {{template "admin_account_tabs" "general"}}

  <form method="POST" action="/admin/account" class="r-card space-y-5 text-sm">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <div class="flex items-center gap-4 pb-4 border-b border-[rgb(var(--border))]">
      <div class="r-avatar text-xl w-14 h-14 rounded-2xl">{{printf "%.1s" .Email}}</div>
      <div>
        <p class="font-semibold text-[rgb(var(--text))]">{{.Email}}</p>
        <p class="t-caption text-[rgb(var(--muted))] mt-0.5">Account settings</p>
      </div>
    </div>

    <div>
      <label class="t-eyebrow block mb-1">Email</label>
      <input value="{{.Email}}" disabled class="r-input w-full opacity-60 cursor-not-allowed">
      <p class="t-caption text-[rgb(var(--muted))] mt-1">Email is managed under Users; change there.</p>
    </div>

    <div>
      <label class="t-eyebrow block mb-1">Phone (E.164)</label>
      <input name="phone_e164" value="{{.Phone}}" placeholder="+48555111222" pattern="^\+[1-9]\d{1,14}$" class="r-input w-full font-mono">
      <p class="t-caption text-[rgb(var(--muted))] mt-1">Used for SMS 2FA + outage alerts. Tab "Security (2FA)" enables the SMS factor once phone is set.</p>
    </div>

    <div class="flex justify-end pt-1">
      <button class="r-btn-primary cursor-pointer">Save</button>
    </div>
  </form>

  <!-- Linked OAuth providers -->
  <section class="r-card space-y-3 text-sm">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <h2 class="t-h3">Linked login providers</h2>
      <div class="flex items-center gap-2 flex-wrap">
        {{if .OIDCEnabled}}
        <form method="POST" action="/admin/oauth-identities/link/oidc">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="r-btn-ghost text-xs cursor-pointer">
            + Link OIDC provider
          </button>
        </form>
        {{end}}
        {{if .GitHubEnabled}}
        <form method="POST" action="/admin/oauth-identities/link/github">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="r-btn-secondary inline-flex items-center gap-1.5 text-xs cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            Link GitHub
          </button>
        </form>
        {{end}}
        {{if .GoogleEnabled}}
        <form method="POST" action="/admin/oauth-identities/link/google">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="r-btn-secondary inline-flex items-center gap-1.5 text-xs cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Link Google
          </button>
        </form>
        {{end}}
      </div>
    </div>

    {{if .OAuthIdentities}}
    <ul class="divide-y divide-[rgb(var(--border))]">
      {{range .OAuthIdentities}}
      <li class="flex items-center justify-between py-2.5 gap-3">
        <div class="flex items-center gap-2.5 min-w-0">
          <span class="icon-chip flex-shrink-0">
            {{if eq .Provider "github"}}
            <svg class="w-4 h-4 text-[rgb(var(--text))]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            {{else if eq .Provider "google"}}
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            {{else if eq .Provider "microsoft"}}
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true"><path fill="#f25022" d="M1 1h10v10H1z"/><path fill="#00a4ef" d="M13 1h10v10H13z"/><path fill="#7fba00" d="M1 13h10v10H1z"/><path fill="#ffb900" d="M13 13h10v10H13z"/></svg>
            {{else}}
            <svg class="w-4 h-4 text-[rgb(var(--muted))]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {{end}}
          </span>
          <div class="min-w-0">
            <p class="font-medium text-[rgb(var(--text))] truncate">{{.Label}}</p>
            {{if .Email}}<p class="t-caption text-[rgb(var(--muted))] truncate">{{.Email}}</p>{{end}}
          </div>
        </div>
        <form method="POST" action="/admin/oauth-identities/{{.ID}}/unlink" class="flex-shrink-0">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button class="r-btn-danger text-xs cursor-pointer">Unlink</button>
        </form>
      </li>
      {{end}}
    </ul>
    {{else}}
    <p class="t-small text-[rgb(var(--muted))]">No OAuth providers linked yet.</p>
    {{end}}
  </section>
</div>
{{end}}

{{define "admin_account_tabs"}}
<nav class="flex gap-1 border-b border-[rgb(var(--border))] text-sm">
  <a href="/admin/account" class="px-3 py-2 -mb-px border-b-2 transition-colors {{if eq . "general"}}border-[rgb(var(--accent))] text-[rgb(var(--accent))] font-medium{{else}}border-transparent text-[rgb(var(--muted))] hover:text-[rgb(var(--text))]{{end}}">General</a>
  <a href="/admin/2fa" class="px-3 py-2 -mb-px border-b-2 transition-colors {{if eq . "twofa"}}border-[rgb(var(--accent))] text-[rgb(var(--accent))] font-medium{{else}}border-transparent text-[rgb(var(--muted))] hover:text-[rgb(var(--text))]{{end}}">Security (2FA)</a>
  <a href="/admin/api-keys" class="px-3 py-2 -mb-px border-b-2 transition-colors {{if eq . "api_keys"}}border-[rgb(var(--accent))] text-[rgb(var(--accent))] font-medium{{else}}border-transparent text-[rgb(var(--muted))] hover:text-[rgb(var(--text))]{{end}}">API keys</a>
</nav>
{{end}}
