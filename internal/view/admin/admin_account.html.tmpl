{{define "admin_account"}}
<div class="space-y-4 max-w-2xl">
  {{template "admin_account_tabs" "general"}}

  <form method="POST" action="/admin/account" class="hpg-card space-y-5 text-sm">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
      <input value="{{.Email}}" disabled class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 bg-slate-50 dark:bg-zinc-800 text-slate-500">
      <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Email is managed under Users; change there.</p>
    </div>

    <div>
      <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Phone (E.164)</label>
      <input name="phone_e164" value="{{.Phone}}" placeholder="+48555111222" pattern="^\+[1-9]\d{1,14}$" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 font-mono">
      <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Used for SMS 2FA + outage alerts. Tab "Security (2FA)" enables the SMS factor once phone is set.</p>
    </div>

    <div class="flex justify-end pt-1">
      <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Save</button>
    </div>
  </form>
</div>
{{end}}

{{define "admin_account_tabs"}}
<nav class="flex gap-1 border-b border-slate-200 dark:border-zinc-800 text-sm">
  <a href="/admin/account" class="px-3 py-2 -mb-px border-b-2 {{if eq . "general"}}border-indigo-600 text-indigo-700 dark:text-indigo-400 font-medium{{else}}border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700{{end}}">General</a>
  <a href="/admin/2fa" class="px-3 py-2 -mb-px border-b-2 {{if eq . "twofa"}}border-indigo-600 text-indigo-700 dark:text-indigo-400 font-medium{{else}}border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700{{end}}">Security (2FA)</a>
  <a href="/admin/api-keys" class="px-3 py-2 -mb-px border-b-2 {{if eq . "api_keys"}}border-indigo-600 text-indigo-700 dark:text-indigo-400 font-medium{{else}}border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700{{end}}">API keys</a>
</nav>
{{end}}
