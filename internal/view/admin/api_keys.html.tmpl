{{define "api_keys"}}
<div class="space-y-4">
{{template "admin_account_tabs" "api_keys"}}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <section class="lg:col-span-2 r-card !p-0 overflow-hidden">
    {{if .NewPlain}}
    <div class="p-5 bg-[rgb(var(--warning)/.1)] border-b border-[rgb(var(--warning)/.3)]">
      <h3 class="t-h3 text-[rgb(var(--warning))] mb-2">Key created - copy it now</h3>
      <p class="t-caption text-[rgb(var(--warning)/.8)] mb-2">This is the only time the full key will be shown.</p>
      <code class="block bg-[rgb(var(--surface))] ring-1 ring-[rgb(var(--warning)/.4)] rounded-lg px-3 py-2 text-sm font-mono break-all">{{.NewPlain}}</code>
    </div>
    {{end}}

    <!-- Search row -->
    <div class="flex items-center justify-between gap-3 px-4 py-3 border-b border-[rgb(var(--border))]">
      <form method="GET" action="/admin/api-keys" class="flex items-center gap-2 flex-1">
        {{if .ViewAll}}<input type="hidden" name="all" value="1">{{end}}
        <div class="relative flex-1 max-w-xs">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[rgb(var(--muted))]" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="9" cy="9" r="5"/><path d="M13.5 13.5l3 3"/></svg>
          <input name="q" value="{{.Q}}" placeholder="Search name, scopes..." class="r-input w-full pl-9">
        </div>
        <button class="r-btn-primary text-xs cursor-pointer">Search</button>
        {{if .Q}}<a href="/admin/api-keys{{if .ViewAll}}?all=1{{end}}" class="t-caption text-[rgb(var(--muted))] hover:underline">Clear</a>{{end}}
      </form>
      <div class="flex items-center gap-2">
        {{if .ViewAll}}
        <a href="/admin/api-keys" class="r-btn-secondary text-xs cursor-pointer">Back to my keys</a>
        {{else if eq .Role "super_admin"}}
        <a href="/admin/api-keys?all=1" class="r-btn-ghost text-xs cursor-pointer">View all</a>
        {{end}}
        <button type="button" id="ak-save-filter-btn" class="r-btn-ghost text-xs cursor-pointer">Save filter</button>
      </div>
    </div>

    {{if .SavedFilters}}
    <div class="flex flex-wrap items-center gap-2 px-4 py-2 border-b border-[rgb(var(--border))] text-xs">
      <span class="t-eyebrow">Saved:</span>
      {{range .SavedFilters}}
      <div class="flex items-center gap-1">
        <a href="/admin/api-keys?saved_filter={{.ID}}" class="r-pill r-pill-info hover:opacity-80 transition-opacity cursor-pointer">
          {{.Name}}
        </a>
        <form method="POST" action="/admin/saved-filters/api_keys/{{.ID}}/delete" class="inline">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button type="submit" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--danger))] cursor-pointer" title="Delete">&times;</button>
        </form>
      </div>
      {{end}}
    </div>
    {{end}}

    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead class="sticky top-0 bg-[rgb(var(--surface))/95] backdrop-blur-sm z-10">
          <tr>
            {{if .ViewAll}}<th>Owner</th>{{end}}
            <th>
              <a href="/admin/api-keys?q={{.Q}}&sort=name&dir={{if and (eq .Sort "name") (eq .Dir "asc")}}desc{{else}}asc{{end}}{{if .ViewAll}}&all=1{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
                Name
                {{if eq .Sort "name"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
              </a>
            </th>
            <th>Prefix</th>
            <th>Scopes</th>
            <th>
              <a href="/admin/api-keys?q={{.Q}}&sort=last_used_at&dir={{if and (eq .Sort "last_used_at") (eq .Dir "asc")}}desc{{else}}asc{{end}}{{if .ViewAll}}&all=1{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
                Last used
                {{if eq .Sort "last_used_at"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
              </a>
            </th>
            <th>Last IP</th>
            <th>Requests</th>
            <th>
              <a href="/admin/api-keys?q={{.Q}}&sort=created_at&dir={{if and (eq .Sort "created_at") (eq .Dir "asc")}}desc{{else}}asc{{end}}{{if .ViewAll}}&all=1{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
                Created
                {{if eq .Sort "created_at"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
              </a>
            </th>
            <th>Expires</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{range .Keys}}
          <tr class="{{if .Revoked}}opacity-50{{end}}">
            {{if .ViewAll}}<td class="tabular-nums text-[rgb(var(--muted))] whitespace-nowrap">{{if .OwnerEmail}}{{.OwnerEmail}}{{else}}<span class="text-[rgb(var(--border))]">-</span>{{end}}</td>{{end}}
            <td class="font-medium text-[rgb(var(--text))] whitespace-nowrap">{{.Name}}</td>
            <td><code class="t-caption bg-[rgb(var(--surface-2))] px-1.5 py-0.5 rounded">hpg_{{.Prefix}}&hellip;</code></td>
            <td class="t-caption text-[rgb(var(--muted))] font-mono">{{.Scopes}}</td>
            <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{if .LastUsedAt}}{{.LastUsedAt}}{{else}}<span class="text-[rgb(var(--border))]">-</span>{{end}}</td>
            <td class="t-caption text-[rgb(var(--muted))] font-mono tabular-nums">{{if .LastUsedIP}}{{.LastUsedIP}}{{else}}<span class="text-[rgb(var(--border))]">-</span>{{end}}</td>
            <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{.UseCount}}</td>
            <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{.CreatedAt}}</td>
            <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{if .ExpiresAt}}{{.ExpiresAt}}{{else}}<span class="text-[rgb(var(--border))]">never</span>{{end}}</td>
            <td class="text-right whitespace-nowrap">
              {{if not .Revoked}}
              <form method="POST" action="/admin/api-keys/{{.ID}}/revoke" data-confirm="Revoke {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="r-btn-danger text-xs cursor-pointer">Revoke</button>
              </form>
              {{else}}<span class="r-pill r-pill-neutral">revoked</span>{{end}}
            </td>
          </tr>
          {{else}}
          <tr><td colspan="{{if $.ViewAll}}10{{else}}9{{end}}" class="px-4 py-16 text-center">
            <div class="r-empty">
              <div class="r-empty-icon">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <p class="font-medium text-[rgb(var(--text))]">{{if .Q}}No keys match your search{{else}}No API keys yet{{end}}</p>
              <p class="t-small text-[rgb(var(--muted))]">{{if .Q}}Try a different search term or clear the filter.{{else}}Create a key using the form on the right.{{end}}</p>
            </div>
          </td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{template "pagination" (dict "Total" .Total "TotalPgs" .TotalPgs "Page" .Page "PrevURL" .PrevURL "NextURL" .NextURL "Size" .Size)}}
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-1">New API key</h2>
    <p class="t-small text-[rgb(var(--muted))] mb-4">Keys belong to your user. Use them to call <code>/api/v1/*</code> via <code>Authorization: Bearer &hellip;</code>.</p>
    <form method="POST" action="/admin/api-keys" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="t-eyebrow block mb-1">Name</label>
        <input name="name" required placeholder="fossbilling-integration" class="r-input w-full">
      </div>
      <div>
        <label class="t-eyebrow block mb-2">Scopes</label>
        <div class="space-y-1.5">
          <label class="flex items-center gap-2 cursor-pointer t-small text-[rgb(var(--text))]">
            <input type="checkbox" name="scope_services" value="1" checked class="rounded cursor-pointer">
            services
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-small text-[rgb(var(--text))]">
            <input type="checkbox" name="scope_routes" value="1" checked class="rounded cursor-pointer">
            routes
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-small text-[rgb(var(--text))]">
            <input type="checkbox" name="scope_nodes" value="1" checked class="rounded cursor-pointer">
            nodes
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-small text-[rgb(var(--text))]">
            <input type="checkbox" name="scope_admin_read" value="1" class="rounded cursor-pointer">
            admin:read
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-small text-[rgb(var(--text))]">
            <input type="checkbox" name="scope_admin_write" value="1" class="rounded cursor-pointer">
            admin:write
          </label>
        </div>
        <p class="t-caption text-[rgb(var(--muted))] mt-1">Reserved for future per-endpoint authorization.</p>
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Expires in (days)</label>
        <input name="expires_days" type="number" min="0" max="3650" value="0" class="r-input w-full tabular-nums">
        <p class="t-caption text-[rgb(var(--muted))] mt-1">0 = never expires. Recommended: 90.</p>
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Rate limit (requests/min)</label>
        <input name="rate_limit_rpm" type="number" min="0" max="100000" value="0" class="r-input w-full tabular-nums">
        <p class="t-caption text-[rgb(var(--muted))] mt-1">0 = no cap. Cap is per user (max across their keys).</p>
      </div>
      <button class="r-btn-primary w-full cursor-pointer">Create key</button>
    </form>
  </section>
</div>

<!-- Save filter modal -->
<div id="ak-save-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="ak-sf-overlay"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="r-card shadow-xl w-full max-w-sm" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between mb-4">
        <h3 class="t-h3">Save filter</h3>
        <button type="button" id="ak-sf-close" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] cursor-pointer">&times;</button>
      </div>
      <form method="POST" action="/admin/saved-filters/api_keys" class="space-y-3 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <input type="hidden" name="query_json" value="{{.QueryValues}}">
        <div>
          <label class="t-eyebrow block mb-1">Filter name</label>
          <input name="filter_name" required placeholder="e.g. Active keys" class="r-input w-full">
        </div>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" id="ak-sf-cancel" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script nonce="{{.CSPNonce}}">
(function(){
  var btn = document.getElementById("ak-save-filter-btn");
  var modal = document.getElementById("ak-save-modal");
  var overlay = document.getElementById("ak-sf-overlay");
  var closeBtn = document.getElementById("ak-sf-close");
  var cancelBtn = document.getElementById("ak-sf-cancel");
  if (!btn || !modal) return;
  function open(){ modal.classList.remove("hidden"); }
  function close(){ modal.classList.add("hidden"); }
  btn.addEventListener("click", open);
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function(e){ if(e.key==="Escape") close(); });
})();
</script>
</div>
{{end}}
