{{define "host_logs"}}
<div class="space-y-4 max-w-7xl">
  <div class="flex items-center justify-between gap-4">
    <div>
      <a href="/admin/hosts/{{.RouteID}}/edit" class="text-xs text-slate-500 hover:text-indigo-600">← edit host</a>
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mt-0.5">
        Access logs
        {{if .Domain}}<span class="text-sm font-normal text-slate-500 dark:text-slate-400 font-mono ml-1">{{.Domain}}</span>{{end}}
      </h2>
    </div>
    <div class="flex items-center gap-2">
      <!-- Live tail toggle -->
      <button id="btn-tail" type="button"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg ring-1 ring-emerald-300 dark:ring-emerald-700 text-emerald-700 dark:text-emerald-400 text-xs font-medium hover:bg-emerald-50 dark:hover:bg-emerald-500/10 cursor-pointer transition-colors">
        <span id="tail-dot" class="w-2 h-2 rounded-full bg-slate-400"></span>
        <span id="tail-label">Start live tail</span>
      </button>
      <a href="/admin/hosts/{{.RouteID}}/logs.json" target="_blank"
        class="px-3 py-1.5 rounded-lg ring-1 ring-slate-200/70 dark:ring-zinc-700 text-xs hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
        JSON
      </a>
      <a href="/admin/hosts/{{.RouteID}}/rollups.csv?window=30d"
        class="px-3 py-1.5 rounded-lg ring-1 ring-slate-200/70 dark:ring-zinc-700 text-xs hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer">
        Rollup CSV
      </a>
      <!-- Export dropdown -->
      <div class="relative" id="export-wrap">
        <button type="button" id="btn-export"
          class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg ring-1 ring-slate-200/70 dark:ring-zinc-700 text-xs hover:bg-slate-50 dark:hover:bg-zinc-800 cursor-pointer transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          Export
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </button>
        <div id="export-menu" class="hidden absolute right-0 mt-1 w-36 rounded-lg shadow-lg ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 z-20 py-1">
          <a id="export-csv" href="#"
            class="block px-3 py-1.5 text-xs text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
            Export CSV
          </a>
          <a id="export-json" href="#"
            class="block px-3 py-1.5 text-xs text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
            Export JSON
          </a>
        </div>
      </div>
    </div>
  </div>

  {{if .Error}}
  <div class="hpg-alert-err text-sm">{{.Error}}</div>
  {{end}}

  <section class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Requests, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{.AnalyticsTotal}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">total</span>
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .StatusBuckets}}
        <span class="hpg-pill {{if eq .Bucket "2xx"}}hpg-pill-ok{{else if eq .Bucket "3xx"}}hpg-pill-warn{{else if or (eq .Bucket "4xx") (eq .Bucket "5xx")}}hpg-pill-err{{else}}hpg-pill-muted{{end}}">
          {{.Bucket}} {{.Count}}
        </span>
        {{else}}
        <span class="hpg-pill hpg-pill-muted">no traffic</span>
        {{end}}
      </div>
    </div>

    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Top paths</p>
      <div class="mt-3 space-y-2">
        {{range .TopPaths}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono text-xs text-slate-700 dark:text-slate-300" title="{{.Path}}">{{.Path}}</span>
          <span class="hpg-pill hpg-pill-muted tabular-nums">{{.Count}}</span>
        </div>
        {{else}}
        <p class="text-xs text-slate-500 dark:text-slate-400">No path data yet.</p>
        {{end}}
      </div>
    </div>

    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Remote IPs</p>
      <div class="mt-3 space-y-2">
        {{range .TopRemoteIPs}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono text-xs text-slate-700 dark:text-slate-300" title="{{.RemoteIP}}">{{.RemoteIP}}</span>
          <span class="hpg-pill hpg-pill-muted tabular-nums">{{.Count}}</span>
        </div>
        {{else}}
        <p class="text-xs text-slate-500 dark:text-slate-400">No IP data yet.</p>
        {{end}}
      </div>
    </div>

    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Traffic trend</p>
      <div class="mt-3 grid grid-cols-6 gap-1.5">
        {{range .TrafficPoints}}
        <div class="rounded-lg bg-slate-50 px-1.5 py-2 text-center ring-1 ring-slate-200/70 dark:bg-zinc-900 dark:ring-zinc-800">
          <div class="font-mono text-[10px] text-slate-400">{{.Start.Format "15:04"}}</div>
          <div class="mt-1 text-xs font-semibold tabular-nums text-slate-800 dark:text-slate-100">{{.Count}}</div>
        </div>
        {{else}}
        <p class="col-span-6 text-xs text-slate-500 dark:text-slate-400">No recent samples.</p>
        {{end}}
      </div>
    </div>
  </section>

  <section class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
    <!-- Transfer summary -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Transfer, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        {{$tb := .BytesSummary.TotalBytes}}
        {{if ge $tb 1073741824}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{printf "%.1f" (divf $tb 1073741824)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">GB</span>
        {{else if ge $tb 1048576}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{printf "%.1f" (divf $tb 1048576)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">MB</span>
        {{else if ge $tb 1024}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{printf "%.1f" (divf $tb 1024)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">KB</span>
        {{else}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{$tb}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">B</span>
        {{end}}
      </div>
      {{if gt .BytesSummary.AvgBytes 0}}
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">avg {{.BytesSummary.AvgBytes}} B/req</p>
      {{end}}
    </div>

    <!-- Bandwidth 7d from rollups -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Bandwidth, 7d</p>
      <div class="mt-2 flex items-baseline gap-2">
        {{$bw := .TotalBandwidth7d}}
        {{if ge $bw 1073741824}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{printf "%.1f" (divf $bw 1073741824)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">GB</span>
        {{else if ge $bw 1048576}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{printf "%.1f" (divf $bw 1048576)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">MB</span>
        {{else if ge $bw 1024}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{printf "%.1f" (divf $bw 1024)}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">KB</span>
        {{else}}
        <span class="text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">{{$bw}}</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">B</span>
        {{end}}
      </div>
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">from rollups</p>
    </div>

    <!-- Protocol breakdown -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Protocol, 24h</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .ProtoBreakdown}}
        <span class="hpg-pill {{if eq .Proto "h2"}}hpg-pill-indigo{{else if eq .Proto "h3"}}hpg-pill-violet{{else}}hpg-pill-muted{{end}}">
          {{.Proto}} {{.Count}}
        </span>
        {{else}}
        <span class="hpg-pill hpg-pill-muted">no data</span>
        {{end}}
      </div>
    </div>

    <!-- Top Methods -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Methods</p>
      <div class="mt-3 space-y-2">
        {{range .TopMethods}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono text-xs font-semibold text-slate-700 dark:text-slate-300">{{.Method}}</span>
          <span class="hpg-pill hpg-pill-muted tabular-nums">{{.Count}}</span>
        </div>
        {{else}}
        <p class="text-xs text-slate-500 dark:text-slate-400">No method data yet.</p>
        {{end}}
      </div>
    </div>

    <!-- Top User Agents -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">User agents</p>
      <div class="mt-3 space-y-2">
        {{range .TopUserAgents}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate text-xs text-slate-700 dark:text-slate-300" title="{{.UserAgent}}">{{.UserAgent}}</span>
          <span class="hpg-pill hpg-pill-muted tabular-nums flex-shrink-0">{{.Count}}</span>
        </div>
        {{else}}
        <p class="text-xs text-slate-500 dark:text-slate-400">No user-agent data yet.</p>
        {{end}}
      </div>
    </div>

    <!-- Top Countries -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Top countries</p>
      <ul class="mt-3 divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .TopCountries}}
        <li class="flex items-center justify-between gap-2 py-1.5">
          <span class="text-sm font-medium {{if .Country}}text-slate-700 dark:text-slate-200{{else}}text-slate-400 dark:text-slate-500{{end}}">
            {{if .Country}}{{.Country}}{{else}}Unknown{{end}}
          </span>
          <span class="text-xs text-slate-500 dark:text-slate-400">{{.Count}}</span>
        </li>
        {{else}}
        <li class="py-1.5 text-xs text-slate-500 dark:text-slate-400">No country data yet.</li>
        {{end}}
      </ul>
    </div>

    <!-- Latency -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Latency (ms)</p>
      {{if gt .Latency.Max 0.0}}
      <div class="mt-3 space-y-2">
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs text-slate-500 dark:text-slate-400">avg</span>
          <span class="font-mono text-xs font-semibold tabular-nums text-slate-800 dark:text-slate-100">{{printf "%.1f" .Latency.Avg}}</span>
        </div>
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs text-slate-500 dark:text-slate-400">p50</span>
          <span class="font-mono text-xs font-semibold tabular-nums text-slate-800 dark:text-slate-100">{{printf "%.1f" .Latency.P50}}</span>
        </div>
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs text-slate-500 dark:text-slate-400">p95</span>
          <span class="font-mono text-xs font-semibold tabular-nums text-slate-800 dark:text-slate-100">{{printf "%.1f" .Latency.P95}}</span>
        </div>
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs text-slate-500 dark:text-slate-400">max</span>
          <span class="font-mono text-xs font-semibold tabular-nums text-rose-600 dark:text-rose-400">{{printf "%.1f" .Latency.Max}}</span>
        </div>
      </div>
      {{else}}
      <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">No latency data yet.</p>
      {{end}}
    </div>

    <!-- Error rate series -->
    <div class="hpg-card">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Error rate, 24h</p>
      <div class="mt-3 grid grid-cols-6 gap-1.5">
        {{range .ErrorRateSeries}}
        <div class="rounded-lg bg-slate-50 px-1.5 py-2 text-center ring-1 ring-slate-200/70 dark:bg-zinc-900 dark:ring-zinc-800 {{if and (gt .TotalCount 0) (gt .ErrorCount 0)}}ring-rose-200 dark:ring-rose-800/50{{end}}">
          <div class="font-mono text-[10px] text-slate-400">{{.Start.Format "15:04"}}</div>
          <div class="mt-1 text-xs font-semibold tabular-nums {{if and (gt .TotalCount 0) (gt .ErrorCount 0)}}text-rose-600 dark:text-rose-400{{else}}text-slate-800 dark:text-slate-100{{end}}">
            {{if gt .TotalCount 0}}{{.ErrorCount}}/{{.TotalCount}}{{else}}-{{end}}
          </div>
        </div>
        {{else}}
        <p class="col-span-6 text-xs text-slate-500 dark:text-slate-400">No recent samples.</p>
        {{end}}
      </div>
    </div>
  </section>

  <!-- Traffic chart section with 24h/7d/30d window toggle -->
  <section class="hpg-card space-y-4" id="traffic-chart-section">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Traffic over time</p>
      <div class="flex gap-1" id="chart-window-btns">
        <button type="button" data-window="24h"
          class="chart-win-btn px-2.5 py-1 rounded-lg text-xs font-medium cursor-pointer transition-colors bg-indigo-600 text-white">24h</button>
        <button type="button" data-window="7d"
          class="chart-win-btn px-2.5 py-1 rounded-lg text-xs font-medium cursor-pointer transition-colors ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800">7d</button>
        <button type="button" data-window="30d"
          class="chart-win-btn px-2.5 py-1 rounded-lg text-xs font-medium cursor-pointer transition-colors ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800">30d</button>
      </div>
    </div>

    <!-- Summary stat cards populated by JS -->
    <div id="chart-summary" class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="rounded-xl ring-1 ring-slate-200/70 dark:ring-zinc-800 bg-slate-50 dark:bg-zinc-900 px-4 py-3">
        <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Requests</p>
        <p id="cs-requests" class="mt-1 text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">-</p>
      </div>
      <div class="rounded-xl ring-1 ring-slate-200/70 dark:ring-zinc-800 bg-slate-50 dark:bg-zinc-900 px-4 py-3">
        <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">4xx errors</p>
        <p id="cs-4xx" class="mt-1 text-2xl font-semibold tabular-nums text-amber-600 dark:text-amber-400">-</p>
      </div>
      <div class="rounded-xl ring-1 ring-slate-200/70 dark:ring-zinc-800 bg-slate-50 dark:bg-zinc-900 px-4 py-3">
        <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">5xx errors</p>
        <p id="cs-5xx" class="mt-1 text-2xl font-semibold tabular-nums text-rose-600 dark:text-rose-400">-</p>
      </div>
      <div class="rounded-xl ring-1 ring-slate-200/70 dark:ring-zinc-800 bg-slate-50 dark:bg-zinc-900 px-4 py-3">
        <p class="text-[11px] uppercase tracking-wide text-slate-500 dark:text-slate-400">Avg / Max latency</p>
        <p id="cs-latency" class="mt-1 text-2xl font-semibold tabular-nums text-slate-900 dark:text-slate-100">-</p>
      </div>
    </div>

    <!-- SVG chart area -->
    <div id="chart-wrap" class="relative overflow-hidden rounded-xl ring-1 ring-slate-200/70 dark:ring-zinc-800 bg-white dark:bg-zinc-900" style="height:180px">
      <svg id="traffic-svg" width="100%" height="100%" preserveAspectRatio="none" style="display:block"></svg>
      <div id="chart-empty" class="hidden absolute inset-0 flex items-center justify-center text-sm text-slate-400 dark:text-slate-500">No traffic data for this window.</div>
      <div id="chart-loading" class="absolute inset-0 flex items-center justify-center text-sm text-slate-400 dark:text-slate-500">Loading…</div>
    </div>
  </section>

  <!-- Filter form -->
  <form method="GET" action="/admin/hosts/{{.RouteID}}/logs"
        id="log-filter-form"
        class="hpg-card flex flex-wrap gap-3 items-end">
    <!-- Status range -->
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">Status min</label>
      <input type="number" name="status_min" min="100" max="599" placeholder="e.g. 400"
        value="{{if .Filter.StatusMin}}{{.Filter.StatusMin}}{{end}}"
        class="w-24 px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 transition-colors">
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">Status max</label>
      <input type="number" name="status_max" min="100" max="599" placeholder="e.g. 499"
        value="{{if .Filter.StatusMax}}{{.Filter.StatusMax}}{{end}}"
        class="w-24 px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 transition-colors">
    </div>
    <!-- Method -->
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">Method</label>
      <select name="method"
        class="px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 cursor-pointer transition-colors">
        <option value="">All</option>
        {{range $m := (slice "GET" "POST" "PUT" "PATCH" "DELETE" "HEAD" "OPTIONS")}}
        <option value="{{$m}}" {{if eq $.Filter.Method $m}}selected{{end}}>{{$m}}</option>
        {{end}}
      </select>
    </div>
    <!-- Remote IP -->
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">Remote IP</label>
      <input type="text" name="remote_ip" placeholder="1.2.3.4"
        value="{{.Filter.RemoteIP}}"
        class="w-32 px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 font-mono transition-colors">
    </div>
    <!-- URI pattern -->
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">URI contains</label>
      <input type="text" name="uri" placeholder="/api/"
        value="{{.Filter.URIPattern}}"
        class="w-36 px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 font-mono transition-colors">
    </div>
    <!-- Date from -->
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">From</label>
      <input type="date" name="from"
        value="{{if not .Filter.From.IsZero}}{{.Filter.From.Format "2006-01-02"}}{{end}}"
        class="px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 transition-colors">
    </div>
    <!-- Date to -->
    <div class="flex flex-col gap-1">
      <label class="text-xs font-medium text-slate-500 dark:text-slate-400">To</label>
      <input type="date" name="to"
        value="{{if not .Filter.To.IsZero}}{{.Filter.To.Format "2006-01-02"}}{{end}}"
        class="px-2 py-1.5 rounded-lg text-xs ring-1 ring-slate-200 dark:ring-zinc-700 bg-white dark:bg-zinc-900 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-indigo-400 transition-colors">
    </div>
    <!-- Actions -->
    <div class="flex items-center gap-2 ml-auto">
      <button type="submit"
        class="px-3 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-medium cursor-pointer transition-colors">
        Filter
      </button>
      <a href="/admin/hosts/{{.RouteID}}/logs"
        class="px-3 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-xs hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
        Clear
      </a>
    </div>
  </form>

  {{if not .Entries}}
  <div class="hpg-card text-sm text-slate-500 dark:text-slate-400 text-center py-12">
    No log entries yet. Entries appear here once Caddy starts forwarding requests.
  </div>
  {{end}}

  <section class="hpg-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="log-table">
        <thead>
          <tr class="border-b border-slate-100 dark:border-zinc-800 text-left">
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs whitespace-nowrap">Time</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Method</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Proto</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Path</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Status</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Latency</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">↓ Resp</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">↑ Req</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Remote IP</th>
            <th class="px-4 py-2.5 font-medium text-slate-500 dark:text-slate-400 text-xs">Country</th>
          </tr>
        </thead>
        <tbody id="log-body" class="divide-y divide-slate-100 dark:divide-zinc-800">
          {{range .Entries}}
          <tr class="hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors">
            <td class="px-4 py-2 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap font-mono">{{.TS.Format "2006-01-02 15:04:05"}}</td>
            <td class="px-4 py-2"><span class="hpg-method-badge text-xs font-mono font-semibold">{{.Method}}</span></td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{if .Proto}}{{.Proto}}{{else}}-{{end}}</td>
            <td class="px-4 py-2 font-mono text-xs text-slate-700 dark:text-slate-300 max-w-xs truncate" title="{{.URI}}">{{.URI}}</td>
            <td class="px-4 py-2">
              <span class="inline-block px-1.5 py-0.5 rounded text-xs font-semibold font-mono
                {{if lt .Status 300}}text-emerald-700 bg-emerald-50 dark:text-emerald-400 dark:bg-emerald-500/10
                {{else if lt .Status 400}}text-amber-700 bg-amber-50 dark:text-amber-400 dark:bg-emerald-500/10
                {{else}}text-rose-700 bg-rose-50 dark:text-rose-400 dark:bg-rose-500/10{{end}}">
                {{.Status}}
              </span>
            </td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{.LatencyMS}}ms</td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{if .BytesResp}}{{formatBytes .BytesResp}}{{else}}-{{end}}</td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{if .BytesReq}}{{formatBytes .BytesReq}}{{else}}-{{end}}</td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{.RemoteIP}}</td>
            <td class="px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400">{{if .Country}}{{.Country}}{{else}}-{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{if .Entries}}
    <div class="px-4 py-2 border-t border-slate-100 dark:border-zinc-800 text-xs text-slate-400">
      Showing {{len .Entries}} entries.
      <a href="?" class="text-indigo-500 hover:underline ml-1">Refresh</a>
    </div>
    {{end}}
  </section>
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  var routeID = {{.RouteID}};
  var btn = document.getElementById('btn-tail');
  var dot = document.getElementById('tail-dot');
  var label = document.getElementById('tail-label');
  var tbody = document.getElementById('log-body');
  var es = null;
  var maxRows = 200;

  function statusClass(s){
    if(s < 300) return 'text-emerald-700 bg-emerald-50 dark:text-emerald-400 dark:bg-emerald-500/10';
    if(s < 400) return 'text-amber-700 bg-amber-50 dark:text-amber-400 dark:bg-amber-500/10';
    return 'text-rose-700 bg-rose-50 dark:text-rose-400 dark:bg-rose-500/10';
  }

  function cell(className, text, title){
    var td = document.createElement('td');
    td.className = className;
    td.textContent = text == null ? '' : String(text);
    if(title) td.title = title;
    return td;
  }

  function prependRow(e){
    var ts = new Date(e.ts).toLocaleString('sv').replace('T',' ');
    var tr = document.createElement('tr');
    tr.className = 'hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors';
    tr.appendChild(cell('px-4 py-2 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap font-mono', ts));

    var methodCell = document.createElement('td');
    methodCell.className = 'px-4 py-2';
    var method = document.createElement('span');
    method.className = 'text-xs font-mono font-semibold';
    method.textContent = e.method || '';
    methodCell.appendChild(method);
    tr.appendChild(methodCell);

    tr.appendChild(cell('px-4 py-2 font-mono text-xs text-slate-700 dark:text-slate-300 max-w-xs truncate', e.uri || '', e.uri || ''));

    var statusCell = document.createElement('td');
    statusCell.className = 'px-4 py-2';
    var status = document.createElement('span');
    status.className = 'inline-block px-1.5 py-0.5 rounded text-xs font-semibold font-mono ' + statusClass(Number(e.status) || 0);
    status.textContent = e.status == null ? '' : String(e.status);
    statusCell.appendChild(status);
    tr.appendChild(statusCell);

    tr.appendChild(cell('px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400', (e.latency_ms || 0) + 'ms'));
    tr.appendChild(cell('px-4 py-2 text-xs font-mono text-slate-500 dark:text-slate-400', e.remote_ip || ''));
    tbody.insertBefore(tr, tbody.firstChild);
    // Trim to maxRows
    while(tbody.rows.length > maxRows) tbody.deleteRow(tbody.rows.length-1);
  }

  function startTail(){
    if(es) return;
    es = new EventSource('/admin/hosts/'+routeID+'/logs/stream');
    es.addEventListener('log', function(ev){
      try{ prependRow(JSON.parse(ev.data)); }catch(e){}
    });
    es.onerror = function(){ stopTail(); };
    dot.classList.replace('bg-slate-400','bg-emerald-500');
    label.textContent = 'Stop live tail';
  }
  function stopTail(){
    if(es){ es.close(); es=null; }
    dot.classList.replace('bg-emerald-500','bg-slate-400');
    label.textContent = 'Start live tail';
  }

  btn.addEventListener('click', function(){ es ? stopTail() : startTail(); });

  // Export dropdown: build URL from current filter form values.
  (function(){
    var wrap = document.getElementById('export-wrap');
    var menu = document.getElementById('export-menu');
    var btnExp = document.getElementById('btn-export');

    function filterParams(){
      var form = document.getElementById('log-filter-form');
      if(!form) return '';
      var p = new URLSearchParams();
      ['status_min','status_max','method','remote_ip','uri','from','to'].forEach(function(n){
        var el = form.elements[n];
        if(el && el.value) p.set(n, el.value);
      });
      return p.toString() ? '&' + p.toString() : '';
    }

    function exportURL(fmt){
      return '/admin/hosts/'+routeID+'/logs/export?format='+fmt+filterParams();
    }

    btnExp.addEventListener('click', function(e){
      e.stopPropagation();
      menu.classList.toggle('hidden');
    });

    document.addEventListener('click', function(){ menu.classList.add('hidden'); });

    document.getElementById('export-csv').addEventListener('click', function(e){
      e.preventDefault();
      window.location.href = exportURL('csv');
      menu.classList.add('hidden');
    });
    document.getElementById('export-json').addEventListener('click', function(e){
      e.preventDefault();
      window.location.href = exportURL('json');
      menu.classList.add('hidden');
    });
  })();
})();
</script>

<script nonce="{{.CSPNonce}}">
(function(){
  var routeID = {{.RouteID}};
  var activeWindow = '24h';

  var elReq = document.getElementById('cs-requests');
  var el4xx = document.getElementById('cs-4xx');
  var el5xx = document.getElementById('cs-5xx');
  var elLat = document.getElementById('cs-latency');
  var svg   = document.getElementById('traffic-svg');
  var wrap  = document.getElementById('chart-wrap');
  var empty = document.getElementById('chart-empty');
  var loading = document.getElementById('chart-loading');

  // Update window-toggle button active state.
  function setActiveBtn(win) {
    document.querySelectorAll('.chart-win-btn').forEach(function(b) {
      var active = b.dataset.window === win;
      b.className = 'chart-win-btn px-2.5 py-1 rounded-lg text-xs font-medium cursor-pointer transition-colors ' +
        (active
          ? 'bg-indigo-600 text-white'
          : 'ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800');
    });
  }

  // Format a number with k/M suffix.
  function fmt(n) {
    if (n >= 1e6) return (n/1e6).toFixed(1) + 'M';
    if (n >= 1e3) return (n/1e3).toFixed(1) + 'k';
    return String(n);
  }

  // Draw a simple SVG polyline bar chart from series data.
  function drawChart(series) {
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    var W = wrap.clientWidth || 600;
    var H = wrap.clientHeight || 180;
    var padL = 4, padR = 4, padT = 12, padB = 24;
    var chartW = W - padL - padR;
    var chartH = H - padT - padB;

    var maxReq = 0;
    series.forEach(function(b){ if (b.requests > maxReq) maxReq = b.requests; });
    if (maxReq === 0) maxReq = 1; // avoid div/0

    var n = series.length;
    var barW = Math.max(2, chartW / n - 1);

    var ns = 'http://www.w3.org/2000/svg';

    // Baseline
    var base = document.createElementNS(ns, 'line');
    base.setAttribute('x1', padL);
    base.setAttribute('y1', padT + chartH);
    base.setAttribute('x2', padL + chartW);
    base.setAttribute('y2', padT + chartH);
    base.setAttribute('stroke', 'currentColor');
    base.setAttribute('stroke-width', '1');
    base.setAttribute('class', 'text-slate-200 dark:text-zinc-700');
    svg.appendChild(base);

    series.forEach(function(b, i) {
      var x = padL + (i / n) * chartW;
      var reqH  = (b.requests / maxReq) * chartH;
      var errH  = ((b.errors_4xx + b.errors_5xx) / maxReq) * chartH;

      // Requests bar (indigo)
      var rBar = document.createElementNS(ns, 'rect');
      rBar.setAttribute('x', x);
      rBar.setAttribute('y', padT + chartH - reqH);
      rBar.setAttribute('width', barW);
      rBar.setAttribute('height', reqH);
      rBar.setAttribute('rx', '2');
      rBar.setAttribute('fill', '#6366f1');
      rBar.setAttribute('opacity', '0.7');
      svg.appendChild(rBar);

      // Error overlay (rose)
      if (errH > 0) {
        var eBar = document.createElementNS(ns, 'rect');
        eBar.setAttribute('x', x);
        eBar.setAttribute('y', padT + chartH - errH);
        eBar.setAttribute('width', barW);
        eBar.setAttribute('height', errH);
        eBar.setAttribute('rx', '2');
        eBar.setAttribute('fill', '#f43f5e');
        eBar.setAttribute('opacity', '0.8');
        svg.appendChild(eBar);
      }

      // Label: first, middle, last bucket time
      if (i === 0 || i === Math.floor(n/2) || i === n-1) {
        var t = document.createElementNS(ns, 'text');
        t.setAttribute('x', x + barW/2);
        t.setAttribute('y', padT + chartH + 16);
        t.setAttribute('text-anchor', 'middle');
        t.setAttribute('font-size', '9');
        t.setAttribute('fill', 'currentColor');
        t.setAttribute('class', 'text-slate-400 dark:text-slate-500');
        // Show date+time for ≥7d windows, just HH:MM for 24h
        var d = new Date(b.bucket_start);
        var label = activeWindow === '24h'
          ? d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})
          : (d.getMonth()+1)+'/'+d.getDate();
        t.textContent = label;
        svg.appendChild(t);
      }
    });
  }

  function load(win) {
    activeWindow = win;
    setActiveBtn(win);
    loading.classList.remove('hidden');
    empty.classList.add('hidden');

    fetch('/admin/hosts/' + routeID + '/rollups.json?window=' + win)
      .then(function(r){ return r.json(); })
      .then(function(data) {
        loading.classList.add('hidden');
        var s = data.summary || {};
        var series = data.series || [];

        // Fill summary cards.
        elReq.textContent = fmt(s.requests || 0);
        el4xx.textContent = fmt(s.errors_4xx || 0);
        el5xx.textContent = fmt(s.errors_5xx || 0);
        var avgLat = (s.requests > 0) ? Math.round(s.latency_sum_ms / s.requests) : 0;
        elLat.textContent = avgLat + ' / ' + (s.latency_max_ms || 0) + ' ms';

        if (series.length === 0) {
          empty.classList.remove('hidden');
          while (svg.firstChild) svg.removeChild(svg.firstChild);
          return;
        }
        drawChart(series);
      })
      .catch(function() {
        loading.classList.add('hidden');
        empty.classList.remove('hidden');
        empty.textContent = 'Failed to load chart data.';
      });
  }

  // Wire up toggle buttons.
  document.querySelectorAll('.chart-win-btn').forEach(function(b) {
    b.addEventListener('click', function(){ load(b.dataset.window); });
  });

  // Load default window on page ready.
  load('24h');
})();
</script>
{{end}}
