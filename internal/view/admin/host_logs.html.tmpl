{{define "host_logs"}}
<div class="space-y-4">
  <div class="flex items-center justify-between gap-4">
    <div>
      <a href="/admin/hosts/{{.RouteID}}/edit" class="t-caption" style="color:rgb(var(--muted))">
        <svg class="inline h-3 w-3 mr-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        edit host
      </a>
      <h2 class="t-h2 mt-0.5">
        Access logs
        {{if .Domain}}<span class="t-small font-normal font-mono ml-1" style="color:rgb(var(--muted))">{{.Domain}}</span>{{end}}
      </h2>
    </div>
    <div class="flex items-center gap-2">
      <!-- Live tail toggle -->
      <button id="btn-tail" type="button"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg t-caption font-medium cursor-pointer transition-colors"
        style="border:1px solid rgb(var(--success)/.40);color:rgb(var(--success))">
        <span id="tail-dot" class="w-2 h-2 rounded-full" style="background:rgb(var(--muted))"></span>
        <span id="tail-label">Start live tail</span>
      </button>
      <a href="/admin/hosts/{{.RouteID}}/logs.json" target="_blank" class="r-btn-ghost px-3 py-1.5 t-caption">
        <svg class="inline h-3.5 w-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        JSON
      </a>
      <a href="/admin/hosts/{{.RouteID}}/rollups.csv?window=30d" class="r-btn-ghost px-3 py-1.5 t-caption cursor-pointer">
        <svg class="inline h-3.5 w-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Rollup CSV
      </a>
      <!-- Export dropdown -->
      <div class="relative" id="export-wrap">
        <button type="button" id="btn-export"
          class="r-btn-secondary inline-flex items-center gap-1 px-3 py-1.5 t-caption cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          Export
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </button>
        <div id="export-menu" class="hidden absolute right-0 mt-1 w-36 rounded-xl z-20 py-1 overflow-hidden"
          style="background:rgb(var(--surface));border:1px solid rgb(var(--border));box-shadow:0 4px 16px rgba(0,0,0,.12)">
          <a id="export-csv" href="#"
            class="block px-3 py-1.5 t-small transition-colors cursor-pointer hover:opacity-80">
            Export CSV
          </a>
          <a id="export-json" href="#"
            class="block px-3 py-1.5 t-small transition-colors cursor-pointer hover:opacity-80">
            Export JSON
          </a>
        </div>
      </div>
    </div>
  </div>

  {{if .Error}}
  <div class="r-card t-small" style="background:rgb(var(--danger)/.10);border-color:rgb(var(--danger)/.30);color:rgb(var(--danger))">{{.Error}}</div>
  {{end}}

  <section class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
    <div class="r-card">
      <p class="t-eyebrow">Requests, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        <span class="t-display tabular-nums">{{.AnalyticsTotal}}</span>
        <span class="t-caption">total</span>
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .StatusBuckets}}
        <span class="r-pill {{if eq .Bucket "2xx"}}r-pill-success{{else if eq .Bucket "3xx"}}r-pill-info{{else if eq .Bucket "4xx"}}r-pill-warning{{else if eq .Bucket "5xx"}}r-pill-danger{{else}}r-pill-neutral{{end}} tabular-nums">
          {{.Bucket}} {{.Count}}
        </span>
        {{else}}
        <span class="r-pill r-pill-neutral">no traffic</span>
        {{end}}
      </div>
    </div>

    <div class="r-card">
      <p class="t-eyebrow">Top paths</p>
      <div class="mt-3 space-y-2">
        {{range .TopPaths}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono t-caption" title="{{.Path}}">{{.Path}}</span>
          <span class="r-pill r-pill-neutral tabular-nums">{{.Count}}</span>
        </div>
        {{else}}
        <p class="t-caption">No path data yet.</p>
        {{end}}
      </div>
    </div>

    <div class="r-card">
      <p class="t-eyebrow">Remote IPs</p>
      <div class="mt-3 space-y-2">
        {{range .TopRemoteIPs}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono t-caption" title="{{.RemoteIP}}">{{.RemoteIP}}</span>
          <span class="r-pill r-pill-neutral tabular-nums">{{.Count}}</span>
        </div>
        {{else}}
        <p class="t-caption">No IP data yet.</p>
        {{end}}
      </div>
    </div>

    <div class="r-card">
      <p class="t-eyebrow">Traffic trend</p>
      <div class="mt-3 grid grid-cols-6 gap-1.5">
        {{range .TrafficPoints}}
        <div class="rounded-lg px-1.5 py-2 text-center" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
          <div class="font-mono t-caption">{{.Start.Format "15:04"}}</div>
          <div class="mt-1 t-small font-semibold tabular-nums">{{.Count}}</div>
        </div>
        {{else}}
        <p class="col-span-6 t-caption">No recent samples.</p>
        {{end}}
      </div>
    </div>
  </section>

  <section class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
    <!-- Transfer summary -->
    <div class="r-card">
      <p class="t-eyebrow">Transfer, 24h</p>
      <div class="mt-2 flex items-baseline gap-2">
        {{$tb := .BytesSummary.TotalBytes}}
        {{if ge $tb 1073741824}}
        <span class="t-display tabular-nums">{{printf "%.1f" (divf $tb 1073741824)}}</span>
        <span class="t-caption">GB</span>
        {{else if ge $tb 1048576}}
        <span class="t-display tabular-nums">{{printf "%.1f" (divf $tb 1048576)}}</span>
        <span class="t-caption">MB</span>
        {{else if ge $tb 1024}}
        <span class="t-display tabular-nums">{{printf "%.1f" (divf $tb 1024)}}</span>
        <span class="t-caption">KB</span>
        {{else}}
        <span class="t-display tabular-nums">{{$tb}}</span>
        <span class="t-caption">B</span>
        {{end}}
      </div>
      {{if gt .BytesSummary.AvgBytes 0}}
      <p class="mt-1 t-caption">avg {{formatBytes .BytesSummary.AvgBytes}}/req</p>
      {{end}}
      {{if gt .BytesSummary.TotalBytesReq 0}}
      <p class="mt-0.5 t-caption">&#8593; {{formatBytes .BytesSummary.TotalBytesReq}} upload</p>
      {{end}}
    </div>

    <!-- Bandwidth 7d from rollups -->
    <div class="r-card">
      <p class="t-eyebrow">Bandwidth, 7d</p>
      <div class="mt-2 flex items-baseline gap-2">
        {{$bw := .TotalBandwidth7d}}
        {{if ge $bw 1073741824}}
        <span class="t-display tabular-nums">{{printf "%.1f" (divf $bw 1073741824)}}</span>
        <span class="t-caption">GB</span>
        {{else if ge $bw 1048576}}
        <span class="t-display tabular-nums">{{printf "%.1f" (divf $bw 1048576)}}</span>
        <span class="t-caption">MB</span>
        {{else if ge $bw 1024}}
        <span class="t-display tabular-nums">{{printf "%.1f" (divf $bw 1024)}}</span>
        <span class="t-caption">KB</span>
        {{else}}
        <span class="t-display tabular-nums">{{$bw}}</span>
        <span class="t-caption">B</span>
        {{end}}
      </div>
      <p class="mt-1 t-caption">from rollups</p>
    </div>

    <!-- Protocol breakdown -->
    <div class="r-card">
      <p class="t-eyebrow">Protocol, 24h</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {{range .ProtoBreakdown}}
        <span class="r-pill {{if eq .Proto "h2"}}r-pill-info{{else if eq .Proto "h3"}}r-pill-info{{else}}r-pill-neutral{{end}} tabular-nums">
          {{.Proto}} {{.Count}}
        </span>
        {{else}}
        <span class="r-pill r-pill-neutral">no data</span>
        {{end}}
      </div>
    </div>

    <!-- Top Methods -->
    <div class="r-card">
      <p class="t-eyebrow">Methods</p>
      <div class="mt-3 space-y-2">
        {{range .TopMethods}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate font-mono t-caption font-semibold">{{.Method}}</span>
          <span class="r-pill r-pill-neutral tabular-nums">{{.Count}}</span>
        </div>
        {{else}}
        <p class="t-caption">No method data yet.</p>
        {{end}}
      </div>
    </div>

    <!-- Top User Agents -->
    <div class="r-card">
      <p class="t-eyebrow">User agents</p>
      <div class="mt-3 space-y-2">
        {{range .TopUserAgents}}
        <div class="flex items-center justify-between gap-3">
          <span class="min-w-0 truncate t-caption" title="{{.UserAgent}}">{{.UserAgent}}</span>
          <span class="r-pill r-pill-neutral tabular-nums flex-shrink-0">{{.Count}}</span>
        </div>
        {{else}}
        <p class="t-caption">No user-agent data yet.</p>
        {{end}}
      </div>
    </div>

    <!-- Top Countries -->
    <div class="r-card">
      <p class="t-eyebrow">Top countries</p>
      <ul class="mt-3 divide-y" style="border-color:rgb(var(--border))">
        {{range .TopCountries}}
        <li class="flex items-center justify-between gap-2 py-1.5">
          <span class="t-small font-medium {{if not .Country}}opacity-50{{end}}">
            {{if .Country}}{{.Country}}{{else}}Unknown{{end}}
          </span>
          <span class="t-caption tabular-nums">{{.Count}}</span>
        </li>
        {{else}}
        <li class="py-1.5 t-caption">No country data yet.</li>
        {{end}}
      </ul>
    </div>

    <!-- Top ASNs -->
    <div class="r-card">
      <p class="t-eyebrow">Top ASNs</p>
      <ul class="mt-3 divide-y" style="border-color:rgb(var(--border))">
        {{range .TopASNOrgs}}
        <li class="flex items-center justify-between gap-2 py-1.5">
          <span class="t-small font-medium truncate min-w-0" title="{{.Org}}">{{.Org}}</span>
          <span class="t-caption tabular-nums shrink-0">{{.Count}}</span>
        </li>
        {{else}}
        <li class="py-1.5 t-caption">No ASN data yet.</li>
        {{end}}
      </ul>
    </div>

    <!-- Latency -->
    <div class="r-card">
      <p class="t-eyebrow">Latency (ms)</p>
      {{if gt .Latency.Max 0.0}}
      <div class="mt-3 space-y-2">
        <div class="flex items-center justify-between gap-3">
          <span class="t-caption">avg</span>
          <span class="font-mono t-caption font-semibold tabular-nums">{{printf "%.1f" .Latency.Avg}}</span>
        </div>
        <div class="flex items-center justify-between gap-3">
          <span class="t-caption">p50</span>
          <span class="font-mono t-caption font-semibold tabular-nums">{{printf "%.1f" .Latency.P50}}</span>
        </div>
        <div class="flex items-center justify-between gap-3">
          <span class="t-caption">p95</span>
          <span class="font-mono t-caption font-semibold tabular-nums">{{printf "%.1f" .Latency.P95}}</span>
        </div>
        <div class="flex items-center justify-between gap-3">
          <span class="t-caption">max</span>
          <span class="font-mono t-caption font-semibold tabular-nums" style="color:rgb(var(--danger))">{{printf "%.1f" .Latency.Max}}</span>
        </div>
      </div>
      {{else}}
      <p class="mt-3 t-caption">No latency data yet.</p>
      {{end}}
    </div>

    <!-- Error rate series -->
    <div class="r-card">
      <p class="t-eyebrow">Error rate, 24h</p>
      <div class="mt-3 grid grid-cols-6 gap-1.5">
        {{range .ErrorRateSeries}}
        <div class="rounded-lg px-1.5 py-2 text-center {{if and (gt .TotalCount 0) (gt .ErrorCount 0)}}ring-1{{end}}"
          style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border));{{if and (gt .TotalCount 0) (gt .ErrorCount 0)}}border-color:rgb(var(--danger)/.35){{end}}">
          <div class="font-mono t-caption">{{.Start.Format "15:04"}}</div>
          <div class="mt-1 t-caption font-semibold tabular-nums {{if and (gt .TotalCount 0) (gt .ErrorCount 0)}}text-danger{{end}}"
            style="{{if and (gt .TotalCount 0) (gt .ErrorCount 0)}}color:rgb(var(--danger)){{end}}">
            {{if gt .TotalCount 0}}{{.ErrorCount}}/{{.TotalCount}}{{else}}-{{end}}
          </div>
        </div>
        {{else}}
        <p class="col-span-6 t-caption">No recent samples.</p>
        {{end}}
      </div>
    </div>
  </section>

  <!-- Traffic chart section with 24h/7d/30d window toggle -->
  <section class="r-card space-y-4" id="traffic-chart-section">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="t-eyebrow">Traffic over time</p>
      <div class="r-segment" id="chart-window-btns">
        <button type="button" data-window="24h" class="r-segment-item chart-win-btn cursor-pointer is-active">24h</button>
        <button type="button" data-window="7d" class="r-segment-item chart-win-btn cursor-pointer">7d</button>
        <button type="button" data-window="30d" class="r-segment-item chart-win-btn cursor-pointer">30d</button>
      </div>
    </div>

    <!-- Summary stat cards populated by JS -->
    <div id="chart-summary" class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="rounded-xl px-4 py-3" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
        <p class="t-eyebrow">Requests</p>
        <p id="cs-requests" class="mt-1 t-display tabular-nums">-</p>
      </div>
      <div class="rounded-xl px-4 py-3" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
        <p class="t-eyebrow">4xx errors</p>
        <p id="cs-4xx" class="mt-1 t-display tabular-nums" style="color:rgb(var(--warning))">-</p>
      </div>
      <div class="rounded-xl px-4 py-3" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
        <p class="t-eyebrow">5xx errors</p>
        <p id="cs-5xx" class="mt-1 t-display tabular-nums" style="color:rgb(var(--danger))">-</p>
      </div>
      <div class="rounded-xl px-4 py-3" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
        <p class="t-eyebrow">Avg / Max latency</p>
        <p id="cs-latency" class="mt-1 t-display tabular-nums">-</p>
      </div>
    </div>

    <!-- SVG chart area -->
    <div id="chart-wrap" class="relative overflow-hidden rounded-xl" style="height:180px;background:rgb(var(--surface));border:1px solid rgb(var(--border))">
      <svg id="traffic-svg" width="100%" height="100%" preserveAspectRatio="none" style="display:block"></svg>
      <div id="chart-empty" class="hidden absolute inset-0 flex items-center justify-center t-small" style="color:rgb(var(--muted))">No traffic data for this window.</div>
      <div id="chart-loading" class="absolute inset-0 flex items-center justify-center t-small" style="color:rgb(var(--muted))">Loading...</div>
    </div>
  </section>

  <!-- Filter form -->
  <form method="GET" action="/admin/hosts/{{.RouteID}}/logs"
        id="log-filter-form"
        class="r-card flex flex-wrap gap-3 items-end">
    <!-- Status range -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">Status min</label>
      <input type="number" name="status_min" min="100" max="599" placeholder="e.g. 400"
        value="{{if .Filter.StatusMin}}{{.Filter.StatusMin}}{{end}}"
        class="r-input w-24 font-mono tabular-nums">
    </div>
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">Status max</label>
      <input type="number" name="status_max" min="100" max="599" placeholder="e.g. 499"
        value="{{if .Filter.StatusMax}}{{.Filter.StatusMax}}{{end}}"
        class="r-input w-24 font-mono tabular-nums">
    </div>
    <!-- Method -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">Method</label>
      <select name="method" class="r-select cursor-pointer">
        <option value="">All</option>
        {{range $m := (slice "GET" "POST" "PUT" "PATCH" "DELETE" "HEAD" "OPTIONS")}}
        <option value="{{$m}}" {{if eq $.Filter.Method $m}}selected{{end}}>{{$m}}</option>
        {{end}}
      </select>
    </div>
    <!-- Remote IP -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">Remote IP</label>
      <input type="text" name="remote_ip" placeholder="1.2.3.4"
        value="{{.Filter.RemoteIP}}"
        class="r-input w-32 font-mono">
    </div>
    <!-- URI pattern -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">URI contains</label>
      <input type="text" name="uri" placeholder="/api/"
        value="{{.Filter.URIPattern}}"
        class="r-input w-36 font-mono">
    </div>
    <!-- Country -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">Country (ISO2)</label>
      <input type="text" name="country" maxlength="2" placeholder="e.g. US"
        value="{{.Filter.Country}}"
        class="r-input w-20 uppercase font-mono">
    </div>
    <!-- ASN org -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">ASN org</label>
      <input type="text" name="asn_org" maxlength="128" placeholder="e.g. Google"
        value="{{.Filter.ASNOrg}}"
        class="r-input w-32">
    </div>
    <!-- Date from -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">From</label>
      <input type="date" name="from"
        value="{{if not .Filter.From.IsZero}}{{.Filter.From.Format "2006-01-02"}}{{end}}"
        class="r-input">
    </div>
    <!-- Date to -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">To</label>
      <input type="date" name="to"
        value="{{if not .Filter.To.IsZero}}{{.Filter.To.Format "2006-01-02"}}{{end}}"
        class="r-input">
    </div>
    <!-- Sort -->
    <div class="flex flex-col gap-1">
      <label class="t-caption font-medium">Sort</label>
      <select name="sort" class="r-select cursor-pointer">
        <option value=""            {{if eq .Sort ""}}selected{{end}}>Newest first</option>
        <option value="status_desc" {{if eq .Sort "status_desc"}}selected{{end}}>Errors first (status &#8595;)</option>
        <option value="status_asc"  {{if eq .Sort "status_asc"}}selected{{end}}>Status &#8593;</option>
      </select>
    </div>
    <!-- Actions -->
    <div class="flex items-center gap-2 ml-auto">
      <button type="submit" class="r-btn-primary px-3 py-1.5 t-caption cursor-pointer">
        <svg class="inline h-3.5 w-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        Filter
      </button>
      <a href="/admin/hosts/{{.RouteID}}/logs" class="r-btn-ghost px-3 py-1.5 t-caption">
        Clear
      </a>
    </div>
  </form>

  {{if not .Entries}}
  <div class="r-card text-center py-12">
    <p class="t-small" style="color:rgb(var(--muted))">No log entries yet. Entries appear here once Caddy starts forwarding requests.</p>
  </div>
  {{end}}

  <section class="r-card !p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="r-table w-full" id="log-table">
        <thead>
          <tr>
            <th class="whitespace-nowrap">Time</th>
            <th>Method</th>
            <th>Proto</th>
            <th>Path</th>
            <th>Status</th>
            <th>Latency</th>
            <th>&#8595; Resp</th>
            <th>&#8593; Req</th>
            <th>Remote IP</th>
            <th>Country</th>
          </tr>
        </thead>
        <tbody id="log-body">
          {{range .Entries}}
          <tr>
            <td class="whitespace-nowrap font-mono tabular-nums t-caption">{{.TS.Format "2006-01-02 15:04:05"}}</td>
            <td><span class="font-mono t-caption font-semibold">{{.Method}}</span></td>
            <td class="font-mono t-caption tabular-nums">{{if .Proto}}{{.Proto}}{{else}}-{{end}}</td>
            <td class="font-mono t-caption max-w-xs truncate" title="{{.URI}}">{{.URI}}</td>
            <td>
              <span class="r-pill font-mono tabular-nums
                {{if lt .Status 300}}r-pill-success
                {{else if lt .Status 400}}r-pill-info
                {{else if lt .Status 500}}r-pill-warning
                {{else}}r-pill-danger{{end}}">
                {{.Status}}
              </span>
            </td>
            <td class="font-mono t-caption tabular-nums">{{.LatencyMS}}ms</td>
            <td class="font-mono t-caption tabular-nums">{{if .BytesResp}}{{formatBytes .BytesResp}}{{else}}-{{end}}</td>
            <td class="font-mono t-caption tabular-nums">{{if .BytesReq}}{{formatBytes .BytesReq}}{{else}}-{{end}}</td>
            <td class="font-mono t-caption">{{.RemoteIP}}</td>
            <td class="font-mono t-caption">{{if .Country}}{{.Country}}{{else}}-{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    <div class="px-4 py-2" style="border-top:1px solid rgb(var(--border))">
      {{template "pagination" (dict "Total" .TotalRows "TotalPgs" .TotalPages "Page" .Page "PrevURL" .PrevURL "NextURL" .NextURL "Size" .PageSize)}}
    </div>
  </section>
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  var routeID = {{.RouteID}};
  var btn = document.getElementById('btn-tail');
  var dot = document.getElementById('tail-dot');
  var label = document.getElementById('tail-label');
  var tbody = document.getElementById('log-body');
  var es = null;
  var maxRows = 200;

  function statusPillClass(s){
    if(s < 300) return 'r-pill r-pill-success';
    if(s < 400) return 'r-pill r-pill-info';
    if(s < 500) return 'r-pill r-pill-warning';
    return 'r-pill r-pill-danger';
  }

  function cell(className, text, title){
    var td = document.createElement('td');
    td.className = className;
    td.textContent = text == null ? '' : String(text);
    if(title) td.title = title;
    return td;
  }

  function prependRow(e){
    var ts = new Date(e.ts).toLocaleString('sv').replace('T',' ');
    var tr = document.createElement('tr');

    tr.appendChild(cell('whitespace-nowrap font-mono tabular-nums t-caption', ts));

    var methodCell = document.createElement('td');
    var method = document.createElement('span');
    method.className = 'font-mono t-caption font-semibold';
    method.textContent = e.method || '';
    methodCell.appendChild(method);
    tr.appendChild(methodCell);

    tr.appendChild(cell('font-mono t-caption max-w-xs truncate', e.uri || '', e.uri || ''));

    var statusCell = document.createElement('td');
    var status = document.createElement('span');
    status.className = statusPillClass(Number(e.status) || 0) + ' font-mono tabular-nums';
    status.textContent = e.status == null ? '' : String(e.status);
    statusCell.appendChild(status);
    tr.appendChild(statusCell);

    tr.appendChild(cell('font-mono t-caption tabular-nums', (e.latency_ms || 0) + 'ms'));
    tr.appendChild(cell('font-mono t-caption', e.remote_ip || ''));
    tbody.insertBefore(tr, tbody.firstChild);
    // Trim to maxRows
    while(tbody.rows.length > maxRows) tbody.deleteRow(tbody.rows.length-1);
  }

  function startTail(){
    if(es) return;
    es = new EventSource('/admin/hosts/'+routeID+'/logs/stream');
    es.addEventListener('log', function(ev){
      try{ prependRow(JSON.parse(ev.data)); }catch(e){}
    });
    es.onerror = function(){ stopTail(); };
    dot.style.background = 'rgb(var(--success))';
    label.textContent = 'Stop live tail';
  }
  function stopTail(){
    if(es){ es.close(); es=null; }
    dot.style.background = 'rgb(var(--muted))';
    label.textContent = 'Start live tail';
  }

  btn.addEventListener('click', function(){ es ? stopTail() : startTail(); });

  // Export dropdown: build URL from current filter form values.
  (function(){
    var wrap = document.getElementById('export-wrap');
    var menu = document.getElementById('export-menu');
    var btnExp = document.getElementById('btn-export');

    function filterParams(){
      var form = document.getElementById('log-filter-form');
      if(!form) return '';
      var p = new URLSearchParams();
      ['status_min','status_max','method','remote_ip','uri','country','asn_org','from','to'].forEach(function(n){
        var el = form.elements[n];
        if(el && el.value) p.set(n, el.value);
      });
      return p.toString() ? '&' + p.toString() : '';
    }

    function exportURL(fmt){
      return '/admin/hosts/'+routeID+'/logs/export?format='+fmt+filterParams();
    }

    btnExp.addEventListener('click', function(e){
      e.stopPropagation();
      menu.classList.toggle('hidden');
    });

    document.addEventListener('click', function(){ menu.classList.add('hidden'); });

    document.getElementById('export-csv').addEventListener('click', function(e){
      e.preventDefault();
      window.location.href = exportURL('csv');
      menu.classList.add('hidden');
    });
    document.getElementById('export-json').addEventListener('click', function(e){
      e.preventDefault();
      window.location.href = exportURL('json');
      menu.classList.add('hidden');
    });
  })();
})();
</script>

<script nonce="{{.CSPNonce}}">
(function(){
  var routeID = {{.RouteID}};
  var activeWindow = '24h';

  var elReq = document.getElementById('cs-requests');
  var el4xx = document.getElementById('cs-4xx');
  var el5xx = document.getElementById('cs-5xx');
  var elLat = document.getElementById('cs-latency');
  var svg   = document.getElementById('traffic-svg');
  var wrap  = document.getElementById('chart-wrap');
  var empty = document.getElementById('chart-empty');
  var loading = document.getElementById('chart-loading');

  // Update window-toggle button active state.
  function setActiveBtn(win) {
    document.querySelectorAll('.chart-win-btn').forEach(function(b) {
      var active = b.dataset.window === win;
      b.classList.toggle('is-active', active);
    });
  }

  // Format a number with k/M suffix.
  function fmt(n) {
    if (n >= 1e6) return (n/1e6).toFixed(1) + 'M';
    if (n >= 1e3) return (n/1e3).toFixed(1) + 'k';
    return String(n);
  }

  // Draw a simple SVG polyline bar chart from series data.
  function drawChart(series) {
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    var W = wrap.clientWidth || 600;
    var H = wrap.clientHeight || 180;
    var padL = 4, padR = 4, padT = 12, padB = 24;
    var chartW = W - padL - padR;
    var chartH = H - padT - padB;

    var maxReq = 0;
    series.forEach(function(b){ if (b.requests > maxReq) maxReq = b.requests; });
    if (maxReq === 0) maxReq = 1; // avoid div/0

    var n = series.length;
    var barW = Math.max(2, chartW / n - 1);

    var ns = 'http://www.w3.org/2000/svg';

    // Baseline
    var base = document.createElementNS(ns, 'line');
    base.setAttribute('x1', padL);
    base.setAttribute('y1', padT + chartH);
    base.setAttribute('x2', padL + chartW);
    base.setAttribute('y2', padT + chartH);
    base.setAttribute('stroke', 'currentColor');
    base.setAttribute('stroke-width', '1');
    base.setAttribute('class', 'text-slate-200 dark:text-zinc-700');
    svg.appendChild(base);

    series.forEach(function(b, i) {
      var x = padL + (i / n) * chartW;
      var reqH  = (b.requests / maxReq) * chartH;
      var errH  = ((b.errors_4xx + b.errors_5xx) / maxReq) * chartH;

      // Requests bar (accent)
      var rBar = document.createElementNS(ns, 'rect');
      rBar.setAttribute('x', x);
      rBar.setAttribute('y', padT + chartH - reqH);
      rBar.setAttribute('width', barW);
      rBar.setAttribute('height', reqH);
      rBar.setAttribute('rx', '2');
      rBar.setAttribute('fill', 'rgb(var(--accent))');
      rBar.setAttribute('opacity', '0.7');
      svg.appendChild(rBar);

      // Error overlay (danger)
      if (errH > 0) {
        var eBar = document.createElementNS(ns, 'rect');
        eBar.setAttribute('x', x);
        eBar.setAttribute('y', padT + chartH - errH);
        eBar.setAttribute('width', barW);
        eBar.setAttribute('height', errH);
        eBar.setAttribute('rx', '2');
        eBar.setAttribute('fill', 'rgb(var(--danger))');
        eBar.setAttribute('opacity', '0.8');
        svg.appendChild(eBar);
      }

      // Label: first, middle, last bucket time
      if (i === 0 || i === Math.floor(n/2) || i === n-1) {
        var t = document.createElementNS(ns, 'text');
        t.setAttribute('x', x + barW/2);
        t.setAttribute('y', padT + chartH + 16);
        t.setAttribute('text-anchor', 'middle');
        t.setAttribute('font-size', '9');
        t.setAttribute('fill', 'currentColor');
        t.setAttribute('class', 'text-slate-400 dark:text-slate-500');
        // Show date+time for >=7d windows, just HH:MM for 24h
        var d = new Date(b.bucket_start);
        var lbl = activeWindow === '24h'
          ? d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})
          : (d.getMonth()+1)+'/'+d.getDate();
        t.textContent = lbl;
        svg.appendChild(t);
      }
    });
  }

  function load(win) {
    activeWindow = win;
    setActiveBtn(win);
    loading.classList.remove('hidden');
    empty.classList.add('hidden');

    fetch('/admin/hosts/' + routeID + '/rollups.json?window=' + win)
      .then(function(r){ return r.json(); })
      .then(function(data) {
        loading.classList.add('hidden');
        var s = data.summary || {};
        var series = data.series || [];

        // Fill summary cards.
        elReq.textContent = fmt(s.requests || 0);
        el4xx.textContent = fmt(s.errors_4xx || 0);
        el5xx.textContent = fmt(s.errors_5xx || 0);
        var avgLat = (s.requests > 0) ? Math.round(s.latency_sum_ms / s.requests) : 0;
        elLat.textContent = avgLat + ' / ' + (s.latency_max_ms || 0) + ' ms';

        if (series.length === 0) {
          empty.classList.remove('hidden');
          while (svg.firstChild) svg.removeChild(svg.firstChild);
          return;
        }
        drawChart(series);
      })
      .catch(function() {
        loading.classList.add('hidden');
        empty.classList.remove('hidden');
        empty.textContent = 'Failed to load chart data.';
      });
  }

  // Wire up toggle buttons.
  document.querySelectorAll('.chart-win-btn').forEach(function(b) {
    b.addEventListener('click', function(){ load(b.dataset.window); });
  });

  // Load default window on page ready.
  load('24h');
})();
</script>
{{end}}
