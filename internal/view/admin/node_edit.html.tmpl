{{define "node_edit"}}
<div class="space-y-6 max-w-2xl">
  <div>
    <a href="/admin/nodes" class="text-xs text-slate-500 hover:text-indigo-600">← all nodes</a>
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mt-1">Edit node: {{.Name}}</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{{.PublicHostname}}{{if .PublicIP}} &middot; {{.PublicIP}}{{end}}</p>
  </div>

  {{if .Error}}<p class="text-sm text-rose-600">{{.Error}}</p>{{end}}

  <section class="hpg-card space-y-4">
    <h3 class="hpg-eyebrow">Outbound IP inventory</h3>
    <p class="text-[11px] text-slate-500 dark:text-slate-400">
      List of source IPs available on this node's NICs. One IP per line. Used when a
      route's egress mode is set to "fixed" (dropdown) or "random" (picked deterministically per route).
      Leave empty if this node has only one egress IP.
    </p>
    <form method="POST" action="/admin/nodes/{{.NodeID}}/edit" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Outbound IPs</label>
        <textarea name="outbound_ips" rows="6"
          placeholder="203.0.113.1&#10;203.0.113.2&#10;2001:db8::1"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono text-xs">{{.OutboundIPs}}</textarea>
        <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Bare IPv4 or IPv6 addresses only, one per line. Caddy rejects /load if an address is not on the NIC.</p>
      </div>
      <!-- Module capabilities: which custom Caddy modules are present on this node -->
      <fieldset class="space-y-3 border-t border-slate-100 dark:border-zinc-700 pt-4">
        <legend class="text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wide mb-2">Module capabilities</legend>
        <p class="text-[11px] text-slate-500 dark:text-slate-400 -mt-1">Which custom Caddy modules are installed on this node</p>
        <div class="flex items-center gap-2 mb-1">
          <button type="button" id="btn-probe" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg ring-1 ring-indigo-300 dark:ring-indigo-700 text-indigo-700 dark:text-indigo-400 text-xs font-medium hover:bg-indigo-50 dark:hover:bg-indigo-500/10 cursor-pointer transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
              <path fill-rule="evenodd" d="M2 10a8 8 0 1 1 16 0 8 8 0 0 1-16 0Zm6.39-2.908a.75.75 0 0 1 .766.027l3.5 2.25a.75.75 0 0 1 0 1.262l-3.5 2.25A.75.75 0 0 1 8 12.25v-4.5a.75.75 0 0 1 .39-.658Z" clip-rule="evenodd" />
            </svg>
            Auto-detect from Caddy
          </button>
          <span id="probe-status" class="text-xs text-slate-500"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-700 dark:text-slate-300">
            <input type="checkbox" name="has_waf" value="1" {{if .HasWAF}}checked{{end}}
              class="rounded border-slate-300 dark:border-zinc-600 text-indigo-600 focus:ring-indigo-500">
            WAF (Coraza)
          </label>
          <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-700 dark:text-slate-300">
            <input type="checkbox" name="has_l4" value="1" {{if .HasL4}}checked{{end}}
              class="rounded border-slate-300 dark:border-zinc-600 text-indigo-600 focus:ring-indigo-500">
            L4 Streams
          </label>
          <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-700 dark:text-slate-300">
            <input type="checkbox" name="has_dns_module" value="1" {{if .HasDNSModule}}checked{{end}}
              class="rounded border-slate-300 dark:border-zinc-600 text-indigo-600 focus:ring-indigo-500">
            DNS-01 (cert challenges)
          </label>
          <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-700 dark:text-slate-300">
            <input type="checkbox" name="has_rate_limit" value="1" {{if .HasRateLimit}}checked{{end}}
              class="rounded border-slate-300 dark:border-zinc-600 text-indigo-600 focus:ring-indigo-500">
            Rate limit
          </label>
          <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-700 dark:text-slate-300">
            <input type="checkbox" name="has_geoip" value="1" {{if .HasGeoIP}}checked{{end}}
              class="rounded border-slate-300 dark:border-zinc-600 text-indigo-600 focus:ring-indigo-500">
            GeoIP
          </label>
        </div>
        <div class="pt-1">
          <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Caddy version</label>
          <input type="text" name="caddy_version" value="{{.CaddyVersion}}" placeholder="e.g. 2.8.4"
            class="w-48 px-3 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono text-xs">
        </div>
      </fieldset>

      <div class="flex items-center justify-end gap-3 pt-1">
        <a href="/admin/nodes" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 cursor-pointer">Cancel</a>
        <button type="submit"
          class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors cursor-pointer">Save</button>
      </div>
    </form>
  </section>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  document.addEventListener('click', function (e) {
    if (e.target.closest('#btn-probe') === null) return;
    var btn = document.getElementById('btn-probe');
    var status = document.getElementById('probe-status');
    btn.disabled = true;
    status.textContent = 'Detecting...';
    status.className = 'text-xs text-slate-500';
    fetch('/admin/nodes/{{.NodeID}}/probe-capabilities', {method: 'POST'})
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) {
          status.textContent = 'Error: ' + data.error;
          status.className = 'text-xs text-rose-600';
          return;
        }
        // Update checkboxes from detected capabilities.
        var map = {has_waf: data.has_waf, has_l4: data.has_l4, has_dns_module: data.has_dns, has_rate_limit: data.has_rate_limit, has_geoip: data.has_geoip};
        Object.keys(map).forEach(function (name) {
          var el = document.querySelector('input[name="' + name + '"]');
          if (el) el.checked = !!map[name];
        });
        status.textContent = 'Detected!';
        status.className = 'text-xs text-emerald-600';
      })
      .catch(function (err) {
        status.textContent = 'Request failed';
        status.className = 'text-xs text-rose-600';
      })
      .finally(function () { btn.disabled = false; });
  });
})();
</script>
{{end}}
