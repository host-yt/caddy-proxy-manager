{{define "node_edit"}}
<div class="space-y-6 max-w-2xl">
  <div>
    <a href="/admin/nodes" class="t-caption hover:text-[rgb(var(--accent))] transition-colors">
      <svg class="w-3 h-3 inline-block mr-1" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3L5 8l5 5"/></svg>
      all nodes
    </a>
    <h2 class="t-h2 mt-1">Edit node: {{.Name}}</h2>
    <p class="t-caption mt-0.5">{{.PublicHostname}}{{if .PublicIP}} &middot; {{.PublicIP}}{{end}}</p>
  </div>

  {{if .Error}}<p class="t-small" style="color:rgb(var(--danger))">{{.Error}}</p>{{end}}

  <section class="r-card space-y-4">
    <h3 class="t-eyebrow">Outbound IP inventory</h3>
    <p class="t-caption">
      List of source IPs available on this node's NICs. One IP per line. Used when a
      route's egress mode is set to "fixed" (dropdown) or "random" (picked deterministically per route).
      Leave empty if this node has only one egress IP.
    </p>
    <form method="POST" action="/admin/nodes/{{.NodeID}}/edit" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="t-caption font-medium block mb-1">Outbound IPs</label>
        <textarea name="outbound_ips" rows="6"
          placeholder="203.0.113.1&#10;203.0.113.2&#10;2001:db8::1"
          class="r-input w-full font-mono text-xs">{{.OutboundIPs}}</textarea>
        <p class="t-caption mt-1">Bare IPv4 or IPv6 addresses only, one per line. Caddy rejects /load if an address is not on the NIC.</p>
      </div>
      <!-- Module capabilities: which custom Caddy modules are present on this node -->
      <fieldset class="space-y-3 border-t border-[rgb(var(--border))] pt-4">
        <legend class="t-eyebrow mb-2">Module capabilities</legend>
        <p class="t-caption -mt-1">Which custom Caddy modules are installed on this node. Caddy's admin API cannot enumerate modules, so declare them here. Ticking any box makes this node's flags authoritative over the fleet-wide defaults.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_waf" value="1" {{if .HasWAF}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            WAF (Coraza)
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_l4" value="1" {{if .HasL4}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            L4 Streams
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_dns_module" value="1" {{if .HasDNSModule}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            DNS-01 (cert challenges)
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_rate_limit" value="1" {{if .HasRateLimit}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            Rate limit
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_geoip" value="1" {{if .HasGeoIP}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            GeoIP
          </label>
        </div>
        <div class="pt-1">
          <label class="t-caption font-medium block mb-1">Caddy version</label>
          <input type="text" name="caddy_version" value="{{.CaddyVersion}}" placeholder="e.g. 2.8.4"
            class="r-input w-48 font-mono text-xs">
        </div>
      </fieldset>

      <div class="flex items-center justify-end gap-3 pt-1">
        <a href="/admin/nodes" class="r-btn-ghost cursor-pointer">Cancel</a>
        <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
      </div>
    </form>
  </section>
</div>
{{end}}
