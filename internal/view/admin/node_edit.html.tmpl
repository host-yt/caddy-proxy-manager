{{define "node_edit"}}
<div class="space-y-6 max-w-2xl">
  <div>
    <a href="/admin/nodes" class="t-caption hover:text-[rgb(var(--accent))] transition-colors">
      <svg class="w-3 h-3 inline-block mr-1" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3L5 8l5 5"/></svg>
      all nodes
    </a>
    <h2 class="t-h2 mt-1">Edit node: {{.Name}}</h2>
    <p class="t-caption mt-0.5">{{.PublicHostname}}{{if .PublicIP}} &middot; {{.PublicIP}}{{end}}</p>
  </div>

  {{if .Error}}<p class="t-small" style="color:rgb(var(--danger))">{{.Error}}</p>{{end}}

  <section class="r-card space-y-4">
    <h3 class="t-eyebrow">Outbound IP inventory</h3>
    <p class="t-caption">
      List of source IPs available on this node's NICs. One IP per line. Used when a
      route's egress mode is set to "fixed" (dropdown) or "random" (picked deterministically per route).
      Leave empty if this node has only one egress IP.
    </p>
    <form method="POST" action="/admin/nodes/{{.NodeID}}/edit" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="t-caption font-medium block mb-1">Outbound IPs</label>
        <textarea name="outbound_ips" rows="6"
          placeholder="203.0.113.1&#10;203.0.113.2&#10;2001:db8::1"
          class="r-input w-full font-mono text-xs">{{.OutboundIPs}}</textarea>
        <p class="t-caption mt-1">Bare IPv4 or IPv6 addresses only, one per line. Caddy rejects /load if an address is not on the NIC.</p>
      </div>
      <!-- Module capabilities: which custom Caddy modules are present on this node -->
      <fieldset class="space-y-3 border-t border-[rgb(var(--border))] pt-4">
        <legend class="t-eyebrow mb-2">Module capabilities</legend>
        <p class="t-caption -mt-1">Which custom Caddy modules are installed on this node. Caddy's admin API cannot enumerate modules, so declare them here. Ticking any box makes this node's flags authoritative over the fleet-wide defaults.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_waf" value="1" {{if .HasWAF}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            WAF (Coraza)
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_l4" value="1" {{if .HasL4}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            L4 Streams
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_dns_module" value="1" {{if .HasDNSModule}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            DNS-01 (cert challenges)
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_rate_limit" value="1" {{if .HasRateLimit}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            Rate limit
          </label>
          <label class="flex items-center gap-2 cursor-pointer t-body">
            <input type="checkbox" name="has_geoip" value="1" {{if .HasGeoIP}}checked{{end}}
              class="rounded accent-[rgb(var(--accent))]">
            GeoIP
          </label>
        </div>
        <div class="pt-1">
          <label class="t-caption font-medium block mb-1">Caddy version</label>
          <input type="text" name="caddy_version" value="{{.CaddyVersion}}" placeholder="e.g. 2.8.4"
            class="r-input w-48 font-mono text-xs">
        </div>
      </fieldset>

      <!-- Inbound PROXY protocol: node sits behind an L4 balancer (HAProxy etc.)
           that prepends a PROXY v1/v2 header so Caddy sees the real client IP. -->
      <fieldset class="space-y-3 border-t border-[rgb(var(--border))] pt-4">
        <legend class="t-eyebrow mb-2">Inbound PROXY protocol</legend>
        <label class="flex items-center gap-2 cursor-pointer t-body">
          <input type="checkbox" id="pp_in" name="proxy_protocol_in" value="1" {{if .ProxyProtocolIn}}checked{{end}}
            class="rounded accent-[rgb(var(--accent))]">
          Behind L4 load balancer (PROXY protocol)
        </label>
        <p class="t-caption -mt-1">Enable when an L4 balancer or tunnel (e.g. HAProxy) sits in front of this node and sends a PROXY protocol header. Without this, geo-blocking, WAF, rate-limit and analytics see the balancer's IP instead of the real client.</p>
        <div id="pp_fields" class="space-y-3 {{if not .ProxyProtocolIn}}hidden{{end}}">
          <div>
            <label class="t-caption font-medium block mb-1">Allow-list (CIDRs)</label>
            <textarea id="pp_allow" name="proxy_protocol_allow" rows="2"
              placeholder="10.0.0.0/8, 203.0.113.5/32" class="r-input w-full font-mono text-xs">{{.ProxyProtocolAllow}}</textarea>
            <p class="t-caption mt-1">Comma-separated. Only these peers are trusted to prepend a PROXY header. Leave empty to accept from any source.</p>
          </div>
          <!-- SECURITY: a PROXY header is an unauthenticated claim of client IP.
               Any peer allowed to speak it can spoof its source IP - always
               restrict this to the load balancer's own address in production. -->
          <div id="pp_warning" class="hidden r-card bg-[rgb(var(--danger-weak),0.15)] ring-danger/30 t-caption text-danger">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <span>Accepting PROXY headers from any source allows client-IP spoofing - restrict to your LB address.</span>
            </div>
          </div>
          <div>
            <label class="t-caption font-medium block mb-1">Header timeout (ms)</label>
            <input type="number" name="proxy_protocol_timeout_ms" min="1" value="{{.ProxyProtocolTimeoutMs}}"
              class="r-input w-32 font-mono text-xs">
            <p class="t-caption mt-1">How long Caddy waits for the PROXY header before dropping the connection.</p>
          </div>
        </div>
      </fieldset>

      <div class="flex items-center justify-end gap-3 pt-1">
        <a href="/admin/nodes" class="r-btn-ghost cursor-pointer">Cancel</a>
        <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
      </div>
    </form>
  </section>
</div>
<script>
(function(){
  var cb = document.getElementById('pp_in');
  var fields = document.getElementById('pp_fields');
  var allow = document.getElementById('pp_allow');
  var warning = document.getElementById('pp_warning');
  function sync(){
    if (!cb) return;
    if (fields) fields.classList.toggle('hidden', !cb.checked);
    if (warning) warning.classList.toggle('hidden', !(cb.checked && allow && allow.value.trim() === ''));
  }
  if (cb) cb.addEventListener('change', sync);
  if (allow) allow.addEventListener('input', sync);
  sync();
})();
</script>
{{end}}
