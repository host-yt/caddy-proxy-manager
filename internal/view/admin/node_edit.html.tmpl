{{define "node_edit"}}
<div class="space-y-6 max-w-2xl">
  <div>
    <a href="/admin/nodes" class="text-xs text-slate-500 hover:text-indigo-600">← all nodes</a>
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mt-1">Edit node: {{.Name}}</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{{.PublicHostname}}{{if .PublicIP}} &middot; {{.PublicIP}}{{end}}</p>
  </div>

  {{if .Error}}<p class="text-sm text-rose-600">{{.Error}}</p>{{end}}

  <section class="hpg-card space-y-4">
    <h3 class="hpg-eyebrow">Outbound IP inventory</h3>
    <p class="text-[11px] text-slate-500 dark:text-slate-400">
      List of source IPs available on this node's NICs. One IP per line. Used when a
      route's egress mode is set to "fixed" (dropdown) or "random" (picked deterministically per route).
      Leave empty if this node has only one egress IP.
    </p>
    <form method="POST" action="/admin/nodes/{{.NodeID}}/edit" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Outbound IPs</label>
        <textarea name="outbound_ips" rows="6"
          placeholder="203.0.113.1&#10;203.0.113.2&#10;2001:db8::1"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono text-xs">{{.OutboundIPs}}</textarea>
        <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Bare IPv4 or IPv6 addresses only, one per line. Caddy rejects /load if an address is not on the NIC.</p>
      </div>
      <div class="flex items-center justify-end gap-3 pt-1">
        <a href="/admin/nodes" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 cursor-pointer">Cancel</a>
        <button type="submit"
          class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors cursor-pointer">Save</button>
      </div>
    </form>
  </section>
</div>
{{end}}
