{{define "alerts"}}
<div class="space-y-6">

  <div class="flex flex-wrap items-center justify-between gap-3 mb-2">
    <span></span>
    <div class="flex items-center gap-2">
      <a href="/admin/alerts/export.csv{{if .RuleFilter}}?rule_id={{.RuleFilter}}{{end}}" class="r-btn-secondary text-xs" download>Export CSV</a>
      <form method="POST" action="/admin/alerts/test-fire" class="inline">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-ghost text-xs cursor-pointer transition-colors" style="color:rgb(var(--warning));border-color:rgb(var(--warning) / .4)">Send test alert</button>
      </form>
    </div>
  </div>

  <!-- Rule filter tabs -->
  <nav class="r-segment">
    <a href="/admin/alerts" class="r-segment-item {{if eq .RuleFilter ""}}is-active{{end}}">All</a>
    {{range $r := .KnownRules}}
    <a href="/admin/alerts?rule={{$r}}" class="r-segment-item {{if eq $.RuleFilter $r}}is-active{{end}}">{{$r}}</a>
    {{end}}
  </nav>

  <!-- Rules summary 7d -->
  {{if .RulesStatus}}
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-5 py-4 border-b" style="border-color:rgb(var(--border))">
      <p class="t-eyebrow">7-day summary</p>
      <h2 class="t-h3">Alert rules</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Rule</th>
            <th>Last fired</th>
            <th>7d count</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
        {{range .RulesStatus}}
          <tr>
            <td class="font-mono text-xs">{{.RuleID}}</td>
            <td class="text-xs tabular-nums">{{if .LastFired}}{{.LastFired.Format "2006-01-02 15:04"}}{{else}}<span class="t-muted">never</span>{{end}}</td>
            <td class="tabular-nums text-xs {{if gt .FireCount 0}}font-medium{{end}}" style="{{if gt .FireCount 0}}color:rgb(var(--warning)){{end}}">{{.FireCount}}</td>
            <td class="t-small">{{.Description}}</td>
          </tr>
        {{end}}
        </tbody>
      </table>
    </div>
  </section>
  {{end}}

  <!-- Alert thresholds -->
  <section class="r-card">
    <p class="t-eyebrow mb-1">Configuration</p>
    <h2 class="t-h3 mb-3">Alert thresholds</h2>
    <dl class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2">
      <div><dt class="t-eyebrow">Node offline after</dt><dd class="font-medium mt-0.5 tabular-nums">{{.AlertCfg.NodeOfflineMinutes}} min</dd></div>
      <div><dt class="t-eyebrow">WG stale after</dt><dd class="font-medium mt-0.5 tabular-nums">{{.AlertCfg.WGStaleSeconds}} s</dd></div>
      <div><dt class="t-eyebrow">Cert stuck after</dt><dd class="font-medium mt-0.5 tabular-nums">{{.AlertCfg.CertStuckMinutes}} min</dd></div>
      <div><dt class="t-eyebrow">Error rate threshold</dt><dd class="font-medium mt-0.5 tabular-nums">{{.ErrorRatePct100}}%</dd></div>
      <div><dt class="t-eyebrow">Error rate window</dt><dd class="font-medium mt-0.5 tabular-nums">{{.AlertCfg.ErrorRateWindowMinutes}} min</dd></div>
      <div><dt class="t-eyebrow">Cooldown</dt><dd class="font-medium mt-0.5 tabular-nums">{{.AlertCfg.CooldownSeconds}} s</dd></div>
    </dl>
    <dl class="mt-4 grid grid-cols-1 gap-y-2 border-t pt-4" style="border-color:rgb(var(--border))">
      <div class="flex items-center gap-3">
        <dt class="t-eyebrow w-24 shrink-0">Telegram</dt>
        <dd>{{if .AlertCfg.TelegramChatID}}<span class="r-pill r-pill-success">{{.AlertCfg.TelegramChatID}}</span>{{else}}<span class="r-pill r-pill-neutral">not configured</span>{{end}}</dd>
      </div>
    </dl>
    <p class="t-caption mt-3">Configure via ALERT_* environment variables. See docs/DEPLOY.md.</p>
  </section>

  {{if .Rows}}
  <section class="r-card !p-0 overflow-hidden">
    <div class="flex items-center justify-between gap-3 px-5 py-4 border-b" style="border-color:rgb(var(--border))">
      <div class="flex items-center gap-3">
        <div>
          <p class="t-eyebrow">Alert log</p>
          <h2 class="t-h3">Fired alerts</h2>
        </div>
        <span class="icon-chip">last 200</span>
      </div>
    </div>
    <ul class="divide-y" style="border-color:rgb(var(--border))">
      {{range .Rows}}
      <li class="flex flex-col gap-2 px-5 py-4 sm:flex-row sm:items-start sm:gap-4 hover:bg-[rgb(var(--surface-2)/0.5)] transition-colors">
        <div class="shrink-0 sm:w-24 pt-0.5">
          {{if eq .Severity "critical"}}<span class="r-pill r-pill-danger">critical</span>
          {{else if eq .Severity "warning"}}<span class="r-pill r-pill-warning">warning</span>
          {{else}}<span class="r-pill r-pill-info">info</span>
          {{end}}
        </div>
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <span class="font-medium t-body">{{.Title}}</span>
            <span class="font-mono text-xs t-muted">{{.RuleID}}</span>
          </div>
          {{if .Detail}}<p class="mt-1 t-small">{{.Detail}}</p>{{end}}
          {{if .Labels}}<p class="mt-1 font-mono text-xs t-muted break-all">{{.Labels}}</p>{{end}}
        </div>
        <div class="shrink-0 font-mono text-xs t-muted whitespace-nowrap tabular-nums sm:text-right" title="{{.FiredAt}}">{{.FiredAt}}</div>
      </li>
      {{end}}
    </ul>
  </section>
  <p class="t-caption">Showing last 200 alerts.</p>
  {{else}}
  <div class="r-empty">
    <div class="r-empty-icon">
      <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
      </svg>
    </div>
    <h2 class="t-h3">All quiet - no alerts have fired</h2>
    <p class="t-small max-w-md">Alerts fire automatically when a monitored condition trips - a node going offline, a certificate nearing expiry, or a sync failure. Nothing needs your attention right now.</p>
  </div>
  {{end}}

  {{if .KnownRules}}
  <div class="r-card">
    <p class="t-eyebrow">Reference</p>
    <h2 class="t-h3 mt-0.5 mb-1">Monitored conditions</h2>
    <p class="t-small mb-4">These conditions are watched and can raise an alert.</p>
    <ul class="flex flex-wrap gap-2">
      {{range $r := .KnownRules}}
      <li class="r-pill r-pill-neutral font-mono">{{$r}}</li>
      {{end}}
    </ul>
  </div>
  {{end}}

</div>
{{end}}
