{{define "pagination"}}
{{/* expects: .Page .PrevURL .NextURL .Total .TotalPgs .Size */}}
{{if gt .Total 0}}
<div class="flex items-center justify-between mt-3 text-xs text-slate-500 dark:text-slate-400">
  <span>
    {{.Total}} total
    {{if gt .TotalPgs 1}}
      &mdash; page {{.Page}} of {{.TotalPgs}}
    {{end}}
  </span>
  {{if gt .TotalPgs 1}}
  <div class="flex items-center gap-1">
    {{if .PrevURL}}
    <a href="{{.PrevURL}}"
       class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer">
      <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 15l-5-5 5-5"/></svg>
      Prev
    </a>
    {{else}}
    <span class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 opacity-40 cursor-not-allowed">
      <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 15l-5-5 5-5"/></svg>
      Prev
    </span>
    {{end}}
    {{if .NextURL}}
    <a href="{{.NextURL}}"
       class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer">
      Next
      <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M7 5l5 5-5 5"/></svg>
    </a>
    {{else}}
    <span class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 opacity-40 cursor-not-allowed">
      Next
      <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M7 5l5 5-5 5"/></svg>
    </span>
    {{end}}
  </div>
  {{end}}
</div>
{{else}}
<p class="mt-3 text-xs text-slate-400 dark:text-slate-500">No results.</p>
{{end}}
{{end}}
