{{define "hosts_new"}}
<div class="max-w-xl space-y-6">
  <div class="flex items-start gap-3">
    <div class="icon-chip" style="background:rgb(var(--accent-weak));flex-shrink:0">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
    </div>
    <div>
      <p class="t-eyebrow">Hosts</p>
      <h2 class="t-h2">Add host</h2>
      <p class="t-caption">Point a public domain at a backend, or redirect it elsewhere. HTTPS certificates are issued automatically when SSL is on.</p>
    </div>
  </div>

  {{if not .NodeGroups}}
  <!-- First-run: no eligible nodes yet - guide instead of a dead form. -->
  <div class="r-card space-y-4">
    <p class="t-body font-medium">No Caddy nodes are ready yet</p>
    <p class="t-caption">A host needs at least one approved and enabled Caddy node to serve traffic. Three steps:</p>
    <ol class="list-decimal ml-5 space-y-1 t-body">
      <li>Add a node under <a href="/admin/nodes" class="underline" style="color:rgb(var(--accent))">Caddy nodes</a> and install the agent on your server</li>
      <li>Approve and enable the node once it connects</li>
      <li>Come back here and add your host</li>
    </ol>
    <div class="pt-1">
      <a href="/admin/nodes" class="r-btn-primary inline-flex items-center gap-1.5">Go to Caddy nodes</a>
    </div>
  </div>
  {{else}}
  <form method="POST" action="/admin/hosts/new" class="space-y-5 text-sm">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <!-- CORE: the 90% path, always visible -->
    <div class="r-card space-y-5">
      <p class="t-eyebrow">Route</p>

      <div>
        <label class="t-eyebrow mb-1 block">Route kind</label>
        <select id="hpg-kind" name="kind" class="r-select w-full">
          <option value="proxy" {{if ne .Form.Kind "redirect"}}selected{{end}}>Reverse proxy → backend</option>
          <option value="redirect" {{if eq .Form.Kind "redirect"}}selected{{end}}>Redirect → URL</option>
        </select>
      </div>

      <div>
        <label class="t-eyebrow mb-1 block">Public domain</label>
        <div class="flex gap-2">
          <input id="hpg-domain" name="domain" value="{{.Form.Domain}}" required placeholder="app.example.com"
                 class="r-input flex-1">
          <button type="button" id="hpg-dns-check" class="r-btn-secondary text-xs cursor-pointer">Check DNS</button>
        </div>
        <p id="hpg-dns-result" class="t-caption mt-1">DNS A record for this domain must point at the serving node's public IP before Let's Encrypt will issue a cert. Pick a node group below to enable the check.</p>
      </div>

      <div id="hpg-proxy-fields" class="grid grid-cols-6 gap-3">
        <div>
          <label class="t-eyebrow mb-1 block">Scheme</label>
          <select name="upstream_scheme" class="r-select w-full">
            <option value="http"  {{if ne .Form.UpstreamScheme "https"}}selected{{end}}>http</option>
            <option value="https" {{if eq .Form.UpstreamScheme "https"}}selected{{end}}>https</option>
          </select>
        </div>
        <div class="col-span-3">
          <label class="t-eyebrow mb-1 block">Backend host (IP or hostname)</label>
          <input id="hpg-backend" name="backend_ip" value="{{.Form.BackendIP}}" placeholder="10.0.0.5 or backend.example.com"
                 class="r-input w-full">
        </div>
        <div class="col-span-2">
          <label class="t-eyebrow mb-1 block">Port</label>
          <input id="hpg-port" name="port" value="{{.Form.Port}}" type="number" min="1" max="65535" placeholder="8080"
                 class="r-input w-full">
        </div>
      </div>

      <div id="hpg-redirect-fields" class="grid grid-cols-4 gap-3 hidden">
        <div class="col-span-3">
          <label class="t-eyebrow mb-1 block">Destination URL</label>
          <input id="hpg-redirect-url" name="redirect_url" value="{{.Form.RedirectURL}}" placeholder="https://target.example.com"
                 class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow mb-1 block">Code</label>
          <select name="redirect_code" class="r-select w-full">
            <option value="308" {{if eq .Form.RedirectCode "308"}}selected{{end}}>308 Permanent</option>
            <option value="301" {{if eq .Form.RedirectCode "301"}}selected{{end}}>301 Permanent (legacy)</option>
            <option value="307" {{if eq .Form.RedirectCode "307"}}selected{{end}}>307 Temporary</option>
            <option value="302" {{if eq .Form.RedirectCode "302"}}selected{{end}}>302 Found</option>
          </select>
        </div>
      </div>

      <div>
        <label class="t-eyebrow mb-1 block">Node group</label>
        <select id="hpg-node-group" name="node_group_id" required class="r-select w-full">
          <option value="">-- pick a node group --</option>
          {{range .NodeGroups}}
          <option value="{{.ID}}" data-mode="{{.Mode}}"
                  data-nodes="{{range $i, $n := .Nodes}}{{if $i}}, {{end}}{{$n.Name}}{{if $n.IP}} ({{$n.IP}}){{end}}{{end}}"
                  {{if eq (printf "%d" .ID) $.Form.NodeGroupID}}selected{{end}}>{{.Name}} &mdash; {{.Mode}}, {{len .Nodes}} node{{if gt (len .Nodes) 1}}s{{end}}</option>
          {{end}}
        </select>
        <p id="hpg-group-hint" class="t-caption mt-1">Placement is decided by the group's mode, not by a single node.</p>
      </div>

      <label class="flex items-center gap-2 t-body cursor-pointer">
        <input type="checkbox" name="ssl" value="1" {{if .Form.SSL}}checked{{end}} class="rounded cursor-pointer">
        Let's Encrypt SSL (also auto-redirects HTTP &rarr; HTTPS)
      </label>
    </div>

    <!-- ADVANCED: collapsed accordion groups, visually subordinate to the core -->
    <div class="r-card space-y-3">
      <p class="t-eyebrow">Advanced (optional)</p>

      <!-- Protocols / WebSocket -->
      <details class="hpg-adv group rounded-xl" style="border:1px solid rgb(var(--border))">
        <summary class="cursor-pointer select-none px-4 py-3 t-small font-medium flex items-center justify-between rounded-xl transition-colors" style="color:rgb(var(--text))">
          <span>Protocols</span>
          <span style="color:rgb(var(--muted))" class="group-open:rotate-90 transition-transform">&#8250;</span>
        </summary>
        <div class="px-4 pb-4 pt-1 space-y-1">
          <label id="hpg-ws-row" class="flex items-center gap-2 t-body cursor-pointer">
            <input type="checkbox" name="websocket" value="1" {{if .Form.WebSocket}}checked{{end}} class="rounded cursor-pointer">
            WebSocket passthrough
          </label>
        </div>
      </details>

      <!-- External HTTPS upstream -->
      <details class="hpg-adv group rounded-xl" style="border:1px solid rgb(var(--border))">
        <summary class="cursor-pointer select-none px-4 py-3 t-small font-medium flex items-center justify-between rounded-xl transition-colors" style="color:rgb(var(--text))">
          <span>External HTTPS upstream</span>
          <span style="color:rgb(var(--muted))" class="group-open:rotate-90 transition-transform">&#8250;</span>
        </summary>
        <div class="px-4 pb-4 pt-1">
          <div class="rounded-xl p-4 space-y-3" style="border:1px solid rgb(var(--warning,245 158 11)/.4);background:rgb(var(--warning,245 158 11)/.06)">
            <label class="flex items-center gap-2 t-body font-medium cursor-pointer">
              <input type="checkbox" name="upstream_external" value="1" {{if .Form.External}}checked{{end}} class="rounded cursor-pointer">
              External HTTPS upstream (proxy to an allowlisted public API)
            </label>
            <p class="t-caption">
              Forwards <code>https://&lt;this domain&gt;/&lt;path&gt;</code> to the external origin over TLS
              (correct SNI + Host) from this node's egress IP. The host must be in
              <code>EXTERNAL_UPSTREAM_ALLOWLIST</code>; a one-time bearer is generated on save and callers
              must send <code>Authorization: Bearer ...</code>. When ticked, the Backend host/port above are ignored.
            </p>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="t-eyebrow mb-1 block">External host (FQDN)</label>
                <input name="external_host" value="{{.Form.ExternalHost}}" placeholder="adm.tools"
                       class="r-input w-full">
              </div>
              <div>
                <label class="t-eyebrow mb-1 block">Host / SNI override (optional)</label>
                <input name="upstream_host_header" value="{{.Form.UpstreamHostHeader}}" placeholder="defaults to external host"
                       class="r-input w-full">
              </div>
            </div>
          </div>
        </div>
      </details>

      <!-- Wildcard cert (DNS-01) -->
      <details class="hpg-adv group rounded-xl" style="border:1px solid rgb(var(--border))">
        <summary class="cursor-pointer select-none px-4 py-3 t-small font-medium flex items-center justify-between rounded-xl transition-colors" style="color:rgb(var(--text))">
          <span>Wildcard cert (DNS-01)</span>
          <span style="color:rgb(var(--muted))" class="group-open:rotate-90 transition-transform">&#8250;</span>
        </summary>
        <div class="px-4 pb-4 pt-1 flex flex-wrap items-center gap-3">
          <label class="flex items-center gap-2 t-body cursor-pointer">
            <input type="checkbox" name="wildcard_enabled" value="1" {{if .Form.WildcardEnabled}}checked{{end}} class="rounded cursor-pointer">
            Wildcard cert (DNS-01)
          </label>
          <input name="wildcard_zone" value="{{.Form.WildcardZone}}" placeholder="zone e.g. customer.com" class="r-input">
        </div>
      </details>

      <!-- Routing metadata -->
      <details class="hpg-adv group rounded-xl" style="border:1px solid rgb(var(--border))">
        <summary class="cursor-pointer select-none px-4 py-3 t-small font-medium flex items-center justify-between rounded-xl transition-colors" style="color:rgb(var(--text))">
          <span>Tag / group</span>
          <span style="color:rgb(var(--muted))" class="group-open:rotate-90 transition-transform">&#8250;</span>
        </summary>
        <div class="px-4 pb-4 pt-1 space-y-3">
          <div>
            <label class="t-eyebrow mb-1 block">Tag (optional)</label>
            <input name="tag" value="{{.Form.Tag}}" placeholder="saas-customer-1" maxlength="64" class="r-input w-full">
          </div>
          <div>
            <label class="t-eyebrow mb-1 block">Host group (label)</label>
            <select name="group_id" class="r-select w-full cursor-pointer">
              <option value="0">- none -</option>
              {{range .Groups}}
              <option value="{{.ID}}">{{.Name}}</option>
              {{end}}
            </select>
            <p class="t-caption mt-1">Organizational label for filtering the hosts list. Does not affect routing or node placement.</p>
          </div>
        </div>
      </details>

      {{if .CFViews}}
      <!-- Custom fields -->
      <details class="hpg-adv group rounded-xl" style="border:1px solid rgb(var(--border))">
        <summary class="cursor-pointer select-none px-4 py-3 t-small font-medium flex items-center justify-between rounded-xl transition-colors" style="color:rgb(var(--text))">
          <span>Custom fields</span>
          <span style="color:rgb(var(--muted))" class="group-open:rotate-90 transition-transform">&#8250;</span>
        </summary>
        <div class="px-4 pb-4 pt-1 space-y-3">
          {{range .CFViews}}
          {{$cfv := .Value}}
          <div>
            <label class="t-eyebrow mb-1 block">{{.Def.Label}}{{if .Def.Required}}<span style="color:rgb(var(--danger,220 38 38))"> *</span>{{end}}</label>
            {{if eq .Def.Type "bool"}}
            <label class="flex items-center gap-2 t-body cursor-pointer">
              <input type="checkbox" name="cf_{{.Def.Key}}" value="1" {{if eq .Value "1"}}checked{{end}} class="rounded cursor-pointer">
              {{.Def.Label}}
            </label>
            {{else if eq .Def.Type "select"}}
            <select name="cf_{{.Def.Key}}" class="r-select w-full cursor-pointer">
              <option value="">- select -</option>
              {{range .Def.Options}}<option value="{{.}}" {{if eq . $cfv}}selected{{end}}>{{.}}</option>{{end}}
            </select>
            {{else if eq .Def.Type "number"}}
            <input type="number" name="cf_{{.Def.Key}}" value="{{.Value}}" {{if .Def.Required}}required{{end}} class="r-input w-full">
            {{else}}
            <input type="text" name="cf_{{.Def.Key}}" value="{{.Value}}" {{if .Def.Required}}required{{end}} maxlength="1000" class="r-input w-full">
            {{end}}
          </div>
          {{end}}
        </div>
      </details>
      {{end}}
    </div>

    <div class="flex justify-end gap-3 pt-1">
      <a href="/admin/hosts" class="r-btn-ghost">Cancel</a>
      <button class="r-btn-primary cursor-pointer">Add host</button>
    </div>
  </form>
  <script nonce="{{.CSPNonce}}">
  (function(){
    var kindSel = document.getElementById('hpg-kind');
    var proxyEl = document.getElementById('hpg-proxy-fields');
    var redirEl = document.getElementById('hpg-redirect-fields');
    var wsRow   = document.getElementById('hpg-ws-row');
    var beEl    = document.getElementById('hpg-backend');
    var portEl  = document.getElementById('hpg-port');
    var ruEl    = document.getElementById('hpg-redirect-url');
    var extCb   = document.querySelector('input[name=upstream_external]');
    function sync(){
      var r = kindSel.value === 'redirect';
      proxyEl.classList.toggle('hidden', r);
      redirEl.classList.toggle('hidden', !r);
      wsRow.classList.toggle('hidden', r);
      // Client-side required mirrors server validation: proxy needs a backend
      // (unless external upstream replaces it), redirect needs a URL.
      var ext = !!(extCb && extCb.checked);
      if (beEl)   beEl.required   = !r && !ext;
      if (portEl) portEl.required = !r && !ext;
      if (ruEl)   ruEl.required   = r;
    }
    if (kindSel) { kindSel.addEventListener('change', sync); sync(); }
    if (extCb) extCb.addEventListener('change', sync);

    // Node-group hint: spell out what the group's mode means for placement,
    // so picking a group never reads as picking a single node.
    var grpEl   = document.getElementById('hpg-node-group');
    var grpHint = document.getElementById('hpg-group-hint');
    function syncGroupHint(){
      if (!grpEl || !grpHint) return;
      var opt = grpEl.options[grpEl.selectedIndex];
      if (!opt || !opt.value) { grpHint.textContent = 'Placement is decided by the group’s mode, not by a single node.'; return; }
      var nodes = opt.getAttribute('data-nodes') || '';
      switch (opt.getAttribute('data-mode')) {
        case 'active_active':
          grpHint.textContent = 'Served by ALL nodes in this group: ' + nodes + '. Point the domain’s DNS at every node IP (or use DNS load balancing).';
          break;
        case 'failover':
          grpHint.textContent = 'Primary + warm standby picked by priority from: ' + nodes + '.';
          break;
        default:
          grpHint.textContent = 'One node is auto-picked by current load from: ' + nodes + '.';
      }
    }

    // Auto DNS precheck: fire on domain blur + group change (manual button kept),
    // with a debounce + stale-response guard. Renders a status pill into
    // #hpg-dns-result. Vanilla fetch, same-origin (CSP connect-src 'self').
    var domEl  = document.getElementById('hpg-domain');
    var out    = document.getElementById('hpg-dns-result');
    var btn    = document.getElementById('hpg-dns-check');
    var seq = 0, timer = null;
    function setPill(cls, text){ if (out){ out.textContent = text; out.className = 't-caption mt-1 ' + cls; } }
    function syncBtn(){
      if (!btn) return;
      var ready = !!((domEl && domEl.value.trim()) && (grpEl && grpEl.value));
      btn.disabled = !ready;
      btn.classList.toggle('opacity-50', !ready);
      btn.title = ready ? '' : 'Enter a domain and pick a node group first';
    }
    function runDnsCheck(){
      var dom = (domEl && domEl.value || '').trim();
      var grp = grpEl ? grpEl.value : '';
      if (!dom || !grp) return;
      var my = ++seq;
      setPill('', 'checking DNS...');
      fetch('/admin/hosts/check-dns?domain='+encodeURIComponent(dom)+'&group_id='+grp)
        .then(function(r){ return r.json(); })
        .then(function(j){
          if (my !== seq) return; // a newer check superseded this one
          if (j.error){
            var nx = /no such host|not found|nxdomain/i.test(j.error);
            setPill('text-rose-600', nx ? 'x does not resolve (NXDOMAIN)' : ('x lookup error: '+j.error));
            return;
          }
          var got = (j.resolved && j.resolved.length) ? j.resolved.join(', ') : '(none)';
          var want = (j.expected_ips && j.expected_ips.length) ? j.expected_ips.join(' / ') : (j.node_hostname || 'node IP');
          if (j.match) setPill('text-emerald-600', 'resolves to a group node ('+got+')');
          else         setPill('text-amber-600', 'mismatch: '+got+' != '+want);
        })
        .catch(function(){ if (my === seq) setPill('text-rose-600', 'x lookup failed'); });
    }
    function schedule(){ clearTimeout(timer); timer = setTimeout(runDnsCheck, 250); }
    if (domEl)  domEl.addEventListener('blur', runDnsCheck);
    if (domEl)  domEl.addEventListener('input', syncBtn);
    if (grpEl)  grpEl.addEventListener('change', function(){ syncGroupHint(); syncBtn(); schedule(); });
    if (btn)    btn.addEventListener('click', runDnsCheck);
    syncGroupHint(); syncBtn();

    // Auto-open any Advanced group that holds a non-default value (so a
    // validation-error repopulation never hides what the admin already typed).
    document.querySelectorAll('.hpg-adv').forEach(function(d){
      var dirty = false;
      d.querySelectorAll('input, select, textarea').forEach(function(el){
        if (el.type === 'checkbox') { if (el.checked) dirty = true; }
        else if ((el.value || '').trim() !== '') dirty = true;
      });
      if (dirty) d.open = true;
    });
  })();
  </script>
  {{end}}
</div>
{{end}}
