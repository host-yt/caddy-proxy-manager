{{define "tunnels"}}
<div class="space-y-5">
  <div class="flex items-center justify-between gap-4">
    <p class="t-small" style="color:rgb(var(--muted))">WireGuard tunnels customers run from their LAN. Caddy reaches the customer backend through the assigned tunnel IP - no port-forward required.</p>
    {{if ne .Role "support"}}
    <button type="button" data-open-tunnel-modal class="r-btn-primary whitespace-nowrap cursor-pointer">
      <svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      Create tunnel
    </button>
    {{end}}
  </div>

  {{if ne .Role "support"}}
  {{if .NewTunnel}}
  <!-- Just-created tunnel card. Surfaces the one-line installer + live status poll. -->
  <div class="r-card space-y-4" style="border-color:rgb(var(--success)/0.4)">
    <div class="flex items-start justify-between gap-4">
      <div class="flex items-start gap-3">
        <span class="icon-chip" style="background:rgb(var(--success)/.12);color:rgb(var(--success))">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
        </span>
        <div>
          <h3 class="t-h3">Tunnel ready &middot; {{.NewTunnel.Name}}</h3>
          <p class="t-small" style="color:rgb(var(--muted))">Client: <span class="font-mono">{{.NewTunnel.ClientEmail}}</span> &middot; Node: <span class="font-mono">{{.NewTunnel.NodeName}}</span> &middot; IP: <span class="font-mono">{{.NewTunnel.AssignedIP}}</span></p>
        </div>
      </div>
      <span id="hpg-tun-status" class="r-pill r-pill-warning">Waiting for first handshake&hellip;</span>
    </div>
    <div>
      <label class="t-eyebrow block mb-1">Run on the customer's Linux server (root):</label>
      <div class="flex gap-2 items-stretch">
        <code id="hpg-tun-cmd" class="flex-1 block font-mono text-xs p-3 rounded-lg break-all" style="background:rgb(var(--text));color:rgb(var(--bg))">{{.NewTunnel.InstallCommand}}</code>
        <button type="button" data-copy-target="hpg-tun-cmd" class="r-btn-secondary px-3 text-xs cursor-pointer">Copy</button>
      </div>
      <p class="t-caption mt-1" style="color:rgb(var(--muted))">Single-use, expires at <time class="font-mono" data-expires="{{.NewTunnel.ExpiresAt}}">{{.NewTunnel.ExpiresAt}}</time>. Alternative: download <a href="{{.NewTunnel.ConfURL}}" class="underline" style="color:rgb(var(--accent))">.conf</a> manually.</p>
    </div>
  </div>
  {{end}}
  {{end}}

  <div class="r-card !p-0 overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Client</th>
          <th>Node</th>
          <th>Assigned IP</th>
          <th>Endpoint</th>
          <th class="whitespace-nowrap">Status</th>
          <th class="whitespace-nowrap">Health</th>
          <th class="whitespace-nowrap">Last handshake</th>
          <th class="whitespace-nowrap">Traffic</th>
          <th class="text-right"></th>
        </tr>
      </thead>
      <tbody>
      {{range .Tunnels}}
        <tr>
          <td class="whitespace-nowrap">
            <span class="t-body font-medium">{{.Name}}</span>
            {{if .PeerGroupID}}<span class="r-pill r-pill-info ml-1" style="font-size:10px;padding:1px 6px">HA</span>{{end}}
          </td>
          <td class="t-small" style="color:rgb(var(--muted))">{{.ClientEmail}}</td>
          <td class="t-small" style="color:rgb(var(--muted))">{{.NodeName}}</td>
          <td class="font-mono t-small whitespace-nowrap">{{.AssignedIP}}</td>
          <td class="font-mono t-small whitespace-nowrap" style="color:rgb(var(--muted))">{{if .Endpoint}}{{.Endpoint}}{{else}}&mdash;{{end}}</td>
          <td class="whitespace-nowrap">
            {{if eq .Status "active"}}<span class="r-pill r-pill-success">active</span>{{end}}
            {{if eq .Status "pending"}}<span class="r-pill r-pill-warning">pending install</span>{{end}}
            {{if eq .Status "revoked"}}<span class="r-pill r-pill-neutral">revoked</span>{{end}}
          </td>
          <td class="whitespace-nowrap">
            {{if .Healthy}}<span class="r-pill r-pill-success">&#x25cf; connected</span>
            {{else if eq .Status "active"}}<span class="r-pill r-pill-warning">stale</span>
            {{else}}<span style="color:rgb(var(--muted))">&mdash;</span>{{end}}
          </td>
          <td class="font-mono t-small whitespace-nowrap" style="color:rgb(var(--muted))">{{.LastHandshake}}</td>
          <td class="t-small font-mono whitespace-nowrap">
            <span class="flex flex-col tabular-nums leading-tight">
              <span><span style="color:rgb(var(--success))">&#x2193;</span> {{.RxHuman}}</span>
              <span><span style="color:rgb(52,211,153)">&#x2191;</span> {{.TxHuman}}</span>
              <span class="t-caption mt-0.5" style="color:rgb(var(--muted))" title="Lifetime usage (survives rekey/restart)">&Sigma; {{.CumRxHuman}} / {{.CumTxHuman}}</span>
            </span>
          </td>
          <td class="text-right whitespace-nowrap">
            <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="tun-act-{{.ID}}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
            </button>
            <div id="tun-act-{{.ID}}" class="hpg-act-menu" role="menu">
              <button type="button" data-bw-toggle="{{.ID}}" class="hpg-act-item" role="menuitem">Bandwidth</button>
              {{if ne $.Role "support"}}
              {{if ne .Status "revoked"}}
              <form method="POST" action="/admin/tunnels/{{.ID}}/reissue" class="contents" data-confirm="Re-issue config for {{.Name}}? Same keys, fresh install URL with current template (e.g. MTU/MSS updates).">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">Reissue</button>
              </form>
              <form method="POST" action="/admin/tunnels/{{.ID}}/rotate" class="contents" data-confirm="Rotate key for {{.Name}}? Customer will need to re-run install with the new token.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">Rotate</button>
              </form>
              <form method="POST" action="/admin/tunnels/{{.ID}}/revoke" class="contents" data-confirm="Revoke tunnel {{.Name}}? The customer's connection will drop on next node reconcile (~30s).">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Revoke</button>
              </form>
              {{end}}
              <form method="POST" action="/admin/tunnels/{{.ID}}/delete" class="contents" data-confirm="Hard-delete tunnel {{.Name}}? Row + bootstrap tokens removed permanently. Reclaims assigned_ip. Cannot be undone." data-confirm-type="{{.Name}}">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Delete</button>
              </form>
              {{end}}
            </div>
          </td>
        </tr>
        <!-- Inline bandwidth panel, hidden by default, revealed by "bandwidth" button. -->
        <tr id="hpg-bw-row-{{.ID}}" class="hidden">
          <td colspan="10" class="px-4 py-4" style="background:rgb(var(--surface-2)/.5)">
            <div class="flex items-center justify-between mb-3 gap-3">
              <span class="t-small font-medium">Bandwidth &middot; <span class="font-mono">{{.Name}}</span></span>
              <div class="r-segment" data-bw-periods="{{.ID}}">
                <button type="button" data-period="24h" class="r-segment-item is-active hpg-bw-period-btn cursor-pointer">24h</button>
                <button type="button" data-period="7d"  class="r-segment-item hpg-bw-period-btn cursor-pointer">7d</button>
                <button type="button" data-period="30d" class="r-segment-item hpg-bw-period-btn cursor-pointer">30d</button>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <div class="t-caption font-medium mb-1" style="color:rgb(var(--success))">RX (received)</div>
                <canvas id="hpg-bw-rx-{{.ID}}" height="100"></canvas>
              </div>
              <div>
                <div class="t-caption font-medium mb-1" style="color:rgb(14,165,233)">TX (transmitted)</div>
                <canvas id="hpg-bw-tx-{{.ID}}" height="100"></canvas>
              </div>
            </div>
            <p class="t-caption mt-2" style="color:rgb(var(--muted))">Sampled from <code>customer_wg_peer_usage_sample</code>; empty when no WG metering data yet.</p>
          </td>
        </tr>
      {{else}}
        <tr>
          <td colspan="10" class="px-4 py-12 text-center">
            <div class="r-empty">
              <span class="r-empty-icon">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>
              </span>
              <p class="t-body font-medium mt-2">No tunnels yet</p>
              <p class="t-small mt-1" style="color:rgb(var(--muted))">Click "Create tunnel" to onboard a client.</p>
            </div>
          </td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </div>
</div>

<!-- Create-tunnel modal (Cloudflare-style wizard, single step for now). -->
{{if ne .Role "support"}}
<div id="hpg-tunnel-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background:rgba(0,0,0,.45);backdrop-filter:blur(4px)">
  <form method="POST" action="/admin/tunnels" class="r-card shadow-2xl max-w-lg w-full space-y-4">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <h3 class="t-h3">Create customer tunnel</h3>
    <div>
      <label class="t-eyebrow block mb-1">Name</label>
      <input name="name" placeholder="prod-backend" required class="r-input w-full">
    </div>
    <div>
      <label class="t-eyebrow block mb-1">Client</label>
      <select name="client_id" required class="r-select w-full">
        <option value="">-- select client --</option>
        <option value="self">- My own (admin self-tunnel) -</option>
        {{range .Clients}}<option value="{{.ID}}">{{.Email}}</option>{{end}}
      </select>
      <p class="t-caption mt-1" style="color:rgb(var(--muted))">Pick "My own" to create a tunnel bound to your admin account (e.g. for tunneling your Proxmox without opening ports).</p>
    </div>
    <div>
      <label class="t-eyebrow block mb-1">Mode</label>
      <select id="hpg-tun-mode" name="ha" class="r-select w-full">
        <option value="0">Single node</option>
        <option value="1">HA (replicate across multiple nodes)</option>
      </select>
    </div>
    <div id="hpg-tun-single">
      <label class="t-eyebrow block mb-1">Tunnel node</label>
      <select name="node_id" class="r-select w-full">
        <option value="">-- select node --</option>
        {{range .Nodes}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
      </select>
    </div>
    <div id="hpg-tun-ha" class="hidden">
      <label class="t-eyebrow block mb-1">Tunnel nodes (pick 2+ for failover)</label>
      <select name="node_ids" multiple size="4" class="r-select w-full">
        {{range .Nodes}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
      </select>
      <p class="t-caption mt-1" style="color:rgb(var(--muted))">Customer's .conf will list each as a separate [Peer]; kernel picks whichever has a live handshake. Cmd/Ctrl-click to multi-select.</p>
    </div>
    {{if not .Nodes}}<p class="t-caption mt-1" style="color:rgb(var(--danger))">No tunnel-enabled nodes. Edit a node and enable tunnel mode first.</p>{{end}}
    <div class="flex justify-end gap-2 pt-2">
      <button type="button" data-close-tunnel-modal class="r-btn-ghost cursor-pointer">Cancel</button>
      <button type="submit" class="r-btn-primary cursor-pointer">Create</button>
    </div>
  </form>
</div>
{{end}}

<script nonce="{{.CSPNonce}}">
(function(){
  var modal = document.getElementById('hpg-tunnel-modal');
  function open(){ modal.classList.remove('hidden'); modal.classList.add('flex'); }
  function close(){ modal.classList.add('hidden'); modal.classList.remove('flex'); }
  document.querySelectorAll('[data-open-tunnel-modal]').forEach(function(b){ b.addEventListener('click', open); });
  // Mode swap: Single vs HA.
  var modeSel = document.getElementById('hpg-tun-mode');
  var single  = document.getElementById('hpg-tun-single');
  var ha      = document.getElementById('hpg-tun-ha');
  function syncMode(){
    var isHA = modeSel && modeSel.value === '1';
    if (single) single.classList.toggle('hidden', isHA);
    if (ha)     ha.classList.toggle('hidden', !isHA);
  }
  if (modeSel) { modeSel.addEventListener('change', syncMode); syncMode(); }
  document.querySelectorAll('[data-close-tunnel-modal]').forEach(function(b){ b.addEventListener('click', close); });
  modal && modal.addEventListener('click', function(e){ if (e.target === modal) close(); });

  // Copy-to-clipboard.
  document.querySelectorAll('[data-copy-target]').forEach(function(b){
    b.addEventListener('click', function(){
      var t = document.getElementById(b.dataset.copyTarget);
      if (!t) return;
      navigator.clipboard.writeText(t.textContent.trim()).then(function(){
        b.textContent = 'Copied';
        setTimeout(function(){ b.textContent = 'Copy'; }, 1500);
        if (window.hpgToast) window.hpgToast('Copied to clipboard', 'success');
      });
    });
  });

  // Localize + countdown the expiry timestamp.
  document.querySelectorAll('time[data-expires]').forEach(function(el){
    var t = Date.parse(el.dataset.expires);
    if (!t) return;
    function tick(){
      var d = new Date(t);
      var ms = t - Date.now();
      if (ms <= 0) { el.textContent = 'expired'; el.style.color = 'rgb(var(--danger))'; return; }
      var mins = Math.floor(ms / 60000);
      var secs = Math.floor((ms % 60000) / 1000);
      el.textContent = d.toLocaleTimeString() + ' (' + mins + 'm ' + secs + 's left)';
      setTimeout(tick, 1000);
    }
    tick();
  });

  // Live status poll for the just-created tunnel card.
  {{if .NewTunnel}}
  var statusURL = {{.NewTunnel.StatusURL}};
  var badge = document.getElementById('hpg-tun-status');
  var pollCount = 0;
  function poll(){
    if (pollCount++ > 60) return; // give up after ~5 min
    fetch(statusURL).then(function(r){ return r.json(); }).then(function(j){
      if (j.last_handshake) {
        badge.textContent = 'Connected · last handshake ' + j.last_handshake;
        badge.className = 'r-pill r-pill-success';
        return;
      }
      setTimeout(poll, 5000);
    }).catch(function(){ setTimeout(poll, 5000); });
  }
  poll();
  {{end}}
})();
</script>

<script src="/static/js/chart.umd.min.js" nonce="{{.CSPNonce}}"></script>
<script nonce="{{.CSPNonce}}">
(function(){
  if (!window.Chart) return;
  var dark = document.documentElement.classList.contains('dark');
  var gridColor = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
  var tickColor = dark ? '#94a3b8' : '#475569';
  Chart.defaults.color = tickColor;
  Chart.defaults.borderColor = gridColor;

  // chart instances keyed by peer id, so we can destroy/recreate on period change
  var bwCharts = {};

  function fmtBytes(n) {
    if (n >= 1073741824) return (n/1073741824).toFixed(1)+' GB';
    if (n >= 1048576)    return (n/1048576).toFixed(1)+' MB';
    if (n >= 1024)       return (n/1024).toFixed(1)+' KB';
    return n+' B';
  }

  function makeLineChart(canvasId, label, color, labels, data) {
    var el = document.getElementById(canvasId);
    if (!el) return null;
    return new Chart(el, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: label,
          data: data,
          borderColor: color,
          backgroundColor: color.replace(')',',0.12)').replace('rgb','rgba'),
          fill: true,
          tension: 0.3,
          pointRadius: data.length > 30 ? 0 : 2
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: function(v){ return fmtBytes(v); } }
          }
        }
      }
    });
  }

  function loadBandwidth(peerId, period) {
    // Destroy existing charts for this peer.
    if (bwCharts[peerId]) {
      bwCharts[peerId].forEach(function(c){ if(c) c.destroy(); });
    }
    fetch('/admin/tunnels/' + peerId + '/bandwidth.json?period=' + period)
      .then(function(r){ return r.json(); })
      .then(function(d){
        var rxChart = makeLineChart('hpg-bw-rx-'+peerId, 'RX', 'rgb(16,185,129)', d.labels, d.rx);
        var txChart = makeLineChart('hpg-bw-tx-'+peerId, 'TX', 'rgb(14,165,233)',  d.labels, d.tx);
        bwCharts[peerId] = [rxChart, txChart];
      })
      .catch(function(err){ console.warn('bandwidth fetch failed', err); });
  }

  // Wire bandwidth toggle buttons.
  document.querySelectorAll('[data-bw-toggle]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var id = btn.getAttribute('data-bw-toggle');
      var row = document.getElementById('hpg-bw-row-' + id);
      if (!row) return;
      var wasHidden = row.classList.contains('hidden');
      row.classList.toggle('hidden', !wasHidden);
      if (wasHidden) {
        // First open: load 24h data.
        if (!bwCharts[id]) loadBandwidth(id, '24h');
      }
    });
  });

  // Wire period selector buttons inside each bandwidth panel.
  document.querySelectorAll('[data-bw-periods]').forEach(function(bar){
    var id = bar.getAttribute('data-bw-periods');
    bar.querySelectorAll('.hpg-bw-period-btn').forEach(function(b){
      b.addEventListener('click', function(){
        var period = b.getAttribute('data-period');
        // Highlight active button via r-segment is-active class.
        bar.querySelectorAll('.hpg-bw-period-btn').forEach(function(x){
          x.classList.toggle('is-active', x === b);
        });
        loadBandwidth(id, period);
      });
    });
  });
})();
</script>
{{end}}
