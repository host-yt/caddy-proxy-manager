{{define "mtls_crl"}}
<div class="space-y-6">
  {{if .Error}}
  <div class="rounded-xl bg-[rgb(var(--danger)/.12)] ring-1 ring-[rgb(var(--danger)/.4)] p-3 t-small text-[rgb(var(--danger))]">{{.Error}}</div>
  {{end}}

  <section class="r-card flex items-start justify-between gap-4">
    <div>
      <p class="t-eyebrow">mTLS</p>
      <h2 class="t-h3 mt-0.5">Revocation list</h2>
      <p class="t-small text-[rgb(var(--muted))] mt-1">
        Revoked client certificates for CA {{if .CAName}}<strong>{{.CAName}}</strong>{{else}}#{{.CAID}}{{end}}.
        Caddy verifies the cert chain at the TLS handshake; revoked subjects must also be removed from the trust path where applicable.
      </p>
    </div>
    <a href="/admin/mtls" class="r-btn-secondary shrink-0 text-sm">Back to authorities</a>
  </section>

  <section class="r-card !p-0 overflow-hidden">
    <table class="r-table w-full text-sm">
      <thead>
        <tr>
          <th>Subject</th>
          <th>Serial</th>
          <th>Issued</th>
          <th>Expires</th>
          <th>Revoked</th>
        </tr>
      </thead>
      <tbody>
      {{range .Revoked}}
        <tr>
          <td class="font-medium text-[rgb(var(--text))] text-xs">{{.Subject}}</td>
          <td class="font-mono t-caption text-[rgb(var(--muted))]">{{.Serial}}</td>
          <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{.IssuedAt}}</td>
          <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{.NotAfter}}</td>
          <td class="t-caption text-[rgb(var(--danger))] whitespace-nowrap tabular-nums">{{.RevokedAt}}</td>
        </tr>
      {{else}}
        <tr><td colspan="5" class="px-4 py-6 text-center text-[rgb(var(--muted))] text-xs">No revoked certificates for this CA.</td></tr>
      {{end}}
      </tbody>
    </table>
  </section>
</div>
{{end}}
