{{define "node_detail"}}
<div class="space-y-6">
  <div>
    <a href="/admin/nodes" class="text-xs text-slate-500 hover:text-indigo-600">← all nodes</a>
    <p class="text-xs text-slate-500 dark:text-slate-400 font-mono mt-1">{{.Node.PublicHost}}{{if .Node.PublicIP}} · {{.Node.PublicIP}}{{end}} · group {{.Node.GroupName}}</p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="hpg-card">
      <div class="hpg-eyebrow">Health</div>
      <div class="hpg-stat-num mt-1">
        {{if eq .Node.Health "healthy"}}<span class="text-emerald-600">healthy</span>{{else if eq .Node.Health "unhealthy"}}<span class="text-rose-600">unhealthy</span>{{else}}<span class="text-slate-500">{{.Node.Health}}</span>{{end}}
      </div>
      <div class="text-xs text-slate-500 mt-1">{{if .Node.LastSeen}}seen {{.Node.LastSeen}}{{else}}never seen{{end}}</div>
    </div>
    <div class="hpg-card">
      <div class="hpg-eyebrow">Routes</div>
      <div class="hpg-stat-num mt-1">{{.ActiveRoutes}} / {{.RouteCount}}</div>
      <div class="text-xs text-slate-500 mt-1">active / total · cap {{.Node.MaxRoutes}}</div>
    </div>
    <div class="hpg-card">
      <div class="hpg-eyebrow">Failed</div>
      <div class="hpg-stat-num mt-1 {{if .FailedRoutes}}text-rose-600{{else}}text-slate-700 dark:text-slate-200{{end}}">{{.FailedRoutes}}</div>
    </div>
    <div class="hpg-card">
      <div class="hpg-eyebrow">Approval</div>
      <div class="mt-2">
        {{if .Node.Approved}}<span class="hpg-pill hpg-pill-ok">approved</span>{{else}}<span class="hpg-pill hpg-pill-warn">pending</span>{{end}}
      </div>
      <div class="mt-2">
        {{if .Node.Enabled}}<span class="hpg-pill hpg-pill-ok">enabled</span>{{else}}<span class="hpg-pill hpg-pill-muted">disabled</span>{{end}}
      </div>
    </div>
  </div>

  {{if .Node.TunnelEnabled}}
  <section class="hpg-card">
    <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-3">WG tunnel health</h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-xs">
      <div class="rounded-lg bg-slate-50 dark:bg-zinc-800/60 px-3 py-2">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1">MTU</div>
        <div class="font-semibold text-slate-800 dark:text-slate-100">
          {{if .Node.TunnelMTU.Valid}}{{.Node.TunnelMTU.Int32}}{{else}}<span class="text-slate-400">unknown</span>{{end}}
        </div>
      </div>
      <div class="rounded-lg bg-slate-50 dark:bg-zinc-800/60 px-3 py-2">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1">Keepalive</div>
        <div class="font-semibold text-slate-800 dark:text-slate-100">{{.Node.WGKeepalive}}s</div>
      </div>
      <div class="rounded-lg bg-slate-50 dark:bg-zinc-800/60 px-3 py-2">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1">ip_forward</div>
        <div class="font-semibold">
          {{if .Node.FwdIPForward.Valid}}
            {{if .Node.FwdIPForward.Bool}}<span class="text-emerald-600">enabled</span>{{else}}<span class="text-rose-600">DISABLED</span>{{end}}
          {{else}}<span class="text-slate-400">unknown</span>{{end}}
        </div>
      </div>
      <div class="rounded-lg bg-slate-50 dark:bg-zinc-800/60 px-3 py-2">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1">Firewall</div>
        <div class="font-semibold text-slate-800 dark:text-slate-100">
          {{if .Node.FwdFirewallBackend.Valid}}{{.Node.FwdFirewallBackend.String}}{{else}}<span class="text-slate-400">unknown</span>{{end}}
        </div>
      </div>
      {{if .Node.WstunnelHealthy.Valid}}
      <div class="rounded-lg bg-slate-50 dark:bg-zinc-800/60 px-3 py-2">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1">wstunnel</div>
        <div class="font-semibold">
          {{if .Node.WstunnelHealthy.Bool}}<span class="text-emerald-600">healthy</span>{{else}}<span class="text-rose-600">down</span>{{end}}
        </div>
      </div>
      {{end}}
      {{if .Node.FwdPolicyDrop.Valid}}{{if .Node.FwdPolicyDrop.Bool}}
      {{if and .Node.FwdDockerRules.Valid .Node.FwdDockerRules.Bool}}
      {{/* DROP exists but DOCKER-USER accept is active -> Docker-routed forward is covered. Info, not alarm. */}}
      <div class="rounded-lg bg-slate-50 dark:bg-zinc-800/60 px-3 py-2 col-span-2">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1">Forward policy</div>
        <div class="text-slate-600 dark:text-slate-300">Host has FORWARD policy DROP, but Docker forwarding is covered by an active DOCKER-USER accept rule. Backends reached outside Docker (bare-metal/LAN) would still need a host FORWARD accept for wg-tun0.</div>
      </div>
      {{else}}
      <div class="rounded-lg bg-amber-50 dark:bg-amber-900/20 px-3 py-2 col-span-2">
        <div class="text-[10px] uppercase tracking-wide text-amber-600 dark:text-amber-400 mb-1">Forward policy DROP</div>
        <div class="text-amber-700 dark:text-amber-300">Host firewall drops forwarded traffic and no DOCKER-USER accept covers it - tunnel-to-backend may be silently blackholed. Add a FORWARD accept for wg-tun0 (firewalld/ufw/nft).</div>
      </div>
      {{end}}
      {{end}}{{end}}
      {{if .Node.FwdLastSetupError.Valid}}{{if .Node.FwdLastSetupError.String}}
      <div class="rounded-lg bg-rose-50 dark:bg-rose-900/20 px-3 py-2 col-span-4">
        <div class="text-[10px] uppercase tracking-wide text-rose-600 dark:text-rose-400 mb-1">Last setup error</div>
        <div class="font-mono text-rose-700 dark:text-rose-300 break-all">{{.Node.FwdLastSetupError.String}}</div>
      </div>
      {{end}}{{end}}
    </div>
    {{if .Node.FwdReportedAt.Valid}}{{if .Node.FwdReportedAt.String}}
    <p class="mt-2 text-[11px] text-slate-400 dark:text-slate-500">Last agent report: {{.Node.FwdReportedAt.String}}</p>
    {{end}}{{end}}
  </section>
  {{end}}

  <!-- Module capabilities badges -->
  <section class="hpg-card">
    <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-1">Module capabilities</h3>
    <p class="text-[11px] text-slate-500 dark:text-slate-400 mb-3">Which custom Caddy modules are installed on this node</p>
    <div class="flex flex-wrap gap-2">
      {{if .Node.HasWAF}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          WAF (Coraza)
        </span>
      {{else}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-slate-100 text-slate-600 dark:bg-zinc-800 dark:text-zinc-400">
          WAF (Coraza)
        </span>
      {{end}}
      {{if .Node.HasL4}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          L4 Streams
        </span>
      {{else}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-slate-100 text-slate-600 dark:bg-zinc-800 dark:text-zinc-400">
          L4 Streams
        </span>
      {{end}}
      {{if .Node.HasDNSModule}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          DNS-01
        </span>
      {{else}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-slate-100 text-slate-600 dark:bg-zinc-800 dark:text-zinc-400">
          DNS-01
        </span>
      {{end}}
      {{if .Node.HasRateLimit}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Rate limit
        </span>
      {{else}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-slate-100 text-slate-600 dark:bg-zinc-800 dark:text-zinc-400">
          Rate limit
        </span>
      {{end}}
      {{if .Node.HasGeoIP}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          GeoIP
        </span>
      {{else}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-slate-100 text-slate-600 dark:bg-zinc-800 dark:text-zinc-400">
          GeoIP
        </span>
      {{end}}
      {{if .Node.CaddyVersion}}
        <span class="text-xs font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 bg-indigo-50 text-indigo-600 dark:bg-indigo-500/15 dark:text-indigo-300">
          Caddy v{{.Node.CaddyVersion}}
        </span>
      {{end}}
    </div>
    {{if .Node.HasGeoIP}}
    <div class="mt-3 pt-3 border-t border-slate-100 dark:border-zinc-800 text-xs text-slate-500 dark:text-slate-400 flex flex-wrap items-center gap-3">
      <span class="font-medium text-slate-600 dark:text-slate-300">GeoIP DB:</span>
      {{if .GeoIPMeta.Available}}
        <span class="text-emerald-600 dark:text-emerald-400">loaded</span>
      {{else}}
        <span class="text-amber-600 dark:text-amber-400">not loaded</span>
      {{end}}
      {{if .GeoIPMeta.FetchedAt}}
        <span>fetched {{.GeoIPMeta.FetchedAt}}</span>
        {{if .GeoIPMeta.SizeHuman}}<span>{{.GeoIPMeta.SizeHuman}}</span>{{end}}
        {{if .GeoIPMeta.SHA256Short}}<span class="font-mono">{{.GeoIPMeta.SHA256Short}}…</span>{{end}}
      {{else}}
        <span class="text-slate-400">not downloaded yet</span>
      {{end}}
      {{if .GeoIPMeta.LastError}}
        <span class="text-rose-600 dark:text-rose-400" title="Last refresh error">⚠ {{.GeoIPMeta.LastError}}</span>
      {{end}}
      {{if .GeoIPMeta.LastAttempt}}
        <span class="text-slate-400">last attempt {{.GeoIPMeta.LastAttempt}}</span>
      {{end}}
    </div>
    {{end}}
    <div class="mt-3 flex items-center gap-3">
      <button id="btn-reprobe" data-node-id="{{.Node.ID}}"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-700 hover:bg-slate-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700 transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/>
        </svg>
        Re-probe
      </button>
      <span id="reprobe-result" class="text-xs"></span>
    </div>
  </section>

  {{if or .NodeBandwidth24h .NodeRequests24h}}
  <section class="hpg-card">
    <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-3">Traffic · last 24h</h3>
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <p class="text-2xl font-bold text-sky-600 dark:text-sky-400">{{formatBytes .NodeBandwidth24h}}</p>
        <p class="text-xs text-slate-500 mt-0.5">Bandwidth out</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-slate-800 dark:text-slate-100">{{.NodeRequests24h}}</p>
        <p class="text-xs text-slate-500 mt-0.5">Requests</p>
      </div>
    </div>
    {{if .TopRoutesBW}}
    <ul class="space-y-1.5">
      {{range .TopRoutesBW}}
      <li class="flex items-center gap-2">
        <a href="/admin/hosts/{{.RouteID}}/logs" class="text-xs font-medium text-slate-700 dark:text-slate-200 hover:text-indigo-600 dark:hover:text-indigo-400 truncate flex-1">{{.Domain}}</a>
        <span class="text-xs text-slate-500 dark:text-slate-400 flex-shrink-0">{{formatBytes .BytesResp}}</span>
        <span class="text-xs text-slate-400 dark:text-slate-500 flex-shrink-0">{{.Requests}} req</span>
      </li>
      {{end}}
    </ul>
    {{end}}
  </section>
  {{end}}

  {{if .NodeAlerts}}
  <section class="hpg-card !p-0 overflow-hidden">
    <div class="px-5 py-3 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-amber-500 flex-shrink-0">
        <path fill-rule="evenodd" d="M10 2a6 6 0 0 0-6 6c0 1.887-.454 3.665-1.257 5.234a.75.75 0 0 0 .515 1.076 32.91 32.91 0 0 0 3.256.508 3.5 3.5 0 0 0 6.972 0 32.903 32.903 0 0 0 3.256-.508.75.75 0 0 0 .515-1.076A11.448 11.448 0 0 1 16 8a6 6 0 0 0-6-6ZM8.05 14.943a33.54 33.54 0 0 0 3.9 0 2 2 0 0 1-3.9 0Z" clip-rule="evenodd"/>
      </svg>
      <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Recent alerts</h3>
    </div>
    <div class="overflow-x-auto"><table class="w-full text-xs">
      <thead class="text-left uppercase tracking-wide text-slate-500 dark:text-slate-400">
        <tr><th class="px-5 py-2">Severity</th><th class="px-5 py-2">Title</th><th class="px-5 py-2">Time</th></tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .NodeAlerts}}
        <tr>
          <td class="px-5 py-3">
            {{if eq .Severity "critical"}}<span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-semibold bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-300">critical</span>
            {{else if eq .Severity "warning"}}<span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">warning</span>
            {{else}}<span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-semibold bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">{{.Severity}}</span>{{end}}
          </td>
          <td class="px-5 py-3 text-slate-700 dark:text-slate-200">{{.Title}}</td>
          <td class="px-5 py-3 font-mono text-slate-500 dark:text-slate-400">{{.FiredAt}}</td>
        </tr>
        {{end}}
      </tbody>
    </table></div>
  </section>
  {{end}}

  <div class="flex items-center gap-3 flex-wrap">
    <form method="POST" action="/admin/nodes/{{.Node.ID}}/resync">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Resync from DB</button>
    </form>
    <button type="button" id="btn-failover-preview" data-node-id="{{.Node.ID}}"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg ring-1 ring-amber-300 dark:ring-amber-700 text-amber-700 dark:text-amber-400 text-xs font-medium hover:bg-amber-50 dark:hover:bg-amber-500/10 cursor-pointer transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
        <path fill-rule="evenodd" d="M9.661 2.237a.531.531 0 0 1 .678 0 11.947 11.947 0 0 0 7.078 2.749.5.5 0 0 1 .479.425c.069.52.104 1.05.104 1.589 0 5.162-3.26 9.563-7.834 11.256a.48.48 0 0 1-.332 0C5.26 16.563 2 12.162 2 7c0-.539.035-1.069.104-1.589a.5.5 0 0 1 .48-.425 11.947 11.947 0 0 0 7.077-2.749Zm2.56 5.349a.75.75 0 1 0-1.06-1.06L9.25 8.44l-.711-.711a.75.75 0 0 0-1.06 1.06l1.241 1.242a.75.75 0 0 0 1.06 0l2.44-2.445Z" clip-rule="evenodd"/>
      </svg>
      Preview failover
    </button>
    <span class="text-xs text-slate-500 dark:text-slate-400">Rebuild the full Caddy config from the database and POST /load on this node.</span>
  </div>

  <!-- Failover preview modal -->
  <div id="hpg-failover-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
    <div class="hpg-card max-w-2xl w-full relative">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Failover preview</h3>
        <button type="button" data-action="close-failover-modal"
          class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 cursor-pointer transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/>
          </svg>
        </button>
      </div>
      <div id="hpg-failover-modal-body" class="text-sm text-slate-700 dark:text-slate-300">
        Loading...
      </div>
    </div>
  </div>

  <section class="hpg-card !p-0 overflow-hidden">
    <div class="px-5 py-3">
      <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Recent routes (latest 25)</h3>
    </div>
    <div class="overflow-x-auto"><table class="w-full text-sm">
      <thead class="text-left text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">
        <tr><th class="px-5 py-2">Domain</th><th class="px-5 py-2">Upstream</th><th class="px-5 py-2">Client</th><th class="px-5 py-2">Status</th></tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .RecentRoutes}}
        <tr>
          <td class="px-5 py-3 font-mono text-xs">{{.Domain}}</td>
          <td class="px-5 py-3 font-mono text-xs">{{.BackendIP}}:{{.UpstreamPort}}</td>
          <td class="px-5 py-3 text-xs">{{.ClientEmail}}</td>
          <td class="px-5 py-3 text-xs">{{.Status}}{{if .LastError}}<span class="ml-1 text-rose-600" title="{{.LastError}}">⚠</span>{{end}}</td>
        </tr>
        {{else}}
        <tr><td colspan="4" class="px-5 py-6 text-center text-slate-500">No routes assigned.</td></tr>
        {{end}}
      </tbody>
    </table></div>
  </section>

  <section class="hpg-card !p-0 overflow-hidden">
    <div class="px-5 py-3">
      <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Recent audit (latest 20)</h3>
    </div>
    <div class="overflow-x-auto"><table class="w-full text-xs">
      <thead class="text-left uppercase tracking-wide text-slate-500 dark:text-slate-400">
        <tr><th class="px-5 py-2">When</th><th class="px-5 py-2">Actor</th><th class="px-5 py-2">Action</th><th class="px-5 py-2">Meta</th></tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .RecentAudit}}
        <tr>
          <td class="px-5 py-3 font-mono">{{.When}}</td>
          <td class="px-5 py-3">{{.Email}}</td>
          <td class="px-5 py-3 font-mono">{{.Action}}</td>
          <td class="px-5 py-3 font-mono text-slate-500 truncate max-w-md">{{.Meta}}</td>
        </tr>
        {{else}}
        <tr><td colspan="4" class="px-5 py-6 text-center text-slate-500">No node-scoped audit entries yet.</td></tr>
        {{end}}
      </tbody>
    </table></div>
  </section>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  // Open/close failover preview modal.
  document.addEventListener('click', function (e) {
    if (e.target.closest('#btn-failover-preview')) {
      var nodeID = document.getElementById('btn-failover-preview').dataset.nodeId;
      var modal = document.getElementById('hpg-failover-modal');
      var body = document.getElementById('hpg-failover-modal-body');
      body.innerHTML = '<p class="text-slate-500">Loading…</p>';
      modal.classList.remove('hidden');
      fetch('/admin/nodes/' + nodeID + '/failover-preview', {credentials: 'same-origin', headers: {Accept: 'application/json'}})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.error) { body.innerHTML = '<p class="text-rose-600">' + d.error + '</p>'; return; }
          var html = '';
          // Mode warning for non-failover groups.
          if (d.mode === 'single' || d.mode === '') {
            html += '<p class="text-amber-700 dark:text-amber-400">This node group does not have failover mode. No automatic route movement would occur.</p>';
            body.innerHTML = html;
            return;
          }
          // Eligible targets.
          if (!d.eligible_targets || d.eligible_targets.length === 0) {
            html += '<p class="text-rose-600 mb-3">No healthy sibling nodes available for failover.</p>';
          } else {
            html += '<p class="text-xs text-slate-500 dark:text-slate-400 mb-2">Eligible target nodes: ';
            html += d.eligible_targets.map(function (t) { return '<span class="font-medium text-emerald-600">' + t.name + '</span>'; }).join(', ');
            html += '</p>';
          }
          // Routes table.
          if (!d.routes_to_move || d.routes_to_move.length === 0) {
            html += '<p class="text-slate-500">No active routes on this node.</p>';
          } else {
            html += '<div class="overflow-x-auto"><table class="w-full text-xs">';
            html += '<thead class="text-left uppercase tracking-wide text-slate-500 dark:text-slate-400"><tr>';
            html += '<th class="px-3 py-2">Domain</th><th class="px-3 py-2">Status</th><th class="px-3 py-2">Can move</th></tr></thead>';
            html += '<tbody class="divide-y divide-slate-100 dark:divide-zinc-800">';
            d.routes_to_move.forEach(function (route) {
              var indicator = route.can_move
                ? '<span class="text-emerald-600 flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>yes</span>'
                : '<span class="text-rose-600 flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>no' + (route.reason ? ' (' + route.reason + ')' : '') + '</span>';
              html += '<tr><td class="px-3 py-2 font-mono">' + route.domain + '</td>';
              html += '<td class="px-3 py-2">' + route.status + '</td>';
              html += '<td class="px-3 py-2">' + indicator + '</td></tr>';
            });
            html += '</tbody></table></div>';
            // Summary.
            html += '<p class="mt-3 text-xs text-slate-500 dark:text-slate-400">';
            html += '<span class="text-emerald-600 font-medium">' + d.movable_count + '</span> routes can move, ';
            html += '<span class="text-rose-600 font-medium">' + d.blocked_count + '</span> blocked';
            html += '</p>';
          }
          body.innerHTML = html;
        })
        .catch(function () { body.innerHTML = '<p class="text-rose-600">Request failed.</p>'; });
      return;
    }
    if (e.target.closest('[data-action="close-failover-modal"]')) {
      document.getElementById('hpg-failover-modal').classList.add('hidden');
    }
    // Close on backdrop click.
    if (e.target === document.getElementById('hpg-failover-modal')) {
      document.getElementById('hpg-failover-modal').classList.add('hidden');
    }
  });

  // Re-probe capabilities.
  var btnReprobe = document.getElementById('btn-reprobe');
  if (btnReprobe) {
    btnReprobe.addEventListener('click', function () {
      var nodeID = btnReprobe.dataset.nodeId;
      var result = document.getElementById('reprobe-result');
      btnReprobe.disabled = true;
      btnReprobe.textContent = 'Probing…';
      result.textContent = '';
      result.className = 'text-xs';
      fetch('/admin/nodes/' + nodeID + '/probe-capabilities', {method: 'POST', credentials: 'same-origin', headers: {Accept: 'application/json'}})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.ok) {
            result.textContent = d.error || 'Probe failed';
            result.className = 'text-xs text-rose-600 dark:text-rose-400';
            return;
          }
          var parts = [
            'WAF ' + (d.has_waf ? '✓' : '✗'),
            'L4 ' + (d.has_l4 ? '✓' : '✗'),
            'DNS ' + (d.has_dns ? '✓' : '✗'),
            'Rate limit ' + (d.has_rate_limit ? '✓' : '✗'),
            'GeoIP ' + (d.has_geoip ? '✓' : '✗'),
          ];
          result.textContent = 'Updated: ' + parts.join(', ');
          result.className = 'text-xs text-emerald-600 dark:text-emerald-400';
        })
        .catch(function () {
          result.textContent = 'Request failed';
          result.className = 'text-xs text-rose-600 dark:text-rose-400';
        })
        .finally(function () {
          btnReprobe.disabled = false;
          btnReprobe.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg> Re-probe';
        });
    });
  }
})();
</script>
{{end}}
