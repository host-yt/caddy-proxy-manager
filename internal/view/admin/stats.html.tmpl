        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Routes deleted</td><td class="text-right font-mono">{{.Ops.RoutesDeleted}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">SSO-jump logins</td><td class="text-right font-mono">{{.Ops.SSOJumpSuccess}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">SSO-jump denied</td><td class="text-right font-mono">{{.Ops.SSOJumpDenied}}</td></tr>
