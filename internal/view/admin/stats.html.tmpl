        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Backups failed</td><td class="text-right font-mono text-rose-700 dark:text-rose-400">{{.Ops.BackupsFailed}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Webhooks sent</td><td class="text-right font-mono">{{.Ops.WebhookSent}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Webhooks failed</td><td class="text-right font-mono text-rose-700 dark:text-rose-400">{{.Ops.WebhookFailed}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">API keys created</td><td class="text-right font-mono">{{.Ops.APIKeysCreated}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">API keys revoked</td><td class="text-right font-mono">{{.Ops.APIKeysRevoked}}</td></tr>
      </tbody>
    </table>
    <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-3">Raw Prometheus surface: <a class="text-indigo-600 dark:text-indigo-400 hover:underline" href="/metrics" target="_blank" rel="noopener">/metrics</a> (IP-gated by <code>APP_METRICS_ALLOW</code>).</p>
  </section>
</div>
</div><!-- /Security & Ops -->

<script src="/static/js/chart.umd.min.js" nonce="{{.CSPNonce}}"></script>
<script nonce="{{.CSPNonce}}">
(function(){
  var dark = document.documentElement.classList.contains('dark');
  var grid = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
  var tick = dark ? '#94a3b8' : '#475569';
  Chart.defaults.color = tick;
  Chart.defaults.borderColor = grid;

  var charts = [];

  charts.push(new Chart(document.getElementById('routeStatusChart'), {
    type: 'doughnut',
    data: {
      labels: {{.RouteStatusLabels}},
      datasets: [{ data: {{.RouteStatusValues}}, backgroundColor: ['#10b981','#f59e0b','#ef4444','#94a3b8'] }]
    },
    options: { plugins:{legend:{position:'bottom'}}, cutout:'65%' }
  }));

  charts.push(new Chart(document.getElementById('trafficChart'), {
    type: 'line',
    data: {
      labels: {{.TrafficLabels}},
      datasets: [{ label:'req/hour', data: {{.TrafficValues}}, borderColor:'#4f46e5', backgroundColor:'rgba(79,70,229,0.15)', fill:true, tension:0.3, pointRadius:0 }]
    },
    options: { plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}} }
  }));

  charts.push(new Chart(document.getElementById('activityChart'), {
    type: 'bar',
    data: {
      labels: {{.ActivityLabels}},
      datasets: [{ label:'audit events', data: {{.ActivityValues}}, backgroundColor:'#6366f1' }]
    },
    options: { plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}} }
  }));

  // Client-side tabs. Charts inside a hidden pane render at 0px, so resize on reveal.
  var bar = document.querySelector('[data-stats-tabs]');
  if (bar) {
    var tabs = bar.querySelectorAll('.hpg-stats-tab');
    var panes = document.querySelectorAll('[data-pane]');
    var activeCls = ['bg-indigo-600', 'text-white'];
    var inactiveCls = ['bg-white', 'ring-1', 'ring-slate-200', 'dark:bg-zinc-800', 'dark:ring-zinc-700', 'text-slate-700', 'dark:text-slate-300'];
    function show(name){
      tabs.forEach(function(t){
        var on = t.getAttribute('data-tab') === name;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        (on ? inactiveCls : activeCls).forEach(function(c){ t.classList.remove(c); });
        (on ? activeCls : inactiveCls).forEach(function(c){ t.classList.add(c); });
      });
      panes.forEach(function(p){ p.hidden = p.getAttribute('data-pane') !== name; });
      // pane became visible; let charts re-measure their now non-zero container
      requestAnimationFrame(function(){ charts.forEach(function(c){ c.resize(); }); });
      if (history.replaceState) history.replaceState(null, '', '#' + name);
    }
    tabs.forEach(function(t){ t.addEventListener('click', function(){ show(t.getAttribute('data-tab')); }); });
    var initial = (location.hash || '').replace('#','');
    var valid = Array.prototype.some.call(tabs, function(t){ return t.getAttribute('data-tab') === initial; });
    show(valid ? initial : 'overview');
  }
})();
</script>
{{end}}
