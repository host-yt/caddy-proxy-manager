      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Caddy pushes OK</td><td class="text-right font-mono text-emerald-700 dark:text-emerald-400">{{.Ops.CaddyPushes}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Caddy pushes failed</td><td class="text-right font-mono text-rose-700 dark:text-rose-400">{{.Ops.CaddyPushFails}}</td></tr>
        <tr><td class="py-1.5 text-slate-600 dark:text-slate-300">Cache flushes</td><td class="text-right font-mono">{{.Ops.CacheFlushes}}</td></tr>
