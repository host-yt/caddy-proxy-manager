{{define "stats"}}
<!-- Tab bar -->
<nav class="r-segment mb-6" role="tablist" data-stats-tabs>
  <button type="button" class="r-segment-item hpg-stats-tab" data-tab="overview" aria-selected="true">Overview</button>
  <button type="button" class="r-segment-item hpg-stats-tab" data-tab="traffic" aria-selected="false">Traffic</button>
  <button type="button" class="r-segment-item hpg-stats-tab" data-tab="cache" aria-selected="false">Cache</button>
  <button type="button" class="r-segment-item hpg-stats-tab" data-tab="security" aria-selected="false">Security &amp; Ops</button>
</nav>

<!-- Overview -->
<div data-pane="overview">
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <div class="r-card">
    <div class="t-eyebrow">Caddy nodes</div>
    <div class="t-display mt-1 tabular-nums">{{.NodeCount}}</div>
    <div class="t-small mt-1"><span style="color:rgb(var(--success))">{{.NodeHealthy}}</span> healthy · <span style="color:rgb(var(--danger))">{{.NodeDown}}</span> down</div>
  </div>
  <div class="r-card">
    <div class="t-eyebrow">Routes (active)</div>
    <div class="t-display mt-1 tabular-nums">{{.RouteActive}}</div>
    <div class="t-small mt-1 tabular-nums">{{.RoutePending}} pending · {{.RouteFailed}} failed</div>
  </div>
  <div class="r-card">
    <div class="t-eyebrow">Clients</div>
    <div class="t-display mt-1 tabular-nums">{{.ClientCount}}</div>
    <div class="t-small mt-1 tabular-nums">{{.ServiceCount}} services</div>
  </div>
  <div class="r-card">
    <div class="t-eyebrow">Requests / 24h</div>
    <div class="t-display mt-1 tabular-nums">{{.Requests24h}}</div>
    <div class="t-small mt-1 tabular-nums">{{.Errors24h}} errors</div>
  </div>
</div>

<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Route status</h2>
  <div class="max-w-sm mx-auto"><canvas id="routeStatusChart" height="180"></canvas></div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <section class="r-card">
    <h2 class="t-h3 mb-3">Top clients by bandwidth</h2>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr><th>Client</th><th>Services</th><th>Routes</th><th>Active</th><th>Bandwidth 7d</th></tr>
        </thead>
        <tbody>
          {{range .TopClients}}
          <tr>
            <td>{{if gt .ClientID 0}}<a href="/admin/clients/{{.ClientID}}" class="hover:text-[rgb(var(--accent))] transition-colors">{{.Name}}</a>{{else}}{{.Name}}{{end}}</td>
            <td class="tabular-nums">{{.Services}}</td>
            <td class="tabular-nums">{{.Routes}}</td>
            <td class="tabular-nums" style="color:rgb(var(--success))">{{.Active}}</td>
            <td class="font-mono tabular-nums">{{.Bandwidth7dHuman}}</td>
          </tr>
          {{else}}
          <tr><td colspan="5" class="px-3 py-6 text-center t-muted">No clients yet.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3">Recent routes</h2>
    <ul class="divide-y" style="border-color:rgb(var(--border))">
      {{range .RecentRoutes}}
      <li class="py-2 flex items-center justify-between">
        <div class="min-w-0">
          <code class="t-body truncate block">{{.Domain}}{{.PathPrefix}}</code>
          <div class="t-small">→ {{.NodeName}} · port {{.Port}} · {{.CreatedAt}}</div>
        </div>
        <span class="ml-3 flex-shrink-0 {{if eq .Status "active"}}r-pill r-pill-success{{else if eq .Status "failed"}}r-pill r-pill-danger{{else}}r-pill r-pill-warning{{end}}">{{.Status}}</span>
      </li>
      {{else}}
      <li class="py-6 text-center t-muted">No routes yet.</li>
      {{end}}
    </ul>
  </section>
</div>

{{if .RecentSignups}}
<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Recent signups</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
        </tr>
      </thead>
      <tbody>
        {{range .RecentSignups}}
        <tr>
          <td>
            <a href="/admin/users?q={{.Email}}" class="hover:underline cursor-pointer transition-colors" style="color:rgb(var(--accent))">{{.Email}}</a>
          </td>
          <td>
            {{if eq .Role "admin"}}<span class="r-pill r-pill-info">{{.Role}}</span>
            {{else}}<span class="r-pill r-pill-neutral">{{.Role}}</span>
            {{end}}
          </td>
          <td class="font-mono text-xs tabular-nums">{{.CreatedAt}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>
{{end}}

<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Plan distribution</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr><th>Plan</th><th>Clients</th><th>Services</th><th>Routes</th><th>Active</th></tr>
      </thead>
      <tbody>
        {{range .PlanUsage}}
        <tr>
          <td>{{.PlanName}}</td>
          <td class="font-bold tabular-nums">{{.ClientCount}}</td>
          <td class="tabular-nums">{{.ServiceCount}}</td>
          <td class="tabular-nums">{{.RouteCount}}</td>
          <td class="tabular-nums" style="color:rgb(var(--success))">{{.ActiveRoutes}}</td>
        </tr>
        {{else}}
        <tr><td colspan="5" class="px-3 py-6 text-center t-muted">No plans configured.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

{{if .NodeTraffic}}
<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Node traffic (7d)</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr><th>Node</th><th>Bandwidth 7d</th><th>Requests 7d</th><th>Routes</th></tr>
      </thead>
      <tbody>
        {{range .NodeTraffic}}
        <tr>
          <td class="font-medium">{{.NodeName}}</td>
          <td class="font-mono tabular-nums">{{.Bytes7dHuman}}</td>
          <td class="font-mono tabular-nums">{{.Requests7d}}</td>
          <td class="tabular-nums">{{.RouteCount}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>
{{end}}

{{if .PlanViolations}}
<section class="r-card mb-6" style="border-color:rgb(var(--danger) / .4)">
  <h2 class="t-h3 mb-3" style="color:rgb(var(--danger))">Plan violations</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Client</th>
          <th>Plan</th>
          <th>Issue</th>
        </tr>
      </thead>
      <tbody>
        {{range .PlanViolations}}
        <tr>
          <td>
            <a href="/admin/clients/{{.ClientID}}" class="hover:underline cursor-pointer transition-colors" style="color:rgb(var(--accent))">{{.ClientEmail}}</a>
          </td>
          <td>{{.PlanName}}</td>
          <td style="color:rgb(var(--danger))">{{.Reason}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>
{{end}}

{{if .ModuleMismatches}}
<section class="r-card mb-6" style="border-color:rgb(var(--warning) / .4)">
  <h2 class="t-h3 mb-3" style="color:rgb(var(--warning))">Module mismatches (routes using unavailable Caddy modules)</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Domain</th>
          <th>Node</th>
          <th>Missing module</th>
        </tr>
      </thead>
      <tbody>
        {{range .ModuleMismatches}}
        <tr>
          <td>
            <a href="/admin/hosts?q={{.Domain}}" class="hover:underline cursor-pointer transition-colors font-mono" style="color:rgb(var(--accent))">{{.Domain}}</a>
          </td>
          <td>{{.NodeName}}</td>
          <td class="font-medium" style="color:rgb(var(--warning))">{{.Feature}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>
{{end}}

{{if .WAFTopRoutes}}
<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Top WAF events (7d)</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Domain</th>
          <th>Total events</th>
          <th>Blocked</th>
        </tr>
      </thead>
      <tbody>
        {{range .WAFTopRoutes}}
        <tr>
          <td class="font-mono">
            {{if and (ne .Domain "(deleted)") (ne .RouteID 0)}}
            <a href="/admin/waf?route_id={{.RouteID}}" class="hover:underline cursor-pointer transition-colors" style="color:rgb(var(--accent))">{{.Domain}}</a>
            {{else}}
            <span class="t-muted">{{.Domain}}</span>
            {{end}}
          </td>
          <td class="font-mono tabular-nums">{{.EventCount}}</td>
          <td class="font-mono tabular-nums" style="color:rgb(var(--danger))">{{.Blocked}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>
{{end}}
</div><!-- /Overview -->

<!-- Traffic -->
<div data-pane="traffic" hidden>
<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Requests per hour (last 24h, all nodes)</h2>
  <canvas id="trafficChart" height="120"></canvas>
</section>

<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Per-node traffic</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Node</th>
          <th>Health</th>
          <th>Routes</th>
          <th>Req / last hour</th>
          <th>Errors / hour</th>
          <th>Bytes out / hour</th>
          <th>Active conns</th>
        </tr>
      </thead>
      <tbody>
        {{range .NodeStats}}
        <tr>
          <td class="font-medium">{{.Name}}</td>
          <td>
            {{if eq .Health "healthy"}}<span class="r-pill r-pill-success">{{.Health}}</span>
            {{else if eq .Health "down"}}<span class="r-pill r-pill-danger">{{.Health}}</span>
            {{else}}<span class="r-pill r-pill-neutral">{{.Health}}</span>
            {{end}}
          </td>
          <td class="tabular-nums">{{.CurrentRoutes}} / {{.MaxRoutes}}</td>
          <td class="font-mono tabular-nums">{{.RequestsHour}}</td>
          <td class="font-mono tabular-nums" style="color:rgb(var(--danger))">{{.ErrorsHour}}</td>
          <td class="font-mono tabular-nums">{{.BytesOutHourHuman}}</td>
          <td class="font-mono tabular-nums">{{.ActiveConns}}</td>
        </tr>
        {{else}}
        <tr><td colspan="7" class="px-3 py-6 text-center t-muted">No nodes scraped yet. Metrics start populating ~60s after a node comes online.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

{{if .HourlyMax}}
<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Traffic · last 24 hours</h2>
  <div class="flex items-end gap-0.5 h-14 overflow-x-auto pb-1">
    {{range .HourlyTraffic}}
    {{$reqH := mulf (divf .Requests $.HourlyMax) 48.0}}
    {{$errH := mulf (divf .Errors $.HourlyMax) 48.0}}
    <div class="flex flex-col items-center gap-0.5 flex-1 min-w-[8px]" title="{{.HourLabel}} - {{.Requests}} req, {{.Errors}} err">
      <div class="flex items-end gap-px w-full justify-center">
        <div class="rounded-t transition-all w-1.5" style="height:{{printf "%.0f" $reqH}}px;background:rgb(var(--accent))"></div>
        {{if .Errors}}<div class="rounded-t transition-all w-1.5" style="height:{{printf "%.0f" $errH}}px;background:rgb(var(--danger))"></div>{{end}}
      </div>
    </div>
    {{end}}
  </div>
  <div class="flex gap-3 mt-2 t-small">
    <span class="flex items-center gap-1"><span class="inline-block w-3 h-2 rounded-sm" style="background:rgb(var(--accent))"></span>Requests</span>
    <span class="flex items-center gap-1"><span class="inline-block w-3 h-2 rounded-sm" style="background:rgb(var(--danger))"></span>Errors</span>
  </div>
</section>
{{end}}

<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Activity (last 24h)</h2>
  <canvas id="activityChart" height="100"></canvas>
</section>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <div class="r-card">
    <div class="t-eyebrow">Transfer / 24h</div>
    <div class="t-display mt-1 tabular-nums">{{if .BytesTotalHuman}}{{.BytesTotalHuman}}{{else}}-{{end}}</div>
    <div class="t-small mt-1">response bytes</div>
  </div>
  <div class="r-card">
    <p class="t-eyebrow mb-2">Protocol (24h)</p>
    <div class="flex flex-wrap gap-1.5">
      {{range .ProtoBreakdown}}
      {{if eq .Proto "h2"}}<span class="r-pill r-pill-info">{{.Proto}} <span class="tabular-nums font-bold ml-1">{{.Count}}</span></span>
      {{else if eq .Proto "h3"}}<span class="r-pill r-pill-info">{{.Proto}} <span class="tabular-nums font-bold ml-1">{{.Count}}</span></span>
      {{else}}<span class="r-pill r-pill-neutral">{{.Proto}} <span class="tabular-nums font-bold ml-1">{{.Count}}</span></span>
      {{end}}
      {{else}}
      <span class="t-small">No traffic yet.</span>
      {{end}}
    </div>
  </div>
</div>

{{if .TopASNs}}
<section class="r-card mb-6">
  <h2 class="t-h3 mb-3">Top ASNs (7d)</h2>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr><th>Organization</th><th class="text-right">Requests</th></tr>
      </thead>
      <tbody>
        {{range .TopASNs}}
        <tr>
          <td class="font-mono">{{.Org}}</td>
          <td class="text-right font-mono tabular-nums">{{.Count}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>
{{end}}
</div><!-- /Traffic -->

<!-- Cache -->
<div data-pane="cache" hidden>
<section class="r-card mb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="t-h3">Origin cache</h2>
    {{if .Cache.ModuleEnabled}}<span class="r-pill r-pill-success">Souin module available</span>
    {{else}}<span class="r-pill r-pill-neutral">Souin disabled (CACHE_HANDLER_AVAILABLE=0)</span>
    {{end}}
  </div>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    <div>
      <div class="t-eyebrow">Cached routes</div>
      <div class="t-h2 mt-0.5 tabular-nums">{{.Cache.RoutesWithCache}}</div>
    </div>
    <div>
      <div class="t-eyebrow">With Vary key</div>
      <div class="t-h2 mt-0.5 tabular-nums">{{.Cache.RoutesWithVary}}</div>
    </div>
    <div>
      <div class="t-eyebrow">Purge</div>
      <div class="t-small mt-1">Per route - open <em>Edit host</em>, click <em>Purge cache</em>.</div>
    </div>
  </div>
  {{if .Cache.TopCachedHosts}}
  <div class="overflow-x-auto mt-4">
    <table class="r-table">
      <thead>
        <tr>
          <th>Host</th>
          <th>Node</th>
          <th>TTL</th>
          <th>Vary</th>
        </tr>
      </thead>
      <tbody>
        {{range .Cache.TopCachedHosts}}
        <tr>
          <td class="font-mono">{{.Domain}}{{.PathPrefix}}</td>
          <td>{{.NodeName}}</td>
          <td class="font-mono tabular-nums">{{.TTLSecs}}s</td>
          <td class="font-mono">{{if .Vary}}{{.Vary}}{{else}}-{{end}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{end}}
  <p class="t-caption mt-3">Real hit/miss counters land when Souin Prometheus scrape is wired into the node metrics pipeline. This card surfaces routes opted into caching to spot misconfig at a glance.</p>
</section>
</div><!-- /Cache -->

<!-- Security & Ops -->
<div data-pane="security" hidden>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <section class="r-card">
    <h2 class="t-h3 mb-3">Auth &amp; 2FA (last 24h)</h2>
    <div class="grid grid-cols-2 gap-3">
      <div class="rounded-xl p-3" style="background:rgb(var(--success) / .1)">
        <div class="t-eyebrow" style="color:rgb(var(--success))">Logins OK</div>
        <div class="t-display tabular-nums mt-0.5" style="color:rgb(var(--success))">{{.Security.LoginSuccess}}</div>
      </div>
      <div class="rounded-xl p-3" style="background:rgb(var(--danger) / .1)">
        <div class="t-eyebrow" style="color:rgb(var(--danger))">Logins failed</div>
        <div class="t-display tabular-nums mt-0.5" style="color:rgb(var(--danger))">{{.Security.LoginFail}}</div>
      </div>
    </div>
    <div class="mt-4">
      <div class="t-eyebrow mb-2">Login path</div>
      <table class="w-full text-sm">
        <tbody class="divide-y" style="border-color:rgb(var(--border))">
          <tr><td class="py-1.5 t-body">Password</td><td class="text-right font-mono tabular-nums">{{.Security.LoginViaPass}}</td></tr>
          <tr><td class="py-1.5 t-body">OIDC / SSO</td><td class="text-right font-mono tabular-nums">{{.Security.LoginViaOIDC}}</td></tr>
          <tr><td class="py-1.5 t-body">Passkey</td><td class="text-right font-mono tabular-nums">{{.Security.LoginViaPassk}}</td></tr>
          <tr><td class="py-1.5 t-body">SSO jump</td><td class="text-right font-mono tabular-nums">{{.Security.LoginViaSSOJ}}</td></tr>
        </tbody>
      </table>
    </div>
    <div class="mt-4">
      <div class="t-eyebrow mb-2">2FA factor used</div>
      <table class="w-full text-sm">
        <tbody class="divide-y" style="border-color:rgb(var(--border))">
          <tr><td class="py-1.5 t-body">TOTP</td><td class="text-right font-mono tabular-nums">{{.Security.MFATOTP}}</td></tr>
          <tr><td class="py-1.5 t-body">SMS</td><td class="text-right font-mono tabular-nums">{{.Security.MFASMS}}</td></tr>
          <tr><td class="py-1.5 t-body">Email</td><td class="text-right font-mono tabular-nums">{{.Security.MFAEmail}}</td></tr>
          <tr><td class="py-1.5 t-body">Passkey</td><td class="text-right font-mono tabular-nums">{{.Security.MFAPasskey}}</td></tr>
          <tr><td class="py-1.5 t-muted">None (password only)</td><td class="text-right font-mono tabular-nums">{{.Security.MFANone}}</td></tr>
        </tbody>
      </table>
    </div>
    <div class="mt-4 t-small">
      OTP fails: <span class="font-mono tabular-nums">{{.Security.OTPFails}}</span> ·
      Passkeys added: <span class="font-mono tabular-nums">{{.Security.PasskeyAdds}}</span> ·
      removed: <span class="font-mono tabular-nums">{{.Security.PasskeyDels}}</span>
    </div>
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3">Enrollment posture</h2>
    <table class="w-full text-sm">
      <tbody class="divide-y" style="border-color:rgb(var(--border))">
        <tr><td class="py-1.5 t-body">Active admins</td><td class="text-right font-mono tabular-nums">{{.Security.ActiveAdmins}}</td></tr>
        <tr><td class="py-1.5 t-body">Active clients</td><td class="text-right font-mono tabular-nums">{{.Security.ActiveClient}}</td></tr>
        <tr><td class="py-1.5 t-body">Users with TOTP</td><td class="text-right font-mono tabular-nums">{{.Security.UsersWithTOTP}}</td></tr>
        <tr><td class="py-1.5 t-body">Users with SMS 2FA</td><td class="text-right font-mono tabular-nums">{{.Security.UsersWithSMS}}</td></tr>
        <tr><td class="py-1.5 t-body">Users with Email 2FA</td><td class="text-right font-mono tabular-nums">{{.Security.UsersWithMail}}</td></tr>
        <tr><td class="py-1.5 t-body">Users with Passkey</td><td class="text-right font-mono tabular-nums">{{.Security.UsersWithPK}}</td></tr>
      </tbody>
    </table>
    <p class="t-caption mt-3">Pull from <code>users</code> table. A 0 row means the matching migration hasn't run on this database.</p>
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3">Caddy &amp; routes (last 24h)</h2>
    <table class="w-full text-sm">
      <tbody class="divide-y" style="border-color:rgb(var(--border))">
        <tr><td class="py-1.5 t-body">Caddy pushes OK</td><td class="text-right font-mono tabular-nums" style="color:rgb(var(--success))">{{.Ops.CaddyPushes}}</td></tr>
        <tr><td class="py-1.5 t-body">Caddy pushes failed</td><td class="text-right font-mono tabular-nums" style="color:rgb(var(--danger))">{{.Ops.CaddyPushFails}}</td></tr>
        <tr><td class="py-1.5 t-body">Cache flushes</td><td class="text-right font-mono tabular-nums">{{.Ops.CacheFlushes}}</td></tr>
        <tr><td class="py-1.5 t-body">Routes created</td><td class="text-right font-mono tabular-nums">{{.Ops.RoutesCreated}}</td></tr>
        <tr><td class="py-1.5 t-body">Routes deleted</td><td class="text-right font-mono tabular-nums">{{.Ops.RoutesDeleted}}</td></tr>
        <tr><td class="py-1.5 t-body">SSO-jump logins</td><td class="text-right font-mono tabular-nums">{{.Ops.SSOJumpSuccess}}</td></tr>
        <tr><td class="py-1.5 t-body">SSO-jump denied</td><td class="text-right font-mono tabular-nums">{{.Ops.SSOJumpDenied}}</td></tr>
      </tbody>
    </table>
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3">Integrations (last 24h)</h2>
    <table class="w-full text-sm">
      <tbody class="divide-y" style="border-color:rgb(var(--border))">
        <tr><td class="py-1.5 t-body">Backups run</td><td class="text-right font-mono tabular-nums" style="color:rgb(var(--success))">{{.Ops.BackupsRun}}</td></tr>
        <tr><td class="py-1.5 t-body">Backups failed</td><td class="text-right font-mono tabular-nums" style="color:rgb(var(--danger))">{{.Ops.BackupsFailed}}</td></tr>
        <tr><td class="py-1.5 t-body">Webhooks sent</td><td class="text-right font-mono tabular-nums">{{.Ops.WebhookSent}}</td></tr>
        <tr><td class="py-1.5 t-body">Webhooks failed</td><td class="text-right font-mono tabular-nums" style="color:rgb(var(--danger))">{{.Ops.WebhookFailed}}</td></tr>
        <tr><td class="py-1.5 t-body">API keys created</td><td class="text-right font-mono tabular-nums">{{.Ops.APIKeysCreated}}</td></tr>
        <tr><td class="py-1.5 t-body">API keys revoked</td><td class="text-right font-mono tabular-nums">{{.Ops.APIKeysRevoked}}</td></tr>
      </tbody>
    </table>
    <p class="t-caption mt-3">Raw Prometheus surface: <a class="hover:underline" style="color:rgb(var(--accent))" href="/metrics" target="_blank" rel="noopener">/metrics</a> (IP-gated by <code>APP_METRICS_ALLOW</code>).</p>
  </section>
</div>
</div><!-- /Security & Ops -->

<script src="/static/js/chart.umd.min.js" nonce="{{.CSPNonce}}"></script>
<script nonce="{{.CSPNonce}}">
(function(){
  var dark = document.documentElement.classList.contains('dark');
  var grid = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
  var tick = dark ? '#94a3b8' : '#475569';
  Chart.defaults.color = tick;
  Chart.defaults.borderColor = grid;

  var charts = [];

  charts.push(new Chart(document.getElementById('routeStatusChart'), {
    type: 'doughnut',
    data: {
      labels: {{.RouteStatusLabels}},
      datasets: [{ data: {{.RouteStatusValues}}, backgroundColor: ['#10b981','#f59e0b','#ef4444','#94a3b8'] }]
    },
    options: { plugins:{legend:{position:'bottom'}}, cutout:'65%' }
  }));

  charts.push(new Chart(document.getElementById('trafficChart'), {
    type: 'line',
    data: {
      labels: {{.TrafficLabels}},
      datasets: [{ label:'req/hour', data: {{.TrafficValues}}, borderColor:'#4f46e5', backgroundColor:'rgba(79,70,229,0.15)', fill:true, tension:0.3, pointRadius:0 }]
    },
    options: { plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}} }
  }));

  charts.push(new Chart(document.getElementById('activityChart'), {
    type: 'bar',
    data: {
      labels: {{.ActivityLabels}},
      datasets: [{ label:'audit events', data: {{.ActivityValues}}, backgroundColor:'#6366f1' }]
    },
    options: { plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}} }
  }));

  // Client-side tabs. Charts inside hidden panes render at 0px, so resize on reveal.
  var bar = document.querySelector('[data-stats-tabs]');
  if (bar) {
    var tabs = bar.querySelectorAll('.hpg-stats-tab');
    var panes = document.querySelectorAll('[data-pane]');
    function show(name){
      tabs.forEach(function(t){
        var on = t.getAttribute('data-tab') === name;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.classList.toggle('is-active', on);
      });
      panes.forEach(function(p){ p.hidden = p.getAttribute('data-pane') !== name; });
      requestAnimationFrame(function(){ charts.forEach(function(c){ c.resize(); }); });
      if (history.replaceState) history.replaceState(null, '', '#' + name);
    }
    tabs.forEach(function(t){ t.addEventListener('click', function(){ show(t.getAttribute('data-tab')); }); });
    var initial = (location.hash || '').replace('#','');
    var valid = Array.prototype.some.call(tabs, function(t){ return t.getAttribute('data-tab') === initial; });
    show(valid ? initial : 'overview');
  }
})();
</script>
{{end}}
