{{define "backups"}}
<div class="space-y-8">

  <section class="r-card max-w-md">
    <h2 class="t-eyebrow mb-3">Schedule</h2>
    <form method="POST" action="/admin/backups/schedule" class="space-y-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block t-small mb-1" style="color:rgb(var(--muted))">Interval (hours, 0 = disabled)</label>
        <input type="number" min="0" name="interval_hours" value="{{.Schedule.IntervalHours}}" class="r-input w-full tabular-nums">
      </div>
      <div>
        <label class="block t-small mb-1" style="color:rgb(var(--muted))">Retention (days, 0 = keep forever)</label>
        <input type="number" min="0" name="retention_days" value="{{.Schedule.RetentionDays}}" class="r-input w-full tabular-nums">
      </div>
      <label class="flex items-center gap-2 t-small cursor-pointer" style="color:rgb(var(--text))">
        <input type="checkbox" name="encrypt" value="1" {{if .Schedule.EncryptByDef}}checked{{end}} class="r-toggle">
        <span>Encrypt artifacts at rest (AES-256-GCM, key = HKDF(APP_SECRET))</span>
      </label>
      <button class="r-btn-primary">Save schedule</button>
    </form>
  </section>

  <section class="r-card p-0 overflow-hidden">
    <div class="p-5 flex items-center justify-between" style="border-bottom:1px solid rgb(var(--border))">
      <h2 class="t-eyebrow">Destinations</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead>
          <tr>
            <th>Name</th>
            <th>Kind</th>
            <th>Endpoint</th>
            <th>Status</th>
            <th class="text-right"></th>
          </tr>
        </thead>
        <tbody>
          {{range .Destinations}}
            <tr>
              <td class="font-medium">{{.Name}}</td>
              <td>{{.Kind}}</td>
              <td class="t-small" style="color:rgb(var(--muted))">{{.Summary}}</td>
              <td>{{if .Enabled}}<span class="r-pill r-pill-success">enabled</span>{{else}}<span class="r-pill r-pill-neutral">disabled</span>{{end}}</td>
              <td class="text-right space-x-3">
                <form method="POST" action="/admin/backups/destinations/{{.ID}}/test" class="inline">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--accent))">test</button>
                </form>
                <form method="POST" action="/admin/backups/destinations/{{.ID}}/verify" class="inline">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--warning))" title="Download most recent backup, decrypt, walk tar, assert dump.sql present.">verify</button>
                </form>
                <form method="POST" action="/admin/backups/run-now" class="inline">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <input type="hidden" name="destination_id" value="{{.ID}}">
                  <input type="hidden" name="encrypt" value="1">
                  <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--success))">run now</button>
                </form>
                <form method="POST" action="/admin/backups/destinations/{{.ID}}/delete" class="inline"
                      data-confirm="Delete destination {{.Name}}?">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--danger))">delete</button>
                </form>
              </td>
            </tr>
          {{else}}
            <tr><td colspan="5" class="px-5 py-6 text-center" style="color:rgb(var(--muted))">No destinations configured.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>

    <details class="p-5" style="border-top:1px solid rgb(var(--border))">
      <summary class="cursor-pointer t-small font-medium" style="color:rgb(var(--text))">Add destination</summary>
      <form method="POST" action="/admin/backups/destinations" class="mt-4 space-y-3 text-sm max-w-2xl">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block t-small mb-1" style="color:rgb(var(--muted))">Name</label>
            <input name="name" required class="r-input w-full">
          </div>
          <div>
            <label class="block t-small mb-1" style="color:rgb(var(--muted))">Kind</label>
            <select name="kind" class="r-select w-full">
              {{range .NewKindOpts}}<option value="{{.}}">{{.}}</option>{{end}}
            </select>
          </div>
        </div>

        <p class="t-small leading-relaxed" style="color:rgb(var(--muted))">
          Fill the keys for the chosen kind:<br>
          <b>sftp</b>: host, port, user, password OR private_key, host_key (or insecure_host_key=1), path<br>
          <b>ftp</b>: host, port, user, password, tls=explicit|implicit, skip_verify, path<br>
          <b>s3</b>: endpoint, region, bucket, access_key, secret_key, prefix, use_ssl, path_style<br>
          <b>local</b>: path (absolute, inside container)<br>
          <b>Hetzner Storage Box</b>: kind=sftp, host=uXXXXXX.your-storagebox.de, port=23, user=uXXXXXX, password=…, path=./backups
        </p>

        {{$k := .}}
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">host</label><input name="cfg_host" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">port</label><input name="cfg_port" class="r-input w-full tabular-nums"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">user / access_key</label><input name="cfg_user" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">password / secret_key</label><input name="cfg_password" type="password" class="r-input w-full"></div>
          <div class="col-span-2"><label class="block t-small mb-1" style="color:rgb(var(--muted))">private_key (SFTP, PEM)</label><textarea name="cfg_private_key" rows="3" class="r-input w-full font-mono text-xs"></textarea></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">private_key_pass</label><input name="cfg_private_key_pass" type="password" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">host_key (SFTP, "ssh-ed25519 …")</label><input name="cfg_host_key" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">insecure_host_key (0/1)</label><input name="cfg_insecure_host_key" value="0" class="r-input w-full tabular-nums"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">tls (FTP) explicit|implicit</label><input name="cfg_tls" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">skip_verify (0/1)</label><input name="cfg_skip_verify" value="0" class="r-input w-full tabular-nums"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">endpoint (S3)</label><input name="cfg_endpoint" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">region (S3)</label><input name="cfg_region" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">bucket (S3)</label><input name="cfg_bucket" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">access_key (S3)</label><input name="cfg_access_key" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">secret_key (S3)</label><input name="cfg_secret_key" type="password" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">prefix (S3)</label><input name="cfg_prefix" class="r-input w-full"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">use_ssl (S3) 0/1</label><input name="cfg_use_ssl" value="1" class="r-input w-full tabular-nums"></div>
          <div><label class="block t-small mb-1" style="color:rgb(var(--muted))">path_style (S3) 0/1</label><input name="cfg_path_style" value="0" class="r-input w-full tabular-nums"></div>
          <div class="col-span-2"><label class="block t-small mb-1" style="color:rgb(var(--muted))">path / base directory</label><input name="cfg_path" class="r-input w-full"></div>
        </div>
        {{$_ := $k}}

        <button class="r-btn-primary">Save destination</button>
      </form>
    </details>
  </section>

  <section class="r-card max-w-md {{if .Drill.Stale}}ring-2{{end}}" {{if .Drill.Stale}}style="border-color:rgb(var(--danger))"{{end}}>
    <div class="flex items-center justify-between mb-3">
      <h2 class="t-eyebrow">Restore drill</h2>
      <form method="POST" action="/admin/backups/drill/run">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-primary cursor-pointer transition-colors">Run now</button>
      </form>
    </div>
    {{if .Drill.Stale}}
      <p class="t-small font-medium mb-2" style="color:rgb(var(--danger))">
        <svg class="inline w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        {{if .Drill.HasRun}}Last successful drill is older than 7 days.{{else}}Drill has never run.{{end}}
      </p>
    {{end}}
    <dl class="text-sm space-y-1">
      {{if .Drill.HasRun}}
        <div class="flex justify-between">
          <dt style="color:rgb(var(--muted))">Status</dt>
          <dd>{{if .Drill.Success}}<span class="r-pill r-pill-success">ok</span>{{else}}<span class="r-pill r-pill-danger">failed</span>{{end}}</dd>
        </div>
        <div class="flex justify-between">
          <dt style="color:rgb(var(--muted))">Started</dt>
          <dd class="t-small tabular-nums" style="color:rgb(var(--text))">{{.Drill.StartedAt}}</dd>
        </div>
        <div class="flex justify-between">
          <dt style="color:rgb(var(--muted))">Finished</dt>
          <dd class="t-small tabular-nums" style="color:rgb(var(--text))">{{.Drill.FinishedAt}}</dd>
        </div>
        {{if .Drill.ErrorMsg}}
        <div class="mt-1">
          <dt class="t-small" style="color:rgb(var(--muted))">Error</dt>
          <dd class="t-small break-all" style="color:rgb(var(--danger))">{{.Drill.ErrorMsg}}</dd>
        </div>
        {{end}}
      {{else}}
        <div class="t-small" style="color:rgb(var(--muted))">No drill has run yet. Scheduled cadence: every 72 h (leader only).</div>
      {{end}}
    </dl>
  </section>

  <section class="r-card max-w-md">
    <div class="flex items-center gap-2 mb-3">
      <svg class="w-4 h-4 shrink-0" style="color:rgb(var(--muted))" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/>
      </svg>
      <h2 class="t-eyebrow">Manual restore</h2>
    </div>
    <p class="t-small mb-3" style="color:rgb(var(--muted))">
      Restore is an operator action - no panel button. Run a restore drill first to verify backup integrity.
    </p>
    <ol class="space-y-2 t-small list-decimal list-inside" style="color:rgb(var(--text))">
      <li>Download the backup archive from your configured destination (SFTP / S3 / FTP / Local).</li>
      <li>If encrypted, decrypt:<br>
        <code class="font-mono text-[11px] px-1.5 py-0.5 rounded break-all" style="background:rgb(var(--surface-2))">openssl enc -d -aes-256-cbc -pbkdf2 -k "$HPG_BACKUP_KEY" -in backup.enc | tar xz</code>
      </li>
      <li>Stop HPG, restore the MySQL dump:<br>
        <code class="font-mono text-[11px] px-1.5 py-0.5 rounded break-all" style="background:rgb(var(--surface-2))">mysql -u root hpg &lt; dump.sql</code>
      </li>
      <li>Restart HPG service.</li>
    </ol>
  </section>

  <section class="r-card p-0 overflow-hidden">
    <div class="p-5" style="border-bottom:1px solid rgb(var(--border))">
      <h2 class="t-eyebrow">Recent jobs</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead>
          <tr>
            <th>ID</th>
            <th>Destination</th>
            <th>Kind</th>
            <th>Status</th>
            <th>Size (KB)</th>
            <th>Enc</th>
            <th>Started</th>
            <th>Finished</th>
            <th>Artifact</th>
          </tr>
        </thead>
        <tbody>
          {{range .Jobs}}
            <tr>
              <td class="tabular-nums">{{.ID}}</td>
              <td>{{.DestName}}</td>
              <td>{{.Kind}}</td>
              <td>
                {{if eq .Status "succeeded"}}<span class="r-pill r-pill-success">{{.Status}}</span>
                {{else if eq .Status "failed"}}<span class="r-pill r-pill-danger">{{.Status}}</span>
                {{else}}<span class="r-pill r-pill-warning">{{.Status}}</span>{{end}}
              </td>
              <td class="tabular-nums">{{.SizeKB}}</td>
              <td>{{if .Encrypted}}yes{{else}}no{{end}}</td>
              <td class="t-small tabular-nums" style="color:rgb(var(--muted))">{{.StartedAt}}</td>
              <td class="t-small tabular-nums" style="color:rgb(var(--muted))">{{.FinishedAt}}</td>
              <td class="t-small" style="color:rgb(var(--muted))">{{.ArtifactKey}}{{if .Error}}<br><span style="color:rgb(var(--danger))">{{.Error}}</span>{{end}}</td>
            </tr>
          {{else}}
            <tr><td colspan="9" class="px-5 py-6 text-center" style="color:rgb(var(--muted))">No backups yet.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

</div>
{{end}}
