{{define "deployment"}}
<div class="max-w-4xl space-y-6">

  <!-- Current profile summary -->
  <div class="r-card space-y-3">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="t-eyebrow">Current deployment mode</div>
        <h2 class="t-h2 mt-1" style="color:rgb(var(--text))">{{.CurrentLabel}}</h2>
        <p class="t-small mt-1" style="color:rgb(var(--muted))">{{.CurrentDescription}}</p>
      </div>
      <span class="r-pill r-pill-success flex items-center gap-1.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        Active
      </span>
    </div>
    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-3 t-small pt-1">
      <div><dt style="color:rgb(var(--muted))">UI mode</dt><dd class="font-medium mt-0.5" style="color:rgb(var(--text))">{{.CurrentUIMode}}</dd></div>
      <div><dt style="color:rgb(var(--muted))">Tenant mode</dt><dd class="font-medium mt-0.5" style="color:rgb(var(--text))">{{.CurrentTenantMode}}</dd></div>
      <div><dt style="color:rgb(var(--muted))">RBAC mode</dt><dd class="font-medium mt-0.5" style="color:rgb(var(--text))">{{.CurrentRBACMode}}</dd></div>
      <div><dt style="color:rgb(var(--muted))">Database</dt><dd class="font-medium mt-0.5 uppercase" style="color:rgb(var(--text))">{{.DBDriver}}</dd></div>
    </dl>
  </div>

  <!-- SQLite note: only MySQL is selectable today -->
  {{if not .SQLiteAvailable}}
  <div class="rounded-xl p-3 flex items-start gap-2 t-small" style="background:rgb(var(--warning) / .1);border:1px solid rgb(var(--warning) / .3);color:rgb(var(--warning))">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0 mt-0.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
    <span>SQLite is not wired yet, so MySQL/MariaDB is the only available database regardless of a profile's recommendation. Lower profiles still recommend SQLite for when it lands.</span>
  </div>
  {{end}}

  <!-- Profile cards + switch form -->
  <form method="POST" action="/admin/deployment" class="space-y-4">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {{range .Options}}
      <label class="block r-card p-4 transition-colors {{if $.CanSwitch}}cursor-pointer{{end}}"
             style="{{if .Current}}border-color:rgb(var(--accent));background:rgb(var(--accent-weak)){{end}}">
        <div class="flex items-start gap-3">
          {{if $.CanSwitch}}
          <input type="radio" name="profile" value="{{.Value}}" {{if .Current}}checked{{end}} class="mt-1" style="accent-color:rgb(var(--accent))">
          {{end}}
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-semibold" style="color:rgb(var(--text))">{{.Label}}</span>
              {{if .Current}}<span class="r-pill r-pill-info">Current</span>{{end}}
              {{if and (not .Current) .IsUpgrade}}<span class="r-pill r-pill-success">Upgrade</span>{{end}}
              {{if .IsDowngrade}}<span class="r-pill r-pill-warning">Downgrade</span>{{end}}
            </div>
            <p class="t-small mt-1" style="color:rgb(var(--muted))">{{.Description}}</p>
            <p class="t-caption mt-2" style="color:rgb(var(--muted))">
              Recommended DB: <span class="font-medium uppercase" style="color:rgb(var(--text))">{{.RecommendDB}}</span>{{if .RequireMySQL}} (required){{end}}
            </p>
          </div>
        </div>
      </label>
      {{end}}
    </div>

    {{if .CanSwitch}}
    <div class="r-card space-y-3" style="background:rgb(var(--surface-2) / .5)">
      <label class="flex items-start gap-2 t-small cursor-pointer" style="color:rgb(var(--text))">
        <input type="checkbox" name="confirm_downgrade" value="yes" class="mt-0.5" style="accent-color:rgb(var(--warning))">
        <span>I understand that picking a lower (downgrade) profile <strong>hides</strong> its extra modules. No data is deleted - it is only hidden until you switch back.</span>
      </label>
      <div class="flex justify-end">
        <button type="submit" class="r-btn-primary cursor-pointer transition-colors">Switch deployment mode</button>
      </div>
    </div>
    {{else}}
    <p class="t-small" style="color:rgb(var(--muted))">Read-only view. Only a super admin can change the deployment mode.</p>
    {{end}}
  </form>

</div>
{{end}}
