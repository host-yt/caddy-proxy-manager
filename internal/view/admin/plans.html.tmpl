{{define "plans"}}
<section class="r-card !p-0 overflow-hidden">
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-[rgb(var(--border))]">
    <div class="flex items-center gap-3">
      <div class="icon-chip">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/>
        </svg>
      </div>
      <div>
        <p class="t-eyebrow">Catalog</p>
        <h2 class="t-h3">Plans</h2>
      </div>
      <span class="r-pill r-pill-neutral">{{len .Plans}}</span>
    </div>
    {{if .CanManage}}<button type="button" id="plan-new-btn" class="r-btn-primary cursor-pointer">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      New plan
    </button>{{end}}
  </div>
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Kind</th>
          <th>Max domains</th>
          <th>Max ports</th>
          <th>SSL</th>
          <th>Path</th>
          <th>WS</th>
          <th>Ext proxy</th>
          <th>Node group</th>
          <th>WG key rotation</th>
          <th>Services</th>
          <th>Clients</th>
          <th>Routes</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range .Plans}}
        <tr>
          <td class="font-medium whitespace-nowrap">{{.Name}}</td>
          <td>
            {{if eq .Kind "npm"}}<span class="r-pill r-pill-info">NPM</span>{{else}}<span class="r-pill r-pill-neutral">restricted</span>{{end}}
          </td>
          <td>{{.MaxDomains}}</td>
          <td>{{.MaxPorts}}</td>
          <td>{{if .SSL}}<span class="r-pill r-pill-success">yes</span>{{else}}<span class="r-pill r-pill-neutral">no</span>{{end}}</td>
          <td>{{if .PathRouting}}<span class="r-pill r-pill-success">yes</span>{{else}}<span class="r-pill r-pill-neutral">no</span>{{end}}</td>
          <td>{{if .WebSocket}}<span class="r-pill r-pill-success">yes</span>{{else}}<span class="r-pill r-pill-neutral">no</span>{{end}}</td>
          <td>{{if .ExternalProxy}}<span class="r-pill r-pill-success">yes</span>{{else}}<span class="r-pill r-pill-neutral">no</span>{{end}}</td>
          <td class="whitespace-nowrap">{{.NodeGroupName}}</td>
          <td>{{if .WGKeyRotationDays}}{{.WGKeyRotationDays}}d{{else}}<span class="text-[rgb(var(--muted))]">inherit</span>{{end}}</td>
          <td>{{if .ServiceCount}}{{.ServiceCount}}{{else}}-{{end}}</td>
          <td>{{if .ClientCount}}{{.ClientCount}}{{else}}-{{end}}</td>
          <td>{{if .RouteCount}}{{.RouteCount}}{{else}}-{{end}}</td>
          <td class="text-right whitespace-nowrap">
            {{if not .Owned}}<span class="r-pill r-pill-neutral">global</span>{{else}}
            <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="plan-act-{{.ID}}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
            </button>
            <div id="plan-act-{{.ID}}" class="hpg-act-menu" role="menu">
              <button type="button"
                class="plan-edit-btn hpg-act-item"
                role="menuitem"
                data-id="{{.ID}}"
                data-name="{{.Name}}"
                data-kind="{{.Kind}}"
                data-maxdomains="{{.MaxDomains}}"
                data-maxports="{{.MaxPorts}}"
                data-ssl="{{if .SSL}}1{{else}}0{{end}}"
                data-pathrouting="{{if .PathRouting}}1{{else}}0{{end}}"
                data-websocket="{{if .WebSocket}}1{{else}}0{{end}}"
                data-wildcard="{{if .Wildcard}}1{{else}}0{{end}}"
                data-externalproxy="{{if .ExternalProxy}}1{{else}}0{{end}}"
                data-allowegressip="{{if .AllowEgressIP}}1{{else}}0{{end}}"
                data-ratelimit="{{.RateLimitRPM}}"
                data-nodegroup="{{.NodeGroupID}}"
                data-wgkeyrotdays="{{.WGKeyRotationDays}}">Edit</button>
              <form method="POST" action="/admin/plans/{{.ID}}/delete" class="contents" data-confirm="Delete plan {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Delete</button>
              </form>
            </div>
            {{end}}
          </td>
        </tr>
        {{else}}
        <tr><td colspan="14" class="px-4 py-16 text-center">
          <div class="flex flex-col items-center gap-3">
            <div class="icon-chip w-12 h-12">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
            </div>
            <p class="t-body font-medium">No plans yet</p>
            <p class="t-small text-[rgb(var(--muted))] max-w-xs">Create a plan to define feature limits for client service accounts.</p>
          </div>
        </td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

<!-- Create/Edit modal -->
<div id="plan-modal" class="fixed inset-0 z-50 hidden">
  <div id="plan-modal-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-center justify-center overflow-y-auto p-4 sm:p-6">
    <div class="r-card w-full max-w-lg max-h-[90vh] overflow-y-auto relative" role="dialog" aria-modal="true">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="t-eyebrow">Catalog</p>
          <h2 id="plan-modal-title" class="t-h3">New plan</h2>
        </div>
        <button type="button" id="plan-modal-close"
          class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] transition-colors cursor-pointer" aria-label="Close">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <form id="plan-form" method="POST" action="/admin/plans" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="t-eyebrow block mb-1.5">Name</label>
          <input name="name" required class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Plan kind</label>
          <select name="kind" class="r-select w-full">
            <option value="restricted" selected>Restricted - admin pins backend IP + port range</option>
            <option value="npm">NPM-style - client edits backend IP + ports themselves</option>
          </select>
          <p class="t-caption text-[rgb(var(--muted))] mt-1">Restricted enforces the hosting-provider model (sell port slices on shared backends). NPM-style hands full control to the customer; only use for trusted resellers / self-use accounts.</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="t-eyebrow block mb-1.5">Max domains</label>
            <input name="max_domains" type="number" min="1" value="5" required class="r-input w-full font-mono">
          </div>
          <div>
            <label class="t-eyebrow block mb-1.5">Max ports</label>
            <input name="max_ports" type="number" min="1" value="20" required class="r-input w-full font-mono">
          </div>
        </div>
        <div class="space-y-2.5">
          <label class="flex items-center gap-2 cursor-pointer t-small"><input type="checkbox" name="ssl" value="1" checked class="rounded"> SSL enabled</label>
          <label class="flex items-center gap-2 cursor-pointer t-small"><input type="checkbox" name="path_routing" value="1" class="rounded"> Path routing</label>
          <label class="flex items-center gap-2 cursor-pointer t-small"><input type="checkbox" name="websocket" value="1" checked class="rounded"> WebSocket</label>
          <label class="flex items-center gap-2 cursor-pointer t-small"><input type="checkbox" name="wildcard" value="1" class="rounded"> Wildcard domains</label>
          <label class="flex items-center gap-2 cursor-pointer t-small"><input type="checkbox" name="external_proxy" value="1" class="rounded"> Allow external HTTPS upstream proxy</label>
          <label class="flex items-center gap-2 cursor-pointer t-small"><input type="checkbox" name="allow_egress_ip" value="1" class="rounded"> Allow custom egress IP (fixed/random)</label>
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Rate limit (req/min, 0 = none)</label>
          <input name="rate_limit_rpm" type="number" min="0" value="0" class="r-input w-full font-mono">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">WG key rotation (days, 0 = inherit global)</label>
          <input name="wg_key_rotation_days" type="number" min="0" value="0" class="r-input w-full font-mono">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Node group</label>
          <select name="node_group_id" required class="r-select w-full">
            {{range .Groups}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
          </select>
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="plan-modal-cancel" class="r-btn-ghost cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save plan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  var modal = document.getElementById("plan-modal");
  var form = document.getElementById("plan-form");
  var title = document.getElementById("plan-modal-title");
  if (!modal || !form) return;

  function setVal(name, value) {
    var el = form.elements[name];
    if (el) el.value = (value == null ? "" : value);
  }
  // Checkbox prefill: data-* booleans are "1"/"0".
  function setCheck(name, value) {
    var el = form.elements[name];
    if (el) el.checked = (value === "1");
  }

  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  // Create mode: reset form, post to collection endpoint.
  document.getElementById("plan-new-btn").addEventListener("click", function () {
    form.reset();
    form.action = "/admin/plans";
    if (title) title.textContent = "New plan";
    open();
  });

  // Edit mode: prefill from data-* attrs, post to /{id}/edit.
  var editBtns = document.querySelectorAll(".plan-edit-btn");
  for (var i = 0; i < editBtns.length; i++) {
    editBtns[i].addEventListener("click", function () {
      var d = this.dataset;
      form.action = "/admin/plans/" + d.id + "/edit";
      if (title) title.textContent = "Edit plan";
      setVal("name", d.name);
      setVal("kind", d.kind);
      setVal("max_domains", d.maxdomains);
      setVal("max_ports", d.maxports);
      setCheck("ssl", d.ssl);
      setCheck("path_routing", d.pathrouting);
      setCheck("websocket", d.websocket);
      setCheck("wildcard", d.wildcard);
      setCheck("external_proxy", d.externalproxy);
      setCheck("allow_egress_ip", d.allowegressip);
      setVal("rate_limit_rpm", d.ratelimit);
      setVal("wg_key_rotation_days", d.wgkeyrotdays || "0");
      setVal("node_group_id", d.nodegroup);
      open();
    });
  }

  var closeBtn = document.getElementById("plan-modal-close");
  var cancelBtn = document.getElementById("plan-modal-cancel");
  var overlay = document.getElementById("plan-modal-overlay");
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });
})();
</script>
{{end}}
