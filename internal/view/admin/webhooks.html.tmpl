{{define "webhooks"}}
<div class="space-y-6">

  <section class="r-card p-0 overflow-hidden">
    <div class="p-5" style="border-bottom:1px solid rgb(var(--border))">
      <h2 class="t-h3" style="color:rgb(var(--text))">Endpoints</h2>
      <p class="t-small mt-1" style="color:rgb(var(--muted))">Events POSTed as JSON with HMAC-SHA256 in <code>X-HPG-Signature</code>. Supported event types: <code>route.created</code>, <code>route.active</code>, <code>route.failed</code>, <code>node.joined</code>, <code>node.approved</code>, <code>node.down</code>, <code>cert.issued</code>, <code>backup.success</code>, <code>backup.failed</code>. Use <code>*</code> for all, or a pattern like <code>route.*</code>.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead>
          <tr>
            <th>Name</th>
            <th>URL</th>
            <th>Events</th>
            <th>Enabled</th>
            <th>Created</th>
            <th>Last delivery</th>
            <th class="text-right"></th>
          </tr>
        </thead>
        <tbody>
          {{range .Endpoints}}
          <tr>
            <td class="font-medium">{{.Name}}</td>
            <td class="t-small"><code>{{.URL}}</code></td>
            <td class="t-small" style="color:rgb(var(--muted))">{{.Events}}</td>
            <td>{{if .Enabled}}<span class="r-pill r-pill-success">yes</span>{{else}}<span class="r-pill r-pill-neutral">no</span>{{end}}</td>
            <td class="t-small tabular-nums" style="color:rgb(var(--muted))">{{.Created}}</td>
            <td class="t-small">
              {{if eq .LastDelivStatus "never"}}<span style="color:rgb(var(--muted))">never</span>
              {{else if eq .LastDelivStatus "success"}}<span class="r-pill r-pill-success">&#10003; {{.LastDelivHTTP}}</span><span class="t-small ml-1" style="color:rgb(var(--muted))">{{.LastDelivAge}}</span>
              {{else if eq .LastDelivStatus "failed"}}<span class="r-pill r-pill-danger" title="{{.LastDelivErr}}">&#10007; {{.LastDelivHTTP}}</span><span class="t-small ml-1" style="color:rgb(var(--muted))">{{.LastDelivAge}}</span>
              {{else}}<span class="r-pill r-pill-warning">pending</span>{{end}}
            </td>
            <td class="text-right space-x-3">
              <form method="POST" action="/admin/webhooks/{{.ID}}/test" class="inline">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--accent))">test</button>
              </form>
              <form method="POST" action="/admin/webhooks/{{.ID}}/rotate-secret" class="inline" data-confirm="Rotate signing secret for {{.Name}}? Current secret will stop working immediately.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="t-small cursor-pointer hover:underline" style="color:rgb(var(--warning))">rotate secret</button>
              </form>
              <form method="POST" action="/admin/webhooks/{{.ID}}/delete" class="inline" data-confirm="Delete {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--danger))">delete</button>
              </form>
            </td>
          </tr>
          {{else}}
          <tr><td colspan="7" class="px-4 py-6 text-center" style="color:rgb(var(--muted))">No endpoints configured.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3" style="color:rgb(var(--text))">Add endpoint</h2>
    <form method="POST" action="/admin/webhooks" class="space-y-3 text-sm max-w-2xl">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block t-small mb-1" style="color:rgb(var(--muted))">Name</label>
          <input name="name" required class="r-input w-full">
        </div>
        <div>
          <label class="block t-small mb-1" style="color:rgb(var(--muted))">Events pattern</label>
          <input name="events" value="*" required class="r-input w-full">
        </div>
      </div>
      <div>
        <label class="block t-small mb-1" style="color:rgb(var(--muted))">URL</label>
        <input name="url" type="url" required placeholder="https://billing.example.com/hooks/hpg" class="r-input w-full font-mono text-xs">
      </div>
      <div>
        <label class="block t-small mb-1" style="color:rgb(var(--muted))">HMAC secret (stored encrypted; receiver verifies <code>X-HPG-Signature</code>)</label>
        <input name="secret" type="password" class="r-input w-full">
      </div>
      <label class="flex items-center gap-2 t-small cursor-pointer" style="color:rgb(var(--text))">
        <input type="checkbox" name="enabled" value="1" checked class="r-toggle"> Enabled
      </label>
      <button class="r-btn-primary">Save endpoint</button>
    </form>
  </section>

  <section class="r-card p-0 overflow-hidden">
    <div class="p-5" style="border-bottom:1px solid rgb(var(--border))">
      <h2 class="t-h3" style="color:rgb(var(--text))">Recent deliveries</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead>
          <tr>
            <th>ID</th>
            <th>Endpoint</th>
            <th>Event</th>
            <th>Status</th>
            <th>HTTP</th>
            <th>Tries</th>
            <th>Created</th>
            <th>Error</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{range .Deliveries}}
          <tr>
            <td class="tabular-nums">{{.ID}}</td>
            <td>{{.EndpointID}}</td>
            <td class="t-small">{{.EventType}}</td>
            <td>
              {{if or (eq .Status "success") (eq .Status "delivered")}}<span class="r-pill r-pill-success">{{.Status}}</span>
              {{else if or (eq .Status "failed") (eq .Status "dead") (eq .Status "error")}}<span class="r-pill r-pill-danger">{{.Status}}</span>
              {{else if eq .Status "pending"}}<span class="r-pill r-pill-warning">{{.Status}}</span>
              {{else}}<span class="r-pill r-pill-neutral">{{.Status}}</span>{{end}}
            </td>
            <td class="tabular-nums">{{if .HTTPCode}}{{.HTTPCode}}{{else}}-{{end}}</td>
            <td class="tabular-nums">{{.Attempts}}</td>
            <td class="t-small tabular-nums" style="color:rgb(var(--muted))">{{.CreatedAt}}</td>
            <td class="t-small" style="color:rgb(var(--danger))">{{.LastError}}</td>
            <td>
              {{if or (eq .Status "failed") (eq .Status "dead") (eq .Status "error")}}
              <form method="POST" action="/admin/webhooks/deliveries/{{.ID}}/retry" class="inline">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="r-btn-secondary t-small cursor-pointer transition-colors">retry</button>
              </form>
              {{end}}
            </td>
          </tr>
          {{else}}
          <tr><td colspan="9" class="px-4 py-6 text-center" style="color:rgb(var(--muted))">No deliveries yet.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>
</div>
{{end}}
