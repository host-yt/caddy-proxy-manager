{{define "dashboard"}}
<!-- Hero greeting -->
<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
  <div>
    <p class="t-eyebrow mb-1">Overview</p>
    <h1 class="t-h1">Welcome{{if .AdminName}}, {{.AdminName}}{{end}}</h1>
    <p class="t-small mt-1">Here is what needs your attention today.</p>
  </div>
  <a href="/admin/hosts/new" class="r-btn-primary inline-flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
    Add a host
  </a>
</div>

<!-- KPI stat row -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-5">
  <div class="r-card flex items-center gap-4">
    <span class="icon-chip" style="background:rgb(var(--accent)/.12);color:rgb(var(--accent))">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="t-eyebrow">Active hosts</p>
      <p class="t-display">{{.Counts.ActiveHosts}}</p>
      <p class="t-caption">of {{.Counts.TotalHosts}} total</p>
    </div>
  </div>

  <div class="r-card flex items-center gap-4">
    <span class="icon-chip" style="background:rgb(var(--warning)/.12);color:rgb(var(--warning))">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="t-eyebrow">Pending</p>
      <p class="t-display {{if .Counts.PendingHosts}}" style="color:rgb(var(--warning)){{end}}">{{.Counts.PendingHosts}}</p>
      <p class="t-caption">awaiting DNS/SSL</p>
    </div>
  </div>

  <div class="r-card flex items-center gap-4">
    <span class="icon-chip" style="background:rgb(var(--info,56 189 248)/.12);color:rgb(var(--info,56 189 248))">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3V6a3 3 0 013-3h13.5a3 3 0 013 3v5.25a3 3 0 01-3 3m-13.5 0H3m18.75 0H21m-1.5 0v5.25m-15-5.25v5.25m0 0H3m1.5 0h15m0 0H21M9 18h6"/></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="t-eyebrow">Nodes online</p>
      <p class="t-display">{{.Counts.NodesOnline}}<span class="t-body" style="color:rgb(var(--muted))">/{{.Counts.NodesTotal}}</span></p>
      <p class="t-caption {{if lt .Counts.NodesOnline .Counts.NodesTotal}}" style="color:rgb(var(--warning)){{else}}" style="color:rgb(var(--success)){{end}}">{{if lt .Counts.NodesOnline .Counts.NodesTotal}}degraded{{else}}healthy{{end}}</p>
    </div>
  </div>

  <div class="r-card flex items-center gap-4">
    <span class="icon-chip" style="background:rgb(var(--success)/.12);color:rgb(var(--success))">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="t-eyebrow">Clients</p>
      <p class="t-display">{{.Counts.Clients}}</p>
      <p class="t-caption">{{.Counts.Plans}} plan{{if ne .Counts.Plans 1}}s{{end}}</p>
      {{if .Counts.SuspendedServices}}
      <a href="/admin/services?status=suspended" class="t-caption cursor-pointer hover:underline" style="color:rgb(var(--warning))">{{.Counts.SuspendedServices}} suspended</a>
      {{end}}
    </div>
  </div>
</div>

<!-- System health pills -->
<div class="flex flex-wrap items-center gap-2 mb-6">
  <span class="r-pill {{if lt .Counts.NodesOnline .Counts.NodesTotal}}r-pill-warning{{else}}r-pill-success{{end}}">
    <span class="h-1.5 w-1.5 rounded-full inline-block mr-1 {{if lt .Counts.NodesOnline .Counts.NodesTotal}}bg-current{{else}}bg-current{{end}}"></span>
    {{if lt .Counts.NodesOnline .Counts.NodesTotal}}Fleet degraded{{else}}Fleet healthy{{end}}
  </span>
  {{if .Counts.FailedHosts}}
  <a href="/admin/hosts?status=failed" class="r-pill r-pill-danger cursor-pointer transition-colors">
    <span class="h-1.5 w-1.5 rounded-full bg-current inline-block mr-1"></span>
    {{.Counts.FailedHosts}} host{{if ne .Counts.FailedHosts 1}}s{{end}} failed
  </a>
  {{end}}
  {{if .Counts.PendingHosts}}
  <a href="/admin/hosts?status=pending_dns" class="r-pill r-pill-info cursor-pointer transition-colors">
    <span class="h-1.5 w-1.5 rounded-full bg-current inline-block mr-1 animate-pulse"></span>
    {{.Counts.PendingHosts}} provisioning
  </a>
  {{end}}
  {{if .Counts.MTLSCAsExpiringSoon}}
  <a href="/admin/mtls" class="r-pill r-pill-warning cursor-pointer transition-colors">
    <span class="h-1.5 w-1.5 rounded-full bg-current inline-block mr-1"></span>
    {{.Counts.MTLSCAsExpiringSoon}} mTLS CA expiring
  </a>
  {{end}}
</div>

<!-- Needs attention -->
<section class="r-card mb-6">
  <div class="flex items-center gap-3 mb-4">
    <span class="icon-chip" style="background:rgb(var(--warning)/.12);color:rgb(var(--warning))">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
    </span>
    <div>
      <h2 class="t-h3">Needs attention</h2>
      <p class="t-caption">Highest-priority signals across the fleet.</p>
    </div>
  </div>
  {{if .Attention}}
  <ul class="space-y-2">
    {{range .Attention}}
    <li>
      <a href="{{.URL}}" class="group flex items-center gap-3 rounded-xl px-3 py-2.5 ring-1 border-l-4 transition-colors cursor-pointer
        {{if eq .Severity "error"}}border-l-[rgb(var(--danger))] ring-[rgb(var(--danger)/.25)] bg-[rgb(var(--danger)/.08)] hover:bg-[rgb(var(--danger)/.12)]
        {{else if eq .Severity "warn"}}border-l-[rgb(var(--warning))] ring-[rgb(var(--warning)/.25)] bg-[rgb(var(--warning)/.08)] hover:bg-[rgb(var(--warning)/.12)]
        {{else}}border-l-[rgb(var(--accent))] ring-[rgb(var(--accent)/.25)] bg-[rgb(var(--accent)/.08)] hover:bg-[rgb(var(--accent)/.12)]{{end}}">
        <span class="h-2.5 w-2.5 rounded-full flex-shrink-0
          {{if eq .Severity "error"}}bg-[rgb(var(--danger))]{{else if eq .Severity "warn"}}bg-[rgb(var(--warning))]{{else}}bg-[rgb(var(--accent))]{{end}}"></span>
        <span class="t-small flex-1 min-w-0
          {{if eq .Severity "error"}}text-[rgb(var(--danger))]{{else if eq .Severity "warn"}}text-[rgb(var(--warning))]{{else}}text-[rgb(var(--accent))]{{end}}">{{.Text}}</span>
        <span class="r-pill {{if eq .Severity "error"}}r-pill-danger{{else if eq .Severity "warn"}}r-pill-warning{{else}}r-pill-info{{end}}">{{.Severity}}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 opacity-50 group-hover:opacity-90 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </li>
    {{end}}
  </ul>
  {{if .Truncated}}
  <a href="/admin/hosts" class="mt-3 inline-flex items-center gap-1 t-small cursor-pointer hover:underline" style="color:rgb(var(--accent))">
    View all hosts
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </a>
  {{end}}
  {{else}}
  <div class="flex items-center gap-3 rounded-xl px-4 py-4 ring-1 ring-[rgb(var(--success)/.3)] bg-[rgb(var(--success)/.08)]">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:rgb(var(--success))"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <div>
      <p class="t-body font-medium" style="color:rgb(var(--success))">All clear</p>
      <p class="t-caption">No failing hosts, pending certs, or node issues right now.</p>
    </div>
  </div>
  {{end}}
</section>

<!-- Traffic + recent activity -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <section class="r-card lg:col-span-2">
    <div class="flex items-center gap-3 mb-4">
      <span class="icon-chip" style="background:rgb(var(--accent)/.12);color:rgb(var(--accent))">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
      </span>
      <div class="flex-1 flex items-baseline justify-between">
        <div>
          <h2 class="t-h3">Requests</h2>
          <p class="t-caption">Last 24 hours</p>
        </div>
        <span class="r-pill r-pill-neutral"><span class="tabular-nums font-semibold">{{.Traffic.Total}}</span> total</span>
      </div>
    </div>
    {{if .Traffic.Values}}
    <div id="dash-spark" class="flex items-end gap-px h-32" aria-hidden="true">
      {{range .Traffic.Values}}
      <div class="flex-1 min-w-0 rounded-t-md transition-[height]" style="height:1px;background:rgb(var(--accent)/.7)" data-v="{{.}}"></div>
      {{end}}
    </div>
    <div class="flex justify-between t-caption mt-2 font-mono">
      {{range $i, $l := .Traffic.Labels}}{{if or (eq $i 0) (eq $i 6) (eq $i 12) (eq $i 18) (eq $i 23)}}<span>{{$l}}</span>{{end}}{{end}}
    </div>
    {{else}}
    <div class="h-32 flex items-center justify-center t-small">No traffic data yet.</div>
    {{end}}
  </section>

  <section class="r-card">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <span class="icon-chip" style="background:rgb(56 189 248/.12);color:rgb(56 189 248)">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </span>
        <h2 class="t-h3">Recent activity</h2>
      </div>
      <a href="/admin/audit" class="t-caption cursor-pointer hover:underline" style="color:rgb(var(--accent))">View all</a>
    </div>
    {{if .RecentEvents}}
    <ul class="space-y-3">
      {{range .RecentEvents}}
      <li class="flex items-start gap-3">
        <span class="r-avatar shrink-0">{{firstRune .Actor}}</span>
        <div class="min-w-0 flex-1">
          <div class="flex items-center justify-between gap-2">
            <code class="t-small truncate" style="color:rgb(var(--text))">{{.Action}}</code>
            <span class="t-caption font-mono flex-shrink-0">{{.When}}</span>
          </div>
          <p class="t-caption truncate">{{.Actor}}{{if .Entity}} · {{.Entity}}{{end}}</p>
        </div>
      </li>
      {{end}}
    </ul>
    {{else}}
    <div class="py-8 text-center t-small">No recent activity.</div>
    {{end}}
  </section>
</div>

{{if or .TopRoutes .TopClients}}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

  {{if .TopRoutes}}
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-4 py-3 border-b border-[rgb(var(--border))]">
      <p class="t-eyebrow">Top routes · 24h</p>
    </div>
    <ul class="divide-y divide-[rgb(var(--border))]">
      {{range .TopRoutes}}
      <li class="flex items-center justify-between px-4 py-2.5">
        <a href="/admin/hosts/{{.RouteID}}/logs" class="t-body font-medium truncate cursor-pointer hover:underline" style="color:rgb(var(--text))">{{.Domain}}</a>
        <span class="t-caption ml-3 flex-shrink-0">{{.Requests}} req</span>
      </li>
      {{end}}
    </ul>
  </section>
  {{end}}

  {{if .TopClients}}
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-4 py-3 border-b border-[rgb(var(--border))]">
      <p class="t-eyebrow">Top clients · 7d</p>
    </div>
    <ul class="divide-y divide-[rgb(var(--border))]">
      {{range .TopClients}}
      <li class="flex items-center justify-between px-4 py-2.5">
        <a href="/admin/clients/{{.ClientID}}" class="t-body font-medium truncate cursor-pointer hover:underline" style="color:rgb(var(--text))">{{.DisplayName}}</a>
        <span class="t-caption ml-3 flex-shrink-0">{{formatBytes .BandwidthBytes}}</span>
      </li>
      {{end}}
    </ul>
  </section>
  {{end}}

</div>
{{end}}

{{if .Traffic.Values}}
<script nonce="{{.CSPNonce}}">
// Size sparkline bars from data-v values; max-relative heights keep it theme-agnostic.
(function(){
  var wrap = document.getElementById('dash-spark');
  if (!wrap) return;
  var bars = wrap.querySelectorAll('[data-v]');
  var max = 0;
  bars.forEach(function(b){ var v = +b.dataset.v || 0; if (v > max) max = v; });
  bars.forEach(function(b){
    var v = +b.dataset.v || 0;
    var pct = max > 0 ? Math.round((v / max) * 100) : 0;
    b.style.height = Math.max(pct, 2) + '%';
    b.title = v + ' req';
  });
})();
</script>
{{end}}
{{end}}
