{{define "worldmap"}}
<div class="space-y-6">

<div class="flex justify-end">
  <a href="/admin/stats" class="r-btn-secondary text-xs inline-flex items-center gap-1.5 cursor-pointer transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    Statistics
  </a>
</div>

{{if .DBUnavailable}}
<section class="r-card t-small" style="color:rgb(var(--muted))">
  Database is not available - traffic by country cannot be built right now.
</section>
{{else}}

{{if not .GeoIPAvailable}}
<div class="r-card flex items-start gap-3" style="background:rgb(var(--warning)/.10);border-color:rgb(var(--warning)/.30)">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" style="color:rgb(var(--warning))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  <div>
    <strong class="t-small font-semibold" style="color:rgb(var(--warning))">GeoIP database not configured</strong>
    <span class="t-small" style="color:rgb(var(--warning))"> - configure MaxMind credentials in
    <a href="/admin/settings" class="underline hover:no-underline">Settings</a>
    to map visitor countries. Without it, all requests fall into the unknown bucket below.</span>
  </div>
</div>
{{end}}

<!-- Filters: host selector + time range -->
<div class="r-card flex flex-wrap items-end gap-4">
  <div class="min-w-[220px] flex-1">
    <label for="wm-host" class="block t-caption font-medium mb-1">Host</label>
    <select id="wm-host" class="r-select w-full cursor-pointer">
      <option value="0" {{if eq .SelectedRoute 0}}selected{{end}}>All hosts</option>
      {{range .Hosts}}
      <option value="{{.RouteID}}" {{if eq $.SelectedRoute .RouteID}}selected{{end}}>{{.Label}}</option>
      {{end}}
    </select>
  </div>
  <div>
    <label class="block t-caption font-medium mb-1">Time range</label>
    <div id="wm-range" class="r-segment" role="group">
      <button type="button" data-range="24h" class="r-segment-item cursor-pointer {{if eq .Range "24h"}}is-active{{end}}">24h</button>
      <button type="button" data-range="7d" class="r-segment-item cursor-pointer {{if eq .Range "7d"}}is-active{{end}}">7d</button>
      <button type="button" data-range="30d" class="r-segment-item cursor-pointer {{if eq .Range "30d"}}is-active{{end}}">30d</button>
    </div>
  </div>
</div>

<!-- SVG world map heatmap -->
<div class="r-card !p-0 overflow-hidden">
  <div class="px-5 py-4 flex flex-wrap items-center justify-between gap-3" style="border-bottom:1px solid rgb(var(--border))">
    <div>
      <p class="t-eyebrow">Visitor traffic</p>
      <p class="t-small" style="color:rgb(var(--muted))">
        {{if .SelectedHost}}{{.SelectedHost}}{{else}}All hosts{{end}}
        &middot; {{len .Countries}} countr{{if eq (len .Countries) 1}}y{{else}}ies{{end}}
      </p>
    </div>
    <div class="flex items-center gap-2 t-caption">
      <span style="color:rgb(var(--muted))">Fewer</span>
      <span class="inline-block w-4 h-3 rounded-sm" style="background:rgb(var(--accent)/.15)"></span>
      <span class="inline-block w-4 h-3 rounded-sm" style="background:rgb(var(--accent)/.40)"></span>
      <span class="inline-block w-4 h-3 rounded-sm" style="background:rgb(var(--accent)/.65)"></span>
      <span class="inline-block w-4 h-3 rounded-sm" style="background:rgb(var(--accent)/.85)"></span>
      <span class="inline-block w-4 h-3 rounded-sm" style="background:rgb(var(--accent))"></span>
      <span style="color:rgb(var(--muted))">More</span>
    </div>
  </div>

  <div class="relative select-none overflow-hidden max-h-[50vh]" id="worldmap-wrap" style="background:rgb(var(--surface-2))">
    {{if .WorldSVG}}
    <div id="worldmap-inner" class="w-full">{{.WorldSVG}}</div>
    {{else}}
    <div class="py-16 text-center t-small" style="color:rgb(var(--muted))">World map asset not available.</div>
    {{end}}
    <!-- Reset zoom button - shown when zoomed in -->
    <button id="wm-zoom-reset" style="display:none"
      class="absolute top-3 right-3 z-10 flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 r-btn-ghost t-caption cursor-pointer">
      <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/><path d="m15 9-6 6M9 9l6 6"/></svg>
      Reset zoom
    </button>
    <p class="absolute bottom-2 left-0 right-0 text-center t-caption pointer-events-none select-none" style="color:rgb(var(--muted)/.60)">Ctrl+scroll to zoom &middot; Drag to pan &middot; Double-click to reset</p>
    <div id="wm-tooltip"
         class="pointer-events-none absolute z-20 hidden rounded-xl px-3 py-2 t-small min-w-[140px]"
         style="background:rgb(var(--surface));border:1px solid rgb(var(--border));box-shadow:0 4px 16px rgba(0,0,0,.12)">
      <p id="wm-tt-name" class="font-semibold t-body mb-0.5" style="color:rgb(var(--text))"></p>
      <p id="wm-tt-count" style="color:rgb(var(--muted))"></p>
      <p id="wm-tt-pct" class="mt-0.5 font-medium" style="color:rgb(var(--accent))"></p>
    </div>
  </div>
</div>

<!-- Ranked country table -->
<div class="r-card">
  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-4">
    <p class="t-eyebrow">Countries by request volume</p>
    <p class="t-small" style="color:rgb(var(--muted))">
      <span class="font-semibold tabular-nums" style="color:rgb(var(--text))">{{.TotalRequests}}</span> total requests
    </p>
  </div>

  {{if .Countries}}
  <div class="space-y-2">
    {{range .Countries}}
    <div class="flex items-center gap-3">
      <span class="shrink-0 w-9 px-1 py-0.5 rounded-md t-caption font-mono font-bold text-center tabular-nums" style="background:rgb(var(--accent)/.15);color:rgb(var(--accent))">{{.Code}}</span>
      <span class="shrink-0 w-40 truncate t-small font-medium" style="color:rgb(var(--text))">{{.Name}}</span>
      <div class="flex-1 h-2 rounded-full overflow-hidden" style="background:rgb(var(--surface-2))">
        <div class="h-full rounded-full" style="width:{{printf "%.1f" .BarPercent}}%;background:rgb(var(--accent))"></div>
      </div>
      <span class="shrink-0 w-20 text-right t-small tabular-nums" style="color:rgb(var(--text))">{{.Count}}</span>
      <span class="shrink-0 w-14 text-right t-caption tabular-nums" style="color:rgb(var(--muted))">{{printf "%.1f" .Percent}}%</span>
    </div>
    {{end}}
  </div>
  {{end}}

  {{if .UnknownCount}}
  <div class="{{if .Countries}}mt-4 pt-4{{end}} flex items-center gap-3" style="{{if .Countries}}border-top:1px solid rgb(var(--border)){{end}}">
    <span class="shrink-0 w-9 px-1 py-0.5 rounded-md t-caption font-mono font-bold text-center" style="background:rgb(var(--surface-2));color:rgb(var(--muted))">?</span>
    <span class="shrink-0 w-40 truncate t-small font-medium" style="color:rgb(var(--muted))">Unknown location</span>
    <div class="flex-1"></div>
    <span class="shrink-0 w-20 text-right t-small tabular-nums" style="color:rgb(var(--muted))">{{.UnknownCount}}</span>
    <span class="shrink-0 w-14 text-right t-caption tabular-nums" style="color:rgb(var(--muted))">{{printf "%.1f" .UnknownPercent}}%</span>
  </div>
  {{end}}

  {{if and (not .Countries) (not .UnknownCount)}}
  <p class="t-small py-6 text-center" style="color:rgb(var(--muted))">No traffic recorded in this window.</p>
  {{end}}
</div>

{{end}}{{/* not DBUnavailable */}}
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  var counts = {{.CountryJSON}};
  var total  = {{.TotalRequests}};

  var hostSel = document.getElementById('wm-host');
  if (hostSel) {
    hostSel.addEventListener('change', function(){
      var p = new URLSearchParams(window.location.search);
      if (this.value && this.value !== '0') { p.set('route_id', this.value); } else { p.delete('route_id'); }
      window.location.search = p.toString();
    });
  }
  document.querySelectorAll('.wm-range-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var p = new URLSearchParams(window.location.search);
      p.set('range', this.getAttribute('data-range'));
      window.location.search = p.toString();
    });
  });
  // Also handle segment-item buttons
  document.querySelectorAll('[data-range]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var p = new URLSearchParams(window.location.search);
      p.set('range', this.getAttribute('data-range'));
      window.location.search = p.toString();
    });
  });

  var countryNames = {"AE":"UAE","AF":"Afghanistan","AL":"Albania","AM":"Armenia","AO":"Angola","AR":"Argentina","AT":"Austria","AU":"Australia","AZ":"Azerbaijan","BA":"Bosnia","BD":"Bangladesh","BE":"Belgium","BF":"Burkina Faso","BG":"Bulgaria","BI":"Burundi","BJ":"Benin","BN":"Brunei","BO":"Bolivia","BR":"Brazil","BT":"Bhutan","BW":"Botswana","BY":"Belarus","BZ":"Belize","CA":"Canada","CD":"DR Congo","CF":"CAR","CG":"Congo","CH":"Switzerland","CI":"Ivory Coast","CL":"Chile","CM":"Cameroon","CN":"China","CO":"Colombia","CR":"Costa Rica","CU":"Cuba","CY":"Cyprus","CZ":"Czech Republic","DE":"Germany","DJ":"Djibouti","DK":"Denmark","DO":"Dominican Rep.","DZ":"Algeria","EC":"Ecuador","EE":"Estonia","EG":"Egypt","EH":"W. Sahara","ER":"Eritrea","ES":"Spain","ET":"Ethiopia","FI":"Finland","FJ":"Fiji","FR":"France","GA":"Gabon","GB":"United Kingdom","GE":"Georgia","GH":"Ghana","GL":"Greenland","GN":"Guinea","GQ":"Eq. Guinea","GR":"Greece","GT":"Guatemala","GW":"Guinea-Bissau","GY":"Guyana","HN":"Honduras","HR":"Croatia","HT":"Haiti","HU":"Hungary","ID":"Indonesia","IE":"Ireland","IL":"Israel","IN":"India","IQ":"Iraq","IR":"Iran","IS":"Iceland","IT":"Italy","JO":"Jordan","JP":"Japan","KE":"Kenya","KG":"Kyrgyzstan","KH":"Cambodia","KP":"North Korea","KR":"South Korea","KW":"Kuwait","KZ":"Kazakhstan","LA":"Laos","LB":"Lebanon","LK":"Sri Lanka","LR":"Liberia","LS":"Lesotho","LT":"Lithuania","LV":"Latvia","LY":"Libya","MA":"Morocco","MD":"Moldova","ME":"Montenegro","MG":"Madagascar","MK":"North Macedonia","ML":"Mali","MM":"Myanmar","MN":"Mongolia","MR":"Mauritania","MW":"Malawi","MX":"Mexico","MY":"Malaysia","MZ":"Mozambique","NA":"Namibia","NC":"New Caledonia","NE":"Niger","NG":"Nigeria","NI":"Nicaragua","NL":"Netherlands","NO":"Norway","NP":"Nepal","NZ":"New Zealand","OM":"Oman","PA":"Panama","PE":"Peru","PG":"Papua New Guinea","PH":"Philippines","PK":"Pakistan","PL":"Poland","PR":"Puerto Rico","PS":"Palestine","PT":"Portugal","PY":"Paraguay","QA":"Qatar","RO":"Romania","RS":"Serbia","RU":"Russia","RW":"Rwanda","SA":"Saudi Arabia","SD":"Sudan","SE":"Sweden","SI":"Slovenia","SK":"Slovakia","SL":"Sierra Leone","SN":"Senegal","SO":"Somalia","SR":"Suriname","SS":"South Sudan","SV":"El Salvador","SY":"Syria","SZ":"Eswatini","TD":"Chad","TF":"Fr. South Territories","TG":"Togo","TH":"Thailand","TJ":"Tajikistan","TL":"Timor-Leste","TM":"Turkmenistan","TN":"Tunisia","TR":"Turkey","TW":"Taiwan","TZ":"Tanzania","UA":"Ukraine","UG":"Uganda","US":"United States","UY":"Uruguay","UZ":"Uzbekistan","VE":"Venezuela","VN":"Vietnam","YE":"Yemen","ZA":"South Africa","ZM":"Zambia","ZW":"Zimbabwe","SG":"Singapore","HK":"Hong Kong","LU":"Luxembourg","MT":"Malta","LI":"Liechtenstein","AD":"Andorra","MC":"Monaco","SM":"San Marino","MV":"Maldives","BB":"Barbados","JM":"Jamaica","TT":"Trinidad & Tobago","BS":"Bahamas"};

  var max = 0;
  Object.keys(counts).forEach(function(k){ if (counts[k] > max) max = counts[k]; });

  // Read accent token from CSS so the ramp adapts to palette switches.
  function accentRGB() {
    return getComputedStyle(document.documentElement).getPropertyValue('--accent').trim().replace(/\s+/g, ',');
  }
  function getRamp() {
    var a = accentRGB();
    return [
      'rgba(' + a + ',0.15)',
      'rgba(' + a + ',0.35)',
      'rgba(' + a + ',0.55)',
      'rgba(' + a + ',0.75)',
      'rgba(' + a + ',1)',
    ];
  }

  function isDark() { return document.documentElement.classList.contains('dark'); }
  function getNeutral() { return isDark() ? '#3f3f46' : '#e2e8f0'; }
  function getStroke()  { return isDark() ? '#18181b' : '#ffffff'; }

  function bucketColor(v) {
    if (!v || max <= 0) return getNeutral();
    var r = getRamp();
    var idx = Math.ceil(v / max * r.length) - 1;
    return r[Math.max(0, Math.min(idx, r.length - 1))];
  }

  var wrap    = document.getElementById('worldmap-wrap');
  var tooltip = document.getElementById('wm-tooltip');
  if (!wrap || !tooltip) return;
  var ttName  = document.getElementById('wm-tt-name');
  var ttCount = document.getElementById('wm-tt-count');
  var ttPct   = document.getElementById('wm-tt-pct');
  var resetBtn = document.getElementById('wm-zoom-reset');

  // Zoom/pan state
  var origVB = null, curVB = null;
  var panning = false, panSX = 0, panSY = 0, panVBX = 0, panVBY = 0;

  // Hover state - tracked explicitly to avoid stuck highlights
  var activePath = null;

  function setActive(path, on) {
    if (!path) return;
    var v = counts[path.getAttribute('id')] || 0;
    if (on) {
      path.setAttribute('stroke', 'rgba(' + accentRGB() + ',0.85)');
      path.setAttribute('stroke-width', '1.5');
      path.style.filter = 'brightness(1.12)';
    } else {
      path.setAttribute('fill', bucketColor(v));
      path.setAttribute('stroke', getStroke());
      path.setAttribute('stroke-width', '0.15');
      path.style.filter = '';
    }
  }

  function clampVB() {
    if (curVB.w > origVB.w) { curVB.w = origVB.w; curVB.h = origVB.h; }
    curVB.x = Math.max(origVB.x, Math.min(origVB.x + origVB.w - curVB.w, curVB.x));
    curVB.y = Math.max(origVB.y, Math.min(origVB.y + origVB.h - curVB.h, curVB.y));
  }

  function applyVB(svgEl) {
    svgEl.setAttribute('viewBox', curVB.x + ' ' + curVB.y + ' ' + curVB.w + ' ' + curVB.h);
    if (resetBtn) resetBtn.style.display = (Math.abs(curVB.w - origVB.w) > 1) ? 'flex' : 'none';
  }

  function resetZoom(svgEl) {
    curVB.x = origVB.x; curVB.y = origVB.y; curVB.w = origVB.w; curVB.h = origVB.h;
    applyVB(svgEl);
  }

  function initZoom(svgEl) {
    var parts = (svgEl.getAttribute('viewBox') || '').split(/[\s,]+/).map(Number);
    if (parts.length < 4 || parts.some(isNaN)) return;
    origVB = {x: parts[0], y: parts[1], w: parts[2], h: parts[3]};
    curVB  = {x: origVB.x, y: origVB.y, w: origVB.w, h: origVB.h};
    svgEl.style.cursor = 'grab';

    if (resetBtn) {
      resetBtn.addEventListener('click', function() { resetZoom(svgEl); });
    }

    svgEl.addEventListener('wheel', function(e) {
      if (!e.ctrlKey && !e.metaKey) return; // let page scroll; zoom only on Ctrl+scroll
      e.preventDefault();
      var rect = svgEl.getBoundingClientRect();
      var mx = curVB.x + (e.clientX - rect.left) / rect.width  * curVB.w;
      var my = curVB.y + (e.clientY - rect.top)  / rect.height * curVB.h;
      var factor = e.deltaY < 0 ? 0.75 : 1.33;
      var nw = Math.max(origVB.w / 12, Math.min(origVB.w, curVB.w * factor));
      var nh = origVB.h / origVB.w * nw;
      curVB.x = mx - (e.clientX - rect.left) / rect.width  * nw;
      curVB.y = my - (e.clientY - rect.top)  / rect.height * nh;
      curVB.w = nw; curVB.h = nh;
      clampVB();
      applyVB(svgEl);
    }, {passive: false});

    svgEl.addEventListener('mousedown', function(e) {
      if (e.button !== 0) return;
      panning = true;
      panSX = e.clientX; panSY = e.clientY;
      panVBX = curVB.x;  panVBY = curVB.y;
      svgEl.style.cursor = 'grabbing';
      // Suppress country hover events during drag
      svgEl.style.pointerEvents = 'none';
      e.preventDefault();
    });

    window.addEventListener('mousemove', function(e) {
      if (!panning) return;
      var rect = svgEl.getBoundingClientRect();
      curVB.x = panVBX + (panSX - e.clientX) / rect.width  * curVB.w;
      curVB.y = panVBY + (panSY - e.clientY) / rect.height * curVB.h;
      clampVB();
      applyVB(svgEl);
    });

    window.addEventListener('mouseup', function() {
      if (!panning) return;
      panning = false;
      svgEl.style.cursor = 'grab';
      svgEl.style.pointerEvents = '';
      if (activePath) { setActive(activePath, false); activePath = null; }
      onLeave();
    });

    svgEl.addEventListener('dblclick', function() { resetZoom(svgEl); });

    // Touch: single-finger pan
    svgEl.addEventListener('touchstart', function(e) {
      if (e.touches.length !== 1) return;
      panning = true;
      panSX = e.touches[0].clientX; panSY = e.touches[0].clientY;
      panVBX = curVB.x; panVBY = curVB.y;
      e.preventDefault();
    }, {passive: false});
    svgEl.addEventListener('touchmove', function(e) {
      if (!panning || e.touches.length !== 1) return;
      var rect = svgEl.getBoundingClientRect();
      curVB.x = panVBX + (panSX - e.touches[0].clientX) / rect.width  * curVB.w;
      curVB.y = panVBY + (panSY - e.touches[0].clientY) / rect.height * curVB.h;
      clampVB();
      applyVB(svgEl);
      e.preventDefault();
    }, {passive: false});
    svgEl.addEventListener('touchend', function() { panning = false; });
  }

  function colorMap() {
    var svgEl = wrap.querySelector('svg');
    if (!svgEl) return;
    if (!svgEl.getAttribute('viewBox')) {
      var w = parseInt(svgEl.getAttribute('width')  || '700', 10) || 700;
      var h = parseInt(svgEl.getAttribute('height') || '350', 10) || 350;
      svgEl.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
    }
    svgEl.removeAttribute('width');
    svgEl.removeAttribute('height');
    svgEl.style.display = 'block';
    svgEl.style.width   = '100%';
    svgEl.style.height  = 'auto';
    svgEl.style.maxHeight = '50vh';

    initZoom(svgEl);

    svgEl.querySelectorAll('path[id]').forEach(function(path){
      var code = path.getAttribute('id');
      if (!code || code.length !== 2) return;
      var v = counts[code] || 0;
      path.setAttribute('fill', bucketColor(v));
      path.setAttribute('stroke', getStroke());
      path.setAttribute('stroke-width', '0.15');
      path.style.transition = 'filter .1s';

      path.addEventListener('mouseenter', function(e) {
        if (panning) return;
        // Always reset the previous highlight before setting a new one
        if (activePath && activePath !== path) setActive(activePath, false);
        activePath = path;
        setActive(path, true);
        onEnter(e, code, v);
      });
      path.addEventListener('mousemove', function(e) { if (!panning) onMove(e); });
      path.addEventListener('mouseleave', function() {
        setActive(path, false);
        if (activePath === path) activePath = null;
        onLeave();
      });
    });

    // Safety net: clear any stuck highlight when mouse leaves SVG entirely
    svgEl.addEventListener('mouseleave', function() {
      if (activePath) { setActive(activePath, false); activePath = null; }
      onLeave();
    });
  }

  // Re-apply neutral + stroke colors when theme toggles (dark/light)
  function recolorAll() {
    var svgEl = wrap.querySelector('svg');
    if (!svgEl) return;
    svgEl.querySelectorAll('path[id]').forEach(function(path) {
      var code = path.getAttribute('id');
      if (!code || code.length !== 2 || path === activePath) return;
      path.setAttribute('fill', bucketColor(counts[code] || 0));
      path.setAttribute('stroke', getStroke());
    });
  }
  if (window.MutationObserver) {
    new MutationObserver(recolorAll).observe(document.documentElement, {attributes: true, attributeFilter: ['class']});
  }

  function onEnter(e, code, v) {
    var pct = total > 0 ? (v / total * 100) : 0;
    ttName.textContent  = countryNames[code] || code;
    ttCount.textContent = v.toLocaleString() + ' request' + (v !== 1 ? 's' : '');
    ttPct.textContent   = pct.toFixed(1) + '% of total';
    tooltip.classList.remove('hidden');
    onMove(e);
  }
  function onMove(e) {
    var rect = wrap.getBoundingClientRect();
    var x = e.clientX - rect.left + 12;
    var y = e.clientY - rect.top  + 12;
    var tw = tooltip.offsetWidth || 150;
    if (x + tw > rect.width - 8) x = e.clientX - rect.left - tw - 8;
    tooltip.style.left = x + 'px';
    tooltip.style.top  = y + 'px';
  }
  function onLeave() { tooltip.classList.add('hidden'); }

  colorMap();
})();
</script>
{{end}}
