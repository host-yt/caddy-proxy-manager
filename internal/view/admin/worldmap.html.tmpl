{{define "worldmap"}}
<div class="space-y-6">

{{if .DBUnavailable}}
<section class="hpg-card text-sm text-slate-600 dark:text-slate-300">
  Database is not available - the world map cannot be built right now.
</section>
{{else}}

{{if not .GeoIPAvailable}}
<div class="rounded-xl bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/30 px-4 py-3 text-sm text-amber-800 dark:text-amber-200 flex items-start gap-3">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  <div>
    <strong>GeoIP database not configured</strong> - configure MaxMind credentials in
    <a href="/admin/settings" class="underline hover:no-underline">Settings</a>
    to populate the map with node locations.
    All nodes are listed below without location data.
  </div>
</div>
{{end}}

<!-- SVG world map card -->
<div class="hpg-card p-0 overflow-hidden">
  <div class="px-5 py-4 border-b border-slate-200/70 dark:border-zinc-800 flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="hpg-eyebrow">Infrastructure presence</p>
      <p class="text-sm text-slate-600 dark:text-slate-400">{{len .Countries}} countr{{if eq (len .Countries) 1}}y{{else}}ies{{end}} with nodes</p>
    </div>
    <!-- Legend -->
    <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400">
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-emerald-500/80"></span>Healthy</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-amber-400/80"></span>Degraded</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-rose-500/80"></span>Down</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-slate-200 dark:bg-zinc-700"></span>No nodes</span>
    </div>
  </div>

  <!-- Inline SVG: CSP sets object-src 'none', so <object>/<embed> are blocked -->
  <div class="relative bg-slate-50 dark:bg-zinc-900 select-none overflow-hidden" id="worldmap-wrap">
    {{if .WorldSVG}}
    <div id="worldmap-inner" class="w-full">{{.WorldSVG}}</div>
    {{else}}
    <div class="py-16 text-center text-sm text-slate-400 dark:text-slate-500">World map asset not available.</div>
    {{end}}
    <!-- Tooltip positioned via JS -->
    <div id="wm-tooltip"
         class="pointer-events-none absolute z-20 hidden rounded-lg bg-white dark:bg-zinc-900 ring-1 ring-slate-200 dark:ring-zinc-700 shadow-lg shadow-slate-900/10 px-3 py-2 text-xs text-slate-700 dark:text-slate-200 min-w-[120px]">
      <p id="wm-tt-name" class="font-semibold text-sm text-slate-900 dark:text-white mb-0.5"></p>
      <p id="wm-tt-count" class="text-slate-500 dark:text-slate-400"></p>
      <p id="wm-tt-health" class="mt-0.5 font-medium"></p>
    </div>
  </div>
</div>

<!-- Node list grouped by country -->
<div class="hpg-card">
  <p class="hpg-eyebrow mb-3">Nodes by location</p>

  {{if .Countries}}
  <div class="space-y-4">
    {{range .Countries}}
    <div>
      <div class="flex items-center gap-2 mb-1.5">
        <span class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-900 dark:text-white">
          <span class="px-1.5 py-0.5 rounded text-[11px] font-mono font-bold
            {{if eq .Health "healthy"}}bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-300
            {{else if eq .Health "degraded"}}bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-300
            {{else}}bg-rose-100 text-rose-700 dark:bg-rose-500/20 dark:text-rose-300{{end}}">{{.Code}}</span>
          {{.Name}}
        </span>
        <span class="text-xs text-slate-400 dark:text-slate-500">{{.NodeCount}} node{{if ne .NodeCount 1}}s{{end}}</span>
      </div>
      <div class="divide-y divide-slate-100 dark:divide-zinc-800 rounded-lg border border-slate-200 dark:border-zinc-800 overflow-hidden">
        {{range .Nodes}}
        <div class="flex items-center gap-3 px-3 py-2 text-sm bg-white dark:bg-zinc-900/50">
          <span class="shrink-0 w-2 h-2 rounded-full
            {{if eq .HealthStatus "healthy"}}bg-emerald-500
            {{else if eq .HealthStatus "degraded"}}bg-amber-400
            {{else}}bg-rose-500{{end}}"></span>
          <span class="font-medium text-slate-900 dark:text-white truncate">{{.Name}}</span>
          <span class="text-slate-400 dark:text-slate-500 font-mono text-xs">{{.PublicIP}}</span>
          <span class="ml-auto shrink-0 text-xs
            {{if eq .HealthStatus "healthy"}}text-emerald-600 dark:text-emerald-400
            {{else if eq .HealthStatus "degraded"}}text-amber-600 dark:text-amber-400
            {{else}}text-rose-600 dark:text-rose-400{{end}}">{{.HealthStatus}}</span>
          {{if not .IsEnabled}}<span class="shrink-0 hpg-pill hpg-pill-muted">disabled</span>{{end}}
        </div>
        {{end}}
      </div>
    </div>
    {{end}}
  </div>
  {{end}}

  {{if .Unknown}}
  <div class="{{if .Countries}}mt-6 pt-6 border-t border-slate-200/70 dark:border-zinc-800{{end}}">
    <div class="flex items-center gap-2 mb-1.5">
      <span class="text-sm font-medium text-slate-500 dark:text-slate-400">Unknown location</span>
      <span class="text-xs text-slate-400 dark:text-slate-500">{{len .Unknown}} node{{if ne (len .Unknown) 1}}s{{end}}</span>
    </div>
    <div class="divide-y divide-slate-100 dark:divide-zinc-800 rounded-lg border border-slate-200 dark:border-zinc-800 overflow-hidden">
      {{range .Unknown}}
      <div class="flex items-center gap-3 px-3 py-2 text-sm bg-white dark:bg-zinc-900/50">
        <span class="shrink-0 w-2 h-2 rounded-full
          {{if eq .HealthStatus "healthy"}}bg-emerald-500
          {{else if eq .HealthStatus "degraded"}}bg-amber-400
          {{else}}bg-rose-500{{end}}"></span>
        <span class="font-medium text-slate-900 dark:text-white truncate">{{.Name}}</span>
        <span class="text-slate-400 dark:text-slate-500 font-mono text-xs">{{if .PublicIP}}{{.PublicIP}}{{else}}no IP{{end}}</span>
        <span class="ml-auto shrink-0 text-xs text-slate-400 dark:text-slate-500">unresolved</span>
      </div>
      {{end}}
    </div>
  </div>
  {{end}}

  {{if and (not .Countries) (not .Unknown)}}
  <p class="text-sm text-slate-500 dark:text-slate-400 py-4 text-center">No Caddy nodes registered yet.</p>
  {{end}}
</div>

{{end}}{{/* not DBUnavailable */}}
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  // Server-rendered JSON maps ISO2 -> health tier.
  var countryHealth = {{.CountryJSON}};

  var colors = {
    healthy:  {fill:'#10b981', stroke:'#059669'},
    degraded: {fill:'#fbbf24', stroke:'#d97706'},
    down:     {fill:'#ef4444', stroke:'#dc2626'}
  };
  var nodeCounts = {};
  var countryNames = {"AE":"UAE","AF":"Afghanistan","AL":"Albania","AM":"Armenia","AO":"Angola","AR":"Argentina","AT":"Austria","AU":"Australia","AZ":"Azerbaijan","BA":"Bosnia","BD":"Bangladesh","BE":"Belgium","BF":"Burkina Faso","BG":"Bulgaria","BI":"Burundi","BJ":"Benin","BN":"Brunei","BO":"Bolivia","BR":"Brazil","BT":"Bhutan","BW":"Botswana","BY":"Belarus","BZ":"Belize","CA":"Canada","CD":"DR Congo","CF":"CAR","CG":"Congo","CH":"Switzerland","CI":"Ivory Coast","CL":"Chile","CM":"Cameroon","CN":"China","CO":"Colombia","CR":"Costa Rica","CU":"Cuba","CY":"Cyprus","CZ":"Czech Republic","DE":"Germany","DJ":"Djibouti","DK":"Denmark","DO":"Dominican Rep.","DZ":"Algeria","EC":"Ecuador","EE":"Estonia","EG":"Egypt","EH":"W. Sahara","ER":"Eritrea","ES":"Spain","ET":"Ethiopia","FI":"Finland","FJ":"Fiji","FR":"France","GA":"Gabon","GB":"United Kingdom","GE":"Georgia","GH":"Ghana","GL":"Greenland","GN":"Guinea","GQ":"Eq. Guinea","GR":"Greece","GT":"Guatemala","GW":"Guinea-Bissau","GY":"Guyana","HN":"Honduras","HR":"Croatia","HT":"Haiti","HU":"Hungary","ID":"Indonesia","IE":"Ireland","IL":"Israel","IN":"India","IQ":"Iraq","IR":"Iran","IS":"Iceland","IT":"Italy","JO":"Jordan","JP":"Japan","KE":"Kenya","KG":"Kyrgyzstan","KH":"Cambodia","KP":"North Korea","KR":"South Korea","KW":"Kuwait","KZ":"Kazakhstan","LA":"Laos","LB":"Lebanon","LK":"Sri Lanka","LR":"Liberia","LS":"Lesotho","LT":"Lithuania","LV":"Latvia","LY":"Libya","MA":"Morocco","MD":"Moldova","ME":"Montenegro","MG":"Madagascar","MK":"North Macedonia","ML":"Mali","MM":"Myanmar","MN":"Mongolia","MR":"Mauritania","MW":"Malawi","MX":"Mexico","MY":"Malaysia","MZ":"Mozambique","NA":"Namibia","NC":"New Caledonia","NE":"Niger","NG":"Nigeria","NI":"Nicaragua","NL":"Netherlands","NO":"Norway","NP":"Nepal","NZ":"New Zealand","OM":"Oman","PA":"Panama","PE":"Peru","PG":"Papua New Guinea","PH":"Philippines","PK":"Pakistan","PL":"Poland","PR":"Puerto Rico","PS":"Palestine","PT":"Portugal","PY":"Paraguay","QA":"Qatar","RO":"Romania","RS":"Serbia","RU":"Russia","RW":"Rwanda","SA":"Saudi Arabia","SD":"Sudan","SE":"Sweden","SI":"Slovenia","SK":"Slovakia","SL":"Sierra Leone","SN":"Senegal","SO":"Somalia","SR":"Suriname","SS":"South Sudan","SV":"El Salvador","SY":"Syria","SZ":"Eswatini","TD":"Chad","TF":"Fr. South Territories","TG":"Togo","TH":"Thailand","TJ":"Tajikistan","TL":"Timor-Leste","TM":"Turkmenistan","TN":"Tunisia","TR":"Turkey","TW":"Taiwan","TZ":"Tanzania","UA":"Ukraine","UG":"Uganda","US":"United States","UY":"Uruguay","UZ":"Uzbekistan","VE":"Venezuela","VN":"Vietnam","YE":"Yemen","ZA":"South Africa","ZM":"Zambia","ZW":"Zimbabwe","SG":"Singapore","HK":"Hong Kong","LU":"Luxembourg"};
  var healthLabel = {healthy:'Healthy', degraded:'Degraded', down:'Down / unreachable'};
  var healthClass  = {healthy:'text-emerald-600', degraded:'text-amber-600', down:'text-rose-600'};

  // Build node counts from server-rendered template data.
  {{range .Countries}}nodeCounts["{{.Code}}"] = {{.NodeCount}};
  {{end}}

  var wrap    = document.getElementById('worldmap-wrap');
  var tooltip = document.getElementById('wm-tooltip');
  if (!wrap || !tooltip) return;

  var ttName   = document.getElementById('wm-tt-name');
  var ttCount  = document.getElementById('wm-tt-count');
  var ttHealth = document.getElementById('wm-tt-health');

  function colorMap() {
    var svgEl = wrap.querySelector('svg');
    if (!svgEl) return;
    // Responsive: let SVG scale to container width.
    svgEl.setAttribute('width', '100%');
    svgEl.setAttribute('height', 'auto');
    svgEl.style.display = 'block';
    svgEl.style.maxHeight = '540px';

    var paths = svgEl.querySelectorAll('path[id]');
    paths.forEach(function(path){
      var code = path.getAttribute('id');
      if (!code || code.length !== 2) return;
      var h = countryHealth[code];
      if (!h) return;
      var c = colors[h];
      if (!c) return;
      path.setAttribute('fill', c.fill);
      path.setAttribute('stroke', c.stroke);
      path.setAttribute('stroke-width', '0.6');
      path.style.cursor = 'pointer';
      path.style.transition = 'opacity 0.15s';
      path.addEventListener('mouseenter', function(e){ onEnter(e, code, h); });
      path.addEventListener('mousemove',  function(e){ onMove(e); });
      path.addEventListener('mouseleave', onLeave);
    });
  }

  function onEnter(e, code, h) {
    var cnt = nodeCounts[code] || 0;
    ttName.textContent   = countryNames[code] || code;
    ttCount.textContent  = cnt + ' node' + (cnt !== 1 ? 's' : '');
    ttHealth.textContent = healthLabel[h] || h;
    ttHealth.className   = 'mt-0.5 font-medium ' + (healthClass[h] || 'text-slate-500');
    tooltip.classList.remove('hidden');
    onMove(e);
  }
  function onMove(e) {
    var rect = wrap.getBoundingClientRect();
    var x = e.clientX - rect.left + 12;
    var y = e.clientY - rect.top  + 12;
    var tw = tooltip.offsetWidth || 140;
    if (x + tw > rect.width - 8) x = e.clientX - rect.left - tw - 8;
    tooltip.style.left = x + 'px';
    tooltip.style.top  = y + 'px';
  }
  function onLeave() { tooltip.classList.add('hidden'); }

  colorMap();
})();
</script>
{{end}}
