{{define "external_allowlist"}}
<div class="space-y-6">

  <section class="r-card !p-0 overflow-hidden">
    <div class="px-5 pt-5 pb-4 border-b" style="border-color:rgb(var(--border))">
      <p class="t-eyebrow">Security</p>
      <h2 class="t-h2">External upstream allowlist</h2>
      <p class="t-small mt-1">FQDNs an <strong>External HTTPS upstream</strong> route is permitted to proxy to. Open-relay defense: a node never reaches a host not on this list. Effective allowlist is the <strong>union</strong> of these DB entries and the <code>EXTERNAL_UPSTREAM_ALLOWLIST</code> env CSV.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Host</th>
            <th>Note</th>
            <th>Added</th>
            <th class="text-right"></th>
          </tr>
        </thead>
        <tbody>
          {{range .Hosts}}
          <tr>
            <td class="font-mono font-medium">{{.Host}}</td>
            <td>{{.Note}}</td>
            <td class="text-xs tabular-nums">{{.Created}}</td>
            <td class="text-right">
              <form method="POST" action="/admin/settings/external-allowlist/{{.ID}}/delete" class="inline" data-confirm="Remove {{.Host}} from the allowlist?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="r-btn-danger text-xs cursor-pointer">delete</button>
              </form>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="px-5 py-8 text-center t-muted">
              No DB allowlist hosts.
              {{if not .EnvHosts}}External routes will be rejected until a host is added here or via env.{{end}}
            </td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{if .EnvHosts}}
    <div class="px-5 py-3 border-t t-small" style="border-color:rgb(var(--border))">
      <span class="font-medium t-body">From env (read-only):</span>
      {{range .EnvHosts}}<code class="mx-0.5 px-1.5 py-0.5 rounded-lg" style="background:rgb(var(--surface-2))">{{.}}</code>{{end}}
    </div>
    {{end}}
  </section>

  <section class="r-card">
    <p class="t-eyebrow mb-1">Add host</p>
    <h2 class="t-h3 mb-3">Add to allowlist</h2>
    <form method="POST" action="/admin/settings/external-allowlist" class="space-y-3 max-w-2xl">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="t-caption block mb-1">Host (FQDN)</label>
          <input name="host" required placeholder="adm.tools" class="r-input w-full font-mono text-xs">
        </div>
        <div>
          <label class="t-caption block mb-1">Note (optional)</label>
          <input name="note" maxlength="255" placeholder="adm.tools gov API" class="r-input w-full text-xs">
        </div>
      </div>
      <button class="r-btn-primary cursor-pointer">Add host</button>
    </form>
  </section>

</div>
{{end}}
