{{define "audit"}}
<div class="mb-4 flex flex-wrap gap-2 text-sm">
  <a href="/admin/audit" class="px-3 py-1 rounded-full {{if eq .Filter ""}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">All</a>
  <a href="/admin/audit?entity=auth" class="px-3 py-1 rounded-full {{if eq .Filter "auth"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Auth</a>
  <a href="/admin/audit?entity=plan" class="px-3 py-1 rounded-full {{if eq .Filter "plan"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Plans</a>
  <a href="/admin/audit?entity=client" class="px-3 py-1 rounded-full {{if eq .Filter "client"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Clients</a>
  <a href="/admin/audit?entity=service" class="px-3 py-1 rounded-full {{if eq .Filter "service"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Services</a>
  <a href="/admin/audit?entity=route" class="px-3 py-1 rounded-full {{if eq .Filter "route"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Routes</a>
  <a href="/admin/audit?entity=user" class="px-3 py-1 rounded-full {{if eq .Filter "user"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Users</a>
  <a href="/admin/audit?entity=node" class="px-3 py-1 rounded-full {{if eq .Filter "node"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Nodes</a>
  <a href="/admin/audit?entity=settings" class="px-3 py-1 rounded-full {{if eq .Filter "settings"}}bg-indigo-600 text-white{{else}}bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-700{{end}}">Settings</a>
</div>

<form method="GET" action="/admin/audit" class="hpg-card mb-4 grid grid-cols-1 sm:grid-cols-4 gap-3 text-sm">
  <input type="hidden" name="entity" value="{{.Filter}}">
  <div>
    <label class="hpg-eyebrow block mb-1">Action contains</label>
    <input name="action" value="{{.ActionLike}}" placeholder="impersonate" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div>
    <label class="hpg-eyebrow block mb-1">Actor (email or system)</label>
    <input name="actor" value="{{.ActorLike}}" placeholder="alice@" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div>
    <label class="hpg-eyebrow block mb-1">Since</label>
    <input name="since" type="date" value="{{.Since}}" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <div class="flex items-end gap-2">
    <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-xs font-medium hover:bg-indigo-700">Filter</button>
    <a href="/admin/audit{{if .Filter}}?entity={{.Filter}}{{end}}" class="px-4 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-xs text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-zinc-800">Reset</a>
  </div>
</form>

<div class="hpg-card overflow-x-auto p-0">
  <table class="w-full text-sm">
    <thead class="hpg-eyebrow text-left bg-slate-50/60 dark:bg-zinc-800/40">
      <tr>
        <th class="px-4 py-3 font-medium">When</th>
        <th class="px-4 py-3 font-medium">Actor</th>
        <th class="px-4 py-3 font-medium">Action</th>
        <th class="px-4 py-3 font-medium">Entity</th>
        <th class="px-4 py-3 font-medium">ID</th>
        <th class="px-4 py-3 font-medium">IP</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
      {{range .Entries}}
      <tr>
        <td class="px-4 py-3 text-xs font-mono text-slate-700 dark:text-slate-200 whitespace-nowrap">{{.CreatedAt}}</td>
        <td class="px-4 py-3 text-slate-600 dark:text-slate-300">{{.ActorLabel}}</td>
        <td class="px-4 py-3"><code class="text-xs">{{.Action}}</code></td>
        <td class="px-4 py-3 text-slate-700 dark:text-slate-200">{{.Entity}}</td>
        <td class="px-4 py-3 text-xs text-slate-500 dark:text-slate-400">{{.EntityID}}</td>
        <td class="px-4 py-3 text-xs text-slate-500 dark:text-slate-400 font-mono">{{.IP}}</td>
      </tr>
      {{else}}
      <tr><td colspan="6" class="px-4 py-8 text-center text-slate-500 dark:text-slate-400">No audit entries yet.</td></tr>
      {{end}}
    </tbody>
  </table>
</div>
<div class="mt-3 flex items-center gap-3">
  <p class="text-xs text-slate-500">Showing last {{.Limit}} entries.</p>
  <a href="/admin/audit/export?entity={{.Filter}}&action={{.ActionLike}}&actor={{.ActorLike}}&since={{.Since}}&format=csv"
     class="text-xs px-3 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-zinc-800">
    Export CSV
  </a>
  <a href="/admin/audit/export?entity={{.Filter}}&action={{.ActionLike}}&actor={{.ActorLike}}&since={{.Since}}&format=json"
     class="text-xs px-3 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-zinc-800">
    Export JSON
  </a>
</div>
{{end}}
