{{define "audit"}}
<!-- Entity filter tab bar -->
<nav class="r-segment mb-4" role="tablist">
  <a href="/admin/audit" class="r-segment-item {{if eq .Filter ""}}is-active{{end}}">All</a>
  <a href="/admin/audit?entity=auth" class="r-segment-item {{if eq .Filter "auth"}}is-active{{end}}">Auth</a>
  <a href="/admin/audit?entity=plan" class="r-segment-item {{if eq .Filter "plan"}}is-active{{end}}">Plans</a>
  <a href="/admin/audit?entity=client" class="r-segment-item {{if eq .Filter "client"}}is-active{{end}}">Clients</a>
  <a href="/admin/audit?entity=service" class="r-segment-item {{if eq .Filter "service"}}is-active{{end}}">Services</a>
  <a href="/admin/audit?entity=route" class="r-segment-item {{if eq .Filter "route"}}is-active{{end}}">Routes</a>
  <a href="/admin/audit?entity=user" class="r-segment-item {{if eq .Filter "user"}}is-active{{end}}">Users</a>
  <a href="/admin/audit?entity=node" class="r-segment-item {{if eq .Filter "node"}}is-active{{end}}">Nodes</a>
  <a href="/admin/audit?entity=settings" class="r-segment-item {{if eq .Filter "settings"}}is-active{{end}}">Settings</a>
</nav>

<form method="GET" action="/admin/audit" class="r-card mb-4 grid grid-cols-1 sm:grid-cols-5 gap-3">
  <input type="hidden" name="entity" value="{{.Filter}}">
  <div>
    <label class="t-eyebrow block mb-1">Search</label>
    <input name="q" value="{{.Q}}" placeholder="action, entity, actor..." class="r-input w-full">
  </div>
  <div>
    <label class="t-eyebrow block mb-1">Action contains</label>
    <input name="action" value="{{.ActionLike}}" placeholder="impersonate" class="r-input w-full">
  </div>
  <div>
    <label class="t-eyebrow block mb-1">Actor (email or system)</label>
    <input name="actor" value="{{.ActorLike}}" placeholder="alice@" class="r-input w-full">
  </div>
  <div>
    <label class="t-eyebrow block mb-1">Since</label>
    <input name="since" type="date" value="{{.Since}}" class="r-input w-full">
  </div>
  <div class="flex items-end gap-2">
    <button class="r-btn-primary text-xs cursor-pointer transition-colors">Filter</button>
    <a href="/admin/audit{{if .Filter}}?entity={{.Filter}}{{end}}" class="r-btn-secondary text-xs">Reset</a>
  </div>
</form>

{{if .SavedFilters}}
<div class="r-card mb-4">
  <p class="t-eyebrow mb-2">Saved filters</p>
  <div class="flex flex-wrap gap-2">
    {{range .SavedFilters}}
    <div class="flex items-center gap-1">
      <a href="/admin/audit?saved_filter={{.ID}}" class="r-pill r-pill-info cursor-pointer">{{.Name}}</a>
      <form method="POST" action="/admin/saved-filters/audit/{{.ID}}/delete" class="inline">
        <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
        <button type="submit" class="t-muted hover:text-[rgb(var(--danger))] text-xs cursor-pointer" title="Delete filter">&times;</button>
      </form>
    </div>
    {{end}}
  </div>
</div>
{{end}}

<div class="r-card !p-0 overflow-hidden mb-4">
  <table class="r-table">
    <thead>
      <tr>
        <th>
          <a href="/admin/audit?entity={{.Filter}}&action={{.ActionLike}}&actor={{.ActorLike}}&since={{.Since}}&q={{.Q}}&sort=created_at&dir={{if and (eq .Sort "created_at") (eq .Dir "desc")}}asc{{else}}desc{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
            When
            {{if eq .Sort "created_at"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
          </a>
        </th>
        <th>
          <a href="/admin/audit?entity={{.Filter}}&action={{.ActionLike}}&actor={{.ActorLike}}&since={{.Since}}&q={{.Q}}&sort=actor&dir={{if and (eq .Sort "actor") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
            Actor
            {{if eq .Sort "actor"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
          </a>
        </th>
        <th>Action</th>
        <th>Entity</th>
        <th>ID</th>
        <th>IP</th>
      </tr>
    </thead>
    <tbody>
      {{range .Entries}}
      <tr>
        <td class="font-mono text-xs tabular-nums whitespace-nowrap">{{.CreatedAt}}</td>
        <td>{{.ActorLabel}}</td>
        <td><code class="text-xs">{{.Action}}</code></td>
        <td>{{.Entity}}</td>
        <td class="text-xs t-muted tabular-nums">{{.EntityID}}</td>
        <td class="font-mono text-xs t-muted">{{.IP}}</td>
      </tr>
      {{else}}
      <tr><td colspan="6" class="px-4 py-8 text-center t-muted">No audit entries match your filter.</td></tr>
      {{end}}
    </tbody>
  </table>
</div>

{{template "pagination" (dict "Total" .Total "TotalPgs" .TotalPgs "Page" .Page "PrevURL" .PrevURL "NextURL" .NextURL "Size" .Size)}}

<div class="mt-3 flex flex-wrap items-center gap-3">
  <a href="/admin/audit/export?entity={{.Filter}}&action={{.ActionLike}}&actor={{.ActorLike}}&since={{.Since}}&format=csv" class="r-btn-secondary text-xs">Export CSV</a>
  <a href="/admin/audit/export?entity={{.Filter}}&action={{.ActionLike}}&actor={{.ActorLike}}&since={{.Since}}&format=json" class="r-btn-secondary text-xs">Export JSON</a>
  <button type="button" id="audit-save-filter-btn" class="r-btn-ghost text-xs cursor-pointer transition-colors" style="color:rgb(var(--accent))">Save filter</button>
  {{if eq .Role "super_admin"}}
  <form method="POST" action="/admin/audit/clear" class="inline ml-auto"
        data-confirm-type="DELETE" data-confirm="Permanently delete ALL audit entries? This cannot be undone.">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <button type="submit" class="r-btn-danger text-xs inline-flex items-center gap-1 cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
      </svg>
      Clear log
    </button>
  </form>
  {{end}}
</div>

<!-- Save filter modal -->
<div id="audit-save-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 backdrop-blur-sm" style="background:rgba(0,0,0,0.5)" id="audit-modal-overlay"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="r-card rounded-2xl shadow-xl w-full max-w-sm !p-6" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between mb-4">
        <h3 class="t-h3">Save filter</h3>
        <button type="button" id="audit-modal-close" class="t-muted hover:text-[rgb(var(--text))] cursor-pointer text-lg leading-none">&times;</button>
      </div>
      <form method="POST" action="/admin/saved-filters/audit" class="space-y-3">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <input type="hidden" name="query_json" value="{{.QueryValues}}">
        <div>
          <label class="t-eyebrow block mb-1">Filter name</label>
          <input name="filter_name" required placeholder="e.g. Auth events today" class="r-input w-full">
        </div>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" id="audit-modal-cancel" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script nonce="{{.CSPNonce}}">
(function(){
  var btn = document.getElementById("audit-save-filter-btn");
  var modal = document.getElementById("audit-save-modal");
  var overlay = document.getElementById("audit-modal-overlay");
  var closeBtn = document.getElementById("audit-modal-close");
  var cancelBtn = document.getElementById("audit-modal-cancel");
  if (!btn || !modal) return;
  btn.addEventListener("click", function(){ modal.classList.remove("hidden"); });
  function close(){ modal.classList.add("hidden"); }
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function(e){ if (e.key==="Escape") close(); });
})();
</script>
{{end}}
