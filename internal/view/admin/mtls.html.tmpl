{{define "mtls"}}
<div class="space-y-6">

  {{if .Flash}}
  <div class="rounded-xl bg-emerald-50 dark:bg-emerald-950/40 ring-1 ring-emerald-200 dark:ring-emerald-800/60 p-3 text-sm text-emerald-800 dark:text-emerald-200">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="rounded-xl bg-rose-50 dark:bg-rose-950/40 ring-1 ring-rose-200 dark:ring-rose-800/60 p-3 text-sm text-rose-800 dark:text-rose-200">{{.Error}}</div>
  {{end}}

  <!-- Header + create action -->
  <section class="hpg-card p-5 flex items-start justify-between gap-4">
    <div>
      <h2 class="font-semibold text-slate-800 dark:text-slate-100 flex items-center gap-2">
        <svg class="h-5 w-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
        </svg>
        Certificate authorities <span class="font-normal text-slate-400">({{.Total}})</span>
      </h2>
      <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 max-w-2xl">Generate a per-tenant or operator CA, issue client certificates for mutual-TLS auth, and revoke them. CA private keys are encrypted at rest; client keys are shown only once at issue time.</p>
      <p class="text-[11px] text-amber-600 dark:text-amber-400 mt-1.5">Scaffold: issued certs are not yet enforced on hosts/paths by the proxy.</p>
    </div>
    <button type="button" onclick="openCAModal()" class="shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors cursor-pointer">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      New CA
    </button>
  </section>

  <!-- CA list, each with its issued certs -->
  {{range .CAs}}
  <section class="hpg-card overflow-hidden p-0">
    <div class="p-4 border-b border-slate-100 dark:border-zinc-800 flex items-start justify-between gap-3">
      <div>
        <h3 class="font-semibold text-slate-800 dark:text-slate-100 text-sm flex items-center gap-2">
          {{if .Name}}{{.Name}}{{else}}<span class="text-slate-400">(unnamed)</span>{{end}}
          {{if eq .Status "active"}}{{if .Expired}}<span class="hpg-pill hpg-pill-err">expired</span>{{else}}<span class="hpg-pill hpg-pill-ok">active</span>{{end}}{{else}}<span class="hpg-pill hpg-pill-warn">{{.Status}}</span>{{end}}
        </h3>
        <p class="font-mono text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">CN={{.CommonName}}</p>
        <p class="text-[11px] text-slate-400 mt-0.5">
          {{if .ClientID.Valid}}Scoped to client #{{.ClientID.Int64}}{{else}}Operator-wide{{end}} · expires {{.NotAfter}}
        </p>
      </div>
      <div class="flex items-center gap-3 text-xs whitespace-nowrap">
        <button type="button" onclick="openIssueModal({{.ID}}, '{{.Name}}')"
          class="inline-flex items-center gap-1 text-indigo-600 dark:text-indigo-400 hover:underline cursor-pointer transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          issue cert
        </button>
        <form method="POST" action="/admin/mtls/ca/{{.ID}}/delete" class="inline" data-confirm="Delete this CA and ALL its issued certificates?">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button class="text-rose-600 dark:text-rose-400 hover:underline cursor-pointer">delete CA</button>
        </form>
      </div>
    </div>

    <table class="w-full text-sm">
      <thead class="text-left hpg-eyebrow">
        <tr>
          <th class="px-4 py-2.5">Subject</th>
          <th class="px-4 py-2.5">Serial</th>
          <th class="px-4 py-2.5">Issued</th>
          <th class="px-4 py-2.5">Expires</th>
          <th class="px-4 py-2.5">Status</th>
          <th class="px-4 py-2.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
      {{range .Certs}}
        <tr>
          <td class="px-4 py-2.5 font-medium text-slate-800 dark:text-slate-100 text-xs">{{.Subject}}</td>
          <td class="px-4 py-2.5 font-mono text-[11px] text-slate-500 dark:text-slate-400">{{.Serial}}</td>
          <td class="px-4 py-2.5 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">{{.IssuedAt}}</td>
          <td class="px-4 py-2.5 text-xs whitespace-nowrap {{if .Expired}}text-rose-600 dark:text-rose-400 font-medium{{else}}text-slate-600 dark:text-slate-300{{end}}">{{.NotAfter}}</td>
          <td class="px-4 py-2.5 text-xs">
            {{if .Revoked}}<span class="hpg-pill hpg-pill-err">revoked</span>
            {{else if .Expired}}<span class="hpg-pill hpg-pill-warn">expired</span>
            {{else}}<span class="hpg-pill hpg-pill-ok">active</span>{{end}}
          </td>
          <td class="px-4 py-2.5 text-right text-xs whitespace-nowrap">
            {{if not .Revoked}}
            <form method="POST" action="/admin/mtls/cert/{{.ID}}/revoke" class="inline" data-confirm="Revoke this client certificate?">
              <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
              <button class="text-rose-600 dark:text-rose-400 hover:underline cursor-pointer">revoke</button>
            </form>
            {{else}}<span class="text-slate-400">revoked {{.RevokedAt}}</span>{{end}}
          </td>
        </tr>
      {{else}}
        <tr><td colspan="6" class="px-4 py-6 text-center text-slate-400 text-xs">No client certificates issued from this CA yet.</td></tr>
      {{end}}
      </tbody>
    </table>
  </section>
  {{else}}
  <section class="hpg-card p-10 text-center text-slate-500 dark:text-slate-400 text-sm">
    No certificate authorities yet. Create one to start issuing client certificates.
  </section>
  {{end}}

</div>

<!-- One-shot issued bundle modal: shown once after a successful issue -->
{{if .Bundle}}
<div id="bundle-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4" aria-modal="true" role="dialog">
  <div class="w-full max-w-2xl rounded-2xl bg-white dark:bg-zinc-900 shadow-2xl ring-1 ring-slate-200 dark:ring-zinc-700 overflow-y-auto max-h-[90vh]">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 dark:border-zinc-800">
      <h2 class="font-semibold text-slate-800 dark:text-slate-100">Client certificate for "{{.Bundle.Subject}}"</h2>
      <button type="button" onclick="closeBundleModal()" class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="p-5 space-y-4 text-sm">
      <div class="rounded-xl bg-amber-50 dark:bg-amber-950/40 ring-1 ring-amber-200 dark:ring-amber-800/60 p-3 text-xs text-amber-800 dark:text-amber-200">
        The private key below is shown <strong>only once</strong> and is never stored on the server. Copy it now - it cannot be recovered.
      </div>
      <p class="text-xs text-slate-500 dark:text-slate-400">Serial <span class="font-mono">{{.Bundle.Serial}}</span></p>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Certificate PEM</label>
        <textarea readonly rows="7" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 dark:text-slate-100 font-mono text-xs resize-y">{{.Bundle.CertPEM}}</textarea>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Private key PEM <span class="text-rose-500">(save now)</span></label>
        <textarea readonly rows="7" class="w-full px-3 py-2 rounded-lg ring-1 ring-rose-200 dark:ring-rose-800/60 border-0 bg-rose-50/40 dark:bg-zinc-800/50 dark:text-slate-100 font-mono text-xs resize-y">{{.Bundle.KeyPEM}}</textarea>
      </div>
      <div class="flex items-center justify-end pt-1">
        <button type="button" onclick="closeBundleModal()" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors cursor-pointer">I have saved the key</button>
      </div>
    </div>
  </div>
</div>
{{end}}

<!-- Create CA modal -->
<div id="ca-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4" aria-modal="true" role="dialog">
  <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-zinc-900 shadow-2xl ring-1 ring-slate-200 dark:ring-zinc-700">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 dark:border-zinc-800">
      <h2 class="font-semibold text-slate-800 dark:text-slate-100">New certificate authority</h2>
      <button type="button" onclick="closeCAModal()" class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form method="POST" action="/admin/mtls/ca" class="p-5 space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Label (optional)</label>
        <input name="name" placeholder="e.g. Acme device fleet CA"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Common name <span class="text-rose-500">*</span></label>
        <input name="common_name" required placeholder="e.g. Acme Internal Root CA"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Client ID (optional)</label>
          <input name="client_id" type="number" min="1" placeholder="operator-wide if blank"
            class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
        </div>
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Valid for (days)</label>
          <input name="valid_days" type="number" min="1" placeholder="3650"
            class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
        </div>
      </div>
      <div class="flex items-center justify-end gap-3 pt-1">
        <button type="button" onclick="closeCAModal()" class="px-4 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm transition-colors cursor-pointer">Cancel</button>
        <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors cursor-pointer">Generate CA</button>
      </div>
    </form>
  </div>
</div>

<!-- Issue client cert modal -->
<div id="issue-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4" aria-modal="true" role="dialog">
  <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-zinc-900 shadow-2xl ring-1 ring-slate-200 dark:ring-zinc-700">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 dark:border-zinc-800">
      <h2 class="font-semibold text-slate-800 dark:text-slate-100">Issue client certificate <span id="issue-ca-name" class="font-normal text-slate-400"></span></h2>
      <button type="button" onclick="closeIssueModal()" class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form id="issue-form" method="POST" class="p-5 space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <p class="text-xs text-slate-500 dark:text-slate-400">A fresh keypair is generated and signed by this CA. The private key is returned once and not stored.</p>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Subject (common name) <span class="text-rose-500">*</span></label>
        <input name="subject" required placeholder="e.g. device-42 or alice@acme.com"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Valid for (days)</label>
        <input name="valid_days" type="number" min="1" placeholder="365"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
      </div>
      <div class="flex items-center justify-end gap-3 pt-1">
        <button type="button" onclick="closeIssueModal()" class="px-4 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm transition-colors cursor-pointer">Cancel</button>
        <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors cursor-pointer">Issue certificate</button>
      </div>
    </form>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
function openCAModal() { document.getElementById('ca-modal').classList.remove('hidden'); }
function closeCAModal() { document.getElementById('ca-modal').classList.add('hidden'); }
function openIssueModal(caID, name) {
  var f = document.getElementById('issue-form');
  f.action = '/admin/mtls/ca/' + caID + '/issue';
  document.getElementById('issue-ca-name').textContent = name ? '(' + name + ')' : '';
  document.getElementById('issue-modal').classList.remove('hidden');
}
function closeIssueModal() { document.getElementById('issue-modal').classList.add('hidden'); }
function closeBundleModal() {
  var m = document.getElementById('bundle-modal');
  if (m) m.remove(); // drop the key from the DOM once dismissed
}
// Close any open modal on backdrop click.
['ca-modal','issue-modal','bundle-modal'].forEach(function(id) {
  var m = document.getElementById(id);
  if (m) m.addEventListener('click', function(e) { if (e.target === this) this.classList.add('hidden'); });
});
</script>
{{end}}
