{{define "mtls"}}
<div class="space-y-6">

  {{if .Flash}}
  <div class="rounded-xl bg-[rgb(var(--success)/.12)] ring-1 ring-[rgb(var(--success)/.4)] p-3 t-small text-[rgb(var(--success))]">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="rounded-xl bg-[rgb(var(--danger)/.12)] ring-1 ring-[rgb(var(--danger)/.4)] p-3 t-small text-[rgb(var(--danger))]">{{.Error}}</div>
  {{end}}

  <!-- Header + create action -->
  <section class="r-card flex items-start justify-between gap-4">
    <div>
      <h2 class="t-h3 flex items-center gap-2">
        <svg class="h-5 w-5 text-[rgb(var(--accent))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
        </svg>
        Certificate authorities <span class="font-normal text-[rgb(var(--muted))]">({{.Total}})</span>
      </h2>
      <p class="t-small text-[rgb(var(--muted))] mt-1 max-w-2xl">Generate a per-tenant or operator CA, issue client certificates for mutual-TLS auth, and revoke them. CA private keys are encrypted at rest; client keys are shown only once at issue time.</p>
      <p class="t-caption text-[rgb(var(--muted))] mt-1.5">Enforce per host under the host editor's <strong>mTLS</strong> tab (Require client certificate &rarr; pick this CA).</p>
    </div>
    <button type="button" data-action="open-ca" class="r-btn-primary shrink-0 inline-flex items-center gap-1.5 cursor-pointer">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      New CA
    </button>
  </section>

  <!-- CA list, each with its issued certs -->
  {{range .CAs}}
  <section class="r-card !p-0 overflow-hidden">
    <div class="px-5 py-4 border-b border-[rgb(var(--border))] flex items-start justify-between gap-3">
      <div>
        <h3 class="t-h3 flex items-center gap-2">
          {{if .Name}}{{.Name}}{{else}}<span class="text-[rgb(var(--muted))]">(unnamed)</span>{{end}}
          {{if eq .Status "active"}}{{if .Expired}}<span class="r-pill r-pill-danger">expired</span>{{else}}<span class="r-pill r-pill-success">active</span>{{end}}{{else}}<span class="r-pill r-pill-warning">{{.Status}}</span>{{end}}
        </h3>
        <p class="font-mono t-caption text-[rgb(var(--muted))] mt-0.5">CN={{.CommonName}}</p>
        <p class="t-caption text-[rgb(var(--muted))] mt-0.5">
          {{if .ClientID.Valid}}Scoped to client #{{.ClientID.Int64}}{{else}}Operator-wide{{end}} &middot; expires {{.NotAfter}}
        </p>
      </div>
      <div class="flex items-center gap-3 text-xs whitespace-nowrap">
        <button type="button" data-action="open-issue" data-ca-id="{{.ID}}" data-ca-name="{{.Name}}"
          class="inline-flex items-center gap-1 text-[rgb(var(--accent))] hover:underline cursor-pointer transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          issue cert
        </button>
        <a href="/admin/mtls/ca/{{.ID}}/bundle.pem" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] transition-colors">CA PEM</a>
        <a href="/admin/mtls/ca/{{.ID}}/crl" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] transition-colors">revocation list</a>
        <form method="POST" action="/admin/mtls/ca/{{.ID}}/delete" class="inline" data-confirm="Delete this CA and ALL its issued certificates?">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button class="text-[rgb(var(--danger))] hover:underline cursor-pointer">delete CA</button>
        </form>
      </div>
    </div>

    <table class="r-table w-full text-sm">
      <thead>
        <tr>
          <th>Subject</th>
          <th>Serial</th>
          <th>Issued</th>
          <th>Expires</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
      {{range .Certs}}
        <tr>
          <td class="font-medium text-[rgb(var(--text))] text-xs">{{.Subject}}</td>
          <td class="font-mono t-caption text-[rgb(var(--muted))]">{{.Serial}}</td>
          <td class="t-caption text-[rgb(var(--muted))] whitespace-nowrap tabular-nums">{{.IssuedAt}}</td>
          <td class="t-caption whitespace-nowrap tabular-nums {{if .Expired}}text-[rgb(var(--danger))] font-medium{{else}}text-[rgb(var(--muted))]{{end}}">{{.NotAfter}}</td>
          <td class="text-xs">
            {{if .Revoked}}<span class="r-pill r-pill-danger">revoked</span>
            {{else if .Expired}}<span class="r-pill r-pill-warning">expired</span>
            {{else}}<span class="r-pill r-pill-success">active</span>{{end}}
          </td>
          <td class="text-right text-xs whitespace-nowrap">
            {{if not .Revoked}}
            <form method="POST" action="/admin/mtls/cert/{{.ID}}/revoke" class="inline" data-confirm="Revoke this client certificate?">
              <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
              <button class="text-[rgb(var(--danger))] hover:underline cursor-pointer">revoke</button>
            </form>
            {{else}}<span class="text-[rgb(var(--muted))]">revoked {{.RevokedAt}}</span>{{end}}
          </td>
        </tr>
      {{else}}
        <tr><td colspan="6" class="px-4 py-6 text-center text-[rgb(var(--muted))] text-xs">No client certificates issued from this CA yet.</td></tr>
      {{end}}
      </tbody>
    </table>
  </section>
  {{else}}
  <section class="r-card">
    <div class="r-empty">
      <div class="r-empty-icon">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      </div>
      <p class="font-medium text-[rgb(var(--text))]">No certificate authorities yet</p>
      <p class="t-small text-[rgb(var(--muted))]">Create one to start issuing client certificates.</p>
    </div>
  </section>
  {{end}}

</div>

<!-- One-shot issued bundle modal: shown once after a successful issue -->
{{if .Bundle}}
<div id="bundle-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" aria-modal="true" role="dialog">
  <div class="r-card w-full max-w-2xl shadow-2xl overflow-y-auto max-h-[90vh]">
    <div class="flex items-center justify-between pb-4 mb-4 border-b border-[rgb(var(--border))]">
      <h2 class="t-h3">Client certificate for "{{.Bundle.Subject}}"</h2>
      <button type="button" data-action="close-bundle" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="space-y-4 text-sm">
      <div class="rounded-xl bg-[rgb(var(--warning)/.12)] ring-1 ring-[rgb(var(--warning)/.4)] p-3 t-caption text-[rgb(var(--warning))]">
        The private key below is shown <strong>only once</strong> and is never stored on the server. Copy it now - it cannot be recovered.
      </div>
      <p class="t-caption text-[rgb(var(--muted))]">Serial <span class="font-mono">{{.Bundle.Serial}}</span></p>
      <div>
        <label class="t-eyebrow block mb-1">Certificate PEM</label>
        <textarea readonly rows="7" class="r-input w-full font-mono text-xs resize-y">{{.Bundle.CertPEM}}</textarea>
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Private key PEM <span class="text-[rgb(var(--danger))]">(save now)</span></label>
        <textarea readonly rows="7" class="r-input w-full font-mono text-xs resize-y ring-[rgb(var(--danger)/.5)]">{{.Bundle.KeyPEM}}</textarea>
      </div>
      <div class="flex items-center justify-end pt-1">
        <button type="button" data-action="close-bundle" class="r-btn-primary cursor-pointer">I have saved the key</button>
      </div>
    </div>
  </div>
</div>
{{end}}

<!-- Create CA modal -->
<div id="ca-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" aria-modal="true" role="dialog">
  <div class="r-card w-full max-w-lg shadow-2xl">
    <div class="flex items-center justify-between pb-4 mb-4 border-b border-[rgb(var(--border))]">
      <h2 class="t-h3">New certificate authority</h2>
      <button type="button" data-action="close-ca" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form method="POST" action="/admin/mtls/ca" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="t-eyebrow block mb-1">Label (optional)</label>
        <input name="name" placeholder="e.g. Acme device fleet CA" class="r-input w-full">
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Common name <span class="text-[rgb(var(--danger))]">*</span></label>
        <input name="common_name" required placeholder="e.g. Acme Internal Root CA" class="r-input w-full">
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="t-eyebrow block mb-1">Client ID (optional)</label>
          <input name="client_id" type="number" min="1" placeholder="operator-wide if blank" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Valid for (days)</label>
          <input name="valid_days" type="number" min="1" placeholder="3650" class="r-input w-full">
        </div>
      </div>
      <div class="flex items-center justify-end gap-3 pt-1">
        <button type="button" data-action="close-ca" class="r-btn-secondary cursor-pointer">Cancel</button>
        <button type="submit" class="r-btn-primary cursor-pointer">Generate CA</button>
      </div>
    </form>
  </div>
</div>

<!-- Issue client cert modal -->
<div id="issue-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" aria-modal="true" role="dialog">
  <div class="r-card w-full max-w-lg shadow-2xl">
    <div class="flex items-center justify-between pb-4 mb-4 border-b border-[rgb(var(--border))]">
      <h2 class="t-h3">Issue client certificate <span id="issue-ca-name" class="font-normal text-[rgb(var(--muted))]"></span></h2>
      <button type="button" data-action="close-issue" class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form id="issue-form" method="POST" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <p class="t-small text-[rgb(var(--muted))]">A fresh keypair is generated and signed by this CA. The private key is returned once and not stored.</p>
      <div>
        <label class="t-eyebrow block mb-1">Subject (common name) <span class="text-[rgb(var(--danger))]">*</span></label>
        <input name="subject" required placeholder="e.g. device-42 or alice@acme.com" class="r-input w-full">
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Valid for (days)</label>
        <input name="valid_days" type="number" min="1" placeholder="365" class="r-input w-full">
      </div>
      <div class="flex items-center justify-end gap-3 pt-1">
        <button type="button" data-action="close-issue" class="r-btn-secondary cursor-pointer">Cancel</button>
        <button type="submit" class="r-btn-primary cursor-pointer">Issue certificate</button>
      </div>
    </form>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function(){
  function openCAModal() { document.getElementById('ca-modal').classList.remove('hidden'); }
  function closeCAModal() { document.getElementById('ca-modal').classList.add('hidden'); }
  function openIssueModal(caID, name) {
    var f = document.getElementById('issue-form');
    f.action = '/admin/mtls/ca/' + caID + '/issue';
    document.getElementById('issue-ca-name').textContent = name ? '(' + name + ')' : '';
    document.getElementById('issue-modal').classList.remove('hidden');
  }
  function closeIssueModal() { document.getElementById('issue-modal').classList.add('hidden'); }
  function closeBundleModal() {
    var m = document.getElementById('bundle-modal');
    if (m) m.remove(); // drop the key from the DOM once dismissed
  }

  // CSP blocks inline on* handlers (nonce applies only to <script>), so wire
  // clicks via delegated data-action instead.
  document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-action]');
    if (!el) return;
    switch (el.getAttribute('data-action')) {
      case 'open-ca':      openCAModal(); break;
      case 'close-ca':     closeCAModal(); break;
      case 'open-issue':   openIssueModal(el.getAttribute('data-ca-id'), el.getAttribute('data-ca-name')); break;
      case 'close-issue':  closeIssueModal(); break;
      case 'close-bundle': closeBundleModal(); break;
    }
  });

  // Close any open modal on backdrop click.
  ['ca-modal','issue-modal','bundle-modal'].forEach(function(id) {
    var m = document.getElementById(id);
    if (m) m.addEventListener('click', function(e) { if (e.target === this) this.classList.add('hidden'); });
  });
})();
</script>
{{end}}
