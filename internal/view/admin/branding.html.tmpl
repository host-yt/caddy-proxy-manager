{{define "branding"}}
<div class="max-w-2xl space-y-4">
  <p class="t-small" style="color:rgb(var(--muted))">Customise the panel + login page brand. URLs must be <code class="text-xs">http://</code> or <code class="text-xs">https://</code> (they render as <code class="text-xs">&lt;img src&gt;</code>/<code class="text-xs">&lt;link href&gt;</code> so other schemes are refused).</p>

  <form method="POST" action="/admin/branding" class="r-card space-y-4 text-sm">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">

    <div>
      <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Brand name</label>
      <input name="brand_name" value="{{.BrandName}}" maxlength="64" placeholder="Hostyt Proxy" class="r-input w-full">
      <p class="t-caption mt-1" style="color:rgb(var(--muted))">Shown in the sidebar + login header. Empty = default "Hostyt Proxy".</p>
    </div>

    <div>
      <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Tagline (optional)</label>
      <input name="tagline" value="{{.Tagline}}" maxlength="128" placeholder="Self-hosted reverse-proxy panel" class="r-input w-full">
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Logo URL (light mode)</label>
        <input name="logo_url_light" value="{{.LogoURLLight}}" placeholder="https://cdn.example.com/logo-dark.svg" class="r-input w-full">
        {{if .LogoURLLight}}<div class="mt-2 inline-block p-2 rounded-xl" style="background:rgb(var(--surface));border:1px solid rgb(var(--border))"><img src="{{.LogoURLLight}}" alt="light preview" class="h-8"></div>{{end}}
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Used on white backgrounds. Pick a logo with dark ink.</p>
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Logo URL (dark mode)</label>
        <input name="logo_url_dark" value="{{.LogoURLDark}}" placeholder="https://cdn.example.com/logo-light.svg" class="r-input w-full">
        {{if .LogoURLDark}}<div class="mt-2 inline-block p-2 rounded-xl" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))"><img src="{{.LogoURLDark}}" alt="dark preview" class="h-8"></div>{{end}}
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Falls back to the light logo if empty. Pick a logo with light ink for dark backgrounds.</p>
      </div>
    </div>

    <div>
      <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Favicon URL</label>
      <input name="favicon_url" value="{{.FaviconURL}}" placeholder="https://cdn.example.com/favicon.ico" class="r-input w-full">
      <p class="t-caption mt-1" style="color:rgb(var(--muted))">16x16 ICO or PNG. Browsers cache aggressively - change the URL or path to bust.</p>
    </div>

    <div class="rounded-xl p-4 space-y-3" style="background:rgb(var(--surface-2) / .5);border:1px solid rgb(var(--border))">
      <div class="t-eyebrow">Error / maintenance page skin</div>
      <p class="t-caption" style="color:rgb(var(--muted))">Branding for the pages Caddy serves directly (404, 403, 502, 503, 504, maintenance). Empty fields fall back to a neutral deep-gray skin.</p>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Error page logo URL</label>
        <input name="error_logo_url" value="{{.ErrorLogoURL}}" placeholder="https://cdn.example.com/logo-error.svg" class="r-input w-full">
        {{if .ErrorLogoURL}}<div class="mt-2 inline-block p-2 rounded-xl" style="background: {{if .ErrorBgColor}}{{.ErrorBgColor}}{{else}}#1f2937{{end}};"><img src="{{.ErrorLogoURL}}" alt="error logo preview" class="h-8"></div>{{end}}
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Error page logo link</label>
        <input name="error_logo_link" value="{{.ErrorLogoLink}}" placeholder="https://www.your-brand.com/" class="r-input w-full">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Where the logo links on error pages. Leave empty for a non-clickable logo.</p>
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Background color</label>
        <div class="flex gap-2 items-center">
          <input name="error_bg_color" value="{{.ErrorBgColor}}" placeholder="#1f2937" class="r-input flex-1 font-mono">
          <span class="inline-block w-8 h-8 rounded-lg shrink-0" style="background: {{if .ErrorBgColor}}{{.ErrorBgColor}}{{else}}#1f2937{{end}};border:1px solid rgb(var(--border))"></span>
        </div>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Hex (#RGB / #RRGGBB / #RRGGBBAA) or rgb()/rgba(). Default is deep slate (#1f2937).</p>
      </div>
    </div>

    <div class="flex justify-end pt-2">
      <button class="r-btn-primary">Save branding</button>
    </div>
  </form>
</div>
{{end}}
