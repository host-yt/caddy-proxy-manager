{{define "tunnel_detail"}}
<div class="space-y-6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <a href="/admin/tunnels" class="t-small flex items-center gap-1 mb-1 transition-colors" style="color:rgb(var(--muted))">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
        All tunnels
      </a>
      <h2 class="t-h2">{{.Peer.Name}}</h2>
      <p class="t-small font-mono mt-0.5" style="color:rgb(var(--muted))">{{.Peer.AssignedIP}} &middot; {{.Peer.NodeName}} &middot; client {{.Peer.ClientEmail}}</p>
    </div>
    <div class="flex items-center gap-2">
      {{if ne .Role "support"}}
      {{if ne .Peer.Status "revoked"}}
      <form method="POST" action="/admin/tunnels/{{.Peer.ID}}/reissue" data-confirm="Re-issue config for {{.Peer.Name}}?">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-secondary t-small cursor-pointer" style="color:rgb(14,165,233)">Reissue config</button>
      </form>
      <form method="POST" action="/admin/tunnels/{{.Peer.ID}}/rotate" data-confirm="Rotate key for {{.Peer.Name}}? Customer must re-run install.">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button class="r-btn-secondary t-small cursor-pointer" style="color:rgb(var(--accent))">Rotate key</button>
      </form>
      {{end}}
      {{end}}
      <a href="/admin/tunnels/{{.Peer.ID}}/usage.csv" class="r-btn-secondary t-small cursor-pointer">
        <svg class="w-3.5 h-3.5 mr-1 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        Export CSV
      </a>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="r-card">
      <div class="t-eyebrow">Status</div>
      <div class="mt-2">
        {{if eq .Peer.Status "active"}}<span class="r-pill r-pill-success">active</span>{{end}}
        {{if eq .Peer.Status "pending"}}<span class="r-pill r-pill-warning">pending install</span>{{end}}
        {{if eq .Peer.Status "revoked"}}<span class="r-pill r-pill-neutral">revoked</span>{{end}}
      </div>
      <div class="t-caption mt-1" style="color:rgb(var(--muted))">since {{.Peer.CreatedAt}}</div>
    </div>
    <div class="r-card">
      <div class="t-eyebrow">Health</div>
      <div class="mt-2">
        {{if .Peer.Healthy}}<span class="r-pill r-pill-success">connected</span>
        {{else if eq .Peer.Status "active"}}<span class="r-pill r-pill-warning">stale</span>
        {{else}}<span class="t-small" style="color:rgb(var(--muted))">-</span>{{end}}
      </div>
      <div class="t-caption mt-1" style="color:rgb(var(--muted))">last handshake {{.Peer.LastHandshake}}</div>
    </div>
    <div class="r-card">
      <div class="t-eyebrow">This month</div>
      <div class="t-display mt-1" style="font-size:1.25rem">{{.MonthRxHuman}}</div>
      <div class="t-caption mt-0.5" style="color:rgb(var(--muted))">RX &middot; TX {{.MonthTxHuman}}</div>
    </div>
    <div class="r-card">
      <div class="t-eyebrow">Key age</div>
      <div class="t-display mt-1" style="font-size:1.25rem">{{.Peer.KeyAgeHuman}}</div>
      {{if .PeakHour}}<div class="t-caption mt-0.5" style="color:rgb(var(--muted))">peak hour {{.PeakHour}} (30d)</div>{{end}}
    </div>
  </div>

  <!-- Bandwidth charts -->
  <div class="r-card space-y-4">
    <div class="flex items-center justify-between gap-3">
      <span class="t-body font-medium">Bandwidth history</span>
      <div class="r-segment" id="hpg-detail-periods">
        <button type="button" data-period="24h" class="r-segment-item is-active hpg-bw-period-btn cursor-pointer">24h</button>
        <button type="button" data-period="7d"  class="r-segment-item hpg-bw-period-btn cursor-pointer">7d</button>
        <button type="button" data-period="30d" class="r-segment-item hpg-bw-period-btn cursor-pointer">30d</button>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="t-caption font-medium mb-1" style="color:rgb(var(--success))">RX (received)</div>
        <canvas id="hpg-detail-rx" height="100"></canvas>
      </div>
      <div>
        <div class="t-caption font-medium mb-1" style="color:rgb(14,165,233)">TX (transmitted)</div>
        <canvas id="hpg-detail-tx" height="100"></canvas>
      </div>
    </div>
    <div class="grid grid-cols-3 gap-4 pt-3" style="border-top:1px solid rgb(var(--border))">
      <div>
        <div class="t-eyebrow">Session RX</div>
        <div class="font-mono t-small font-medium mt-0.5">{{.Peer.RxHuman}}</div>
      </div>
      <div>
        <div class="t-eyebrow">Session TX</div>
        <div class="font-mono t-small font-medium mt-0.5">{{.Peer.TxHuman}}</div>
      </div>
      <div>
        <div class="t-eyebrow">Lifetime</div>
        <div class="font-mono t-small font-medium mt-0.5">{{.Peer.CumRxHuman}} / {{.Peer.CumTxHuman}}</div>
      </div>
    </div>
  </div>

  <!-- Rotation history -->
  <div class="r-card !p-0 overflow-hidden">
    <div class="px-5 py-3" style="border-bottom:1px solid rgb(var(--border))">
      <h3 class="t-body font-medium">Key rotation history</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Source</th>
            <th>Actor</th>
          </tr>
        </thead>
        <tbody>
        {{range .RotationLog}}
          <tr>
            <td class="font-mono t-small" style="color:rgb(var(--muted))">{{.RotatedAt}}</td>
            <td>
              {{if eq .Source "manual"}}<span class="r-pill r-pill-info">manual</span>
              {{else if eq .Source "job"}}<span class="r-pill r-pill-neutral">scheduled</span>
              {{else if eq .Source "reissue"}}<span class="r-pill r-pill-info">reissue</span>
              {{else}}<span class="r-pill r-pill-neutral">{{.Source}}</span>{{end}}
            </td>
            <td class="t-small font-mono" style="color:rgb(var(--muted))">
              {{if .ActorID}}user #{{.ActorID}}{{else}}-{{end}}
            </td>
          </tr>
        {{else}}
          <tr><td colspan="3" class="px-4 py-8 text-center t-small" style="color:rgb(var(--muted))">No rotation events recorded yet.</td></tr>
        {{end}}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="/static/js/chart.umd.min.js" nonce="{{.CSPNonce}}"></script>
<script nonce="{{.CSPNonce}}">
(function(){
  if (!window.Chart) return;
  var dark = document.documentElement.classList.contains('dark');
  var gridColor = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
  var tickColor = dark ? '#94a3b8' : '#475569';
  Chart.defaults.color = tickColor;
  Chart.defaults.borderColor = gridColor;

  var peerId = {{.Peer.ID}};
  var charts = [];

  function fmtBytes(n) {
    if (n >= 1073741824) return (n/1073741824).toFixed(1)+' GB';
    if (n >= 1048576)    return (n/1048576).toFixed(1)+' MB';
    if (n >= 1024)       return (n/1024).toFixed(1)+' KB';
    return n+' B';
  }

  function makeChart(id, label, color, labels, data) {
    var el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: label, data: data,
          borderColor: color,
          backgroundColor: color.replace(')',',0.12)').replace('rgb','rgba'),
          fill: true, tension: 0.3,
          pointRadius: data.length > 30 ? 0 : 2
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { callback: function(v){ return fmtBytes(v); } } } }
      }
    });
  }

  function load(period) {
    charts.forEach(function(c){ if(c) c.destroy(); });
    charts = [];
    fetch('/admin/tunnels/' + peerId + '/bandwidth.json?period=' + period)
      .then(function(r){ return r.json(); })
      .then(function(d){
        charts.push(makeChart('hpg-detail-rx', 'RX', 'rgb(16,185,129)', d.labels, d.rx));
        charts.push(makeChart('hpg-detail-tx', 'TX', 'rgb(14,165,233)', d.labels, d.tx));
      })
      .catch(function(e){ console.warn('bandwidth fetch failed', e); });
  }

  var bar = document.getElementById('hpg-detail-periods');
  if (bar) {
    bar.querySelectorAll('.hpg-bw-period-btn').forEach(function(b){
      b.addEventListener('click', function(){
        bar.querySelectorAll('.hpg-bw-period-btn').forEach(function(x){
          x.classList.toggle('is-active', x === b);
        });
        load(b.getAttribute('data-period'));
      });
    });
  }

  load('24h');
})();
</script>
{{end}}
