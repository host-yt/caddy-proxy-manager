{{define "hosts"}}
<div class="space-y-5">
  <div class="flex items-center justify-between">
    <div>
      <p class="t-eyebrow">Admin</p>
      <h2 class="t-h2">All hosts <span class="t-small" style="color:rgb(var(--muted))">({{.Total}})</span></h2>
      <p class="t-caption">Every domain mapped on every Caddy node, across every client.</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/admin/hosts/export.csv" class="r-btn-ghost inline-flex items-center gap-1.5 text-xs cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export CSV
      </a>
      <a href="/admin/hosts/new" class="r-btn-primary inline-flex items-center gap-1.5 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add host
      </a>
    </div>
  </div>

  {{/* Status summary chips - computed once, click to filter */}}
  {{$total := 0}}
  {{range $k, $v := .StatusCounts}}{{$total = add $total $v}}{{end}}
  {{if $total}}
  <div class="flex flex-wrap gap-2">
    <a href="/admin/hosts" class="r-pill cursor-pointer transition-colors {{if eq .Status ""}}r-pill-info{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{$total}}</span> all
    </a>
    {{with index .StatusCounts "active"}}{{if gt . 0}}
    <a href="/admin/hosts?status=active" class="r-pill cursor-pointer transition-colors {{if eq $.Status "active"}}r-pill-success{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> active
    </a>
    {{end}}{{end}}
    {{with index .StatusCounts "failed"}}{{if gt . 0}}
    <a href="/admin/hosts?status=failed" class="r-pill cursor-pointer transition-colors {{if eq $.Status "failed"}}r-pill-danger{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> failed
    </a>
    {{end}}{{end}}
    {{with index .StatusCounts "pending_dns"}}{{if gt . 0}}
    <a href="/admin/hosts?status=pending_dns" class="r-pill cursor-pointer transition-colors {{if eq $.Status "pending_dns"}}r-pill-warning{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> pending DNS
    </a>
    {{end}}{{end}}
    {{with index .StatusCounts "dns_ok"}}{{if gt . 0}}
    <a href="/admin/hosts?status=dns_ok" class="r-pill cursor-pointer transition-colors {{if eq $.Status "dns_ok"}}r-pill-info{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> DNS ok
    </a>
    {{end}}{{end}}
    {{with index .StatusCounts "pending_ssl"}}{{if gt . 0}}
    <a href="/admin/hosts?status=pending_ssl" class="r-pill cursor-pointer transition-colors {{if eq $.Status "pending_ssl"}}r-pill-info{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> pending SSL
    </a>
    {{end}}{{end}}
    {{with index .StatusCounts "disabled"}}{{if gt . 0}}
    <a href="/admin/hosts?status=disabled" class="r-pill cursor-pointer transition-colors {{if eq $.Status "disabled"}}r-pill-neutral{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> disabled
    </a>
    {{end}}{{end}}
    {{with index .StatusCounts "maintenance"}}{{if gt . 0}}
    <a href="/admin/hosts?status=maintenance" class="r-pill cursor-pointer transition-colors {{if eq $.Status "maintenance"}}r-pill-warning{{else}}r-pill-neutral{{end}}">
      <span class="font-bold">{{.}}</span> maintenance
    </a>
    {{end}}{{end}}
  </div>
  {{end}}

  <form method="GET" action="/admin/hosts" class="r-card flex flex-wrap items-end gap-3 text-sm">
    <div class="flex-1 min-w-[200px]">
      <label class="t-eyebrow mb-1 block">Search</label>
      <input name="q" value="{{.Q}}" placeholder="example.com or alice@" class="r-input w-full">
    </div>
    <div>
      <label class="t-eyebrow mb-1 block">Status</label>
      <select name="status" class="r-select">
        <option value="">any</option>
        <option value="active" {{if eq .Status "active"}}selected{{end}}>active</option>
        <option value="pending_dns" {{if eq .Status "pending_dns"}}selected{{end}}>pending DNS</option>
        <option value="dns_ok" {{if eq .Status "dns_ok"}}selected{{end}}>DNS ok</option>
        <option value="pending_ssl" {{if eq .Status "pending_ssl"}}selected{{end}}>pending SSL</option>
        <option value="failed" {{if eq .Status "failed"}}selected{{end}}>failed</option>
        <option value="disabled" {{if eq .Status "disabled"}}selected{{end}}>disabled</option>
      </select>
    </div>
    <div>
      <label class="t-eyebrow mb-1 block">Node</label>
      <select name="node_id" class="r-select">
        <option value="">any</option>
        {{range .NodeOptions}}
        <option value="{{.ID}}" {{if eq .ID $.NodeIDFilter}}selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </div>
    <div>
      <label class="t-eyebrow mb-1 block">Tag</label>
      <input name="tag" value="{{.TagFilter}}" placeholder="saas-customer-1" class="r-input">
    </div>
    <div>
      <label class="t-eyebrow mb-1 block">Backend IP</label>
      <input type="text" name="backend_ip" value="{{.BackendIPFilter}}" placeholder="192.168.1." class="r-input w-36">
    </div>
    <div>
      <label class="t-eyebrow mb-1 block">Group</label>
      <select name="group_id" class="r-select">
        <option value="">any</option>
        {{range .Groups}}
        <option value="{{.ID}}" {{if eq .ID $.GroupFilter}}selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </div>
    <div class="flex gap-1.5">
      <button class="r-btn-secondary text-xs cursor-pointer">Filter</button>
      <a href="/admin/hosts" class="r-btn-ghost text-xs">Reset</a>
    </div>
  </form>

  <!-- Bulk action form is HIDDEN - it's submitted via JS so per-row
       action buttons (retry/toggle/delete) stay independent. HTML5 forbids
       nested <form> elements; wrapping the table in a bulk form swallowed
       row-level submits and caused "Select at least one row." on retry. -->
  <form method="POST" action="/admin/hosts/bulk" id="hosts-bulk-form" class="hidden">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <input type="hidden" name="action" id="hosts-bulk-action">
    <div id="hosts-bulk-ids"></div>
  </form>

  <section class="r-card !p-0 overflow-hidden">
    {{if .Hosts}}
    <div class="px-5 py-3 flex items-center gap-2 text-xs" style="border-bottom:1px solid rgb(var(--border))">
      <span class="t-eyebrow">Bulk action</span>
      <select id="hosts-bulk-select" class="r-select text-xs">
        <option value="disable">Disable selected</option>
        <option value="enable">Enable selected</option>
        <option value="delete">Delete selected</option>
        <option value="set_tag">Set tag</option>
        <option value="clear_tag">Clear tag</option>
        <option value="move_node">Move to node</option>
        <option value="maintenance_on">Enable maintenance</option>
        <option value="maintenance_off">Disable maintenance</option>
        <option value="retry_ssl">Retry SSL</option>
        <option value="resync">Force resync node</option>
      </select>
      <input type="text" id="hosts-bulk-tag" placeholder="tag" maxlength="64"
             class="r-input hidden w-32 text-xs">
      <select id="hosts-bulk-node" name="node_id" class="r-select hidden text-xs">
        <option value="">Select node...</option>
        {{range .NodeOptions}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
      </select>
      <button type="button" id="hosts-bulk-apply" class="r-btn-secondary text-xs cursor-pointer">Apply</button>
    </div>
    {{end}}
    <div class="overflow-x-auto"><table class="r-table w-full text-sm">
      <!-- sticky header stays visible while scrolling tall tables -->
      <thead class="sticky top-0 z-10" style="background:rgb(var(--surface)/0.97);backdrop-filter:blur(4px)">
        <tr>
          <th class="pl-5 pr-2 py-3 w-8"><input type="checkbox" data-check-all="ids" class="rounded cursor-pointer"></th>
          <th class="min-w-[280px]">Host</th>
          <th class="w-36">Status</th>
          <th class="w-44">Owner</th>
          <th class="text-right w-28">Traffic 24h</th>
          <th class="text-right w-px pr-5">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range .Hosts}}
        <tr id="host-row-{{.RouteID}}" class="hpg-row transition-colors cursor-pointer">
          <td class="pl-5 pr-2 py-4 align-top"><input type="checkbox" name="ids" value="{{.RouteID}}" class="rounded cursor-pointer"></td>

          {{/* HOST: domain + pills | backend | tag + group */}}
          <td class="px-4 py-4 align-top">
            <div class="flex flex-col gap-1">
              {{/* line 1: domain + kind/SSO/mTLS/geo pills */}}
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="font-mono text-xs font-semibold" style="color:rgb(var(--text))">{{.Domain}}{{if .PathPrefix}}<span style="color:rgb(var(--muted))">{{.PathPrefix}}</span>{{end}}</span>
                {{if eq .Kind "redirect"}}<span class="r-pill r-pill-warning">redirect</span>
                {{else if .External}}<span class="r-pill r-pill-info">external</span>
                {{else}}<span class="r-pill r-pill-info">proxy</span>{{end}}
                {{if .SSOProviderURL}}<span title="SSO protected" class="r-pill r-pill-info inline-flex items-center gap-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> SSO
                </span>{{end}}
                {{if .RequireClientCert}}
                  {{if .MTLSCAActive}}<span class="r-pill r-pill-info" title="mTLS: {{.MTLSCAName}}">mTLS</span>
                  {{else}}<span class="r-pill r-pill-warning" title="mTLS requires CA: {{.MTLSCAName}} (inactive)">mTLS!</span>
                  {{end}}
                {{else if .MTLSCAName}}<span class="r-pill r-pill-neutral" title="CA configured, not enforced">mTLS-off</span>{{end}}
                {{if eq .GeoMode "allow"}}<span class="r-pill r-pill-success" title="Geo: allow-list active">geo&#8203;✓</span>{{end}}
                {{if eq .GeoMode "deny"}}<span class="r-pill r-pill-danger" title="Geo: deny-list active">geo&#8203;✗</span>{{end}}
              </div>
              {{/* line 2: backend with arrow icon */}}
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:rgb(var(--muted));flex-shrink:0"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
                <span class="font-mono text-xs" style="color:rgb(var(--muted))">{{.BackendDisplay}}</span>
              </div>
              {{/* line 3: tag + group pills */}}
              {{if or .Tag .GroupName}}
              <div class="flex items-center gap-1 flex-wrap">
                {{if .Tag}}<a href="/admin/hosts?tag={{.Tag}}" class="r-pill r-pill-neutral hover:underline cursor-pointer">{{.Tag}}</a>{{end}}
                {{if .GroupName}}<a href="/admin/hosts?group_id={{.GroupID.Int64}}" class="inline-flex items-center gap-1 r-pill r-pill-neutral hover:underline cursor-pointer transition-colors"><span class="inline-block w-2 h-2 rounded-full flex-shrink-0" style="background:{{.GroupColor}}"></span>{{.GroupName}}</a>{{end}}
              </div>
              {{end}}
            </div>
          </td>

          {{/* STATUS: health pill | cert pill + expiry */}}
          <td class="px-4 py-4 align-top text-xs whitespace-nowrap">
            <div class="flex flex-col gap-1">
              {{/* line 1: health */}}
              <div>
                {{if eq .Health "active"}}<span class="r-pill r-pill-success">active</span>{{end}}
                {{if eq .Health "pending_dns"}}<span class="r-pill r-pill-warning">pending DNS</span>{{end}}
                {{if eq .Health "dns_ok"}}<span class="r-pill r-pill-info">DNS ok</span>{{end}}
                {{if eq .Health "pending_ssl"}}<span class="r-pill r-pill-info">pending SSL</span>{{end}}
                {{if eq .Health "failed"}}<span class="r-pill r-pill-danger" title="{{.LastError}}">failed</span>{{end}}
                {{if eq .Health "disabled"}}<span class="r-pill r-pill-neutral">disabled</span>{{end}}
              </div>
              {{/* line 2: cert status + expiry warning */}}
              <div class="flex items-center gap-1 flex-wrap">
                <span class="t-eyebrow" style="color:rgb(var(--muted))">cert</span>
                {{if eq .CertStatus "active"}}<span class="r-pill r-pill-success">active</span>
                {{else if eq .CertStatus "pending"}}<span class="r-pill r-pill-warning">pending</span>
                {{else}}<span class="r-pill r-pill-neutral">off</span>{{end}}
                {{if ge .CertDaysLeft 0}}{{if le .CertDaysLeft 7}}<span class="r-pill r-pill-danger">exp {{.CertDaysLeft}}d</span>
                {{else if le .CertDaysLeft 30}}<span class="r-pill r-pill-warning">exp {{.CertDaysLeft}}d</span>{{end}}{{end}}
              </div>
              {{if .IssuedAt}}<div class="t-caption" style="color:rgb(var(--muted))" title="Certificate issued">{{.IssuedAt}}</div>{{end}}
            </div>
          </td>

          {{/* OWNER: client email | plan + NPM | node name + hostname */}}
          <td class="px-4 py-4 align-top text-xs">
            <div class="flex flex-col gap-1">
              {{/* line 1: client */}}
              <a href="/admin/clients" class="hover:underline" style="color:rgb(var(--accent))">{{.ClientEmail}}</a>
              {{/* line 2: plan + NPM pill */}}
              <div class="flex items-center gap-1 whitespace-nowrap" style="color:rgb(var(--text))">
                <span>{{.PlanName}}</span>
                {{if eq .PlanKind "npm"}}<span class="r-pill r-pill-info">NPM</span>{{end}}
              </div>
              {{/* line 3: node name + hostname */}}
              <div class="t-caption whitespace-nowrap" style="color:rgb(var(--muted))">{{.NodeName}} {{.NodeHostname}}</div>
            </div>
          </td>

          {{/* TRAFFIC 24h: req | err */}}
          <td class="px-4 py-4 align-top text-xs text-right whitespace-nowrap tabular-nums">
            <div class="flex flex-col gap-1 items-end">
              <div style="color:rgb(var(--text))">
                <span class="t-eyebrow" style="color:rgb(var(--muted))">req </span>{{if gt .Req24h 0}}{{printf "%d" .Req24h}}{{else}}<span style="color:rgb(var(--muted))">-</span>{{end}}
              </div>
              <div>
                <span class="t-eyebrow" style="color:rgb(var(--muted))">err </span>{{if gt .Err24h 0}}<span class="font-medium" style="color:rgb(var(--danger,220 38 38))">{{printf "%d" .Err24h}}</span>{{else}}<span style="color:rgb(var(--muted))">-</span>{{end}}
              </div>
            </div>
          </td>
          <td class="pl-2 pr-5 py-4 align-top text-right">
            <!-- Kebab toggle; menu is position:fixed, opened by global rowactions.js. -->
            <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-expanded="false" aria-haspopup="true"
                    data-hpg-act-btn="host-act-{{.RouteID}}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
              </svg>
            </button>

            <!-- Dropdown menu panel. -->
            <div id="host-act-{{.RouteID}}" class="hpg-act-menu" role="menu">
              <a href="/admin/hosts/{{.RouteID}}/edit" class="hpg-act-item" role="menuitem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit
              </a>
              <a href="/admin/waf?route_id={{.RouteID}}" class="hpg-act-item" role="menuitem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                WAF events
              </a>
              <a href="https://{{.Domain}}" target="_blank" rel="noopener" class="hpg-act-item" role="menuitem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Open site
              </a>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/retry" class="contents" title="Re-run DNS check + re-push to Caddy">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.85"/></svg>
                  Retry
                </button>
              </form>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/toggle" class="contents">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">
                  {{if eq .Status "disabled"}}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 11.08 22 12 12 22 2 12 12 2 22 11.08"/></svg>
                  Enable
                  {{else}}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                  Disable
                  {{end}}
                </button>
              </form>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/toggle-maintenance" class="contents">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  {{if .MaintenanceMode}}Disable maintenance{{else}}Enable maintenance{{end}}
                </button>
              </form>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/clone" class="contents" data-confirm="Clone this route? It will be created as inactive.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">
                  <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
                    <rect x="7" y="7" width="10" height="10" rx="1.5"/>
                    <path d="M4 13V4a1.5 1.5 0 0 1 1.5-1.5H13"/>
                  </svg>
                  Clone
                </button>
              </form>
              <div style="height:1px;background:rgb(var(--border));margin:0.25rem 0.4rem;border-radius:1px;"></div>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/delete" class="contents"
                    hx-post="/admin/hosts/{{.RouteID}}/delete"
                    hx-target="#host-row-{{.RouteID}}" hx-swap="outerHTML swap:150ms"
                    hx-confirm="Delete {{.Domain}}? This cannot be undone.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                  Delete
                </button>
              </form>
            </div>
          </td>
        </tr>
        {{else}}
        <!-- centered empty state with icon and primary CTA -->
        <tr><td colspan="6" class="px-4 py-16 text-center">
          <div class="flex flex-col items-center gap-3">
            <div class="icon-chip" style="width:48px;height:48px;background:rgb(var(--accent-weak))">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:rgb(var(--accent))" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
            </div>
            <p class="t-body font-medium">No hosts found</p>
            <p class="t-caption max-w-xs">Add your first host to start routing traffic through Caddy.</p>
            <a href="/admin/hosts/new" class="r-btn-primary mt-1 inline-flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add first host
            </a>
          </div>
        </td></tr>
        {{end}}
      </tbody>
    </table></div>
    {{if .Hosts}}
    <div class="px-5 py-3.5 flex flex-wrap items-center justify-between gap-2 text-xs" style="border-top:1px solid rgb(var(--border));color:rgb(var(--muted))">
      <span>Showing page {{.Page}} of {{.TotalPages}} · {{.Total}} host{{if ne .Total 1}}s{{end}} total</span>
      <div class="flex items-center gap-1.5">
        {{if .HasPrev}}<a href="/admin/hosts?page={{.PrevPage}}{{.FilterQS}}" class="r-btn-ghost px-3 py-1.5 text-xs">&#8249; Prev</a>
        {{else}}<span class="r-btn-ghost px-3 py-1.5 text-xs opacity-40 cursor-not-allowed">&#8249; Prev</span>{{end}}
        {{if .HasNext}}<a href="/admin/hosts?page={{.NextPage}}{{.FilterQS}}" class="r-btn-ghost px-3 py-1.5 text-xs">Next &#8250;</a>
        {{else}}<span class="r-btn-ghost px-3 py-1.5 text-xs opacity-40 cursor-not-allowed">Next &#8250;</span>{{end}}
      </div>
    </div>
    {{end}}
  </section>

  <!-- Host groups management panel -->
  <details class="r-card group">
    <summary class="flex items-center justify-between cursor-pointer select-none px-5 py-4 -mx-5 -mt-4 -mb-0 rounded-xl">
      <div>
        <p class="t-eyebrow">Organisation</p>
        <h3 class="t-h3">Host groups <span class="icon-chip ml-2 text-xs" style="width:22px;height:22px;font-size:11px;background:rgb(var(--surface-2))">{{len .Groups}}</span></h3>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180" style="color:rgb(var(--muted))" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <div class="mt-4 space-y-4">
      <!-- Create new group -->
      <form method="POST" action="/admin/hosts/groups" class="flex flex-wrap gap-3 items-end text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div class="flex-1 min-w-[160px]">
          <label class="t-eyebrow mb-1 block">New group name</label>
          <input name="name" required maxlength="128" placeholder="e.g. Production" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow mb-1 block">Color</label>
          <input type="color" name="color" value="#6366f1"
            class="w-10 h-9 rounded-lg cursor-pointer" style="border:1px solid rgb(var(--border));background:transparent">
        </div>
        <button type="submit" class="r-btn-primary text-sm cursor-pointer">Add group</button>
      </form>
      <!-- Existing groups list -->
      {{if .Groups}}
      <div class="rounded-xl overflow-hidden" style="border:1px solid rgb(var(--border))">
        {{range .Groups}}
        <div class="flex items-center gap-3 px-4 py-2.5" style="background:rgb(var(--surface));border-bottom:1px solid rgb(var(--border))">
          <span class="inline-block w-3 h-3 rounded-full flex-shrink-0" style="background:{{.Color}}"></span>
          <span class="flex-1 t-body">{{.Name}}</span>
          <a href="/admin/hosts?group_id={{.ID}}" class="text-xs hover:underline cursor-pointer" style="color:rgb(var(--accent))">filter</a>
          <button type="button" class="hg-edit-btn text-xs cursor-pointer" style="color:rgb(var(--muted))" data-id="{{.ID}}" data-name="{{.Name}}" data-color="{{.Color}}">edit</button>
          <form method="POST" action="/admin/hosts/groups/{{.ID}}/delete" class="inline" data-confirm="Delete group {{.Name}}? Routes will be ungrouped.">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <button type="submit" class="text-xs cursor-pointer" style="color:rgb(var(--danger,220 38 38))">delete</button>
          </form>
        </div>
        <!-- Inline edit row -->
        <div id="hg-edit-{{.ID}}" class="hidden px-4 py-3" style="background:rgb(var(--surface-2))">
          <form method="POST" action="/admin/hosts/groups/{{.ID}}/update" class="flex flex-wrap gap-3 items-end text-sm">
            <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
            <div class="flex-1 min-w-[160px]">
              <input name="name" required maxlength="128" value="{{.Name}}" class="r-input w-full">
            </div>
            <div>
              <input type="color" name="color" value="{{.Color}}"
                class="w-10 h-9 rounded-lg cursor-pointer" style="border:1px solid rgb(var(--border));background:transparent">
            </div>
            <button type="submit" class="r-btn-primary text-sm cursor-pointer">Save</button>
            <button type="button" class="hg-cancel-btn r-btn-secondary text-sm cursor-pointer" data-id="{{.ID}}">Cancel</button>
          </form>
        </div>
        {{end}}
      </div>
      {{else}}
      <p class="t-caption">No groups yet.</p>
      {{end}}
    </div>
  </details>

  <script nonce="{{.CSPNonce}}">
  (function(){
    /* -- Bulk action --------------------------------------------------- */
    var sel = document.getElementById('hosts-bulk-select');
    var tagInput = document.getElementById('hosts-bulk-tag');
    var nodeSelect = document.getElementById('hosts-bulk-node');
    // Show tag/node inputs based on selected action.
    if (sel) {
      sel.addEventListener('change', function() {
        if (tagInput) tagInput.classList.toggle('hidden', sel.value !== 'set_tag');
        if (nodeSelect) nodeSelect.classList.toggle('hidden', sel.value !== 'move_node');
      });
    }
    var btn = document.getElementById('hosts-bulk-apply');
    if (btn) {
      btn.addEventListener('click', function(){
        var action = sel.value;
        var ids = Array.from(document.querySelectorAll('tbody input[type="checkbox"][name="ids"]:checked')).map(function(c){ return c.value; });
        if (ids.length === 0) { window.hpgToast && window.hpgToast('Select at least one row.', 'warn'); return; }
        var msg = action === 'delete' ? 'Delete '+ids.length+' host(s)? This cannot be undone.' : action+' '+ids.length+' host(s)?';
        var go = function(){
          document.getElementById('hosts-bulk-action').value = action;
          var box = document.getElementById('hosts-bulk-ids');
          box.innerHTML = '';
          ids.forEach(function(v){
            var i = document.createElement('input');
            i.type = 'hidden'; i.name = 'ids'; i.value = v;
            box.appendChild(i);
          });
          // Append tag value as hidden input when action is set_tag.
          if (action === 'set_tag' && tagInput) {
            var t = document.createElement('input');
            t.type = 'hidden'; t.name = 'tag'; t.value = tagInput.value;
            box.appendChild(t);
          }
          // Append node_id when action is move_node.
          if (action === 'move_node' && nodeSelect) {
            var n = document.createElement('input');
            n.type = 'hidden'; n.name = 'node_id'; n.value = nodeSelect.value;
            box.appendChild(n);
          }
          document.getElementById('hosts-bulk-form').submit();
        };
        if (window.hpgConfirm) {
          window.hpgConfirm(msg).then(function(ok){ if (ok) go(); });
        } else if (confirm(msg)) {
          go();
        }
      });
    }

    /* Row-action kebab open/close is handled globally by rowactions.js. */

    // host group inline edit
    document.querySelectorAll('.hg-edit-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var el = document.getElementById('hg-edit-' + btn.dataset.id);
        if (el) el.classList.toggle('hidden');
      });
    });
    document.querySelectorAll('.hg-cancel-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var el = document.getElementById('hg-edit-' + btn.dataset.id);
        if (el) el.classList.add('hidden');
      });
    });
  })();
  </script>
</div>
{{end}}
