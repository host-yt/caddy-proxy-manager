{{define "hosts"}}
<div class="space-y-5">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">All hosts <span class="text-sm font-normal text-slate-500">({{.Total}})</span></h2>
      <p class="text-xs text-slate-500 dark:text-slate-400">Every domain mapped on every Caddy node, across every client.</p>
    </div>
    <a href="/admin/hosts/new" class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700">+ Add host</a>
  </div>

  <form method="GET" action="/admin/hosts" class="hpg-card flex flex-wrap items-end gap-3 text-sm">
    <div class="flex-1 min-w-[200px]">
      <label class="hpg-eyebrow mb-1 block">Search domain / client email</label>
      <input name="q" value="{{.Q}}" placeholder="example.com or alice@" class="w-full px-3.5 py-2 rounded-full bg-slate-50 dark:bg-zinc-800 ring-1 ring-slate-200/70 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>
    <div>
      <label class="hpg-eyebrow mb-1 block">Status</label>
      <select name="status" class="px-3.5 py-2 rounded-full bg-slate-50 dark:bg-zinc-800 ring-1 ring-slate-200/70 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-400 outline-none">
        <option value="">any</option>
        <option value="active" {{if eq .Status "active"}}selected{{end}}>active</option>
        <option value="pending_dns" {{if eq .Status "pending_dns"}}selected{{end}}>pending DNS</option>
        <option value="dns_ok" {{if eq .Status "dns_ok"}}selected{{end}}>DNS ok</option>
        <option value="pending_ssl" {{if eq .Status "pending_ssl"}}selected{{end}}>pending SSL</option>
        <option value="failed" {{if eq .Status "failed"}}selected{{end}}>failed</option>
        <option value="disabled" {{if eq .Status "disabled"}}selected{{end}}>disabled</option>
      </select>
    </div>
    <div>
      <label class="hpg-eyebrow mb-1 block">Node</label>
      <select name="node_id" class="px-3.5 py-2 rounded-full bg-slate-50 dark:bg-zinc-800 ring-1 ring-slate-200/70 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-400 outline-none">
        <option value="">any</option>
        {{range .NodeOptions}}
        <option value="{{.ID}}" {{if eq .ID $.NodeIDFilter}}selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </div>
    <div>
      <label class="hpg-eyebrow mb-1 block">Tag</label>
      <input name="tag" value="{{.TagFilter}}" placeholder="saas-customer-1" class="px-3.5 py-2 rounded-full bg-slate-50 dark:bg-zinc-800 ring-1 ring-slate-200/70 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>
    <div class="flex gap-1.5">
      <button class="px-4 py-2 rounded-full bg-indigo-600 text-white text-xs font-medium shadow-sm hover:bg-indigo-700">Filter</button>
      <a href="/admin/hosts" class="px-4 py-2 rounded-full ring-1 ring-slate-200/70 dark:ring-zinc-700 text-xs hover:bg-slate-50 dark:hover:bg-zinc-800">Reset</a>
    </div>
  </form>

  <!-- Bulk action form is HIDDEN - it's submitted via JS so per-row
       action buttons (retry/toggle/delete) stay independent. HTML5 forbids
       nested <form> elements; wrapping the table in a bulk form swallowed
       row-level submits and caused "Select at least one row." on retry. -->
  <form method="POST" action="/admin/hosts/bulk" id="hosts-bulk-form" class="hidden">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <input type="hidden" name="action" id="hosts-bulk-action">
    <div id="hosts-bulk-ids"></div>
  </form>

  <section class="hpg-card !p-0 overflow-hidden">
    {{if .Hosts}}
    <div class="px-5 py-3 border-b border-slate-100 dark:border-zinc-800 flex items-center gap-2 text-xs text-slate-600 dark:text-slate-300">
      <span class="hpg-eyebrow">Bulk action</span>
      <select id="hosts-bulk-select" class="px-3 py-1.5 rounded-full bg-slate-50 dark:bg-zinc-800 ring-1 ring-slate-200/70 dark:ring-zinc-700 text-xs outline-none">
        <option value="disable">Disable selected</option>
        <option value="enable">Enable selected</option>
        <option value="delete">Delete selected</option>
      </select>
      <button type="button" id="hosts-bulk-apply" class="px-3 py-1.5 rounded-full bg-slate-800 dark:bg-zinc-700 text-white text-xs hover:bg-slate-900">Apply</button>
    </div>
    {{end}}
    <div class="overflow-x-auto"><table class="w-full text-sm">
      <!-- sticky header stays visible while scrolling tall tables -->
      <thead class="sticky top-0 bg-white/95 dark:bg-zinc-900/95 backdrop-blur-sm z-10 text-left border-b border-slate-100 dark:border-zinc-800">
        <tr>
          <th class="pl-5 pr-2 py-3 w-8"><input type="checkbox" data-check-all="ids" class="rounded"></th>
          <th class="px-4 py-3 min-w-[180px] text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Domain</th>
          <th class="px-4 py-3 text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Backend</th>
          <th class="px-4 py-3 w-24 text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Cert</th>
          <th class="px-4 py-3 w-28 text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Health</th>
          <th class="px-4 py-3 text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Client</th>
          <th class="px-4 py-3 text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Plan</th>
          <th class="px-4 py-3 text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Node</th>
          <th class="pl-2 pr-5 py-3 w-px text-right text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .Hosts}}
        <tr id="host-row-{{.RouteID}}" class="hpg-row hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors cursor-pointer">
          <td class="pl-5 pr-2 py-4 align-top"><input type="checkbox" name="ids" value="{{.RouteID}}" class="rounded"></td>
          <td class="px-4 py-4 align-top">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-mono text-xs font-semibold text-slate-800 dark:text-slate-100">{{.Domain}}{{if .PathPrefix}}<span class="text-slate-400">{{.PathPrefix}}</span>{{end}}</span>
              {{if eq .Kind "redirect"}}<span class="hpg-pill bg-amber-50 text-amber-600 dark:bg-amber-500/15 dark:text-amber-300">redirect</span>
              {{else if .External}}<span class="hpg-pill bg-violet-50 text-violet-600 dark:bg-violet-500/15 dark:text-violet-300">external</span>
              {{else}}<span class="hpg-pill bg-sky-50 text-sky-600 dark:bg-sky-500/15 dark:text-sky-300">proxy</span>{{end}}
              {{if .SSOProviderURL}}<span title="SSO protected" class="hpg-pill bg-violet-50 text-violet-600 dark:bg-violet-500/15 dark:text-violet-300 inline-flex items-center gap-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> SSO</span>{{end}}
            </div>
            {{if .Tag}}<a href="/admin/hosts?tag={{.Tag}}" class="hpg-pill bg-slate-100 text-slate-600 dark:bg-zinc-800 dark:text-slate-300 mt-1.5 hover:bg-indigo-50 hover:text-indigo-600 dark:hover:bg-indigo-500/15 dark:hover:text-indigo-300">{{.Tag}}</a>{{end}}
          </td>
          <td class="px-4 py-4 align-top font-mono text-xs text-slate-500 dark:text-slate-400">{{.BackendDisplay}}</td>
          <td class="px-4 py-4 align-top text-xs whitespace-nowrap">
            {{if eq .CertStatus "active"}}<span class="hpg-pill hpg-pill-ok">active</span>
            {{else if eq .CertStatus "pending"}}<span class="hpg-pill hpg-pill-warn">pending</span>
            {{else}}<span class="hpg-pill hpg-pill-muted">off</span>{{end}}
            {{if ge .CertDaysLeft 0}}{{if le .CertDaysLeft 7}}<span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full ml-1 bg-rose-100 text-rose-700 dark:bg-rose-500/20 dark:text-rose-300">exp in {{.CertDaysLeft}}d</span>
            {{else if le .CertDaysLeft 30}}<span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full ml-1 bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-300">exp in {{.CertDaysLeft}}d</span>{{end}}{{end}}
            {{if .IssuedAt}}<div class="mt-1 text-[10px] text-slate-400" title="Certificate issued">{{.IssuedAt}}</div>{{end}}
          </td>
          <td class="px-4 py-4 align-top text-xs whitespace-nowrap">
            {{if eq .Health "active"}}<span class="hpg-pill hpg-pill-ok">active</span>{{end}}
            {{if eq .Health "pending_dns"}}<span class="hpg-pill hpg-pill-warn">pending DNS</span>{{end}}
            {{if eq .Health "dns_ok"}}<span class="hpg-pill bg-sky-50 text-sky-600 dark:bg-sky-500/15 dark:text-sky-300">DNS ok</span>{{end}}
            {{if eq .Health "pending_ssl"}}<span class="hpg-pill bg-sky-50 text-sky-600 dark:bg-sky-500/15 dark:text-sky-300">pending SSL</span>{{end}}
            {{if eq .Health "failed"}}<span class="hpg-pill hpg-pill-err" title="{{.LastError}}">failed</span>{{end}}
            {{if eq .Health "disabled"}}<span class="hpg-pill hpg-pill-muted">disabled</span>{{end}}
          </td>
          <td class="px-4 py-4 align-top text-xs">
            <a href="/admin/clients" class="text-indigo-600 dark:text-indigo-400 hover:underline">{{.ClientEmail}}</a>
          </td>
          <td class="px-4 py-4 align-top text-xs text-slate-600 dark:text-slate-300 whitespace-nowrap">
            {{.PlanName}}
            {{if eq .PlanKind "npm"}}<span class="hpg-pill bg-indigo-50 text-indigo-600 dark:bg-indigo-500/15 dark:text-indigo-300 ml-1">NPM</span>{{end}}
          </td>
          <td class="px-4 py-4 align-top text-xs text-slate-600 dark:text-slate-300 whitespace-nowrap">{{.NodeName}} <span class="text-slate-400">{{.NodeHostname}}</span></td>
          <td class="pl-2 pr-5 py-4 align-top text-right relative">
            <!-- Desktop: full inline button row (hidden on mobile via CSS). -->
            <div class="hpg-act-desktop inline-flex items-center gap-1.5 text-xs whitespace-nowrap">
              <a href="/admin/hosts/{{.RouteID}}/edit" class="px-2 py-1 rounded-md ring-1 ring-slate-200/70 dark:ring-zinc-700 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-500/15 cursor-pointer transition-colors duration-150">edit</a>
              <a href="https://{{.Domain}}" target="_blank" rel="noopener" title="Open site" class="px-2 py-1 rounded-md ring-1 ring-slate-200/70 dark:ring-zinc-700 text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 cursor-pointer transition-colors duration-150">open ↗</a>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/retry" class="inline" title="Re-run DNS check + re-push to Caddy (forces cert reissue if ACME has been failing)">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="px-2 py-1 rounded-md ring-1 ring-slate-200/70 dark:ring-zinc-700 text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 hover:text-emerald-600 cursor-pointer transition-colors duration-150">retry</button>
              </form>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/toggle" class="inline">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="px-2 py-1 rounded-md ring-1 ring-slate-200/70 dark:ring-zinc-700 text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-500/15 cursor-pointer transition-colors duration-150">{{if eq .Status "disabled"}}enable{{else}}disable{{end}}</button>
              </form>
              <!-- htmx removes the row in place; no-JS falls back to a full POST.
                   hx-confirm is routed through hpgConfirm by the htmx:confirm hook. -->
              <form method="POST" action="/admin/hosts/{{.RouteID}}/delete" class="inline"
                    hx-post="/admin/hosts/{{.RouteID}}/delete"
                    hx-target="#host-row-{{.RouteID}}" hx-swap="outerHTML swap:150ms"
                    hx-confirm="Delete {{.Domain}}? This cannot be undone.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="px-2 py-1 rounded-md ring-1 ring-rose-200/70 dark:ring-rose-500/30 text-rose-600 hover:bg-rose-50 dark:hover:bg-rose-500/15 cursor-pointer transition-colors duration-150">delete</button>
              </form>
            </div>

            <!-- Mobile: three-dot toggle (visible only on mobile via CSS). -->
            <button type="button" class="hpg-act-toggle" aria-label="Row actions" aria-expanded="false" aria-haspopup="true"
                    data-hpg-act-btn="host-act-{{.RouteID}}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
              </svg>
            </button>

            <!-- Dropdown menu panel. -->
            <div id="host-act-{{.RouteID}}" class="hpg-act-menu" role="menu">
              <a href="/admin/hosts/{{.RouteID}}/edit" class="hpg-act-item" role="menuitem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit
              </a>
              <a href="https://{{.Domain}}" target="_blank" rel="noopener" class="hpg-act-item" role="menuitem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Open site
              </a>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/retry" title="Re-run DNS check + re-push to Caddy">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.85"/></svg>
                  Retry
                </button>
              </form>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/toggle">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">
                  {{if eq .Status "disabled"}}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 11.08 22 12 12 22 2 12 12 2 22 11.08"/></svg>
                  Enable
                  {{else}}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                  Disable
                  {{end}}
                </button>
              </form>
              <div style="height:1px;background:rgba(148,163,184,0.2);margin:0.25rem 0.4rem;border-radius:1px;"></div>
              <form method="POST" action="/admin/hosts/{{.RouteID}}/delete"
                    hx-post="/admin/hosts/{{.RouteID}}/delete"
                    hx-target="#host-row-{{.RouteID}}" hx-swap="outerHTML swap:150ms"
                    hx-confirm="Delete {{.Domain}}? This cannot be undone.">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                  Delete
                </button>
              </form>
            </div>
          </td>
        </tr>
        {{else}}
        <!-- centered empty state with icon and primary CTA -->
        <tr><td colspan="9" class="px-4 py-16 text-center">
          <div class="flex flex-col items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 dark:text-zinc-600" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
            <p class="text-sm font-medium text-slate-600 dark:text-slate-300">No hosts found</p>
            <p class="text-xs text-slate-400 dark:text-zinc-500 max-w-xs">Add your first host to start routing traffic through Caddy.</p>
            <a href="/admin/hosts/new" class="mt-1 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add first host
            </a>
          </div>
        </td></tr>
        {{end}}
      </tbody>
    </table></div>
    {{if .Hosts}}
    <div class="px-5 py-3.5 border-t border-slate-100 dark:border-zinc-800 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-600 dark:text-slate-400">
      <span>Showing page {{.Page}} of {{.TotalPages}} <span class="text-slate-400">·</span> {{.Total}} host{{if ne .Total 1}}s{{end}} total</span>
      <div class="flex items-center gap-1.5">
        {{if .HasPrev}}<a href="/admin/hosts?page={{.PrevPage}}{{.FilterQS}}" class="px-3 py-1.5 rounded-full ring-1 ring-slate-200/70 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800">‹ Prev</a>
        {{else}}<span class="px-3 py-1.5 rounded-full ring-1 ring-slate-100 dark:ring-zinc-800 text-slate-300 dark:text-zinc-600">‹ Prev</span>{{end}}
        {{if .HasNext}}<a href="/admin/hosts?page={{.NextPage}}{{.FilterQS}}" class="px-3 py-1.5 rounded-full ring-1 ring-slate-200/70 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800">Next ›</a>
        {{else}}<span class="px-3 py-1.5 rounded-full ring-1 ring-slate-100 dark:ring-zinc-800 text-slate-300 dark:text-zinc-600">Next ›</span>{{end}}
      </div>
    </div>
    {{end}}
  </section>

  <script nonce="{{.CSPNonce}}">
  (function(){
    /* ── Bulk action ───────────────────────────────────────────────── */
    var btn = document.getElementById('hosts-bulk-apply');
    if (btn) {
      btn.addEventListener('click', function(){
        var sel = document.getElementById('hosts-bulk-select');
        var action = sel.value;
        var ids = Array.from(document.querySelectorAll('tbody input[type="checkbox"][name="ids"]:checked')).map(function(c){ return c.value; });
        if (ids.length === 0) { window.hpgToast && window.hpgToast('Select at least one row.', 'warn'); return; }
        var msg = action === 'delete' ? 'Delete '+ids.length+' host(s)? This cannot be undone.' : action+' '+ids.length+' host(s)?';
        var go = function(){
          document.getElementById('hosts-bulk-action').value = action;
          var box = document.getElementById('hosts-bulk-ids');
          box.innerHTML = '';
          ids.forEach(function(v){
            var i = document.createElement('input');
            i.type = 'hidden'; i.name = 'ids'; i.value = v;
            box.appendChild(i);
          });
          document.getElementById('hosts-bulk-form').submit();
        };
        if (window.hpgConfirm) {
          window.hpgConfirm(msg).then(function(ok){ if (ok) go(); });
        } else if (confirm(msg)) {
          go();
        }
      });
    }

    /* ── Mobile row-action dropdown ────────────────────────────────── */
    var openMenu = null; // currently open menu element

    function closeOpen() {
      if (openMenu) {
        openMenu.classList.remove('is-open');
        var prev = document.querySelector('[data-hpg-act-btn][aria-expanded="true"]');
        if (prev) prev.setAttribute('aria-expanded', 'false');
        openMenu = null;
      }
    }

    document.addEventListener('click', function(e) {
      var toggle = e.target.closest('[data-hpg-act-btn]');
      if (toggle) {
        e.stopPropagation();
        var menuId = toggle.dataset.hpgActBtn;
        var menu = document.getElementById(menuId);
        if (!menu) return;
        if (openMenu && openMenu !== menu) closeOpen();
        var isNowOpen = !menu.classList.contains('is-open');
        menu.classList.toggle('is-open', isNowOpen);
        toggle.setAttribute('aria-expanded', isNowOpen ? 'true' : 'false');
        openMenu = isNowOpen ? menu : null;
        return;
      }
      // Click outside closes any open menu.
      if (openMenu && !e.target.closest('.hpg-act-menu')) closeOpen();
    });

    // Escape key closes open menu.
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeOpen();
    });
  })();
  </script>
</div>
{{end}}
