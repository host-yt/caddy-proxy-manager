{{define "resellers"}}
<div class="space-y-6">

  <!-- Create reseller -->
  <div class="r-card space-y-3 text-sm max-w-2xl">
    <h2 class="font-medium" style="color:rgb(var(--text))">New reseller</h2>
    <form method="POST" action="/admin/resellers" class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Name</label>
        <input name="name" maxlength="64" required placeholder="Acme Hosting" class="r-input w-full">
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Slug</label>
        <input name="slug" maxlength="63" required placeholder="acme" class="r-input w-full">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Lowercase, alphanumeric + dashes. Unique.</p>
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Owner email</label>
        <input name="owner_email" type="email" maxlength="128" required placeholder="owner@acme.tld" class="r-input w-full">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Login for the reseller account (role: reseller).</p>
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Owner password</label>
        <input name="owner_password" type="password" minlength="12" required autocomplete="new-password" class="r-input w-full">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Min 12 characters.</p>
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Brand name (optional)</label>
        <input name="brand_name" maxlength="64" placeholder="Acme" class="r-input w-full">
      </div>
      <div>
        <label class="block t-small font-medium mb-1" style="color:rgb(var(--text))">Support email (optional)</label>
        <input name="support_email" type="email" maxlength="128" placeholder="help@acme.tld" class="r-input w-full">
      </div>
      <div class="md:col-span-2">
        <button type="submit" class="r-btn r-btn-primary">Create reseller</button>
      </div>
    </form>
  </div>

  <!-- Reseller packages (aggregate quota tiers) -->
  <div class="r-card space-y-3 text-sm">
    <h2 class="font-medium" style="color:rgb(var(--text))">Packages</h2>
    <p class="t-caption" style="color:rgb(var(--muted))">Aggregate limits + grants shared by subscribed resellers. 0 = unlimited.</p>
    {{range .Packages}}
    <form method="POST" action="/admin/reseller-plans" class="grid grid-cols-2 md:grid-cols-6 gap-2 items-end border-b pb-3" style="border-color:rgb(var(--border))">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <input type="hidden" name="id" value="{{.ID}}">
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Name</label>
        <input name="name" value="{{.Name}}" required class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Max clients</label>
        <input name="max_clients" type="number" min="0" value="{{.MaxClients}}" class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Max services</label>
        <input name="max_services_total" type="number" min="0" value="{{.MaxServices}}" class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Max domains</label>
        <input name="max_domains_total" type="number" min="0" value="{{.MaxDomainsTotal}}" class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">RPM cap</label>
        <input name="rate_limit_rpm_cap" type="number" min="0" value="{{.RateLimitCap}}" class="r-input w-full"></div>
      <div class="flex gap-2">
        <button type="submit" class="r-btn r-btn-secondary">Save</button>
        <button type="submit" formaction="/admin/reseller-plans/{{.ID}}/delete" class="r-btn r-btn-danger-ghost"
                onclick="return confirm('Delete package? Fails if any reseller still uses it.')">Delete</button>
      </div>
      <div class="col-span-2 md:col-span-6">
        <span class="t-caption mr-2" style="color:rgb(var(--muted))">Pools:</span>
        {{$p := .}}{{range $.NodeGroups}}<label class="t-caption mr-3"><input type="checkbox" name="node_group_id" value="{{.ID}}"
          {{$ng := .ID}}{{range $p.NodeGroupIDs}}{{if eq . $ng}}checked{{end}}{{end}}> {{.Name}}</label>{{end}}
        <span class="t-caption mr-2 ml-4" style="color:rgb(var(--muted))">Features:</span>
        {{range $.Features}}<label class="t-caption mr-3"><input type="checkbox" name="feature" value="{{.}}"
          {{$f := .}}{{range $p.Features}}{{if eq . $f}}checked{{end}}{{end}}> {{.}}</label>{{end}}
      </div>
    </form>
    {{end}}
    <!-- New package -->
    <form method="POST" action="/admin/reseller-plans" class="grid grid-cols-2 md:grid-cols-6 gap-2 items-end">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <input type="hidden" name="id" value="0">
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Name</label>
        <input name="name" placeholder="Starter" required class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Max clients</label>
        <input name="max_clients" type="number" min="0" value="0" class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Max services</label>
        <input name="max_services_total" type="number" min="0" value="0" class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">Max domains</label>
        <input name="max_domains_total" type="number" min="0" value="0" class="r-input w-full"></div>
      <div><label class="block t-caption mb-1" style="color:rgb(var(--muted))">RPM cap</label>
        <input name="rate_limit_rpm_cap" type="number" min="0" value="0" class="r-input w-full"></div>
      <div><button type="submit" class="r-btn r-btn-primary">Add package</button></div>
      <div class="col-span-2 md:col-span-6">
        <span class="t-caption mr-2" style="color:rgb(var(--muted))">Pools:</span>
        {{range .NodeGroups}}<label class="t-caption mr-3"><input type="checkbox" name="node_group_id" value="{{.ID}}"> {{.Name}}</label>{{end}}
        <span class="t-caption mr-2 ml-4" style="color:rgb(var(--muted))">Features:</span>
        {{range .Features}}<label class="t-caption mr-3"><input type="checkbox" name="feature" value="{{.}}" checked> {{.}}</label>{{end}}
      </div>
    </form>
  </div>

  {{if not .Resellers}}
  <p class="t-small" style="color:rgb(var(--muted))">No resellers yet. Create one above, then assign clients and provision a reseller-admin.</p>
  {{end}}

  {{range .Resellers}}
  <div class="r-card space-y-4 text-sm">
    <div class="flex items-center justify-between flex-wrap gap-2">
      <div>
        <span class="font-medium" style="color:rgb(var(--text))">{{.Name}}</span>
        <span class="t-caption ml-2" style="color:rgb(var(--muted))">{{.Slug}}</span>
        {{if eq .Status "suspended"}}<span class="r-pill r-pill-danger ml-2">suspended</span>{{else}}<span class="r-pill r-pill-success ml-2">active</span>{{end}}
        <span class="t-caption ml-2" style="color:rgb(var(--muted))">
          {{if .Usage.Limited}}
            clients {{.Usage.Clients}}/{{if .Usage.MaxClients}}{{.Usage.MaxClients}}{{else}}∞{{end}}
            · services {{.Usage.Services}}/{{if .Usage.MaxServices}}{{.Usage.MaxServices}}{{else}}∞{{end}}
            · domains {{.Usage.Domains}}/{{if .Usage.MaxDomains}}{{.Usage.MaxDomains}}{{else}}∞{{end}}
            {{if .Usage.Overselling}}· overselling{{end}}
          {{else}}{{.ClientCount}} clients / {{.AdminCount}} admins · no package (unlimited){{end}}
        </span>
      </div>
      <form method="POST" action="/admin/resellers/{{.ID}}/delete" onsubmit="return confirm('Delete reseller? Owned clients/admins return to platform-direct and their sessions are revoked.')">
        <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
        <button type="submit" class="r-btn r-btn-danger-ghost">Delete</button>
      </form>
    </div>

    <!-- Edit reseller -->
    <form method="POST" action="/admin/resellers/{{.ID}}" class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Name</label>
        <input name="name" value="{{.Name}}" maxlength="64" required class="r-input w-full">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Status</label>
        <select name="status" class="r-input w-full">
          <option value="active" {{if eq .Status "active"}}selected{{end}}>active</option>
          <option value="suspended" {{if eq .Status "suspended"}}selected{{end}}>suspended</option>
        </select>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Brand name</label>
        <input name="brand_name" value="{{.BrandName}}" maxlength="64" class="r-input w-full">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Logo URL</label>
        <input name="logo_url" value="{{.LogoURL}}" class="r-input w-full">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Support email</label>
        <input name="support_email" value="{{.SupportEmail}}" maxlength="128" class="r-input w-full">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Primary color</label>
        <input name="primary_color" value="{{.PrimaryColor}}" placeholder="#3b82f6" class="r-input w-full">
      </div>
      <div class="md:col-span-3">
        <button type="submit" class="r-btn r-btn-secondary">Save</button>
      </div>
    </form>

    <!-- Package + policy -->
    <form method="POST" action="/admin/resellers/{{.ID}}/policy" class="flex items-end gap-3 flex-wrap">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Package</label>
        <select name="reseller_plan_id" class="r-input">
          <option value="0" {{if not .Policy.PlanID}}selected{{end}}>none (unlimited)</option>
          {{$pol := .Policy}}{{range $.Packages}}<option value="{{.ID}}" {{if eq .ID $pol.PlanID}}selected{{end}}>{{.Name}}</option>{{end}}
        </select>
      </div>
      <label class="t-caption pb-2"><input type="checkbox" name="overselling_allowed" value="1" {{if .Policy.Overselling}}checked{{end}}> overselling</label>
      <label class="t-caption pb-2"><input type="checkbox" name="can_create_plans" value="1" {{if .Policy.CanCreatePlans}}checked{{end}}> can create plans</label>
      <button type="submit" class="r-btn r-btn-secondary">Save policy</button>
    </form>

    <!-- Assign a client -->
    <form method="POST" action="/admin/resellers/{{.ID}}/clients" class="flex items-end gap-2 flex-wrap">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <div class="grow">
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Assign client to this reseller</label>
        <select name="client_id" class="r-input w-full">
          {{range $.Clients}}<option value="{{.ID}}">#{{.ID}} {{.Name}}{{if .ResellerID}} (currently: {{.ResellerNam}}){{end}}</option>{{end}}
        </select>
      </div>
      <button type="submit" class="r-btn r-btn-secondary">Assign</button>
      <button type="submit" name="action" value="release" class="r-btn r-btn-ghost">Release</button>
    </form>

    <!-- Provision a reseller-admin -->
    <form method="POST" action="/admin/resellers/{{.ID}}/admins" class="flex items-end gap-2 flex-wrap"
          onsubmit="return confirm('This revokes the user active sessions so the new scope takes effect. Continue?')">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <div class="grow">
        <label class="block t-caption mb-1" style="color:rgb(var(--muted))">Provision reseller-admin (revokes their sessions)</label>
        <select name="user_id" class="r-input w-full">
          {{range $.Admins}}<option value="{{.ID}}">{{.Email}} ({{.Role}}){{if .ResellerID}} - scoped{{end}}</option>{{end}}
        </select>
      </div>
      <button type="submit" class="r-btn r-btn-secondary">Assign</button>
      <button type="submit" name="action" value="release" class="r-btn r-btn-ghost">Release</button>
    </form>
  </div>
  {{end}}

</div>
{{end}}
