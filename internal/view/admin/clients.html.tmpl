{{define "clients"}}
<!-- Hidden bulk form - submitted via JS to avoid nested form issues -->
<form method="POST" action="/admin/clients/bulk" id="cli-bulk-form" class="hidden">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <input type="hidden" name="action" id="cli-bulk-action">
  <div id="cli-bulk-ids"></div>
</form>

<div class="space-y-4">

<!-- Search bar -->
<form method="GET" action="/admin/clients" class="flex items-center gap-2">
  <div class="relative flex-1 max-w-xs">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color:rgb(var(--muted))" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="9" cy="9" r="5"/><path d="M13.5 13.5l3 3"/></svg>
    <input name="q" value="{{.Q}}" placeholder="Search name, email..." class="r-input pl-9">
  </div>
  <button class="r-btn-primary cursor-pointer">Search</button>
  {{if .Q}}<a href="/admin/clients" class="t-small hover:underline cursor-pointer">Clear</a>{{end}}
</form>

{{if .SavedFilters}}
<div class="flex flex-wrap items-center gap-2 text-xs">
  <span class="t-eyebrow">Saved:</span>
  {{range .SavedFilters}}
  <div class="flex items-center gap-1">
    <a href="/admin/clients?saved_filter={{.ID}}" class="r-pill r-pill-info cursor-pointer">{{.Name}}</a>
    <form method="POST" action="/admin/saved-filters/clients/{{.ID}}/delete" class="inline">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <button type="submit" class="t-caption hover:text-[rgb(var(--danger))] cursor-pointer" title="Delete">&times;</button>
    </form>
  </div>
  {{end}}
</div>
{{end}}

<section class="r-card !p-0 overflow-hidden">
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-[rgb(var(--border))]">
    <div class="flex items-center gap-3">
      <div>
        <p class="t-eyebrow">Accounts</p>
        <h2 class="t-h3">Clients</h2>
      </div>
      <span class="r-pill r-pill-neutral">{{.Total}}</span>
    </div>
    <div class="flex items-center gap-2">
      <a href="/admin/clients/export.csv"
        class="r-btn-ghost inline-flex items-center gap-1 text-xs cursor-pointer">
        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M10 3v10M5 13l5 5 5-5"/><path d="M3 17h14"/></svg>
        Download CSV
      </a>
      <button type="button" id="cli-save-filter-btn"
        class="r-btn-secondary inline-flex items-center gap-1 text-xs cursor-pointer">
        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 3h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/><path d="M7 3v5h6V3"/></svg>
        Save filter
      </button>
      <button type="button" id="cli-new-btn"
        class="r-btn-primary inline-flex items-center gap-1.5 cursor-pointer">
        <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M10 4v12M4 10h12"/></svg>
        New client
      </button>
    </div>
  </div>
  <!-- Bulk action bar - hidden until a checkbox is selected -->
  {{if .Clients}}
  <div id="cli-bulk-bar" class="hidden px-5 py-3 border-b border-[rgb(var(--border))] flex items-center gap-2">
    <span class="t-eyebrow">Bulk action</span>
    <select id="cli-bulk-select" class="r-select text-xs">
      <option value="suspend">Suspend selected</option>
      <option value="activate">Activate selected</option>
    </select>
    <button type="button" id="cli-bulk-apply" class="r-btn-secondary text-xs cursor-pointer">Apply</button>
    <span id="cli-bulk-count" class="t-caption"></span>
  </div>
  {{end}}
  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th class="pl-5 pr-2 py-3 w-8"><input type="checkbox" id="cli-chk-all" class="rounded cursor-pointer"></th>
          <th class="px-5 py-3">
            <a href="/admin/clients?q={{.Q}}&sort=display_name&dir={{if and (eq .Sort "display_name") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="inline-flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
              Name
              {{if eq .Sort "display_name"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
            </a>
          </th>
          <th class="px-5 py-3">
            <a href="/admin/clients?q={{.Q}}&sort=email&dir={{if and (eq .Sort "email") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="inline-flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
              Email
              {{if eq .Sort "email"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
            </a>
          </th>
          <th class="px-5 py-3">External ref</th>
          <th class="px-5 py-3">Services</th>
          <th class="px-5 py-3">Bandwidth 30d</th>
          <th class="px-5 py-3">
            <a href="/admin/clients?q={{.Q}}&sort=created_at&dir={{if and (eq .Sort "created_at") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="inline-flex items-center gap-1 cursor-pointer hover:text-[rgb(var(--accent))] transition-colors">
              Created
              {{if eq .Sort "created_at"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
            </a>
          </th>
          <th class="px-5 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range .Clients}}
        <tr class="cursor-pointer">
          <td class="pl-5 pr-2 py-3.5"><input type="checkbox" name="ids" value="{{.ID}}" class="rounded cursor-pointer cli-row-chk"></td>
          <td class="px-5 py-3.5 font-medium whitespace-nowrap">{{.DisplayName}}</td>
          <td class="px-5 py-3.5 whitespace-nowrap">{{.Email}}</td>
          <td class="px-5 py-3.5">{{.ExternalRef}}</td>
          <td class="px-5 py-3.5"><span class="r-pill r-pill-neutral">{{.ServiceCount}}</span></td>
          <td class="px-5 py-3.5 text-xs whitespace-nowrap">{{if .Bandwidth30d}}{{formatBytes .Bandwidth30d}}{{else}}-{{end}}</td>
          <td class="px-5 py-3.5 text-xs whitespace-nowrap">{{.CreatedAt}}</td>
          <td class="px-5 py-3.5 text-right whitespace-nowrap">
            <div class="inline-flex items-center gap-3">
              <button type="button"
                class="cli-edit-btn inline-flex items-center gap-1 text-xs font-medium cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-[rgb(var(--accent))] rounded"
                style="color:rgb(var(--accent))"
                data-id="{{.ID}}"
                data-name="{{if .EditDisplayName}}{{.EditDisplayName}}{{else}}{{.DisplayName}}{{end}}"
                data-email="{{.Email}}"
                data-extref="{{.ExternalRef}}">
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 3.5l3 3L7 16l-3.5.5L4 13z"/></svg>
                edit
              </button>
              <form method="POST" action="/admin/clients/{{.ID}}/delete" data-confirm="Delete client {{.DisplayName}} and their user account?"><input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="inline-flex items-center gap-1 text-xs font-medium cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-[rgb(var(--danger))] rounded" style="color:rgb(var(--danger))">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h12M8 6V4h4v2M6 6l.7 10h6.6L14 6"/></svg>
                  delete
                </button>
              </form>
            </div>
          </td>
        </tr>
        {{else}}
        <!-- centered empty state with icon and primary CTA -->
        <tr><td colspan="8" class="px-5 py-16 text-center">
          <div class="r-empty">
            <span class="r-empty-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <p class="t-body font-medium">{{if .Q}}No clients match your search{{else}}No clients yet{{end}}</p>
            <p class="t-caption max-w-xs">{{if .Q}}Try a different search term or clear the filter.{{else}}Create your first client account to get started.{{end}}</p>
            {{if eq .Q ""}}
            <button type="button" id="cli-empty-new-btn" class="r-btn-primary inline-flex items-center gap-1.5 mt-1 cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              New client
            </button>
            {{end}}
          </div>
        </td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

{{template "pagination" (dict "Total" .Total "TotalPgs" .TotalPgs "Page" .Page "PrevURL" .PrevURL "NextURL" .NextURL "Size" .Size)}}

<!-- Create/Edit modal -->
<div id="cli-modal" class="fixed inset-0 z-50 hidden">
  <div id="cli-modal-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-center justify-center overflow-y-auto p-4 sm:p-6">
    <div class="r-card rounded-2xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto relative" role="dialog" aria-modal="true" aria-labelledby="cli-modal-title">
      <div class="flex items-start justify-between mb-1">
        <div>
          <p class="t-eyebrow">Account</p>
          <h2 id="cli-modal-title" class="t-h3">New client</h2>
        </div>
        <button type="button" id="cli-modal-close"
          class="t-body leading-none cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-[rgb(var(--accent))] rounded" aria-label="Close">&times;</button>
      </div>
      <p class="t-caption mb-5">Clients are customer accounts that own services and hosts. Panel login accounts with roles live under Users.</p>

      <form id="cli-form" method="POST" action="/admin/clients" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="t-eyebrow block mb-1.5">Display name</label>
          <input name="display_name" required placeholder="Acme Corp" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Email (login)</label>
          <input name="email" type="email" required placeholder="ops@acme.com" class="r-input w-full">
        </div>
        <!-- Create-only: password is set on creation, never touched on edit. -->
        <div id="cli-password-field">
          <label class="t-eyebrow block mb-1.5">Initial password</label>
          <input name="password" type="password" minlength="12" class="r-input w-full">
          <p class="t-caption mt-1">Min 12 chars. Give it to the customer; they'll change it after first login.</p>
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">External reference (FOSSBilling order ID)</label>
          <input name="external_ref" class="r-input w-full">
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="cli-modal-cancel" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" id="cli-modal-submit" class="r-btn-primary cursor-pointer">Create client</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Save filter modal -->
<div id="cli-save-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="cli-sf-overlay"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="r-card rounded-2xl shadow-xl w-full max-w-sm" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between mb-4">
        <h3 class="t-h3">Save filter</h3>
        <button type="button" id="cli-sf-close" class="t-body cursor-pointer">&times;</button>
      </div>
      <form method="POST" action="/admin/saved-filters/clients" class="space-y-3 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <input type="hidden" name="query_json" value="{{.QueryValues}}">
        <div>
          <label class="t-eyebrow block mb-1">Filter name</label>
          <input name="filter_name" required placeholder="e.g. Recent clients" class="r-input w-full">
        </div>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" id="cli-sf-cancel" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  var modal = document.getElementById("cli-modal");
  var form = document.getElementById("cli-form");
  var title = document.getElementById("cli-modal-title");
  var submit = document.getElementById("cli-modal-submit");
  var pwField = document.getElementById("cli-password-field");
  if (!modal || !form) return;

  function setVal(name, value) {
    var el = form.elements[name];
    if (el) el.value = (value == null ? "" : value);
  }
  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  var pwInput = form.elements["password"];

  // open modal from both header and empty-state buttons
  function openNewModal() {
    form.reset();
    form.action = "/admin/clients";
    if (title) title.textContent = "New client";
    if (submit) submit.textContent = "Create client";
    if (pwField) pwField.classList.remove("hidden");
    if (pwInput) { pwInput.required = true; pwInput.disabled = false; }
    open();
  }

  var newBtn = document.getElementById("cli-new-btn");
  if (newBtn) newBtn.addEventListener("click", openNewModal);

  // empty-state CTA triggers the same modal
  var emptyNewBtn = document.getElementById("cli-empty-new-btn");
  if (emptyNewBtn) emptyNewBtn.addEventListener("click", openNewModal);

  var editBtns = document.querySelectorAll(".cli-edit-btn");
  for (var i = 0; i < editBtns.length; i++) {
    editBtns[i].addEventListener("click", function () {
      var d = this.dataset;
      form.reset();
      form.action = "/admin/clients/" + d.id + "/edit";
      if (title) title.textContent = "Edit client";
      if (submit) submit.textContent = "Save changes";
      if (pwField) pwField.classList.add("hidden");
      if (pwInput) { pwInput.required = false; pwInput.disabled = true; }
      setVal("display_name", d.name);
      setVal("email", d.email);
      setVal("external_ref", d.extref);
      open();
    });
  }

  var closeBtn = document.getElementById("cli-modal-close");
  var cancelBtn = document.getElementById("cli-modal-cancel");
  var overlay = document.getElementById("cli-modal-overlay");
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });

  // Save filter modal.
  var sfModal = document.getElementById("cli-save-modal");
  var sfBtn = document.getElementById("cli-save-filter-btn");
  var sfOverlay = document.getElementById("cli-sf-overlay");
  var sfClose = document.getElementById("cli-sf-close");
  var sfCancel = document.getElementById("cli-sf-cancel");
  function sfOpen() { if (sfModal) sfModal.classList.remove("hidden"); }
  function sfClose2() { if (sfModal) sfModal.classList.add("hidden"); }
  if (sfBtn) sfBtn.addEventListener("click", sfOpen);
  if (sfClose) sfClose.addEventListener("click", sfClose2);
  if (sfCancel) sfCancel.addEventListener("click", sfClose2);
  if (sfOverlay) sfOverlay.addEventListener("click", sfClose2);

  // Bulk selection logic.
  var bar = document.getElementById("cli-bulk-bar");
  var bulkSel = document.getElementById("cli-bulk-select");
  var bulkApply = document.getElementById("cli-bulk-apply");
  var bulkCount = document.getElementById("cli-bulk-count");
  var chkAll = document.getElementById("cli-chk-all");

  function updateBulkBar() {
    var checked = document.querySelectorAll("tbody input.cli-row-chk:checked");
    if (bar) bar.classList.toggle("hidden", checked.length === 0);
    if (bulkCount) bulkCount.textContent = checked.length + " selected";
  }

  // Wire row checkboxes and select-all.
  document.querySelectorAll("tbody input.cli-row-chk").forEach(function (chk) {
    chk.addEventListener("change", updateBulkBar);
  });
  if (chkAll) {
    chkAll.addEventListener("change", function () {
      document.querySelectorAll("tbody input.cli-row-chk").forEach(function (c) {
        c.checked = chkAll.checked;
      });
      updateBulkBar();
    });
  }

  // Apply bulk action.
  if (bulkApply) {
    bulkApply.addEventListener("click", function () {
      var action = bulkSel ? bulkSel.value : "";
      var ids = Array.from(document.querySelectorAll("tbody input.cli-row-chk:checked")).map(function (c) { return c.value; });
      if (ids.length === 0) { window.hpgToast && window.hpgToast("Select at least one row.", "warn"); return; }
      if (!confirm(action + " " + ids.length + " client(s)?")) return;
      document.getElementById("cli-bulk-action").value = action;
      var box = document.getElementById("cli-bulk-ids");
      box.innerHTML = "";
      ids.forEach(function (v) {
        var inp = document.createElement("input");
        inp.type = "hidden"; inp.name = "ids"; inp.value = v;
        box.appendChild(inp);
      });
      document.getElementById("cli-bulk-form").submit();
    });
  }
})();
</script>
</div>
{{end}}
