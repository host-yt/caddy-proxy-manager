{{define "clients"}}
<div class="space-y-4">

<!-- Search bar -->
<form method="GET" action="/admin/clients" class="flex items-center gap-2">
  <div class="relative flex-1 max-w-xs">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="9" cy="9" r="5"/><path d="M13.5 13.5l3 3"/></svg>
    <input name="q" value="{{.Q}}" placeholder="Search name, email..." class="w-full pl-9 pr-3 py-2 text-sm rounded-lg bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>
  <button class="px-3.5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 cursor-pointer transition-colors">Search</button>
  {{if .Q}}<a href="/admin/clients" class="text-sm text-slate-500 dark:text-slate-400 hover:underline">Clear</a>{{end}}
</form>

{{if .SavedFilters}}
<div class="flex flex-wrap items-center gap-2 text-xs">
  <span class="hpg-eyebrow">Saved:</span>
  {{range .SavedFilters}}
  <div class="flex items-center gap-1">
    <a href="/admin/clients?saved_filter={{.ID}}" class="px-3 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 ring-1 ring-indigo-200 dark:ring-indigo-700 hover:bg-indigo-100 dark:hover:bg-indigo-800/40 transition-colors cursor-pointer">
      {{.Name}}
    </a>
    <form method="POST" action="/admin/saved-filters/clients/{{.ID}}/delete" class="inline">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <button type="submit" class="text-slate-400 hover:text-rose-500 cursor-pointer" title="Delete">&times;</button>
    </form>
  </div>
  {{end}}
</div>
{{end}}

<section class="hpg-card !p-0 overflow-hidden">
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-100 dark:border-zinc-800">
    <div class="flex items-center gap-3">
      <div>
        <p class="hpg-eyebrow">Accounts</p>
        <h2 class="font-semibold text-slate-800 dark:text-slate-100">Clients</h2>
      </div>
      <span class="hpg-chip">{{.Total}}</span>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" id="cli-save-filter-btn"
        class="inline-flex items-center gap-1 text-xs px-2.5 py-1.5 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 cursor-pointer transition-colors">
        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 3h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/><path d="M7 3v5h6V3"/></svg>
        Save filter
      </button>
      <button type="button" id="cli-new-btn"
        class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900">
        <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M10 4v12M4 10h12"/></svg>
        New client
      </button>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-slate-50/95 dark:bg-zinc-800/95 backdrop-blur text-left text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">
        <tr>
          <th class="px-5 py-3 font-medium">
            <a href="/admin/clients?q={{.Q}}&sort=display_name&dir={{if and (eq .Sort "display_name") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
              Name
              {{if eq .Sort "display_name"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
            </a>
          </th>
          <th class="px-5 py-3 font-medium">
            <a href="/admin/clients?q={{.Q}}&sort=email&dir={{if and (eq .Sort "email") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
              Email
              {{if eq .Sort "email"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
            </a>
          </th>
          <th class="px-5 py-3 font-medium">External ref</th>
          <th class="px-5 py-3 font-medium">Services</th>
          <th class="px-5 py-3 font-medium">
            <a href="/admin/clients?q={{.Q}}&sort=created_at&dir={{if and (eq .Sort "created_at") (eq .Dir "asc")}}desc{{else}}asc{{end}}" class="flex items-center gap-1 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
              Created
              {{if eq .Sort "created_at"}}{{if eq .Dir "asc"}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 3l7 7H3z"/></svg>{{else}}<svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17l7-7H3z"/></svg>{{end}}{{end}}
            </a>
          </th>
          <th class="px-5 py-3 text-right font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
        {{range .Clients}}
        <tr class="hover:bg-slate-50/70 dark:hover:bg-zinc-800/40 transition-colors">
          <td class="px-5 py-3.5 font-medium text-slate-800 dark:text-slate-100 whitespace-nowrap">{{.DisplayName}}</td>
          <td class="px-5 py-3.5 text-slate-600 dark:text-slate-300 whitespace-nowrap">{{.Email}}</td>
          <td class="px-5 py-3.5 text-slate-500 dark:text-slate-400">{{.ExternalRef}}</td>
          <td class="px-5 py-3.5"><span class="hpg-pill hpg-pill-muted">{{.ServiceCount}}</span></td>
          <td class="px-5 py-3.5 text-slate-500 dark:text-slate-400 text-xs whitespace-nowrap">{{.CreatedAt}}</td>
          <td class="px-5 py-3.5 text-right whitespace-nowrap">
            <div class="inline-flex items-center gap-3">
              <button type="button"
                class="cli-edit-btn inline-flex items-center gap-1 text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded"
                data-id="{{.ID}}"
                data-name="{{if .EditDisplayName}}{{.EditDisplayName}}{{else}}{{.DisplayName}}{{end}}"
                data-email="{{.Email}}"
                data-extref="{{.ExternalRef}}">
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 3.5l3 3L7 16l-3.5.5L4 13z"/></svg>
                edit
              </button>
              <form method="POST" action="/admin/clients/{{.ID}}/delete" data-confirm="Delete client {{.DisplayName}} and their user account?"><input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="inline-flex items-center gap-1 text-xs font-medium text-rose-600 hover:text-rose-700 hover:underline cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-rose-500 rounded">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h12M8 6V4h4v2M6 6l.7 10h6.6L14 6"/></svg>
                  delete
                </button>
              </form>
            </div>
          </td>
        </tr>
        {{else}}
        <tr><td colspan="6" class="px-5 py-12 text-center text-slate-500 dark:text-slate-400">{{if .Q}}No clients match your search.{{else}}No clients yet.{{end}}</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

{{template "pagination" (dict "Total" .Total "TotalPgs" .TotalPgs "Page" .Page "PrevURL" .PrevURL "NextURL" .NextURL "Size" .Size)}}

<!-- Create/Edit modal -->
<div id="cli-modal" class="fixed inset-0 z-50 hidden">
  <div id="cli-modal-overlay" class="absolute inset-0 bg-slate-900/50 dark:bg-black/60 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-start justify-center overflow-y-auto p-4 sm:p-6">
    <div class="hpg-card rounded-2xl shadow-xl w-full max-w-lg my-8 relative" role="dialog" aria-modal="true" aria-labelledby="cli-modal-title">
      <div class="flex items-start justify-between mb-1">
        <div>
          <p class="hpg-eyebrow">Account</p>
          <h2 id="cli-modal-title" class="font-semibold text-slate-800 dark:text-slate-100">New client</h2>
        </div>
        <button type="button" id="cli-modal-close"
          class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 text-xl leading-none cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded" aria-label="Close">&times;</button>
      </div>
      <!-- Clients own services/hosts; panel login accounts with roles live under Users. -->
      <p class="text-xs text-slate-500 dark:text-slate-400 mb-5">Clients are customer accounts that own services and hosts. Panel login accounts with roles live under Users.</p>

      <form id="cli-form" method="POST" action="/admin/clients" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="hpg-eyebrow block mb-1.5">Display name</label>
          <input name="display_name" required placeholder="Acme Corp" class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none transition-shadow">
        </div>
        <div>
          <label class="hpg-eyebrow block mb-1.5">Email (login)</label>
          <input name="email" type="email" required placeholder="ops@acme.com" class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none transition-shadow">
        </div>
        <!-- Create-only: password is set on creation, never touched on edit. -->
        <div id="cli-password-field">
          <label class="hpg-eyebrow block mb-1.5">Initial password</label>
          <input name="password" type="password" minlength="12" class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none transition-shadow">
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Min 12 chars. Give it to the customer; they'll change it after first login.</p>
        </div>
        <div>
          <label class="hpg-eyebrow block mb-1.5">External reference (FOSSBilling order ID)</label>
          <input name="external_ref" class="w-full px-3 py-2 rounded-lg border-0 bg-slate-50 dark:bg-zinc-800/50 ring-1 ring-slate-200 dark:ring-zinc-700 focus:ring-2 focus:ring-indigo-500 outline-none transition-shadow">
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="cli-modal-cancel"
            class="px-3.5 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 ring-1 ring-slate-200 dark:ring-zinc-700 hover:bg-slate-50 dark:hover:bg-zinc-800/50 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500">Cancel</button>
          <button type="submit" id="cli-modal-submit"
            class="px-4 py-2.5 rounded-lg bg-indigo-600 text-white text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900">Create client</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Save filter modal -->
<div id="cli-save-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-slate-900/50 dark:bg-black/60 backdrop-blur-sm" id="cli-sf-overlay"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="hpg-card rounded-2xl shadow-xl w-full max-w-sm" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-slate-800 dark:text-slate-100">Save filter</h3>
        <button type="button" id="cli-sf-close" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 cursor-pointer">&times;</button>
      </div>
      <form method="POST" action="/admin/saved-filters/clients" class="space-y-3 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <input type="hidden" name="query_json" value="{{.QueryValues}}">
        <div>
          <label class="hpg-eyebrow block mb-1">Filter name</label>
          <input name="filter_name" required placeholder="e.g. Recent clients" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-zinc-800 ring-1 ring-slate-200 dark:ring-zinc-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" id="cli-sf-cancel" class="px-3.5 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-zinc-800 cursor-pointer">Cancel</button>
          <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer transition-colors">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{.CSPNonce}}">
(function () {
  var modal = document.getElementById("cli-modal");
  var form = document.getElementById("cli-form");
  var title = document.getElementById("cli-modal-title");
  var submit = document.getElementById("cli-modal-submit");
  var pwField = document.getElementById("cli-password-field");
  if (!modal || !form) return;

  function setVal(name, value) {
    var el = form.elements[name];
    if (el) el.value = (value == null ? "" : value);
  }
  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  var pwInput = form.elements["password"];

  var newBtn = document.getElementById("cli-new-btn");
  if (newBtn) newBtn.addEventListener("click", function () {
    form.reset();
    form.action = "/admin/clients";
    if (title) title.textContent = "New client";
    if (submit) submit.textContent = "Create client";
    if (pwField) pwField.classList.remove("hidden");
    if (pwInput) { pwInput.required = true; pwInput.disabled = false; }
    open();
  });

  var editBtns = document.querySelectorAll(".cli-edit-btn");
  for (var i = 0; i < editBtns.length; i++) {
    editBtns[i].addEventListener("click", function () {
      var d = this.dataset;
      form.reset();
      form.action = "/admin/clients/" + d.id + "/edit";
      if (title) title.textContent = "Edit client";
      if (submit) submit.textContent = "Save changes";
      if (pwField) pwField.classList.add("hidden");
      if (pwInput) { pwInput.required = false; pwInput.disabled = true; }
      setVal("display_name", d.name);
      setVal("email", d.email);
      setVal("external_ref", d.extref);
      open();
    });
  }

  var closeBtn = document.getElementById("cli-modal-close");
  var cancelBtn = document.getElementById("cli-modal-cancel");
  var overlay = document.getElementById("cli-modal-overlay");
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });

  // Save filter modal.
  var sfModal = document.getElementById("cli-save-modal");
  var sfBtn = document.getElementById("cli-save-filter-btn");
  var sfOverlay = document.getElementById("cli-sf-overlay");
  var sfClose = document.getElementById("cli-sf-close");
  var sfCancel = document.getElementById("cli-sf-cancel");
  function sfOpen() { if (sfModal) sfModal.classList.remove("hidden"); }
  function sfClose2() { if (sfModal) sfModal.classList.add("hidden"); }
  if (sfBtn) sfBtn.addEventListener("click", sfOpen);
  if (sfClose) sfClose.addEventListener("click", sfClose2);
  if (sfCancel) sfCancel.addEventListener("click", sfClose2);
  if (sfOverlay) sfOverlay.addEventListener("click", sfClose2);
})();
</script>
</div>
{{end}}
