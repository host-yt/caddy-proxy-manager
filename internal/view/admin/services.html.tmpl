{{define "services"}}
<!-- Hidden bulk form - submitted via JS to avoid nested form issues -->
<form method="POST" action="/admin/services/bulk" id="svc-bulk-form" class="hidden">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <input type="hidden" name="action" id="svc-bulk-action">
  <div id="svc-bulk-ids"></div>
</form>

<section class="r-card !p-0 overflow-hidden">
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-[rgb(var(--border))]">
    <div class="flex items-center gap-3">
      <div class="icon-chip">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>
        </svg>
      </div>
      <div>
        <p class="t-eyebrow">Fleet</p>
        <h2 class="t-h3">Services</h2>
      </div>
      <span class="r-pill r-pill-neutral">{{len .Services}}</span>
    </div>
    <button type="button" id="svc-new-btn" class="r-btn-primary cursor-pointer">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      New service
    </button>
  </div>

  <div class="px-5 py-3 border-b border-[rgb(var(--border))]">
    <form method="GET" action="/admin/services" class="flex flex-wrap items-center gap-2">
      <input type="search" name="q" value="{{.Q}}"
             placeholder="Name, IP, or client…"
             class="r-input w-52">
      <select name="status" class="r-select">
        <option value="" {{if eq .StatusFilter ""}}selected{{end}}>All statuses</option>
        <option value="active" {{if eq .StatusFilter "active"}}selected{{end}}>Active</option>
        <option value="suspended" {{if eq .StatusFilter "suspended"}}selected{{end}}>Suspended</option>
        <option value="terminated" {{if eq .StatusFilter "terminated"}}selected{{end}}>Terminated</option>
      </select>
      <button type="submit" class="r-btn-primary cursor-pointer">Filter</button>
      {{if or .Q .StatusFilter}}
      <a href="/admin/services" class="r-btn-ghost">Clear</a>
      {{end}}
    </form>
  </div>

  <!-- Bulk action bar - hidden until a checkbox is selected -->
  {{if .Services}}
  <div id="svc-bulk-bar" class="hidden px-5 py-3 border-b border-[rgb(var(--border))] flex items-center gap-2">
    <span class="t-eyebrow">Bulk action</span>
    <select id="svc-bulk-select" class="r-select">
      <option value="suspend">Suspend selected</option>
      <option value="resume">Resume selected</option>
      <option value="delete">Delete selected</option>
    </select>
    <button type="button" id="svc-bulk-apply" class="r-btn-secondary cursor-pointer">Apply</button>
    <span id="svc-bulk-count" class="t-caption text-[rgb(var(--muted))]"></span>
  </div>
  {{end}}

  <div class="overflow-x-auto">
    <table class="r-table">
      <thead>
        <tr>
          <th class="w-8"><input type="checkbox" data-check-all="ids[]" class="rounded"></th>
          <th>Service</th>
          <th>Client</th>
          <th>Backend</th>
          <th>Ports</th>
          <th>Plan</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range .Services}}
        <tr>
          <td><input type="checkbox" name="ids[]" value="{{.ID}}" class="rounded svc-row-chk"></td>
          <td class="font-medium whitespace-nowrap">
            {{.Name}}{{if .Notes}}<span title="{{if gt (len .Notes) 80}}{{slice .Notes 0 80}}...{{else}}{{.Notes}}{{end}}" class="ml-1 text-[rgb(var(--muted))] cursor-help text-xs" aria-label="has notes"><svg class="inline w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></span>{{end}}
          </td>
          <td class="whitespace-nowrap">{{.ClientName}}</td>
          <td><code class="font-mono text-xs bg-[rgb(var(--surface-2))] rounded px-1.5 py-0.5">{{.BackendIP}}</code></td>
          <td class="whitespace-nowrap"><span class="font-mono text-xs text-[rgb(var(--muted))]">{{.PortStart}}-{{.PortEnd}}</span></td>
          <td class="whitespace-nowrap">{{.PlanName}}</td>
          <td>
            <span class="r-pill {{if eq .Status "active"}}r-pill-success{{else if eq .Status "suspended"}}r-pill-warning{{else}}r-pill-danger{{end}}">{{.Status}}</span>
          </td>
          <td class="text-right whitespace-nowrap">
            <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="svc-act-{{.ID}}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
            </button>
            <div id="svc-act-{{.ID}}" class="hpg-act-menu" role="menu">
              <button type="button"
                class="svc-edit-btn hpg-act-item" role="menuitem"
                data-id="{{.ID}}"
                data-name="{{.Name}}"
                data-client="{{.ClientID}}"
                data-backend="{{.BackendIP}}"
                data-pstart="{{.PortStart}}"
                data-pend="{{.PortEnd}}"
                data-plan="{{.PlanID}}"
                data-extref="{{.ExternalRef}}"
                data-notes="{{.Notes}}">Edit</button>
              {{if eq .Status "active"}}
              <form method="POST" action="/admin/services/{{.ID}}/suspend" class="contents" data-confirm="Suspend all routes for {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Suspend</button>
              </form>
              {{else if eq .Status "suspended"}}
              <form method="POST" action="/admin/services/{{.ID}}/resume" class="contents">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item" role="menuitem">Resume</button>
              </form>
              {{end}}
              <form method="POST" action="/admin/services/{{.ID}}/delete" class="contents" data-confirm="Delete service {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        {{else}}
        <tr><td colspan="8" class="px-5 py-12 text-center text-[rgb(var(--muted))]">No services yet.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</section>

<!-- Create/Edit modal -->
<div id="svc-modal" class="fixed inset-0 z-50 hidden">
  <div id="svc-modal-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute inset-0 flex items-center justify-center overflow-y-auto p-4 sm:p-6">
    <div class="r-card w-full max-w-lg max-h-[90vh] overflow-y-auto relative" role="dialog" aria-modal="true">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="t-eyebrow">Provision</p>
          <h2 id="svc-modal-title" class="t-h3">New service</h2>
        </div>
        <button type="button" id="svc-modal-close"
          class="text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] transition-colors cursor-pointer" aria-label="Close">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
        </button>
      </div>

      {{if not .Clients}}
        <p class="t-small text-[rgb(var(--danger,220_38_38))] bg-[rgb(var(--danger,220_38_38)/.08)] ring-1 ring-[rgb(var(--danger,220_38_38)/.3)] rounded-lg p-2.5 mb-3">Create a <a href="/admin/clients" class="underline">client</a> first.</p>
      {{end}}
      {{if not .Plans}}
        <p class="t-small text-[rgb(var(--danger,220_38_38))] bg-[rgb(var(--danger,220_38_38)/.08)] ring-1 ring-[rgb(var(--danger,220_38_38)/.3)] rounded-lg p-2.5 mb-3">Create a <a href="/admin/plans" class="underline">plan</a> first.</p>
      {{end}}

      <form id="svc-form" method="POST" action="/admin/services" class="space-y-4 text-sm">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <div>
          <label class="t-eyebrow block mb-1.5">Client</label>
          <select name="client_id" required class="r-select w-full">
            {{range .Clients}}<option value="{{.ID}}">{{.DisplayName}} ({{.Email}})</option>{{end}}
          </select>
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Service name</label>
          <input name="name" required placeholder="vps-fra-01" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Backend IP (admin-only)</label>
          <input name="backend_ip" required placeholder="10.0.0.5" class="r-input w-full font-mono">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="t-eyebrow block mb-1.5">Port start</label>
            <input name="port_start" type="number" min="1" max="65535" value="30000" required class="r-input w-full font-mono">
          </div>
          <div>
            <label class="t-eyebrow block mb-1.5">Port end</label>
            <input name="port_end" type="number" min="1" max="65535" value="30019" required class="r-input w-full font-mono">
          </div>
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Plan</label>
          <select name="plan_id" required class="r-select w-full">
            {{range .Plans}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
          </select>
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">External reference (FOSSBilling order ID)</label>
          <input name="external_reference" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1.5">Internal notes</label>
          <textarea name="notes" rows="3" placeholder="Visible to admins only"
                    class="r-input w-full resize-y"></textarea>
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="svc-modal-cancel" class="r-btn-ghost cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Save service</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script nonce="{{$.CSPNonce}}">
(function () {
  /* ── Bulk action bar ──────────────────────────────────────────── */
  var bar = document.getElementById('svc-bulk-bar');
  var bulkSel = document.getElementById('svc-bulk-select');
  var bulkApply = document.getElementById('svc-bulk-apply');
  var bulkCount = document.getElementById('svc-bulk-count');

  function updateBar() {
    var checked = document.querySelectorAll('tbody input.svc-row-chk:checked');
    if (!bar) return;
    if (checked.length > 0) {
      bar.classList.remove('hidden');
      if (bulkCount) bulkCount.textContent = checked.length + ' selected';
    } else {
      bar.classList.add('hidden');
    }
  }

  // Attach change handler to row checkboxes and the select-all header checkbox.
  document.querySelectorAll('tbody input.svc-row-chk').forEach(function(c) {
    c.addEventListener('change', updateBar);
  });
  document.querySelectorAll('[data-check-all]').forEach(function(c) {
    c.addEventListener('change', updateBar);
  });

  // Apply bulk action on button click.
  if (bulkApply) {
    bulkApply.addEventListener('click', function () {
      var action = bulkSel ? bulkSel.value : '';
      var ids = Array.from(document.querySelectorAll('tbody input.svc-row-chk:checked')).map(function(c) { return c.value; });
      if (ids.length === 0) { window.hpgToast && window.hpgToast('Select at least one row.', 'warn'); return; }
      var msg = action === 'delete' ? 'Delete ' + ids.length + ' service(s)? This cannot be undone.' : action + ' ' + ids.length + ' service(s)?';
      var go = function () {
        document.getElementById('svc-bulk-action').value = action;
        var box = document.getElementById('svc-bulk-ids');
        box.innerHTML = '';
        ids.forEach(function (v) {
          var inp = document.createElement('input');
          inp.type = 'hidden'; inp.name = 'ids[]'; inp.value = v;
          box.appendChild(inp);
        });
        document.getElementById('svc-bulk-form').submit();
      };
      if (window.hpgConfirm) {
        window.hpgConfirm(msg).then(function (ok) { if (ok) go(); });
      } else if (confirm(msg)) {
        go();
      }
    });
  }

  /* ── Modal open/close ─────────────────────────────────────────── */
  var modal = document.getElementById("svc-modal");
  var form = document.getElementById("svc-form");
  var title = document.getElementById("svc-modal-title");
  if (!modal || !form) return;

  function setVal(name, value) {
    var el = form.elements[name];
    if (el) el.value = (value == null ? "" : value);
  }

  function open() { modal.classList.remove("hidden"); }
  function close() { modal.classList.add("hidden"); }

  // Create mode: reset form, post to collection endpoint.
  document.getElementById("svc-new-btn").addEventListener("click", function () {
    form.reset();
    form.action = "/admin/services";
    if (title) title.textContent = "New service";
    open();
  });

  // Edit mode: prefill from data-* attrs, post to /{id}/edit.
  var editBtns = document.querySelectorAll(".svc-edit-btn");
  for (var i = 0; i < editBtns.length; i++) {
    editBtns[i].addEventListener("click", function () {
      var d = this.dataset;
      form.action = "/admin/services/" + d.id + "/edit";
      if (title) title.textContent = "Edit service";
      setVal("client_id", d.client);
      setVal("name", d.name);
      setVal("backend_ip", d.backend);
      setVal("port_start", d.pstart);
      setVal("port_end", d.pend);
      setVal("plan_id", d.plan);
      setVal("external_reference", d.extref);
      setVal("notes", d.notes);
      open();
    });
  }

  var closeBtn = document.getElementById("svc-modal-close");
  var cancelBtn = document.getElementById("svc-modal-cancel");
  var overlay = document.getElementById("svc-modal-overlay");
  if (closeBtn) closeBtn.addEventListener("click", close);
  if (cancelBtn) cancelBtn.addEventListener("click", close);
  if (overlay) overlay.addEventListener("click", close);
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });
})();
</script>
{{end}}
