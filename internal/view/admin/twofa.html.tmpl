{{define "twofa"}}
<div class="space-y-4">
{{template "admin_account_tabs" "twofa"}}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <section class="r-card">
    <h2 class="t-h3 mb-3">Authenticator app (TOTP)</h2>
    {{if .Enabled}}
    <div class="mb-4"><span class="r-pill r-pill-success">TOTP is active on your account</span></div>
    <form method="POST" action="/admin/2fa/disable" data-confirm="Disable TOTP?">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-danger cursor-pointer">Disable TOTP</button>
    </form>
    {{else if .Enrolling}}
    <p class="t-small text-[rgb(var(--muted))] mb-3">Scan the QR code with your authenticator (1Password, Aegis, Authy, Google Authenticator&hellip;) then enter the 6-digit code below.</p>
    <div class="flex items-start gap-6">
      <img src="data:image/png;base64,{{.QRBase64}}" alt="QR" class="ring-1 ring-[rgb(var(--border))] rounded-xl" width="180" height="180">
      <div class="text-xs">
        <div class="t-eyebrow mb-1">Manual entry</div>
        <code class="block bg-[rgb(var(--surface-2))] p-2 rounded-lg break-all font-mono">{{.Secret}}</code>
      </div>
    </div>
    <form method="POST" action="/admin/2fa/confirm" class="mt-4 space-y-3">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="t-eyebrow block mb-1">6-digit code</label>
        <input name="code" inputmode="numeric" pattern="[0-9]*" maxlength="6" required autofocus
               class="r-input w-full max-w-xs font-mono text-center tracking-widest">
      </div>
      <button class="r-btn-primary cursor-pointer">Enable TOTP</button>
    </form>
    {{else}}
    <p class="t-small text-[rgb(var(--muted))] mb-3">Add a second factor so that even a stolen password can't open your account.</p>
    <form method="POST" action="/admin/2fa/start">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-primary cursor-pointer">Set up TOTP</button>
    </form>
    {{end}}
  </section>

  {{if .RecoveryCodes}}
  <section class="r-card ring-[rgb(var(--warning)/.4)] bg-[rgb(var(--warning)/.06)]">
    <h2 class="t-h3 text-[rgb(var(--warning))] mb-2">Recovery codes</h2>
    <p class="t-caption text-[rgb(var(--warning)/.8)] mb-3">Store these safely. Each works once if you lose access to your authenticator. They won't be shown again.</p>
    <ul class="grid grid-cols-2 gap-2 text-sm font-mono">
      {{range .RecoveryCodes}}<li class="bg-[rgb(var(--surface))] ring-1 ring-[rgb(var(--warning)/.3)] rounded-lg px-2 py-1 tabular-nums">{{.}}</li>{{end}}
    </ul>
  </section>
  {{end}}

  <section class="r-card">
    <h2 class="t-h3 mb-3">SMS two-factor authentication</h2>
    {{if .SMSOTPEnrolling}}
    <p class="t-small text-[rgb(var(--muted))] mb-3">A 6-digit code was sent to your phone. Enter it below to activate SMS 2FA.</p>
    <form method="POST" action="/admin/2fa/sms/confirm" class="space-y-3">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <input name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus
             placeholder="123456"
             class="r-input w-full max-w-xs font-mono text-center tracking-widest">
      <button class="r-btn-primary cursor-pointer">Verify &amp; enable</button>
    </form>
    {{else if .SMSOTPEnabled}}
    <div class="mb-4"><span class="r-pill r-pill-success">SMS 2FA is active</span></div>
    <form method="POST" action="/admin/2fa/sms/disable" data-confirm="Disable SMS 2FA?">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-danger cursor-pointer">Disable SMS 2FA</button>
    </form>
    {{else if not .HasSMS}}
    <p class="t-small text-[rgb(var(--muted))]">SMS provider not configured. Wire it under <a href="/admin/settings" class="text-[rgb(var(--accent))] hover:underline">Settings &rarr; SMS</a> first.</p>
    {{else if .HasPhone}}
    <p class="t-small text-[rgb(var(--muted))] mb-3">Receive a 6-digit code by SMS during sign-in.</p>
    <form method="POST" action="/admin/2fa/sms/start">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-primary cursor-pointer">Set up SMS 2FA</button>
    </form>
    {{else}}
    <p class="t-small text-[rgb(var(--muted))]">Set your phone number in <a href="/admin/account" class="text-[rgb(var(--accent))] hover:underline">Account</a> first.</p>
    {{end}}
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3">Email two-factor authentication</h2>
    {{if .EmailOTPEnrolling}}
    <p class="t-small text-[rgb(var(--muted))] mb-3">A 6-digit code was sent to your email. Enter it below to activate Email 2FA.</p>
    <form method="POST" action="/admin/2fa/email/confirm" class="space-y-3">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <input name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus
             placeholder="123456"
             class="r-input w-full max-w-xs font-mono text-center tracking-widest">
      <button class="r-btn-primary cursor-pointer">Verify &amp; enable</button>
    </form>
    {{else if .EmailOTPEnabled}}
    <div class="mb-4"><span class="r-pill r-pill-success">Email 2FA is active</span></div>
    <form method="POST" action="/admin/2fa/email/disable" data-confirm="Disable Email 2FA?">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-danger cursor-pointer">Disable Email 2FA</button>
    </form>
    {{else if not .HasMailer}}
    <p class="t-small text-[rgb(var(--muted))]">SMTP not configured. Wire it under <a href="/admin/settings" class="text-[rgb(var(--accent))] hover:underline">Settings &rarr; SMTP</a> first.</p>
    {{else}}
    <p class="t-small text-[rgb(var(--muted))] mb-3">Receive a 6-digit code by email during sign-in.</p>
    <form method="POST" action="/admin/2fa/email/start">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <button class="r-btn-primary cursor-pointer">Set up Email 2FA</button>
    </form>
    {{end}}
  </section>

  <section class="r-card lg:col-span-2">
    <div class="flex items-center justify-between mb-3">
      <h2 class="t-h3">Passkeys (WebAuthn)</h2>
      <button id="passkey-add-btn" data-scope="admin" class="r-btn-primary cursor-pointer">+ Add passkey</button>
    </div>
    <p class="t-small text-[rgb(var(--muted))] mb-3">Use Touch ID / Windows Hello / a security key. Passkeys can replace your password - pick one on the login page.</p>
    <div id="passkeys-list" data-scope="admin">
      <p class="t-small text-[rgb(var(--muted))]">Loading&hellip;</p>
    </div>
  </section>
  <script nonce="{{.CSPNonce}}" src="/static/js/passkey.js"></script>

  {{if not .RecoveryCodes}}
  <section class="r-card">
    <h2 class="t-h3 mb-2">Priority &amp; fallbacks</h2>
    <ol class="t-small text-[rgb(var(--muted))] list-decimal list-inside space-y-1">
      <li>TOTP - fastest, works offline.</li>
      <li>SMS - needs a configured SMS provider + phone on file.</li>
      <li>Email - needs SMTP. Slowest, useful as a fallback.</li>
    </ol>
    <p class="t-caption text-[rgb(var(--muted))] mt-3">Sign-in challenges run in this order; whichever factor is enrolled (and configured) wins.</p>
  </section>
  {{end}}
</div>
</div>
{{end}}
