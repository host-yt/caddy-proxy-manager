{{define "map"}}
<div class="space-y-6">
  {{if .DBUnavailable}}
  <section class="r-card text-sm" style="color:rgb(var(--muted))">
    Database is not available, so the infrastructure map cannot be built right now.
  </section>
  {{else}}

  <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    <div class="r-card">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="t-eyebrow">Clients</p>
          <p class="mt-2 t-display">{{.Counts.Clients}}</p>
        </div>
        {{if .ScopeLimited}}<span class="r-pill r-pill-neutral shrink-0">scoped</span>{{end}}
      </div>
      <p class="mt-2 t-caption">Customer owners in the visible topology.</p>
    </div>
    <div class="r-card">
      <p class="t-eyebrow">Services</p>
      <div class="mt-2 flex items-end justify-between gap-3">
        <p class="t-display">{{.Counts.Services}}</p>
        <span class="r-pill r-pill-neutral shrink-0">backends</span>
      </div>
      <p class="mt-2 t-caption">Managed service targets grouped under clients.</p>
    </div>
    <div class="r-card">
      <p class="t-eyebrow">Routes / hosts</p>
      <div class="mt-2 flex items-end justify-between gap-3">
        <p class="t-display">{{.Counts.Routes}}</p>
        <span class="r-pill r-pill-success shrink-0">{{.Counts.ActiveRoutes}} active</span>
      </div>
      <p class="mt-2 t-caption">Public host mappings and upstream ports.</p>
    </div>
    <div class="r-card">
      <p class="t-eyebrow">Fleet / tunnels</p>
      <div class="mt-2 flex items-end justify-between gap-3">
        <p class="t-display tabular-nums">{{.Counts.HealthyNodes}}/{{.Counts.Nodes}}</p>
        <span class="r-pill {{if eq .Counts.ActiveTunnels .Counts.Tunnels}}r-pill-success{{else}}r-pill-warning{{end}} shrink-0">{{.Counts.ActiveTunnels}} WG</span>
      </div>
      <p class="mt-2 t-caption">Healthy edge nodes and active WireGuard peers.</p>
    </div>
  </section>

  {{if .ScopeLimited}}
  <div class="r-card" style="background:rgb(var(--accent)/.08);border-color:rgb(var(--accent)/.25)">
    <p class="t-small" style="color:rgb(var(--accent))">This map is limited to clients assigned to your admin scope. Fleet nodes are shown only when connected to visible routes or tunnels.</p>
  </div>
  {{end}}

  <section class="hpg-topology-shell">
    <div class="hpg-topology-head">
      <div class="min-w-0">
        <p class="t-eyebrow">Live topology</p>
        <h2>Traffic path from customer to edge</h2>
        <p>Each lane shows how a client reaches services, public hosts, edge nodes, and private WG peers.</p>
      </div>
      <div class="hpg-topology-tools">
        <label class="hpg-topology-search">
          <span class="sr-only">Search topology</span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
          <input id="hpg-topology-search" type="search" class="r-input" placeholder="Search clients, hosts, nodes, WG IPs">
        </label>
        <div class="r-segment" aria-label="Topology filters">
          <button type="button" data-topology-filter="all" class="r-segment-item is-active cursor-pointer"><i class="hpg-dot"></i>all</button>
          <button type="button" data-topology-filter="ok" class="r-segment-item cursor-pointer"><i class="hpg-dot hpg-dot-ok"></i>active</button>
          <button type="button" data-topology-filter="warn" class="r-segment-item cursor-pointer"><i class="hpg-dot hpg-dot-warn"></i>pending</button>
          <button type="button" data-topology-filter="err" class="r-segment-item cursor-pointer"><i class="hpg-dot hpg-dot-err"></i>failed</button>
        </div>
      </div>
    </div>

    {{if .Clients}}
    <div class="hpg-topology-scroll">
      <div class="hpg-topology-grid hpg-topology-labels" aria-hidden="true">
        <span>Client</span>
        <span>Services</span>
        <span>Routes</span>
        <span>Edge / tunnel</span>
      </div>
      <div class="hpg-topology-lanes">
        {{range .Clients}}
        <article class="hpg-topology-grid hpg-topology-lane" data-topology-lane>
          <div class="hpg-map-node hpg-map-node-client" tabindex="0" data-map-card data-map-type="Client" data-map-title="{{.Name}}" data-map-status="visible" data-map-meta="{{.ServiceCount}} services · {{.RouteCount}} routes · {{.TunnelCount}} WG peers">
            <div class="r-avatar hpg-map-avatar">{{firstRune .Name}}</div>
            <div class="min-w-0">
              <h3>{{.Name}}</h3>
              <p>{{.Email}}</p>
              <div class="hpg-map-meta">
                <span>{{.ServiceCount}} services</span>
                <span>{{.RouteCount}} routes</span>
                <span>{{.TunnelCount}} WG</span>
              </div>
            </div>
          </div>

          <div class="hpg-map-stack">
            {{range .Services}}
            <div class="hpg-map-node hpg-map-node-service" tabindex="0" data-map-card data-map-type="Service" data-map-title="{{.Name}}" data-map-status="{{.Status}}" data-map-meta="{{.BackendIP}} · ports {{.PortStart}}-{{.PortEnd}}">
              <div class="min-w-0">
                <div class="hpg-map-row">
                  <strong>{{.Name}}</strong>
                  <span class="hpg-state {{if eq .Status "active"}}is-ok{{else if eq .Status "suspended"}}is-warn{{else}}is-err{{end}}">{{.Status}}</span>
                </div>
                <p><span class="font-mono">{{.BackendIP}}</span> ports {{.PortStart}}-{{.PortEnd}}</p>
              </div>
            </div>
            {{else}}
            <div class="hpg-map-empty">No services</div>
            {{end}}
          </div>

          <div class="hpg-map-stack">
            {{range .Services}}
              {{range .Routes}}
              <a href="/admin/hosts/{{.ID}}/edit" class="hpg-map-node hpg-map-node-route" data-map-card data-map-type="Route" data-map-title="{{.Domain}}" data-map-status="{{.Status}}" data-map-meta="{{if .PathPrefix}}{{.PathPrefix}}{{else}}root path{{end}} -> :{{.UpstreamPort}}" data-map-href="/admin/hosts/{{.ID}}/edit">
                <div class="hpg-map-row">
                  <strong>{{.Domain}}</strong>
                  <span class="hpg-state {{if eq .Status "active"}}is-ok{{else if or (eq .Status "pending_dns") (eq .Status "pending_ssl") (eq .Status "dns_ok")}}is-warn{{else}}is-err{{end}}">{{.Status}}</span>
                </div>
                <p>{{if .PathPrefix}}<span class="font-mono">{{.PathPrefix}}</span>{{else}}root path{{end}} -> :{{.UpstreamPort}}</p>
              </a>
              {{end}}
            {{end}}
            {{if .Tunnels}}
            <div class="hpg-map-tunnel-strip">
              {{range .Tunnels}}
              <span class="hpg-map-tunnel {{if eq .Status "active"}}is-ok{{else if eq .Status "pending"}}is-warn{{else}}is-err{{end}}" tabindex="0" data-map-card data-map-type="WG peer" data-map-title="{{.Name}}" data-map-status="{{.Status}}" data-map-meta="{{.AssignedIP}} on {{.NodeName}}">
                <span>{{.Name}}</span>
                <code>{{.AssignedIP}}</code>
              </span>
              {{end}}
            </div>
            {{end}}
          </div>

          <div class="hpg-map-stack">
            {{range .Services}}
              {{range .Routes}}
              <a href="/admin/nodes/{{.NodeID}}" class="hpg-map-node hpg-map-node-edge" data-map-card data-map-type="Edge node" data-map-title="{{.NodeName}}" data-map-status="{{.NodeHealth}}" data-map-meta="{{if .WGPeerID}}via WG {{.WGPeerIP}}{{else}}direct upstream{{end}}" data-map-href="/admin/nodes/{{.NodeID}}">
                <div class="hpg-map-row">
                  <strong>{{.NodeName}}</strong>
                  <span class="hpg-state {{if and .NodeEnabled (eq .NodeHealth "healthy")}}is-ok{{else if eq .NodeHealth "down"}}is-err{{else}}is-warn{{end}}">{{.NodeHealth}}</span>
                </div>
                {{if .WGPeerID}}
                <p>via WG <span class="font-mono">{{.WGPeerIP}}</span></p>
                {{else}}
                <p>direct upstream</p>
                {{end}}
              </a>
              {{end}}
            {{end}}
          </div>
        </article>
        {{end}}
      </div>
    </div>
    <div class="hpg-topology-inspector" id="hpg-topology-inspector">
      <div>
        <p class="t-eyebrow">Inspector</p>
        <strong id="hpg-inspector-title">Hover or focus an object</strong>
        <span id="hpg-inspector-meta">Use search and status filters to isolate a client path.</span>
      </div>
      <div class="hpg-inspector-actions">
        <span id="hpg-visible-count">{{len .Clients}} clients visible</span>
        <a id="hpg-inspector-link" href="#" class="hidden">Open</a>
      </div>
    </div>
    {{else}}
    <div class="hpg-topology-empty">
      <p>No visible topology yet.</p>
      <span>Create clients, services, hosts, or WG tunnels to populate this map.</span>
    </div>
    {{end}}
  </section>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_23rem]">
    <section class="r-card !p-0 overflow-hidden">
      <div class="px-5 py-4" style="border-bottom:1px solid rgb(var(--border))">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="t-eyebrow">Detailed inventory</p>
            <h2 class="mt-1 t-h3">Clients, services, routes, nodes, and WG peers</h2>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="r-pill r-pill-neutral">showing {{.Limits.Clients}} newest clients</span>
            {{if gt .Counts.Clients .Limits.Clients}}<span class="r-pill r-pill-warning">list clipped</span>{{end}}
          </div>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="r-pill r-pill-success">healthy / active</span>
          <span class="r-pill r-pill-warning">pending / degraded</span>
          <span class="r-pill r-pill-danger">down / failed</span>
          <span class="r-pill r-pill-neutral">not shown / disabled</span>
        </div>
      </div>

      <div style="divide-y:1px solid rgb(var(--border))">
        {{range .Clients}}
        <article class="p-4 sm:p-5" style="border-bottom:1px solid rgb(var(--border))">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="flex min-w-0 items-center gap-3">
              <div class="icon-chip shrink-0">{{firstRune .Name}}</div>
              <div class="min-w-0">
                <h3 class="truncate t-h3">{{.Name}}</h3>
                <p class="truncate t-caption">{{.Email}}</p>
              </div>
            </div>
            <div class="grid w-full grid-cols-3 gap-2 text-center sm:w-auto sm:min-w-[17rem]">
              <div class="rounded-lg px-2 py-1.5" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
                <p class="font-mono tabular-nums" style="color:rgb(var(--text))">{{.ServiceCount}}</p>
                <p class="t-caption uppercase tracking-wider">services</p>
              </div>
              <div class="rounded-lg px-2 py-1.5" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
                <p class="font-mono tabular-nums" style="color:rgb(var(--text))">{{.RouteCount}}</p>
                <p class="t-caption uppercase tracking-wider">routes</p>
              </div>
              <div class="rounded-lg px-2 py-1.5" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
                <p class="font-mono tabular-nums" style="color:rgb(var(--text))">{{.TunnelCount}}</p>
                <p class="t-caption uppercase tracking-wider">WG</p>
              </div>
            </div>
          </div>

          <div class="mt-4 space-y-3 pl-3 sm:pl-4" style="border-left:2px solid rgb(var(--border))">
            {{range .Services}}
            <div class="relative rounded-xl p-3" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">
              <div class="absolute -left-[1.1rem] top-5 h-2 w-2 rounded-full" style="background:rgb(var(--border))"></div>
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex min-w-0 flex-wrap items-center gap-2">
                    <span class="r-pill {{if eq .Status "active"}}r-pill-success{{else if eq .Status "suspended"}}r-pill-warning{{else}}r-pill-danger{{end}} shrink-0">{{.Status}}</span>
                    <p class="min-w-0 break-words t-h3">{{.Name}}</p>
                  </div>
                  <div class="mt-2 flex flex-wrap items-center gap-2">
                    <code class="max-w-full break-all rounded-md px-1.5 py-0.5 font-mono text-[11px]" style="background:rgb(var(--surface));border:1px solid rgb(var(--border));color:rgb(var(--text))">{{.BackendIP}}</code>
                    <span class="font-mono t-small">ports {{.PortStart}}-{{.PortEnd}}</span>
                  </div>
                </div>
                <span class="r-pill r-pill-neutral shrink-0 font-mono">svc #{{.ID}}</span>
              </div>

              <div class="mt-3 overflow-hidden rounded-lg" style="background:rgb(var(--surface));border:1px solid rgb(var(--border))">
                {{range .Routes}}
                <div class="p-3" style="border-bottom:1px solid rgb(var(--border))">
                  <div class="last:border-b-0">
                  <div class="grid gap-3 lg:grid-cols-[minmax(0,1.2fr)_minmax(12rem,0.8fr)]">
                    <div class="min-w-0">
                      <div class="flex min-w-0 flex-wrap items-center gap-2">
                        <span class="r-pill {{if eq .Status "active"}}r-pill-success{{else if or (eq .Status "pending_dns") (eq .Status "pending_ssl") (eq .Status "dns_ok")}}r-pill-warning{{else}}r-pill-danger{{end}} shrink-0">{{.Status}}</span>
                        <a href="/admin/hosts/{{.ID}}/edit" class="min-w-0 break-all t-small font-medium" style="color:rgb(var(--accent))">{{.Domain}}</a>
                        {{if .PathPrefix}}<code class="max-w-full break-all rounded-md px-1.5 py-0.5 font-mono text-[11px]" style="background:rgb(var(--surface-2));color:rgb(var(--muted))">{{.PathPrefix}}</code>{{end}}
                      </div>
                      <p class="mt-1 t-caption">upstream <span class="font-mono">:{{.UpstreamPort}}</span></p>
                    </div>
                    <div class="min-w-0 pt-2 lg:pl-3 lg:pt-0" style="border-top:1px solid rgb(var(--border));border-left:none">
                      <div class="flex min-w-0 items-center justify-between gap-2">
                        <a href="/admin/nodes/{{.NodeID}}" class="min-w-0 truncate t-small font-medium" style="color:rgb(var(--text))">{{.NodeName}}</a>
                        <span class="r-pill {{if and .NodeEnabled (eq .NodeHealth "healthy")}}r-pill-success{{else if eq .NodeHealth "down"}}r-pill-danger{{else}}r-pill-warning{{end}} shrink-0">{{.NodeHealth}}</span>
                      </div>
                      {{if .WGPeerID}}
                      <p class="mt-1 min-w-0 break-words t-caption">via WG <span class="font-medium">{{.WGPeerName}}</span> <span class="font-mono">{{.WGPeerIP}}</span></p>
                      {{else}}
                      <p class="mt-1 t-caption">direct node upstream</p>
                      {{end}}
                    </div>
                  </div>
                  <!-- Mobile overflow menu for row actions -->
                  <div class="mt-2 flex items-center justify-end gap-2 sm:hidden">
                    <div class="hpg-row-actions" data-row-actions>
                      <button type="button" class="hpg-row-actions-toggle cursor-pointer rounded-md p-1 transition-colors" style="color:rgb(var(--muted))" aria-label="Row actions" aria-expanded="false" aria-haspopup="menu">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg>
                      </button>
                      <div class="hpg-row-actions-menu hidden" role="menu">
                        <a href="/admin/hosts/{{.ID}}/edit" role="menuitem" class="flex cursor-pointer items-center gap-2 px-3 py-2 t-small transition-colors">
                          <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                          Edit host
                        </a>
                        <a href="/admin/nodes/{{.NodeID}}" role="menuitem" class="flex cursor-pointer items-center gap-2 px-3 py-2 t-small transition-colors">
                          <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
                          View node
                        </a>
                      </div>
                    </div>
                  </div>
                  </div>
                </div>
                {{else}}
                <div class="px-3 py-6 text-center">
                  <p class="t-small font-medium">No routes on this service.</p>
                  <p class="mt-1 t-caption">Add a host mapping to connect this backend to an edge node.</p>
                </div>
                {{end}}
              </div>
            </div>
            {{else}}
            <div class="rounded-xl border border-dashed px-4 py-8 text-center" style="border-color:rgb(var(--border))">
              <p class="t-small font-medium">No services for this client.</p>
              <p class="mt-1 t-caption">Services will appear here before their host routes and node targets.</p>
            </div>
            {{end}}
          </div>

          {{if .Tunnels}}
          <div class="mt-4">
            <p class="t-eyebrow mb-2">Visible WG peers</p>
            <div class="flex flex-wrap gap-2">
              {{range .Tunnels}}
              <span class="group inline-flex max-w-full cursor-default flex-col gap-0.5 rounded-xl px-3 py-1.5 t-small transition-shadow" style="background:rgb(var(--success)/.10);color:rgb(var(--success));border:1px solid rgb(var(--success)/.25)">
                <span class="flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 shrink-0 rounded-full {{if .Healthy}}bg-emerald-500{{else}}bg-amber-400{{end}}" title="{{if .Healthy}}handshake fresh{{else}}stale or no handshake{{end}}"></span>
                  <span class="min-w-0 truncate font-medium">{{.Name}}</span>
                  <span class="shrink-0 font-mono tabular-nums">{{.AssignedIP}}</span>
                </span>
                <span class="flex flex-wrap items-center gap-2 pl-3 t-caption opacity-75">
                  <span class="min-w-0 truncate">{{.NodeName}}</span>
                  {{if .LastHandshakeAt}}<span title="last handshake">{{.LastHandshakeAt}}</span>{{end}}
                  {{if .KeyAgeHuman}}<span title="key age" class="font-mono">key {{.KeyAgeHuman}}</span>{{end}}
                </span>
              </span>
              {{end}}
            </div>
          </div>
          {{end}}
        </article>
        {{else}}
        <div class="px-5 py-16 text-center">
          <p class="t-body font-medium">No topology data to show.</p>
          <p class="mx-auto mt-1 max-w-md t-small">{{if .ScopeLimited}}No clients are currently assigned to your admin scope.{{else}}Create a client, service, and host to populate the map.{{end}}</p>
        </div>
        {{end}}
      </div>
    </section>

    <aside class="space-y-4">
      <section class="r-card !p-0 overflow-hidden">
        <div class="px-5 py-4" style="border-bottom:1px solid rgb(var(--border))">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="t-eyebrow">Nodes</p>
              <h2 class="mt-1 t-h3 font-semibold">Fleet edge</h2>
            </div>
            {{if gt .Counts.Nodes .Limits.Nodes}}<span class="r-pill r-pill-warning shrink-0">clipped</span>{{end}}
          </div>
        </div>
        <div>
          {{range .Nodes}}
          <div class="p-4" style="border-bottom:1px solid rgb(var(--border))">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <a href="/admin/nodes/{{.ID}}" class="block truncate t-body font-medium" style="color:rgb(var(--text))">{{.Name}}</a>
                <p class="mt-1 break-all t-caption">{{if .PublicHostname}}{{.PublicHostname}}{{else if .PublicIP}}{{.PublicIP}}{{else}}no public endpoint{{end}}</p>
              </div>
              <span class="r-pill {{if and .Enabled (eq .HealthStatus "healthy")}}r-pill-success{{else if eq .HealthStatus "down"}}r-pill-danger{{else}}r-pill-warning{{end}} shrink-0">{{.HealthStatus}}</span>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-2">
              <div class="rounded-lg px-2.5 py-2" style="background:rgb(var(--surface-2))">
                <p class="t-caption">route load</p>
                <p class="font-mono tabular-nums t-small" style="color:rgb(var(--text))">{{.CurrentRoutes}}/{{.MaxRoutes}}</p>
              </div>
              <div class="rounded-lg px-2.5 py-2" style="background:rgb(var(--surface-2))">
                <p class="t-caption">visible here</p>
                <p class="font-mono tabular-nums t-small" style="color:rgb(var(--text))">{{.RoutesShown}}R / {{.TunnelsShown}}WG</p>
              </div>
            </div>
            {{if .TunnelEnabled}}
            <div class="mt-3 rounded-lg px-3 py-2 t-small" style="background:rgb(var(--success)/.10);color:rgb(var(--success));border:1px solid rgb(var(--success)/.25)">
              <div class="flex min-w-0 items-center justify-between gap-2">
                <span class="font-medium">WG enabled</span>
                {{if .WGIP}}<span class="shrink-0 font-mono tabular-nums">{{.WGIP}}</span>{{end}}
              </div>
              {{if .TunnelSubnet}}<p class="mt-1 break-all font-mono opacity-80">{{.TunnelSubnet}}</p>{{end}}
              {{if .TunnelMTU.Valid}}<p class="mt-1 t-caption opacity-70">MTU {{.TunnelMTU.Int32}}</p>{{end}}
            </div>
            {{else}}
            <div class="mt-3 rounded-lg px-3 py-2 t-caption" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border))">WG disabled on this node.</div>
            {{end}}
            {{if .Tunnels}}
            <div class="mt-3 space-y-1.5">
              {{range .Tunnels}}
              <div class="flex items-start justify-between gap-2 rounded-lg px-2.5 py-2" style="background:rgb(var(--surface));border:1px solid rgb(var(--border))">
                <div class="min-w-0 flex-1">
                  <div class="flex min-w-0 items-center gap-1.5">
                    <span class="h-1.5 w-1.5 shrink-0 rounded-full {{if .Healthy}}bg-emerald-500{{else}}bg-amber-400{{end}}"></span>
                    <span class="min-w-0 truncate t-small">{{.Name}}</span>
                  </div>
                  <div class="mt-0.5 flex flex-wrap gap-x-2 pl-3 t-caption">
                    <span class="font-mono tabular-nums">{{.AssignedIP}}</span>
                    {{if .LastHandshakeAt}}<span>{{.LastHandshakeAt}}</span>{{end}}
                    {{if .KeyAgeHuman}}<span>key {{.KeyAgeHuman}}</span>{{end}}
                  </div>
                </div>
                <span class="r-pill {{if eq .Status "active"}}r-pill-success{{else if eq .Status "pending"}}r-pill-warning{{else}}r-pill-danger{{end}} shrink-0">{{.Status}}</span>
              </div>
              {{end}}
            </div>
            {{else if .TunnelEnabled}}
            <div class="mt-3 rounded-lg border border-dashed px-3 py-4 text-center t-caption" style="border-color:rgb(var(--border))">No visible WG peers on this node.</div>
            {{end}}
          </div>
          {{else}}
          <div class="px-5 py-10 text-center">
            <p class="t-small font-medium">No nodes are connected to the visible topology.</p>
            <p class="mt-1 t-caption">Nodes appear once routes or tunnels in scope point at them.</p>
          </div>
          {{end}}
        </div>
      </section>

      <section class="r-card t-caption">
        <p class="t-eyebrow mb-2">Display limits</p>
        <p>Showing up to {{.Limits.Clients}} clients, {{.Limits.Services}} services, {{.Limits.Routes}} routes, {{.Limits.Nodes}} nodes, and {{.Limits.Tunnels}} tunnels.</p>
        <p class="mt-2">Summary counts use the full visible scope{{if .ScopeLimited}} after admin scoping{{end}}.</p>
      </section>
    </aside>
  </div>
  {{end}}
</div>
<style nonce="{{.CSPNonce}}">
.hpg-row-actions { position: relative; }
.hpg-row-actions-menu {
  position: absolute;
  right: 0;
  bottom: calc(100% + 4px);
  z-index: 20;
  min-width: 10rem;
  border-radius: 0.5rem;
  background: rgb(var(--surface));
  box-shadow: 0 4px 16px rgba(0,0,0,.12);
  border: 1px solid rgb(var(--border));
  overflow: hidden;
}
.hpg-row-actions-menu:not(.hidden) { display: block; }
</style>
<script nonce="{{.CSPNonce}}">
(function(){
  var LS_KEY = 'hpg_map_filters';
  var shell = document.querySelector('.hpg-topology-shell');
  if (!shell) return;
  var lanes = Array.prototype.slice.call(shell.querySelectorAll('[data-topology-lane]'));
  var cards = Array.prototype.slice.call(shell.querySelectorAll('[data-map-card]'));
  var search = document.getElementById('hpg-topology-search');
  var filterButtons = Array.prototype.slice.call(shell.querySelectorAll('[data-topology-filter]'));
  var title = document.getElementById('hpg-inspector-title');
  var meta = document.getElementById('hpg-inspector-meta');
  var count = document.getElementById('hpg-visible-count');
  var link = document.getElementById('hpg-inspector-link');
  var activeFilter = 'all';

  // --- URL + localStorage persistence ---
  function readSaved() {
    // Each dimension restored independently: URL param wins, else localStorage fallback.
    var params = new URLSearchParams(window.location.search);
    var stored = {};
    try { stored = JSON.parse(localStorage.getItem(LS_KEY) || '{}'); } catch(e) {}
    var q = params.has('q') ? params.get('q') : (stored.q || '');
    var f = params.has('filter') ? params.get('filter') : (stored.filter || 'all');
    return { q: q || '', filter: f || 'all' };
  }

  function persistState(q, filter) {
    // Write to both URL and localStorage so bookmarks and reloads both work.
    var params = new URLSearchParams(window.location.search);
    if (q) { params.set('q', q); } else { params.delete('q'); }
    if (filter && filter !== 'all') { params.set('filter', filter); } else { params.delete('filter'); }
    var newURL = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
    history.replaceState(null, '', newURL);
    try { localStorage.setItem(LS_KEY, JSON.stringify({ q: q, filter: filter })); } catch(e) {}
  }

  function cardTone(card) {
    if (card.querySelector('.is-err') || card.classList.contains('is-err')) return 'err';
    if (card.querySelector('.is-warn') || card.classList.contains('is-warn')) return 'warn';
    if (card.querySelector('.is-ok') || card.classList.contains('is-ok')) return 'ok';
    return 'ok';
  }

  function laneTone(lane) {
    if (lane.querySelector('.is-err')) return 'err';
    if (lane.querySelector('.is-warn')) return 'warn';
    return 'ok';
  }

  function selectCard(card) {
    cards.forEach(function(c){ c.classList.toggle('is-selected', c === card); });
    var lane = card.closest('[data-topology-lane]');
    lanes.forEach(function(l){ l.classList.toggle('is-selected', l === lane); });
    if (title) title.textContent = (card.dataset.mapType || 'Object') + ': ' + (card.dataset.mapTitle || '');
    if (meta) meta.textContent = (card.dataset.mapStatus ? card.dataset.mapStatus + ' - ' : '') + (card.dataset.mapMeta || '');
    if (link) {
      var href = card.dataset.mapHref || card.getAttribute('href') || '';
      link.classList.toggle('hidden', !href);
      if (href) link.setAttribute('href', href);
    }
  }

  function applyFilters() {
    var q = search ? search.value.trim().toLowerCase() : '';
    var visible = 0;
    lanes.forEach(function(lane) {
      var textMatch = !q || lane.textContent.toLowerCase().indexOf(q) !== -1;
      var toneMatch = activeFilter === 'all' || laneTone(lane) === activeFilter;
      var show = textMatch && toneMatch;
      lane.classList.toggle('is-filtered-out', !show);
      if (show) visible++;
    });
    if (count) count.textContent = visible + (visible === 1 ? ' client visible' : ' clients visible');
    persistState(q, activeFilter);
  }

  // Restore saved state.
  var saved = readSaved();
  if (saved.q && search) { search.value = saved.q; }
  if (saved.filter) {
    activeFilter = saved.filter;
    filterButtons.forEach(function(b) {
      b.classList.toggle('is-active', b.dataset.topologyFilter === activeFilter);
    });
  }

  cards.forEach(function(card) {
    card.dataset.mapTone = cardTone(card);
    card.addEventListener('mouseenter', function(){ selectCard(card); });
    card.addEventListener('focus', function(){ selectCard(card); });
    card.addEventListener('click', function(){ selectCard(card); });
  });
  filterButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activeFilter = btn.dataset.topologyFilter || 'all';
      filterButtons.forEach(function(b){ b.classList.toggle('is-active', b === btn); });
      applyFilters();
    });
  });
  if (search) search.addEventListener('input', applyFilters);
  applyFilters();

  // --- Mobile overflow menus ---
  document.querySelectorAll('[data-row-actions]').forEach(function(wrap) {
    var btn = wrap.querySelector('.hpg-row-actions-toggle');
    var menu = wrap.querySelector('.hpg-row-actions-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = !menu.classList.contains('hidden');
      // Close all other menus first.
      document.querySelectorAll('.hpg-row-actions-menu').forEach(function(m) { m.classList.add('hidden'); });
      document.querySelectorAll('.hpg-row-actions-toggle').forEach(function(b) { b.setAttribute('aria-expanded','false'); });
      if (!open) {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded','true');
      }
    });
  });
  // Click outside closes all menus.
  document.addEventListener('click', function() {
    document.querySelectorAll('.hpg-row-actions-menu').forEach(function(m) { m.classList.add('hidden'); });
    document.querySelectorAll('.hpg-row-actions-toggle').forEach(function(b) { b.setAttribute('aria-expanded','false'); });
  });
})();
</script>
<script nonce="{{.CSPNonce}}">
/* Topology edge overlay - draws bezier curves connecting related node cards. */
(function(){
  var shell = document.querySelector('.hpg-topology-shell');
  if (!shell) return;

  /* Color palette matching the design system accent colours. */
  var EDGE_COLOR = {
    'client-service': 'rgba(56,189,248,0.45)',   /* sky-400 */
    'service-route':  'rgba(99,102,241,0.38)',    /* indigo-500 */
    'route-edge':     'rgba(16,185,129,0.40)',    /* emerald-500 */
  };
  var EDGE_COLOR_DARK = {
    'client-service': 'rgba(125,211,252,0.35)',
    'service-route':  'rgba(165,180,252,0.32)',
    'route-edge':     'rgba(52,211,153,0.32)',
  };
  var STROKE_W = 1.5;

  function isDark() {
    return document.documentElement.classList.contains('dark');
  }

  /* Get bounding rect relative to a positioned ancestor (the lane). */
  function relRect(el, ancestor) {
    var er = el.getBoundingClientRect();
    var ar = ancestor.getBoundingClientRect();
    return {
      left:   er.left   - ar.left,
      top:    er.top    - ar.top,
      right:  er.right  - ar.left,
      bottom: er.bottom - ar.top,
      midY:   (er.top + er.bottom) / 2 - ar.top,
    };
  }

  /* Draw a cubic bezier from (x1,y1) to (x2,y2) with horizontal control handles. */
  function curvePath(x1, y1, x2, y2) {
    var cx = (x1 + x2) / 2;
    return 'M' + x1 + ',' + y1 + ' C' + cx + ',' + y1 + ' ' + cx + ',' + y2 + ' ' + x2 + ',' + y2;
  }

  /* Collect one connection from the right-mid of src to left-mid of dst. */
  function edgePath(src, dst, lane) {
    if (!src || !dst) return null;
    var s = relRect(src, lane);
    var d = relRect(dst, lane);
    return curvePath(s.right, s.midY, d.left, d.midY);
  }

  function buildEdgesForLane(lane) {
    var colors = isDark() ? EDGE_COLOR_DARK : EDGE_COLOR;
    var paths = [];

    /* Client card (first column). */
    var clientCard = lane.querySelector('.hpg-map-node-client');
    /* Service cards (second column). */
    var serviceCards = Array.prototype.slice.call(lane.querySelectorAll('.hpg-map-node-service'));
    /* Route cards (third column). */
    var routeCards = Array.prototype.slice.call(lane.querySelectorAll('.hpg-map-node-route'));
    /* Edge node cards (fourth column). */
    var edgeCards = Array.prototype.slice.call(lane.querySelectorAll('.hpg-map-node-edge'));

    /* client -> each service. */
    if (clientCard) {
      serviceCards.forEach(function(svc) {
        var p = edgePath(clientCard, svc, lane);
        if (p) paths.push({ d: p, type: 'client-service' });
      });
      /* client -> tunnel strip (treat strip as one target). */
      var tunnelStrip = lane.querySelector('.hpg-map-tunnel-strip');
      if (tunnelStrip && serviceCards.length === 0) {
        var p = edgePath(clientCard, tunnelStrip, lane);
        if (p) paths.push({ d: p, type: 'client-service' });
      }
    }

    /* service -> route: match by DOM order (routes appear under each service). */
    /* We pair them by index since serviceCards[i] owns routeCards[i*N..(i+1)*N-1]. */
    /* A simpler reliable approach: draw each service to all route cards in same stack. */
    /* The DOM nests: .hpg-map-stack (col 3) -> routes across all services flat. */
    /* Find the two stacks for col2 (services) and col3 (routes+tunnels). */
    var stacks = Array.prototype.slice.call(lane.querySelectorAll('.hpg-map-stack'));
    /* stacks[0] = services, stacks[1] = routes+tunnels, stacks[2] = edge nodes. */

    if (stacks.length >= 2) {
      /* service -> route: pair same-index service to all routes in the routes stack. */
      serviceCards.forEach(function(svc, si) {
        routeCards.forEach(function(rt, ri) {
          /* Only draw if this route belongs to this service: check DOM ancestry. */
          /* Routes are nested inside stacks[1] directly. Without per-service grouping
             in the DOM we pair each service to every route (fan-out) - acceptable. */
          var p = edgePath(svc, rt, lane);
          if (p) paths.push({ d: p, type: 'service-route' });
        });
      });
    }

    /* route -> edge node: match by DOM position index (1:1 mapping in template). */
    routeCards.forEach(function(rt, i) {
      var edge = edgeCards[i];
      if (edge) {
        var p = edgePath(rt, edge, lane);
        if (p) paths.push({ d: p, type: 'route-edge' });
      }
    });

    return paths.map(function(seg) {
      return '<path d="' + seg.d + '" stroke="' + colors[seg.type] + '" stroke-width="' + STROKE_W + '" fill="none" stroke-linecap="round"/>';
    }).join('');
  }

  function renderEdges() {
    /* Skip if grid is single-column (mobile): CSS hides the SVG anyway, but
       avoid work and avoid zero-width SVG noise. */
    var laneEl = shell.querySelector('[data-topology-lane]');
    if (!laneEl) return;
    var laneW = laneEl.getBoundingClientRect().width;
    /* Rough single-column check: lane narrower than ~500px means stacked layout. */
    var singleCol = laneW < 500;

    shell.querySelectorAll('[data-topology-lane]').forEach(function(lane) {
      /* Remove any prior SVG. */
      var old = lane.querySelector('.hpg-topology-edges');
      if (old) old.remove();
      if (singleCol) return;

      var svgContent = buildEdgesForLane(lane);
      if (!svgContent) return;

      var laneRect = lane.getBoundingClientRect();
      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('class', 'hpg-topology-edges');
      svg.setAttribute('aria-hidden', 'true');
      svg.setAttribute('width', laneRect.width);
      svg.setAttribute('height', laneRect.height);
      svg.setAttribute('viewBox', '0 0 ' + laneRect.width + ' ' + laneRect.height);
      svg.innerHTML = svgContent;
      /* Insert as first child so it sits behind node cards. */
      lane.insertBefore(svg, lane.firstChild);
    });
  }

  /* Debounced resize to avoid thrash. */
  var resizeTimer;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(renderEdges, 80);
  }

  /* Re-render on filter/search changes (lanes may appear/disappear). */
  var filterTimer;
  function onFilterChange() {
    clearTimeout(filterTimer);
    filterTimer = setTimeout(renderEdges, 120);
  }

  /* Initial render after layout is stable. */
  if (document.readyState === 'complete') {
    renderEdges();
  } else {
    window.addEventListener('load', renderEdges);
  }
  window.addEventListener('resize', onResize);

  /* Observe topology filter/search mutations to redraw after lanes hide/show. */
  var filterBtns = shell.querySelectorAll('[data-topology-filter]');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', onFilterChange);
  });
  var searchInput = document.getElementById('hpg-topology-search');
  if (searchInput) searchInput.addEventListener('input', onFilterChange);

  /* Redraw when colour scheme toggles (dark/light). */
  var mq = window.matchMedia('(prefers-color-scheme: dark)');
  if (mq && mq.addEventListener) mq.addEventListener('change', renderEdges);
  /* Also watch the html.dark class toggle used by the theme switcher. */
  if (window.MutationObserver) {
    new MutationObserver(renderEdges).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }
})();
</script>
{{end}}
