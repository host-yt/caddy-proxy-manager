<!-- AI chat bubble (floating, fixed bottom-right, z-[70] above toasts). -->
{{template "ai_bubble" .}}

<!-- Toast container (bottom-right). Auto-injected toasts stack here.
     bottom-24 clears the AI bubble (fixed bottom-right, z-[70]) - at bottom-4
     the bubble sat on top of the first toast and cut off its text. -->
<div id="hpg-toasts" role="region" aria-live="polite" aria-label="Notifications" class="fixed bottom-24 right-4 z-50 flex flex-col gap-2 pointer-events-none w-80 max-w-[calc(100vw-2rem)]"></div>

<!-- Modal confirm (replaces native confirm()). Backdrop blur, centered card. -->
<div id="hpg-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
  <div class="rounded-[var(--r-lg,16px)] border shadow-[var(--shadow-soft)] max-w-md w-full p-5 space-y-4" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
    <p id="hpg-modal-msg" class="text-sm whitespace-pre-wrap" style="color:rgb(var(--text))"></p>
    <div class="flex justify-end gap-2">
      <button id="hpg-modal-cancel" type="button" class="r-btn-ghost text-sm h-8 px-3">Cancel</button>
      <button id="hpg-modal-ok" type="button" class="px-3 py-1.5 rounded-[var(--r-sm,8px)] bg-rose-600 text-white text-sm font-semibold hover:bg-rose-700 cursor-pointer transition-colors">Confirm</button>
    </div>
  </div>
</div>

<!-- Modal prompt (replaces native prompt()). Single text input. -->
<div id="hpg-prompt" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
  <div class="rounded-[var(--r-lg,16px)] border shadow-[var(--shadow-soft)] max-w-md w-full p-5 space-y-4" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
    <p id="hpg-prompt-msg" class="text-sm whitespace-pre-wrap" style="color:rgb(var(--text))"></p>
    <input id="hpg-prompt-input" type="text" class="r-input">
    <div class="flex justify-end gap-2">
      <button id="hpg-prompt-cancel" type="button" class="r-btn-ghost text-sm h-8 px-3">Cancel</button>
      <button id="hpg-prompt-ok" type="button" class="r-btn-primary text-sm h-8 px-3">OK</button>
    </div>
  </div>
</div>

<!-- Command palette overlay -->
<div id="hpg-palette" class="fixed inset-0 z-[60] items-center justify-center p-4" style="display:none;background:rgba(0,0,0,.5);backdrop-filter:blur(4px)" role="dialog" aria-modal="true" aria-label="Command palette">
  <div class="rounded-[var(--r-lg,16px)] border w-full max-w-xl overflow-hidden" style="background:rgb(var(--surface));border-color:rgb(var(--border));box-shadow:var(--shadow-soft)">
    <div class="flex items-center gap-2 px-4 py-3 border-b" style="border-color:rgb(var(--border))">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
      </svg>
      <input id="hpg-palette-input" type="text" class="flex-1 bg-transparent text-sm outline-none placeholder:opacity-50" style="color:rgb(var(--text))" placeholder="Search hosts, clients, nodes, tunnels..." autocomplete="off" spellcheck="false">
      <kbd class="hidden sm:inline px-1.5 py-0.5 rounded text-[10px] border" style="color:rgb(var(--muted));background:rgb(var(--surface));border-color:rgb(var(--border))">Esc</kbd>
    </div>
    <ul id="hpg-palette-list" role="listbox" class="max-h-72 overflow-y-auto divide-y" style="border-color:rgb(var(--border))"></ul>
    <div class="px-4 py-2 flex items-center gap-3 text-[10px] border-t" style="color:rgb(var(--muted));border-color:rgb(var(--border))">
      <span><kbd class="font-mono">↑↓</kbd> navigate</span>
      <span><kbd class="font-mono">↵</kbd> open</span>
      <span><kbd class="font-mono">Esc</kbd> close</span>
    </div>
  </div>
</div>

<script nonce="{{.Data.CSPNonce}}">
// Shared UI helpers: toast + modal confirm.
window.hpgToast = function(msg, kind){
  if (!msg) return;
  var wrap = document.getElementById('hpg-toasts'); if (!wrap) return;
  var el = document.createElement('div');
  var palette = kind === 'error'
    ? 'bg-rose-600 text-white'
    : kind === 'warn' ? 'bg-amber-500 text-white'
    : 'bg-emerald-600 text-white';
  el.className = 'pointer-events-auto rounded-lg shadow-lg px-4 py-3 text-sm ' + palette + ' opacity-0 transition-opacity duration-200';
  el.textContent = msg;
  wrap.appendChild(el);
  requestAnimationFrame(function(){ el.classList.remove('opacity-0'); });
  setTimeout(function(){
    el.classList.add('opacity-0');
    setTimeout(function(){ el.remove(); }, 250);
  }, 4000);
};
window.hpgConfirm = function(msg){
  return new Promise(function(resolve){
    var m = document.getElementById('hpg-modal');
    document.getElementById('hpg-modal-msg').textContent = msg || 'Are you sure?';
    m.classList.remove('hidden'); m.classList.add('flex');
    function done(ok){
      m.classList.add('hidden'); m.classList.remove('flex');
      document.getElementById('hpg-modal-ok').onclick = null;
      document.getElementById('hpg-modal-cancel').onclick = null;
      m.onclick = null;
      resolve(ok);
    }
    document.getElementById('hpg-modal-ok').onclick = function(){ done(true); };
    document.getElementById('hpg-modal-cancel').onclick = function(){ done(false); };
    m.onclick = function(e){ if (e.target === m) done(false); };
  });
};
// hpgPrompt: replaces window.prompt(). Resolves to typed string, or null on cancel.
window.hpgPrompt = function(msg, defaultValue){
  return new Promise(function(resolve){
    var m = document.getElementById('hpg-prompt');
    var inp = document.getElementById('hpg-prompt-input');
    document.getElementById('hpg-prompt-msg').textContent = msg || '';
    inp.value = defaultValue || '';
    m.classList.remove('hidden'); m.classList.add('flex');
    setTimeout(function(){ inp.focus(); inp.select(); }, 30);
    function done(val){
      m.classList.add('hidden'); m.classList.remove('flex');
      document.getElementById('hpg-prompt-ok').onclick = null;
      document.getElementById('hpg-prompt-cancel').onclick = null;
      inp.onkeydown = null;
      m.onclick = null;
      resolve(val);
    }
    document.getElementById('hpg-prompt-ok').onclick = function(){ done(inp.value); };
    document.getElementById('hpg-prompt-cancel').onclick = function(){ done(null); };
    m.onclick = function(e){ if (e.target === m) done(null); };
    inp.onkeydown = function(e){
      if (e.key === 'Enter') { e.preventDefault(); done(inp.value); }
      else if (e.key === 'Escape') { e.preventDefault(); done(null); }
    };
  });
};
// hpgConfirmTyped: a destructive-action gate. The user must type `keyword`
// (e.g. the host/node name) exactly before the action proceeds. Builds on
// hpgPrompt so it inherits focus + Esc handling.
window.hpgConfirmTyped = function(msg, keyword){
  return window.hpgPrompt((msg || 'This cannot be undone.') + '\n\nType "' + keyword + '" to confirm:', '')
    .then(function(val){ return val !== null && val.trim() === String(keyword); });
};
</script>
<script nonce="{{.Data.CSPNonce}}">
// Swap moon/sun SVG paths to reflect the active theme (sun shown in dark mode).
function applyThemeIcon(dark){
  var ic=document.getElementById('theme-icon'); if(!ic) return;
  var moon=ic.querySelector('[data-moon]'), sun=ic.querySelector('[data-sun]');
  if(moon) moon.classList.toggle('hidden', dark);
  if(sun) sun.classList.toggle('hidden', !dark);
}
function toggleTheme(){
  var d=document.documentElement;
  var dark=d.classList.toggle('dark');
  localStorage.setItem('theme', dark?'dark':'light');
  applyThemeIcon(dark);
}
(function(){applyThemeIcon(document.documentElement.classList.contains('dark'));})();
// Unified handler bindings. CSP forbids inline onclick=/onsubmit=, so
// templates declare intent via data-* attributes and we wire the
// addEventListener here in a nonced block.
document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('[data-theme-toggle]').forEach(function(el){
    el.addEventListener('click', toggleTheme);
  });
  // Palette switcher: toggle menu; on pick persist to localStorage + apply instantly (server cookie set via the link nav).
  (function(){
    var menu = document.querySelector('[data-palette-menu]');
    if (!menu) return;
    var btn = menu.querySelector('[data-palette-toggle]');
    var list = menu.querySelector('[data-palette-list]');
    function setOpen(open){ list.classList.toggle('hidden', !open); btn.setAttribute('aria-expanded', open?'true':'false'); }
    btn.addEventListener('click', function(e){ e.stopPropagation(); setOpen(list.classList.contains('hidden')); });
    document.addEventListener('click', function(e){ if (!menu.contains(e.target)) setOpen(false); });
    menu.querySelectorAll('[data-palette-pick]').forEach(function(a){
      a.addEventListener('click', function(){
        var slug = a.dataset.palettePick;
        try { localStorage.setItem('ui_theme', slug); } catch(e){}
        document.documentElement.dataset.theme = slug;
      });
    });
  })();
  // Mobile nav drawer: data-nav-toggle opens, data-nav-close (backdrop) closes.
  var sidebar = document.getElementById('admin-sidebar');
  var backdrop = document.getElementById('nav-backdrop');
  function setNav(open){
    if (!sidebar) return;
    if (open){ sidebar.classList.remove('hidden'); sidebar.classList.add('flex'); backdrop.classList.remove('hidden'); }
    else { sidebar.classList.add('hidden'); sidebar.classList.remove('flex'); backdrop.classList.add('hidden'); }
  }
  document.querySelectorAll('[data-nav-toggle]').forEach(function(b){ b.addEventListener('click', function(){ setNav(true); }); });
  document.querySelectorAll('[data-nav-close]').forEach(function(b){ b.addEventListener('click', function(){ setNav(false); }); });
  // data-confirm: gate submit on modal confirmation (replaces native confirm).
  // Forms that also carry data-confirm-type use the typed-confirm gate instead.
  document.querySelectorAll('form[data-confirm]:not([data-confirm-type])').forEach(function(f){
    var armed = false;
    f.addEventListener('submit', function(e){
      if (armed) return;
      e.preventDefault();
      window.hpgConfirm(f.dataset.confirm).then(function(ok){
        if (ok) { armed = true; f.submit(); }
      });
    });
  });
  // data-confirm-type: high-risk action; user must type data-confirm-type
  // (the resource name/keyword) exactly before the submit goes through.
  document.querySelectorAll('form[data-confirm-type]').forEach(function(f){
    var armed = false;
    f.addEventListener('submit', function(e){
      if (armed) return;
      e.preventDefault();
      window.hpgConfirmTyped(f.dataset.confirm, f.dataset.confirmType).then(function(ok){
        if (ok) { armed = true; f.submit(); }
        else { window.hpgToast('Confirmation text did not match - cancelled.', 'warn'); }
      });
    });
  });
  document.querySelectorAll('[data-check-all]').forEach(function(c){
    c.addEventListener('change', function(){
      var name = c.dataset.checkAll;
      document.querySelectorAll('input[name="'+name+'"]').forEach(function(i){ i.checked = c.checked; });
    });
  });
  document.querySelectorAll('form[data-confirm-bulk]').forEach(function(f){
    var armed = false;
    f.addEventListener('submit', function(e){
      if (armed) return;
      e.preventDefault();
      var n = f.querySelectorAll('input[name=ids]:checked').length;
      if (n === 0) { window.hpgToast('Select at least one row.', 'warn'); return; }
      var sel = f.querySelector('select[name=action]');
      var a = sel ? sel.value : '';
      var msg = a === 'delete' ? 'Delete '+n+' host(s)? This cannot be undone.' : a+' '+n+' host(s)?';
      window.hpgConfirm(msg).then(function(ok){
        if (ok) { armed = true; f.submit(); }
      });
    });
  });
  // Route htmx's confirm prompts through our nice modal instead of the
  // native confirm(). hx-confirm="..." sets e.detail.question.
  if (window.htmx) {
    document.body.addEventListener('htmx:confirm', function(e){
      if (!e.detail.question) return; // no hx-confirm -> proceed normally
      e.preventDefault();
      window.hpgConfirm(e.detail.question).then(function(ok){ if (ok) e.detail.issueRequest(true); });
    });
    document.body.addEventListener('htmx:responseError', function(){
      window.hpgToast('Action failed - reload and retry.', 'error');
    });
  }
  // Auto-fire toasts for server-rendered flash/error sentinels.
  document.querySelectorAll('[data-toast]').forEach(function(el){
    window.hpgToast(el.dataset.toastMsg, el.dataset.toast);
  });
});
</script>
<script nonce="{{.Data.CSPNonce}}">
// Command palette: Cmd/Ctrl+K, debounced /admin/search, keyboard nav.
(function(){
  var pal = document.getElementById('hpg-palette');
  var inp = document.getElementById('hpg-palette-input');
  var lst = document.getElementById('hpg-palette-list');
  var btn = document.getElementById('cmd-palette-btn');
  if (!pal || !inp || !lst) return;
  var debTimer = null, items = [], cursor = -1;
  var kindClass = {
    host:   'bg-[rgb(var(--accent)/.12)] text-[rgb(var(--accent))]',
    client: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300',
    node:   'bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300',
    tunnel: 'bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-300'
  };
  function open(){ pal.classList.remove('hidden'); pal.classList.add('flex'); inp.value=''; lst.innerHTML=''; items=[]; cursor=-1; setTimeout(function(){ inp.focus(); },30); }
  function close(){ pal.classList.add('hidden'); pal.classList.remove('flex'); clearTimeout(debTimer); }
  function escHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function render(results){
    items = results; cursor = -1; lst.innerHTML = '';
    if (!results.length){ lst.innerHTML='<li class="px-4 py-3 text-sm text-slate-400 dark:text-slate-600">No results</li>'; return; }
    results.forEach(function(r,i){
      var li = document.createElement('li');
      li.setAttribute('role','option'); li.setAttribute('data-idx',i);
      li.className = 'flex items-center gap-3 px-4 py-2.5 cursor-pointer select-none hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm';
      li.innerHTML =
        '<span class="shrink-0 px-1.5 py-0.5 rounded text-[10px] font-medium '+(kindClass[r.kind]||'')+'">'+escHtml(r.kind)+'</span>'+
        '<span class="flex-1 min-w-0"><span class="block truncate text-slate-900 dark:text-slate-100">'+escHtml(r.label)+'</span>'+
        (r.sub?'<span class="block truncate text-xs text-slate-400 dark:text-slate-500">'+escHtml(r.sub)+'</span>':'')+'</span>';
      li.addEventListener('click', function(){ navigate(i); });
      li.addEventListener('mouseenter', function(){ setCursor(i); });
      lst.appendChild(li);
    });
  }
  function setCursor(idx){
    var els = lst.querySelectorAll('[data-idx]');
    els.forEach(function(el){ el.classList.remove('bg-slate-50','dark:bg-zinc-800'); });
    cursor = idx;
    if (idx>=0 && idx<els.length){ els[idx].classList.add('bg-slate-50','dark:bg-zinc-800'); els[idx].scrollIntoView({block:'nearest'}); }
  }
  function navigate(idx){ if (idx<0||idx>=items.length) return; close(); window.location.href = items[idx].url; }
  function doSearch(q){
    if (q.length<2){ lst.innerHTML=''; items=[]; cursor=-1; return; }
    fetch('/admin/search?q='+encodeURIComponent(q), {credentials:'same-origin', headers:{'Accept':'application/json'}})
      .then(function(res){ return res.ok?res.json():{results:[]}; })
      .then(function(data){ render(data.results||[]); })
      .catch(function(){});
  }
  inp.addEventListener('input', function(){ clearTimeout(debTimer); debTimer=setTimeout(function(){ doSearch(inp.value.trim()); },180); });
  inp.addEventListener('keydown', function(e){
    var len = items.length;
    if (e.key==='ArrowDown'){ e.preventDefault(); if(len) setCursor((cursor+1)%len); }
    else if (e.key==='ArrowUp'){ e.preventDefault(); if(len) setCursor((cursor-1+len)%len); }
    else if (e.key==='Enter'){ e.preventDefault(); navigate(cursor>=0?cursor:0); }
    else if (e.key==='Escape'){ e.preventDefault(); close(); }
  });
  pal.addEventListener('click', function(e){ if (e.target===pal) close(); });
  if (btn) btn.addEventListener('click', open);
  document.addEventListener('keydown', function(e){
    if ((e.metaKey||e.ctrlKey) && (e.key==='k'||e.key==='K')){ e.preventDefault(); if (pal.classList.contains('hidden')) open(); else close(); }
  });
})();
</script>
<script nonce="{{.Data.CSPNonce}}">(function(){var K='hpg-ng';function L(){try{return JSON.parse(localStorage.getItem(K)||'{}')}catch{return{}}}function S(s){try{localStorage.setItem(K,JSON.stringify(s))}catch{}}var st=L();document.querySelectorAll('[data-nav-group]').forEach(function(w){var g=w.dataset.navGroup;var btn=w.querySelector('.nav-group-btn');var body=w.querySelector('.nav-group-body');var chev=btn&&btn.querySelector('.nav-chevron');if(!body)return;var open=st[g]!==false;if(!open){body.style.display='none';if(chev)chev.style.transform='rotate(-90deg)';}if(btn)btn.addEventListener('click',function(){open=!open;st[g]=open;S(st);body.style.display=open?'':'none';if(chev)chev.style.transform=open?'':'rotate(-90deg)';});});document.querySelectorAll('[data-greeting]').forEach(function(el){var h=new Date().getHours();el.textContent=h<12?'Good morning':h<17?'Good afternoon':'Good evening';});})();</script>
</body>
