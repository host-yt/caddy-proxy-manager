  <main id="main-content" role="main" class="p-6 md:p-8 min-w-0 max-w-full overflow-x-hidden">
    <!-- Sticky top status bar: breadcrumb + live chips left; controls right -->
    <header class="sticky top-0 z-20 -mx-6 md:-mx-8 px-4 md:px-6 py-2 mb-6 backdrop-blur ring-1 flex items-center justify-between gap-3 flex-wrap" style="background:rgb(var(--surface)/.92);border-color:rgb(var(--border))">
      <!-- Left: breadcrumb + live status chips -->
      <div class="flex items-center gap-3 min-w-0 flex-wrap">
        <div class="min-w-0">
          {{if .Data.Breadcrumbs}}
          <nav aria-label="Breadcrumb" class="flex items-center flex-nowrap gap-1 text-xs overflow-hidden whitespace-nowrap" style="color:rgb(var(--muted))">
            {{range $i, $c := .Data.Breadcrumbs}}
              {{if $i}}<span class="shrink-0" style="color:rgb(var(--border))">/</span>{{end}}
              {{if $c.URL}}<a href="{{$c.URL}}" class="shrink-0 transition-colors hover:underline" style="color:rgb(var(--muted))">{{$c.Label}}</a>{{else}}<span class="truncate" style="color:rgb(var(--text))">{{$c.Label}}</span>{{end}}
            {{end}}
          </nav>
          {{else}}
          <div class="text-xs font-medium" style="color:rgb(var(--muted))">Admin</div>
          {{end}}
          {{if ne .Page "dashboard"}}<div class="text-sm font-semibold tracking-tight truncate" style="color:rgb(var(--text))">{{.Data.Title}}</div>{{end}}
        </div>
        <!-- Live status chips (admin only, not support) -->
        {{if ne .Data.Role "support"}}
        <div class="hidden sm:flex items-center gap-1.5 flex-wrap">
          <span class="r-pill r-pill-success">
            <span style="display:inline-block;width:.45rem;height:.45rem;border-radius:999px;background:currentColor"></span>
            live
          </span>
          {{if .Data.Features.Nodes}}
          <span class="r-pill r-pill-info" id="hpg-nodes-chip" title="Active Caddy nodes">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.8"><rect x="1" y="1" width="4" height="4" rx="1"/><rect x="7" y="1" width="4" height="4" rx="1"/><rect x="1" y="7" width="4" height="4" rx="1"/><rect x="7" y="7" width="4" height="4" rx="1"/></svg>
            nodes
          </span>
          {{end}}
          {{if .Data.Features.WAF}}
          <span class="r-pill r-pill-warning" id="hpg-waf-chip" title="WAF">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.8"><path d="M6 1l4 1.5v3.5a4 4 0 01-4 4 4 4 0 01-4-4V2.5L6 1z"/></svg>
            WAF
          </span>
          {{end}}
        </div>
        {{end}}
      </div>
      <!-- Right: controls -->
      <div class="flex items-center gap-1.5 text-xs shrink-0" style="color:rgb(var(--muted))">
        <!-- ⌘K command palette trigger -->
        <button type="button" id="cmd-palette-btn"
                class="hidden sm:flex items-center gap-1 px-2.5 py-1.5 rounded-lg cursor-pointer transition-colors font-mono ring-1"
                style="color:rgb(var(--muted));background:rgb(var(--surface-2));ring-color:rgb(var(--border))"
                title="Search (Cmd+K / Ctrl+K)">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
          </svg>
          <span>Search</span>
          <kbd class="px-1 py-0.5 rounded text-[10px] leading-none" style="background:rgb(var(--surface));border:1px solid rgb(var(--border));color:rgb(var(--muted))">⌘K</kbd>
        </button>
        <!-- Theme toggle -->
        <button type="button" data-theme-toggle class="hpg-nav-hover flex items-center gap-1 px-2.5 py-1.5 rounded-lg cursor-pointer transition-colors" style="color:rgb(var(--muted))" title="Toggle theme">
          <svg id="theme-icon" data-mode="moon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path data-moon stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            <g data-sun class="hidden">
              <circle cx="12" cy="12" r="4"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"/>
            </g>
          </svg>
          <span class="hidden sm:inline">Theme</span>
        </button>
        <!-- Palette switcher -->
        <div class="relative" data-palette-menu>
          <button type="button" data-palette-toggle class="hpg-nav-hover flex items-center gap-1 px-2.5 py-1.5 rounded-lg cursor-pointer transition-colors" style="color:rgb(var(--muted))" title="Color palette" aria-haspopup="true" aria-expanded="false">
            <span class="inline-block w-3 h-3 rounded-full shrink-0" style="background:var(--accent-gradient,rgb(var(--accent)))"></span>
            <span class="hidden sm:inline">Palette</span>
          </button>
          <div data-palette-list class="hidden absolute right-0 mt-2 z-30 w-44 py-1.5 rounded-2xl ring-1 shadow-lg text-sm" style="background:rgb(var(--surface));border-color:rgb(var(--border));ring-color:rgb(var(--border))">
            {{$cur := .Data.Theme}}
            <a href="/theme/default" data-palette-pick="default" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Teal (default)</span>{{if eq "default" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/midnight" data-palette-pick="midnight" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Midnight</span>{{if eq "midnight" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/ocean" data-palette-pick="ocean" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Ocean</span>{{if eq "ocean" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/forest" data-palette-pick="forest" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Forest</span>{{if eq "forest" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/violet" data-palette-pick="violet" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Violet</span>{{if eq "violet" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/sunset" data-palette-pick="sunset" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Sunset</span>{{if eq "sunset" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/nord" data-palette-pick="nord" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Nord</span>{{if eq "nord" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/mono" data-palette-pick="mono" class="hpg-nav-hover flex items-center justify-between gap-2 px-3 py-1.5 transition-colors" style="color:rgb(var(--text))"><span>Mono</span>{{if eq "mono" $cur}}<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgb(var(--accent))"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
          </div>
        </div>
        <!-- Role badge -->
        {{if .Data.Role}}<span class="r-pill r-pill-neutral hidden md:inline-flex">{{.Data.Role}}</span>{{end}}
        <!-- Account link -->
        <a href="/admin/account" title="Account settings"
           class="hpg-nav-hover hidden md:inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg transition-colors truncate max-w-[10rem]"
           style="color:rgb(var(--muted))">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <span class="truncate">{{.Data.Email}}</span>
        </a>
        <!-- Sign out -->
        <form action="/auth/logout" method="POST" class="inline">
          <input type="hidden" name="csrf_token" value="{{.Data.CSRF}}">
          <button class="hpg-nav-hover px-2.5 py-1.5 rounded-lg cursor-pointer transition-colors" style="color:rgb(var(--muted))">{{T .Data.Lang "nav.signout"}}</button>
        </form>
      </div>
    </header>
    {{if .Data.Flash}}<div data-toast="success" data-toast-msg="{{.Data.Flash}}" class="hidden"></div>{{end}}
    {{if .Data.Error}}<div data-toast="error" data-toast-msg="{{.Data.Error}}" class="hidden"></div>{{end}}
    {{if .Data.SystemBanner}}
    <div id="hpg-sys-banner" data-banner-text="{{.Data.SystemBanner}}" class="{{if eq .Data.SystemBannerType "error"}}bg-rose-50 border-rose-400 text-rose-800 dark:bg-rose-900/30 dark:border-rose-600 dark:text-rose-200{{else if eq .Data.SystemBannerType "warning"}}bg-amber-50 border-amber-400 text-amber-800 dark:bg-amber-900/30 dark:border-amber-600 dark:text-amber-200{{else}}bg-sky-50 border-sky-400 text-sky-800 dark:bg-sky-900/30 dark:border-sky-600 dark:text-sky-200{{end}} border-l-4 px-4 py-2 text-sm flex items-center gap-2">
      <span class="flex-1">{{.Data.SystemBanner}}</span>
      {{if .Data.SystemBannerLink}}<a href="{{.Data.SystemBannerLink}}" target="_blank" rel="noopener" class="ml-2 underline font-medium whitespace-nowrap cursor-pointer">{{if .Data.SystemBannerLinkLabel}}{{.Data.SystemBannerLinkLabel}}{{else}}Learn more{{end}}</a>{{end}}
      <button id="hpg-sys-banner-x" type="button" class="ml-3 shrink-0 opacity-60 hover:opacity-100 cursor-pointer transition-opacity leading-none" aria-label="Dismiss">&times;</button>
    </div>
    <script nonce="{{.Data.CSPNonce}}">(function(){var b=document.getElementById('hpg-sys-banner');if(!b)return;function key(s){var h=0,i;for(i=0;i<s.length;i++)h=((h<<5)-h+s.charCodeAt(i))|0;return 'hpg-banner-'+h;}var k=key(b.dataset.bannerText||'');try{if(localStorage.getItem(k)){b.style.display='none';return;}}catch(e){}var x=document.getElementById('hpg-sys-banner-x');if(x)x.addEventListener('click',function(){try{localStorage.setItem(k,'1');}catch(e){}b.style.display='none';});})();</script>
    {{end}}
