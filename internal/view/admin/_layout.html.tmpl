{{define "layout.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full" data-theme="{{.Data.Theme}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="csrf-token" content="{{.Data.CSRF}}">
<title>Admin - Hostyt Proxy Gateway</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<link rel="stylesheet" href="/static/css/enhance.css">
<script nonce="{{.Data.CSPNonce}}">(function(){var t=localStorage.getItem('theme');if(t==='light'){/* keep light */}else{document.documentElement.classList.add('dark');}})();</script>
<!-- Palette theme bootstrap: client-side pick applies before paint, even before the ui_theme cookie round-trips. -->
<script nonce="{{.Data.CSPNonce}}">(function(){try{var ok={default:1,midnight:1,ocean:1,forest:1,violet:1,sunset:1,nord:1,mono:1};var p=localStorage.getItem('ui_theme');if(p&&ok[p]&&p!==document.documentElement.dataset.theme)document.documentElement.dataset.theme=p;}catch(e){}})();</script>
{{if .Data.Brand.FaviconURL}}<link rel="icon" href="{{.Data.Brand.FaviconURL}}">{{end}}
<!-- htmx (self-hosted; XHR-based, covered by CSP connect-src 'self'). Used for
     progressive row-scoped swaps; every hx-* action degrades to a full POST. -->
<script src="/static/js/htmx.min.js" nonce="{{.Data.CSPNonce}}" defer></script>
<script src="/static/js/cmdk.js" nonce="{{.Data.CSPNonce}}" defer></script>
<script src="/static/js/sheet.js" nonce="{{.Data.CSPNonce}}" defer></script>
<script src="/static/js/rowactions.js" nonce="{{.Data.CSPNonce}}" defer></script>
<style>
  /* Global form-control dark-mode safety net (see install/_layout for context). */
  input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  select, textarea { color: rgb(var(--c-slate-900)); }
  .dark input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  .dark select, .dark textarea {
    background-color: rgb(var(--c-zinc-800));
    border-color: rgb(var(--c-zinc-700));
    color: rgb(var(--c-zinc-100));
  }
  .dark input::placeholder, .dark textarea::placeholder { color: rgb(var(--c-zinc-500)); }
  .hpg-nav-hover:hover { background: rgb(var(--surface-2)) !important; }
</style>
</head>
<body class="h-full" style="background:rgb(var(--bg));color:rgb(var(--text))">
<a href="#main-content" class="skip-link">Skip to content</a>
<!-- Mobile top bar (sticky, md:hidden). Brand left, burger right. -->
<div class="md:hidden sticky top-0 z-30 flex items-center justify-between px-4 py-3 ring-1" style="background:rgb(var(--surface));color:rgb(var(--text));ring-color:rgb(var(--border))">
  <span class="font-semibold tracking-tight flex items-center gap-2">
    {{if .Data.Brand.LogoURLLight}}<img src="{{.Data.Brand.LogoURLLight}}" alt="" class="h-5 dark:hidden">{{end}}
    {{if .Data.Brand.LogoURLDark}}<img src="{{.Data.Brand.LogoURLDark}}" alt="" class="h-5 hidden dark:block">{{end}}
    {{if not (or .Data.Brand.LogoURLLight .Data.Brand.LogoURLDark)}}<span class="inline-block w-2 h-2 rounded-full bg-accent" style="box-shadow:0 0 0 4px rgb(var(--accent)/.15)"></span>{{end}}
    {{if .Data.Brand.BrandName}}{{.Data.Brand.BrandName}}{{else}}Hostyt Proxy{{end}}
  </span>
  <button type="button" data-nav-toggle aria-label="Menu" class="p-1 -m-1 cursor-pointer" style="color:rgb(var(--muted))">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
</div>
<div id="nav-backdrop" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden" data-nav-close></div>
<div class="min-h-full md:pl-56">
  <aside id="admin-sidebar" class="w-56 border-r p-4 flex-col fixed inset-y-0 left-0 z-40 hidden md:flex md:flex-col overflow-y-auto" style="background:rgb(var(--surface));border-color:rgb(var(--border))">
    <div class="font-semibold text-base tracking-tight mb-6 pb-4 border-b flex items-center gap-2.5" style="border-color:rgb(var(--border))">
      {{if .Data.Brand.LogoURLLight}}<img src="{{.Data.Brand.LogoURLLight}}" alt="" class="h-6 dark:hidden">{{end}}
      {{if .Data.Brand.LogoURLDark}}<img src="{{.Data.Brand.LogoURLDark}}" alt="" class="h-6 hidden dark:block">{{end}}
      {{if not (or .Data.Brand.LogoURLLight .Data.Brand.LogoURLDark)}}<span class="inline-block w-2.5 h-2.5 rounded-full" style="background:rgb(var(--accent));box-shadow:0 0 0 4px rgb(var(--accent)/.15)"></span>{{end}}
      {{if .Data.Brand.BrandName}}{{.Data.Brand.BrandName}}{{else}}Hostyt Proxy{{end}}
    </div>
    <nav class="text-sm flex-1">
      {{if eq .Data.Role "support"}}
      <!-- Support: read-only limited view -->
      <div data-nav-group="support">
      <button type="button" class="nav-group-btn mb-1"><span class="nav-eyebrow">Read-only</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
      <div class="space-y-0.5 nav-group-body">
        <a href="/admin/map" class="nav-link {{if eq .Page "map"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          Infrastructure map
        </a>
        <a href="/admin/worldmap" class="nav-link {{if eq .Page "worldmap"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Traffic map
        </a>
        <a href="/admin/tunnels" class="nav-link {{if eq .Page "tunnels"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Tunnels (WG)
        </a>
      </div>
      </div>
      <p class="mt-4 px-3 text-xs leading-relaxed" style="color:rgb(var(--muted))">Support access is read-only and limited to assigned clients.</p>
      {{else}}
      <!-- Grouped nav: Overview / Proxy & Network / Customers / Security / Observability / Platform (AI chat = floating bubble) -->

      <!-- Overview: Dashboard, Infrastructure map, Traffic map -->
      <div data-nav-group="overview">
      <button type="button" class="nav-group-btn mb-1"><span class="nav-eyebrow">Overview</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
      <div class="space-y-0.5 nav-group-body">
        <a href="/admin" class="nav-link {{if eq .Page "dashboard"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Dashboard
        </a>
        {{if .Data.Features.Map}}<a href="/admin/map" class="nav-link {{if eq .Page "map"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          Infrastructure map
        </a>{{end}}
        {{if .Data.Features.Map}}<a href="/admin/worldmap" class="nav-link {{if eq .Page "worldmap"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Traffic map
        </a>{{end}}
      </div>
      </div>

      <!-- Proxy & Network: Hosts, Streams (L4), Certificates, Caddy nodes, Node groups, Tunnels -->
      {{if or .Data.Features.Hosts .Data.Features.Streams .Data.Features.Certs .Data.Features.Nodes .Data.Features.Tunnels}}
      <div class="mt-4 pt-4" style="border-top:1px solid rgb(var(--border))" data-nav-group="proxy">
      <button type="button" class="nav-group-btn mb-1"><span class="nav-eyebrow">Proxy &amp; Network</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
      <div class="space-y-0.5 nav-group-body">
        {{if .Data.Features.Hosts}}<a href="/admin/hosts" class="nav-link {{if eq .Page "hosts"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
          Hosts
        </a>{{end}}
        {{if .Data.Features.Streams}}<a href="/admin/streams" class="nav-link {{if eq .Page "streams"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Streams (L4)
        </a>{{end}}
        {{if .Data.Features.Certs}}<a href="/admin/certs" class="nav-link {{if eq .Page "certs"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Certificates
        </a>{{end}}
        {{if .Data.Features.Nodes}}<a href="/admin/nodes" class="nav-link {{if eq .Page "nodes"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
          Caddy nodes
        </a>{{end}}
        {{if .Data.Features.Nodes}}<a href="/admin/node-groups" class="nav-link {{if eq .Page "node_groups"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Node groups
        </a>{{end}}
        {{if .Data.Features.Tunnels}}<a href="/admin/tunnels" class="nav-link {{if eq .Page "tunnels"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Tunnels (WG)
        </a>{{end}}
      </div>
      </div>
      {{end}}

      <!-- Customers: Clients, Plans, Services -->
      {{if or .Data.Features.Clients .Data.Features.Plans .Data.Features.Services}}
      <div class="mt-4 pt-4" style="border-top:1px solid rgb(var(--border))" data-nav-group="customers">
      <button type="button" class="nav-group-btn mb-1"><span class="nav-eyebrow">Customers</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
      <div class="space-y-0.5 nav-group-body">
        {{if .Data.Features.Clients}}<a href="/admin/clients" class="nav-link {{if eq .Page "clients"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          Clients
        </a>{{end}}
        {{if .Data.Features.Plans}}<a href="/admin/plans" class="nav-link {{if eq .Page "plans"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
          Plans
        </a>{{end}}
        {{if .Data.Features.Services}}<a href="/admin/services" class="nav-link {{if eq .Page "services"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Services
        </a>{{end}}
        {{if .Data.Features.Services}}<a href="/admin/servers" class="nav-link {{if eq .Page "servers"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
          Backend servers
        </a>{{end}}
        {{if eq .Data.Role "super_admin"}}<a href="/admin/resellers" class="nav-link {{if eq .Page "resellers"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3m9-14h.01M9 7h.01M15 7h.01M12 11h.01M9 11h.01M15 11h.01M12 15h.01M9 15h.01M15 15h.01"/></svg>
          Resellers
        </a>{{end}}
      </div>
      </div>
      {{end}}

      <!-- Security: Users, WAF, mTLS, Audit, External allowlist -->
      {{if or .Data.Features.Users .Data.Features.WAF .Data.Features.Certs .Data.Features.Audit .Data.Features.ExternalAllowlist}}
      <div class="mt-4 pt-4" style="border-top:1px solid rgb(var(--border))" data-nav-group="security">
      <button type="button" class="nav-group-btn mb-1"><span class="nav-eyebrow">Security</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
      <div class="space-y-0.5 nav-group-body">
        {{if .Data.Features.Users}}<a href="/admin/users" class="nav-link {{if eq .Page "users"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          Users
        </a>{{end}}
        {{if .Data.Features.WAF}}<a href="/admin/waf" class="nav-link {{if eq .Page "waf_events"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016zM12 9v2m0 4h.01"/></svg>
          WAF
        </a>{{end}}
        {{if .Data.Features.Certs}}<a href="/admin/mtls" class="nav-link {{if eq .Page "mtls"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
          mTLS
        </a>{{end}}
        {{if .Data.Features.Audit}}<a href="/admin/audit" class="nav-link {{if eq .Page "audit"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Audit
        </a>{{end}}
        {{if .Data.Features.ExternalAllowlist}}<a href="/admin/settings/external-allowlist" class="nav-link {{if eq .Page "external_allowlist"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          External allowlist
        </a>{{end}}
        <a href="/admin/access-groups" class="nav-link {{if eq .Page "access_groups"}}is-active{{end}}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a3 3 0 10-3-3"/></svg>
          Access groups
        </a>
      </div>
      </div>
      {{end}}

      <!-- Observability: Stats, Alerts, Webhooks -->
      {{if or .Data.Features.Stats .Data.Features.Alerts}}
      <div class="mt-4 pt-4" style="border-top:1px solid rgb(var(--border))" data-nav-group="obs">
      <button type="button" class="nav-group-btn mb-1"><span class="nav-eyebrow">Observability</span><svg class="nav-chevron" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"/></svg></button>
      <div class="space-y-0.5 nav-group-body">
        {{if .Data.Features.Stats}}<a href="/admin/stats" class="nav-link {{if eq .Page "stats"}}is-active{{end}}">
