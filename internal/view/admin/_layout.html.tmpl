{{define "layout.html.tmpl"}}<!doctype html>
<html lang="en" class="h-full" data-theme="{{.Data.Theme}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="csrf-token" content="{{.Data.CSRF}}">
<title>Admin - Hostyt Proxy Gateway</title>
<link rel="stylesheet" href="/static/fonts/inter.css">
<link rel="stylesheet" href="/static/css/tailwind.css">
<link rel="stylesheet" href="/static/css/enhance.css">
<script nonce="{{.Data.CSPNonce}}">(function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');if(t==='dark')document.documentElement.classList.add('dark')})();</script>
<!-- Palette theme bootstrap: client-side pick applies before paint, even before the ui_theme cookie round-trips. -->
<script nonce="{{.Data.CSPNonce}}">(function(){try{var ok={default:1,midnight:1,ocean:1,forest:1,violet:1,sunset:1,nord:1,mono:1};var p=localStorage.getItem('ui_theme');if(p&&ok[p]&&p!==document.documentElement.dataset.theme)document.documentElement.dataset.theme=p;}catch(e){}})();</script>
{{if .Data.Brand.FaviconURL}}<link rel="icon" href="{{.Data.Brand.FaviconURL}}">{{end}}
<!-- htmx (self-hosted; XHR-based, covered by CSP connect-src 'self'). Used for
     progressive row-scoped swaps; every hx-* action degrades to a full POST. -->
<script src="/static/js/htmx.min.js" nonce="{{.Data.CSPNonce}}" defer></script>
<style>
  /* Global form-control dark-mode safety net (see install/_layout for context). */
  input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  select, textarea { color: rgb(var(--c-slate-900)); }
  .dark input:not([type=checkbox]):not([type=radio]):not([type=button]):not([type=submit]):not([type=reset]),
  .dark select, .dark textarea {
    background-color: rgb(var(--c-zinc-800));
    border-color: rgb(var(--c-zinc-700));
    color: rgb(var(--c-zinc-100));
  }
  .dark input::placeholder, .dark textarea::placeholder { color: rgb(var(--c-zinc-500)); }
</style>
</head>
<body class="h-full bg-gradient-to-b from-slate-50 via-white to-indigo-50/30 dark:from-zinc-950 dark:via-zinc-950 dark:to-zinc-900 text-slate-900 dark:text-slate-100">
<a href="#main-content" class="skip-link">Skip to content</a>
<!-- Mobile top bar (sticky, md:hidden). Brand left, burger right. -->
<div class="md:hidden sticky top-0 z-30 flex items-center justify-between bg-white dark:bg-zinc-950 text-slate-900 dark:text-white px-4 py-3 ring-1 ring-slate-200/70 dark:ring-zinc-800">
  <span class="font-semibold tracking-tight flex items-center gap-2">
    {{if .Data.Brand.LogoURLLight}}<img src="{{.Data.Brand.LogoURLLight}}" alt="" class="h-5 dark:hidden">{{end}}
    {{if .Data.Brand.LogoURLDark}}<img src="{{.Data.Brand.LogoURLDark}}" alt="" class="h-5 hidden dark:block">{{end}}
    {{if not (or .Data.Brand.LogoURLLight .Data.Brand.LogoURLDark)}}<span class="inline-block w-2 h-2 rounded-full bg-indigo-500"></span>{{end}}
    {{if .Data.Brand.BrandName}}{{.Data.Brand.BrandName}}{{else}}Hostyt Proxy{{end}}
  </span>
  <button type="button" data-nav-toggle aria-label="Menu" class="text-slate-600 dark:text-slate-300 p-1 -m-1">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
</div>
<div id="nav-backdrop" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden" data-nav-close></div>
<div class="min-h-full md:pl-56">
  <aside id="admin-sidebar" class="w-56 bg-white dark:bg-zinc-950 ring-1 ring-slate-200 dark:ring-zinc-800 text-slate-600 dark:text-slate-300 p-4 flex-col fixed inset-y-0 left-0 z-40 hidden md:flex md:flex-col overflow-y-auto">
    <div class="text-slate-900 dark:text-white font-semibold text-base tracking-tight mb-6 pb-4 border-b border-slate-200 dark:border-zinc-800 flex items-center gap-2.5">
      {{if .Data.Brand.LogoURLLight}}<img src="{{.Data.Brand.LogoURLLight}}" alt="" class="h-6 dark:hidden">{{end}}
      {{if .Data.Brand.LogoURLDark}}<img src="{{.Data.Brand.LogoURLDark}}" alt="" class="h-6 hidden dark:block">{{end}}
      {{if not (or .Data.Brand.LogoURLLight .Data.Brand.LogoURLDark)}}<span class="inline-block w-2.5 h-2.5 rounded-full bg-indigo-500 ring-4 ring-indigo-500/15"></span>{{end}}
      {{if .Data.Brand.BrandName}}{{.Data.Brand.BrandName}}{{else}}Hostyt Proxy{{end}}
    </div>
    <nav class="text-sm flex-1">
      <!-- Grouped nav. Crisp uppercase group labels + hairline dividers make sections read as distinct blocks.
           Active item = soft accent pill (font-medium + bg + ring) plus a left accent bar as a non-color cue.
           Each link keeps its href + .Page active-state key unchanged. -->
      <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-3 mb-1.5">Overview</p>
      <div class="space-y-0.5">
        <a href="/admin" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "dashboard"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Dashboard</a>
        <a href="/admin/stats" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "stats"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Statistics</a>
      </div>

      <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-3 mb-1.5 mt-5 pt-4 border-t border-slate-200/80 dark:border-zinc-800">Traffic</p>
      <div class="space-y-0.5">
        <a href="/admin/hosts" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "hosts"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Hosts</a>
        <a href="/admin/streams" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "streams"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Streams (L4)</a>
        <a href="/admin/tunnels" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "tunnels"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Tunnels (WG)</a>
        <a href="/admin/certs" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "certs"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Certificates</a>
      </div>

      <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-3 mb-1.5 mt-5 pt-4 border-t border-slate-200/80 dark:border-zinc-800">Fleet</p>
      <div class="space-y-0.5">
        <a href="/admin/nodes" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "nodes"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Caddy nodes</a>
      </div>

      <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-3 mb-1.5 mt-5 pt-4 border-t border-slate-200/80 dark:border-zinc-800">Customers</p>
      <div class="space-y-0.5">
        <a href="/admin/clients" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "clients"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Clients</a>
        <a href="/admin/plans" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "plans"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Plans</a>
        <a href="/admin/services" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "services"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Services</a>
        <a href="/admin/users" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "users"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Users</a>
      </div>

      <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-3 mb-1.5 mt-5 pt-4 border-t border-slate-200/80 dark:border-zinc-800">System</p>
      <div class="space-y-0.5">
        <a href="/admin/audit" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "audit"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Audit log</a>
        <a href="/admin/alerts" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "alerts"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Alerts</a>
        <a href="/admin/backups" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "backups"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Backups</a>
        <a href="/admin/settings" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "settings"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">Settings</a>
        <a href="/admin/settings/dns-providers" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "dns_providers"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">DNS providers</a>
        <a href="/admin/settings/external-allowlist" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "external_allowlist"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">External allowlist</a>
      </div>

      <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-3 mb-1.5 mt-5 pt-4 border-t border-slate-200/80 dark:border-zinc-800">Tools</p>
      <div class="space-y-0.5">
        <a href="/admin/tools/npm-import" class="block px-3 py-1.5 rounded-lg border-l-2 transition-colors {{if eq .Page "npm_import"}}bg-indigo-50 text-indigo-600 font-medium border-indigo-500 ring-1 ring-indigo-200 dark:bg-indigo-500/15 dark:text-indigo-300 dark:ring-indigo-500/30{{else}}border-transparent text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white{{end}}">NPM import</a>
      </div>

      <div class="mt-5 pt-4 border-t border-slate-200 dark:border-zinc-800">
        <a href="/api-docs" target="_blank" rel="noopener" class="block px-3 py-1.5 rounded-lg transition-colors text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-white">API docs ↗</a>
      </div>
    </nav>
  </aside>
  <main id="main-content" role="main" class="p-6 md:p-8 min-w-0 max-w-full overflow-x-hidden">
    <header class="sticky top-0 z-20 -mx-6 md:-mx-8 px-6 md:px-8 py-3 mb-6 min-h-[4.5rem] bg-white/70 dark:bg-zinc-950/80 backdrop-blur ring-1 ring-slate-200/70 dark:ring-zinc-800 flex items-center justify-between gap-4">
      <!-- Unified page shell: fixed-height box, single-line breadcrumb + title so it never jumps between pages. -->
      <div class="min-w-0">
        {{if .Data.Breadcrumbs}}
        <nav aria-label="Breadcrumb" class="flex items-center flex-nowrap gap-1 text-xs text-slate-500 dark:text-slate-400 mb-0.5 overflow-hidden whitespace-nowrap">
          {{range $i, $c := .Data.Breadcrumbs}}
            {{if $i}}<span class="text-slate-300 dark:text-zinc-600 shrink-0">/</span>{{end}}
            {{if $c.URL}}<a href="{{$c.URL}}" class="shrink-0 hover:text-slate-900 dark:hover:text-white transition-colors">{{$c.Label}}</a>{{else}}<span class="truncate text-slate-600 dark:text-slate-300">{{$c.Label}}</span>{{end}}
          {{end}}
        </nav>
        {{end}}
        {{if ne .Page "dashboard"}}<h1 class="text-xl md:text-2xl font-semibold tracking-tight truncate text-slate-900 dark:text-white">{{.Data.Title}}</h1>{{end}}
        {{if .Data.PageDesc}}<p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5 truncate">{{.Data.PageDesc}}</p>{{end}}
      </div>
      <div class="flex items-center gap-3 text-xs text-slate-600 dark:text-slate-300">
        <!-- Command palette trigger -->
        <button type="button" id="cmd-palette-btn"
                class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs text-slate-500 dark:text-slate-400 cursor-pointer transition-colors hover:bg-slate-100 dark:hover:bg-zinc-800 ring-1 ring-slate-200/70 dark:ring-zinc-700 font-mono"
                title="Search (Cmd+K / Ctrl+K)">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
          </svg>
          <span>Search</span>
          <kbd class="ml-1 px-1 py-0.5 rounded bg-slate-100 dark:bg-zinc-700 text-slate-400 dark:text-slate-500 text-[10px] leading-none border border-slate-200 dark:border-zinc-600">⌘K</kbd>
        </button>
        <button type="button" data-theme-toggle class="flex items-center gap-1.5 px-3 py-1.5 rounded-full cursor-pointer transition-colors hover:bg-slate-100 dark:hover:bg-zinc-800" title="Toggle theme">
          <!-- Heroicons-style moon/sun; JS toggles d.moon/d.sun visibility via the theme-icon group. -->
          <svg id="theme-icon" data-mode="moon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path data-moon stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            <g data-sun class="hidden">
              <circle cx="12" cy="12" r="4"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"/>
            </g>
          </svg>
          <span class="hidden sm:inline">Theme</span>
        </button>
        <!-- Palette switcher: navigates to /theme/{slug} (server switch) and mirrors the choice into localStorage for instant apply. -->
        <div class="relative" data-palette-menu>
          <button type="button" data-palette-toggle class="flex items-center gap-1.5 px-3 py-1.5 rounded-full cursor-pointer transition-colors hover:bg-slate-100 dark:hover:bg-zinc-800" title="Color palette" aria-haspopup="true" aria-expanded="false">
            <span class="inline-block w-3 h-3 rounded-full bg-gradient-to-br from-indigo-500 to-emerald-500 ring-1 ring-black/10"></span>
            <span class="hidden sm:inline">Palette</span>
          </button>
          <div data-palette-list class="hidden absolute right-0 mt-2 z-30 w-44 py-1.5 rounded-2xl bg-white dark:bg-zinc-900 ring-1 ring-slate-200/70 dark:ring-zinc-700 shadow-lg shadow-slate-900/10 text-sm">
            {{$cur := .Data.Theme}}
            <a href="/theme/default" data-palette-pick="default" class="flex items-center justify-between gap-2 px-3 py-1.5 text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-zinc-800 {{if eq "default" $cur}}bg-slate-100 dark:bg-zinc-800 font-medium{{end}}"><span>Slate (default)</span>{{if eq "default" $cur}}<svg class="w-3.5 h-3.5 text-indigo-600 dark:text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/midnight" data-palette-pick="midnight" class="flex items-center justify-between gap-2 px-3 py-1.5 text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-zinc-800 {{if eq "midnight" $cur}}bg-slate-100 dark:bg-zinc-800 font-medium{{end}}"><span>Midnight</span>{{if eq "midnight" $cur}}<svg class="w-3.5 h-3.5 text-indigo-600 dark:text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/ocean" data-palette-pick="ocean" class="flex items-center justify-between gap-2 px-3 py-1.5 text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-zinc-800 {{if eq "ocean" $cur}}bg-slate-100 dark:bg-zinc-800 font-medium{{end}}"><span>Ocean</span>{{if eq "ocean" $cur}}<svg class="w-3.5 h-3.5 text-indigo-600 dark:text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/forest" data-palette-pick="forest" class="flex items-center justify-between gap-2 px-3 py-1.5 text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-zinc-800 {{if eq "forest" $cur}}bg-slate-100 dark:bg-zinc-800 font-medium{{end}}"><span>Forest</span>{{if eq "forest" $cur}}<svg class="w-3.5 h-3.5 text-indigo-600 dark:text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
            <a href="/theme/violet" data-palette-pick="violet" class="flex items-center justify-between gap-2 px-3 py-1.5 text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-zinc-800 {{if eq "violet" $cur}}bg-slate-100 dark:bg-zinc-800 font-medium{{end}}"><span>Violet</span>{{if eq "violet" $cur}}<svg class="w-3.5 h-3.5 text-indigo-600 dark:text-indigo-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{{end}}</a>
