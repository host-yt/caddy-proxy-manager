{{define "legal"}}
<div class="space-y-6">
  <p class="text-sm text-slate-600 dark:text-slate-300">
    Documents below are served publicly at <code>/legal/&lt;slug&gt;</code>. Customers see them rendered as plain text; markdown is preserved as written.
  </p>
  {{range .Docs}}
  <section class="hpg-card">
    <form method="POST" action="/admin/legal/save" class="space-y-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <input type="hidden" name="slug" value="{{.Slug}}">
      <div class="flex items-center justify-between">
        <h3 class="font-semibold text-slate-800 dark:text-slate-100">
          /legal/{{.Slug}}
          <a href="/legal/{{.Slug}}" target="_blank" class="text-xs text-indigo-700 dark:text-indigo-400 hover:underline ml-2">view public →</a>
        </h3>
        {{if .UpdatedAt}}<span class="hpg-pill hpg-pill-muted">updated {{.UpdatedAt}}</span>{{end}}
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Title</label>
        <input name="title" value="{{.Title}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 dark:text-slate-100 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Body (markdown/plaintext)</label>
        <textarea name="body" rows="14" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 dark:text-slate-100 focus:ring-2 focus:ring-indigo-500 font-mono text-xs">{{.Body}}</textarea>
      </div>
      <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Save {{.Slug}}</button>
    </form>
  </section>
  {{end}}
</div>
{{end}}
