{{define "legal"}}
<div class="space-y-6">
  <p class="t-small" style="color:rgb(var(--muted))">
    Documents below are served publicly at <code>/legal/&lt;slug&gt;</code>. Customers see them rendered as plain text; markdown is preserved as written.
  </p>
  {{range .Docs}}
  <section class="r-card">
    <form method="POST" action="/admin/legal/save" class="space-y-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <input type="hidden" name="slug" value="{{.Slug}}">
      <div class="flex items-center justify-between">
        <h3 class="t-h3" style="color:rgb(var(--text))">
          /legal/{{.Slug}}
          <a href="/legal/{{.Slug}}" target="_blank" class="t-small ml-2 hover:underline" style="color:rgb(var(--accent))">view public →</a>
        </h3>
        {{if .UpdatedAt}}<span class="r-pill r-pill-neutral">updated {{.UpdatedAt}}</span>{{end}}
      </div>
      <div>
        <label class="block t-small mb-1" style="color:rgb(var(--muted))">Title</label>
        <input name="title" value="{{.Title}}" class="r-input w-full">
      </div>
      <div>
        <label class="block t-small mb-1" style="color:rgb(var(--muted))">Body (markdown/plaintext)</label>
        <textarea name="body" rows="14" class="r-input w-full font-mono text-xs">{{.Body}}</textarea>
      </div>
      <button class="r-btn-primary">Save {{.Slug}}</button>
    </form>
  </section>
  {{end}}
</div>
{{end}}
