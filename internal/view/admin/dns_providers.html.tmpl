{{define "dns_providers"}}
<div class="space-y-6">

  {{if not .DNS01Available}}
  <div class="rounded-xl p-4 text-sm" style="background:rgb(var(--warning) / .1);border:1px solid rgb(var(--warning) / .3);color:rgb(var(--warning))">
    <strong>DNS-01 is not enabled on this build.</strong> Wildcard policies will not be emitted until every node runs the custom Caddy image (with the <code>caddy-dns/*</code> modules) and <code>DNS01_AVAILABLE=1</code> is set. Flipping it on while a node runs stock Caddy makes that node reject the whole config and drop all its routes.
  </div>
  {{end}}

  <section class="r-card p-0 overflow-hidden">
    <div class="p-5" style="border-bottom:1px solid rgb(var(--border))">
      <h2 class="t-h3" style="color:rgb(var(--text))">DNS providers (wildcard certificates)</h2>
      <p class="t-small mt-1" style="color:rgb(var(--muted))">Per-zone credentials for ACME DNS-01 wildcard issuance (<code>*.zone</code>). Credentials are stored encrypted at rest and are never shown again. Use the most narrowly-scoped token your provider supports (e.g. for Cloudflare a <strong>zone-scoped</strong> token with <em>Zone:Read + DNS:Edit</em> on the target zone only).</p>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table w-full text-sm">
        <thead>
          <tr>
            <th>Zone</th>
            <th>Provider</th>
            <th>Credential</th>
            <th>Created</th>
            <th class="text-right"></th>
          </tr>
        </thead>
        <tbody>
          {{range .Providers}}
          <tr>
            <td class="font-medium"><code>{{.Name}}</code></td>
            <td>{{.Provider}}</td>
            <td>{{if .HasToken}}<span class="r-pill r-pill-success">set</span>{{else}}<span class="r-pill r-pill-neutral">not set</span>{{end}}</td>
            <td class="t-small tabular-nums" style="color:rgb(var(--muted))">{{.Created}}</td>
            <td class="text-right">
              <form method="POST" action="/admin/settings/dns-providers/{{.ID}}/delete" class="inline" data-confirm="Delete DNS provider for {{.Name}}?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button class="t-small cursor-pointer hover:underline" style="color:rgb(var(--danger))">delete</button>
              </form>
            </td>
          </tr>
          {{else}}
          <tr><td colspan="5" class="px-4 py-6 text-center" style="color:rgb(var(--muted))">No DNS providers configured.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

  <section class="r-card">
    <h2 class="t-h3 mb-3" style="color:rgb(var(--text))">Add / rotate provider</h2>
    <form method="POST" action="/admin/settings/dns-providers" class="space-y-3 text-sm max-w-2xl">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block t-small mb-1" style="color:rgb(var(--muted))">Zone (apex)</label>
          <input name="name" required placeholder="customer.com" class="r-input w-full font-mono text-xs">
        </div>
        <div>
          <label class="block t-small mb-1" style="color:rgb(var(--muted))">Provider</label>
          <select id="dns-provider-select" name="provider" class="r-select w-full">
            {{range .Registry}}<option value="{{.Slug}}">{{.DisplayName}}</option>{{end}}
          </select>
        </div>
      </div>
      <!-- Per-provider credential inputs injected here by the nonce'd handler below. -->
      <div id="dns-fields" class="space-y-3"></div>
      <p class="t-caption" style="color:rgb(var(--muted))">Re-saving an existing zone rotates its credentials. Credentials are never displayed after saving.</p>
      <button class="r-btn-primary">Save provider</button>
    </form>
  </section>

  <script nonce="{{.CSPNonce}}">
  (function () {
    // Registry schema (slug -> fields); no credentials, only input metadata.
    var REG = {{.RegistryJSON}};
    var sel = document.getElementById('dns-provider-select');
    var box = document.getElementById('dns-fields');
    if (!sel || !box) return;
    function render() {
      var fields = REG[sel.value] || [];
      box.textContent = '';
      fields.forEach(function (f) {
        var wrap = document.createElement('div');
        var lab = document.createElement('label');
        lab.className = 'block t-small mb-1';
        lab.style.color = 'rgb(var(--muted))';
        lab.textContent = f.label + (f.optional ? ' (optional)' : '');
        var inp = document.createElement('input');
        inp.name = 'field_' + f.key;
        inp.type = f.secret ? 'password' : 'text';
        inp.autocomplete = 'off';
        if (f.placeholder) inp.placeholder = f.placeholder;
        if (!f.optional) inp.required = true;
        inp.className = 'r-input w-full font-mono text-xs';
        wrap.appendChild(lab);
        wrap.appendChild(inp);
        box.appendChild(wrap);
      });
    }
    sel.addEventListener('change', render);
    render();
  })();
  </script>
</div>
{{end}}
