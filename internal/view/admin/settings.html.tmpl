          <div class="text-xs text-slate-500 dark:text-slate-400">Simple Transactional API. App ID + token, no server setup.</div>
        </button>
        <button type="button" data-sms-card="twilio"
          class="sms-provider-card text-left rounded-lg border-2 p-3 transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">
          <div class="font-semibold text-slate-800 dark:text-slate-100 mb-0.5">Twilio</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">Account SID + Auth Token. Verified sender phone or alphanumeric ID.</div>
        </button>
        <button type="button" data-sms-card="smsapi"
          class="sms-provider-card text-left rounded-lg border-2 p-3 transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">
          <div class="font-semibold text-slate-800 dark:text-slate-100 mb-0.5">SMSAPI.pl</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">OAuth Bearer token. EU-based gateway, Polish-market oriented.</div>
        </button>
        <button type="button" data-sms-card="webhook"
          class="sms-provider-card text-left rounded-lg border-2 p-3 transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">
          <div class="font-semibold text-slate-800 dark:text-slate-100 mb-0.5">Generic webhook</div>
          <div class="text-xs text-slate-500 dark:text-slate-400">HTTP POST to any gateway. Payload: to, from, message fields.</div>
