  <section data-settings-pane="email" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-3">SMTP</h2>
    <form method="POST" action="/admin/settings/smtp" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Host</label>
        <input name="host" value="{{.SMTP.Host}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Port</label>
        <input name="port" type="number" min="1" max="65535" value="{{.SMTP.Port}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Encryption</label>
        <select name="encryption" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
          <option value="tls" {{if eq .SMTP.Encryption "tls"}}selected{{end}}>STARTTLS</option>
          <option value="ssl" {{if eq .SMTP.Encryption "ssl"}}selected{{end}}>SSL/TLS</option>
          <option value="none" {{if eq .SMTP.Encryption "none"}}selected{{end}}>None</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Username</label>
        <input name="username" value="{{.SMTP.Username}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Password {{if .SMTP.HasPassword}}<span class="text-emerald-700 dark:text-emerald-400">(saved)</span>{{end}}</label>
        <input name="password" type="password" placeholder="{{if .SMTP.HasPassword}}leave blank to keep{{end}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">From email</label>
        <input name="from_email" type="email" value="{{.SMTP.FromEmail}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">From name</label>
        <input name="from_name" value="{{.SMTP.FromName}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="sm:col-span-2 flex flex-wrap justify-end gap-2 pt-2">
        <button name="action" value="test" class="px-3 py-2 rounded-lg border border-slate-300 dark:border-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm">Send test email</button>
        <button name="action" value="save" class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save SMTP</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="auth" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-3">OIDC / Single sign-on</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">Works with Authentik, Microsoft Entra ID, and any standards-compliant OIDC provider.</p>
    <form id="oidc-form" method="POST" action="/admin/settings/oidc" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="enabled" value="1" {{if .OIDC.Enabled}}checked{{end}}> Enable OIDC sign-in button on the login page</label>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Provider display name</label>
        <input name="provider_name" value="{{.OIDC.ProviderName}}" placeholder="Authentik" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Label for the login button, e.g. "Sign in with Authentik".</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Default role for new users</label>
        <select name="default_role" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
          <option value="support" {{if eq .OIDC.DefaultRole "support"}}selected{{end}}>support</option>
          <option value="admin" {{if eq .OIDC.DefaultRole "admin"}}selected{{end}}>admin</option>
          <option value="client" {{if eq .OIDC.DefaultRole "client"}}selected{{end}}>client</option>
        </select>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">"admin" + auto-provision is refused for safety.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Issuer URL</label>
        <input id="oidc-issuer" name="issuer" value="{{.OIDC.Issuer}}" placeholder="https://authentik.example.com/application/o/hostyt/" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">In Authentik: Application → Provider → "OpenID Configuration Issuer". Paste the base URL, not <code class="text-xs">/.well-known/openid-configuration</code>.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Client ID</label>
        <input name="client_id" value="{{.OIDC.ClientID}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Client secret {{if .OIDC.HasSecret}}<span class="text-emerald-700 dark:text-emerald-400">(saved, encrypted)</span>{{end}}</label>
        <input name="client_secret" type="password" autocomplete="new-password" placeholder="{{if .OIDC.HasSecret}}leave blank to keep{{end}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        {{if .OIDC.HasSecret}}<label class="flex items-center gap-2 mt-1 text-xs text-rose-700 dark:text-rose-400"><input type="checkbox" name="clear_secret" value="1"> Clear stored secret on save</label>{{end}}
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Redirect URL <span class="text-slate-400">(configure this exact URL on the IdP side)</span></label>
        <div class="flex gap-2">
          <input id="oidc-redirect" name="redirect_url" value="{{.OIDC.RedirectURL}}" placeholder="{{.OIDC.DefaultRedirect}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
          <button type="button" data-oidc-fill-redirect data-redirect="{{.OIDC.DefaultRedirect}}" class="shrink-0 px-3 py-2 rounded-lg border border-slate-300 dark:border-zinc-700 text-xs hover:bg-slate-50 dark:hover:bg-zinc-800">Use default</button>
        </div>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Leave blank to auto-fill from APP_URL on save.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Scopes (space-separated; <code class="text-xs">openid</code> always included)</label>
        <input name="scopes" value="{{.OIDC.Scopes}}" placeholder="openid email profile" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Add <code class="text-xs">groups</code> only when your IdP exposes a groups claim you actually map.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="auto_provision" value="1" {{if .OIDC.AutoProvision}}checked{{end}}> Auto-create local account on first OIDC login</label>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Off = admin must pre-create matching email accounts. Existing local users with the same email are linked automatically on first SSO sign-in either way.</p>
      </div>
      <div class="sm:col-span-2 border-t border-slate-200 dark:border-zinc-800 pt-3">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200">
          <input type="checkbox" name="password_login_disabled" value="1" {{if .OIDC.PasswordLoginDisabled}}checked{{end}}>
          <strong>SSO-only mode</strong> - disable password login for all non-admin users (superadmins can always sign in with password as failsafe)
        </label>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">When enabled, the login form is hidden and only the SSO button is shown. Enable only after verifying OIDC works.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200">
          <input type="checkbox" name="allow_unverified_email" value="1" {{if .OIDC.AllowUnverifiedEmail}}checked{{end}}>
          Allow unverified email from IdP
        </label>
        <p class="text-[11px] text-amber-700 dark:text-amber-400 mt-1">By default panel refuses login when the ID token says <code>email_verified: false</code>. Enable ONLY when your IdP (e.g. Authentik tied to corporate AD/LDAP) guarantees email ownership in some other way. Public-signup IdPs without this gate let anyone register <code>victim@yourdomain</code> and take over the matching local account.</p>
      </div>
      <div class="sm:col-span-2 flex flex-wrap items-center justify-between gap-2 pt-2">
        <button type="button" id="oidc-test-btn" class="px-3 py-2 rounded-lg border border-slate-300 dark:border-zinc-700 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-zinc-800 text-sm">Test discovery</button>
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save OIDC</button>
      </div>
      <div id="oidc-test-result" class="sm:col-span-2 hidden text-xs"></div>
    </form>
  </section>

  <section data-settings-pane="auth" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-3">Social login (GitHub, Google)</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Plain OAuth2 sign-in that runs alongside OIDC. Create an OAuth app on each provider, then paste its client id + secret. The secret is stored encrypted at rest.</p>
    <div class="space-y-6">
      {{range .OAuthProviders}}
      <form method="POST" action="/admin/settings/oauth-provider/{{.Provider}}" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm border-t border-slate-200 dark:border-zinc-800 pt-4 first:border-0 first:pt-0">
        <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
        <div class="sm:col-span-2 flex items-center gap-2">
          {{if eq .Provider "github"}}
          <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          {{else if eq .Provider "google"}}
          <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          {{end}}
          <h3 class="font-medium text-slate-800 dark:text-slate-100">{{.Label}}</h3>
        </div>
        <div class="sm:col-span-2">
          <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="enabled" value="1" {{if .Enabled}}checked{{end}}> Show "Sign in with {{.Label}}" on the login page</label>
        </div>
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Client ID</label>
          <input name="client_id" value="{{.ClientID}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
        </div>
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Client secret {{if .HasSecret}}<span class="text-emerald-700 dark:text-emerald-400">(saved, encrypted)</span>{{end}}</label>
          <input name="client_secret" type="password" autocomplete="new-password" placeholder="{{if .HasSecret}}leave blank to keep{{end}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
          {{if .HasSecret}}<label class="flex items-center gap-2 mt-1 text-xs text-rose-700 dark:text-rose-400"><input type="checkbox" name="clear_secret" value="1"> Clear stored secret on save</label>{{end}}
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Authorization callback URL <span class="text-slate-400">(set this exact URL on the provider)</span></label>
          <input value="{{.DefaultRedirect}}" readonly class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-100 dark:bg-zinc-800 text-slate-500 font-mono">
        </div>
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Extra scopes (space-separated)</label>
          <input name="scopes" value="{{.Scopes}}" placeholder="optional" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
          <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">Email + profile scopes are always requested.</p>
        </div>
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Default role for new users</label>
          <select name="default_role" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
            <option value="support" {{if eq .DefaultRole "support"}}selected{{end}}>support</option>
            <option value="client" {{if eq .DefaultRole "client"}}selected{{end}}>client</option>
          </select>
          <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">admin role is never auto-provisioned via social login.</p>
        </div>
        <div class="sm:col-span-2">
          <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="auto_provision" value="1" {{if .AutoProvision}}checked{{end}}> Auto-create a local account on first {{.Label}} login (verified email only)</label>
        </div>
        <div class="sm:col-span-2 flex justify-end pt-1">
          <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm cursor-pointer transition-colors">Save {{.Label}}</button>
        </div>
      </form>
      {{end}}
    </div>
  </section>

  <section data-settings-pane="captcha" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Cloudflare Turnstile (CAPTCHA)</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">Free, privacy-respecting CAPTCHA. Get keys from Cloudflare dashboard → Turnstile.</p>
    <form method="POST" action="/admin/settings/turnstile" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="enabled" value="1" {{if .Turnstile.Enabled}}checked{{end}}> Require Turnstile on login</label>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Site key (public)</label>
        <input name="site_key" value="{{.Turnstile.SiteKey}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Secret key {{if .Turnstile.HasSecret}}<span class="text-emerald-700 dark:text-emerald-400">(saved)</span>{{end}}</label>
        <input name="secret" type="password" placeholder="{{if .Turnstile.HasSecret}}leave blank to keep{{end}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="sm:col-span-2 flex justify-end pt-2">
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save Turnstile</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="cloudflare" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Cloudflare account</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">API token + account ID. Token is verified against Cloudflare on save.</p>
    <form method="POST" action="/admin/settings/cloudflare" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="enabled" value="1" {{if .Cloudflare.Enabled}}checked{{end}}> Cloudflare integration enabled</label>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Account ID</label>
        <input name="account_id" value="{{.Cloudflare.AccountID}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">API token {{if .Cloudflare.HasToken}}<span class="text-emerald-700 dark:text-emerald-400">(saved)</span>{{end}}</label>
        <input name="api_token" type="password" placeholder="{{if .Cloudflare.HasToken}}leave blank to keep{{end}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="trust_connecting_ip" value="1" {{if .Cloudflare.TrustConnectingIP}}checked{{end}}> Trust <code class="text-xs bg-slate-100 dark:bg-zinc-800 px-1 rounded">CF-Connecting-IP</code> header (only when this app sits behind Cloudflare)</label>
      </div>
      <div class="sm:col-span-2 flex justify-end pt-2">
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Verify token &amp; save</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="ai" class="hpg-settings-pane hidden hpg-card">
    <div class="flex items-center gap-2 mb-1">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600 dark:bg-indigo-950 dark:text-indigo-300">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
      </span>
      <h2 class="font-semibold text-slate-800 dark:text-slate-100">AI assistant</h2>
    </div>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">Configure an LLM provider for the in-app assistant. API keys are stored AES-256-GCM encrypted at rest and never shown again - leave a field blank to keep the existing key. Use <strong>Test</strong> to verify a saved key with a minimal request.</p>
    <form method="POST" action="/admin/settings/ai" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Default provider</label>
        <select name="default_provider" class="w-full sm:w-72 px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
          <option value="" {{if eq .AI.DefaultProvider ""}}selected{{end}}>- none -</option>
          {{range .AI.Providers}}
          <option value="{{.ID}}" {{if eq $.AI.DefaultProvider .ID}}selected{{end}}>{{.Label}}</option>
          {{end}}
        </select>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">The assistant uses this provider's key unless overridden.</p>
      </div>

      <div class="grid grid-cols-1 gap-3">
        {{range .AI.Providers}}
        <div class="rounded-lg ring-1 ring-slate-200/70 dark:ring-zinc-800 p-3">
          <div class="flex items-center justify-between mb-2">
            <span class="font-medium text-slate-700 dark:text-slate-200">{{.Label}}</span>
            {{if .Configured}}
            <span class="text-[11px] px-1.5 py-0.5 rounded bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300">Key configured</span>
            {{else}}
            <span class="text-[11px] px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 dark:bg-zinc-800 dark:text-slate-400">Not set</span>
            {{end}}
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2">
            <input name="key_{{.ID}}" type="password" autocomplete="new-password" placeholder="{{if .Configured}}leave blank to keep{{else}}paste API key{{end}}" class="flex-1 px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
            <button type="button" data-ai-test="{{.ID}}" class="px-3 py-2 rounded-lg ring-1 ring-slate-300 dark:ring-zinc-600 text-xs hover:bg-slate-100 dark:hover:bg-zinc-800 cursor-pointer transition-colors whitespace-nowrap">Test key</button>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2 mt-2">
            <label class="block text-xs text-slate-600 dark:text-slate-300 sm:w-16 shrink-0">Model</label>
            <select name="model_{{.ID}}" data-ai-model="{{.ID}}" data-ai-model-saved="{{.Model}}" class="flex-1 px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 text-xs">
              <option value="" {{if eq .Model ""}}selected{{end}}>Default ({{if eq .ID "anthropic"}}claude-3-5-haiku-latest{{else if eq .ID "openai"}}gpt-4o-mini{{else if eq .ID "gemini"}}gemini-1.5-flash{{else}}openai/gpt-4o-mini{{end}})</option>
              {{if .Model}}<option value="{{.Model}}" selected>{{.Model}}</option>{{end}}
            </select>
            <button type="button" data-ai-models-refresh="{{.ID}}" class="px-3 py-2 rounded-lg ring-1 ring-slate-300 dark:ring-zinc-600 text-xs hover:bg-slate-100 dark:hover:bg-zinc-800 cursor-pointer transition-colors whitespace-nowrap">Refresh models</button>
          </div>
          {{if .Configured}}<label class="flex items-center gap-2 mt-2 text-xs text-rose-700 dark:text-rose-400"><input type="checkbox" name="clear_{{.ID}}" value="1"> Remove stored key on save</label>{{end}}
          <p data-ai-models-status="{{.ID}}" class="hidden mt-2 text-xs"></p>
          <p data-ai-test-result="{{.ID}}" class="hidden mt-2 text-xs"></p>
        </div>
        {{end}}
      </div>

      <div class="flex justify-end pt-1">
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm cursor-pointer transition-colors">Save AI settings</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="wireguard" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">WireGuard (multi-node mesh)</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">Required for one-command node join. Auto-generates a keypair on first save.</p>
    <form method="POST" action="/admin/settings/wireguard" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="enabled" value="1" {{if .WireGuard.Enabled}}checked{{end}}> Multi-node mode enabled</label>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Public endpoint (host:port - what new nodes will dial)</label>
        <input name="endpoint" value="{{.WireGuard.Endpoint}}" placeholder="manager.example.com:51820" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Listen port (UDP)</label>
        <input name="listen_port" type="number" value="{{.WireGuard.ListenPort}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Overlay subnet</label>
        <input name="subnet" value="{{.WireGuard.Subnet}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Control plane IP</label>
        <input name="control_ip" value="{{.WireGuard.ControlIP}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
      </div>
      {{if .WireGuard.PublicKey}}
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Control plane public key (given to joining nodes automatically)</label>
        <code class="block bg-slate-50 dark:bg-zinc-800 p-2 rounded-lg text-xs break-all font-mono text-slate-800 dark:text-slate-100 dark:text-slate-200">{{.WireGuard.PublicKey}}</code>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Private key {{if .WireGuard.HasPrivate}}<span class="text-emerald-700 dark:text-emerald-400">stored AES-256-GCM encrypted</span>{{else}}<span class="text-rose-700 dark:text-rose-400">not generated yet</span>{{end}}.</p>
      </div>
      {{end}}
      <div class="sm:col-span-2 flex justify-end pt-2">
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save WireGuard (generates keypair)</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="acme" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-3">ACME / Let's Encrypt</h2>
    <form method="POST" action="/admin/settings/acme" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">ACME contact email</label>
        <input name="email" type="email" required value="{{.ACME.Email}}" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Used as the registration contact for Let's Encrypt.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200"><input type="checkbox" name="staging" value="1" {{if .ACME.Staging}}checked{{end}}> Use Let's Encrypt staging directory</label>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Enable while testing to avoid burning production rate limits. Issued certs will not be trusted by browsers.</p>
      </div>
      <div class="sm:col-span-2 flex justify-end pt-2">
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save ACME</button>
      </div>
    </form>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-3">Changes take effect on the next Caddy push (next route create/delete or node resync).</p>
  </section>

  <section data-settings-pane="mtls" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Mutual TLS (mTLS) enforcement</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Controls how Caddy behaves when a client-cert is required on a route but no valid certificate is presented. Changes take effect on the next Caddy push.</p>
    <form method="POST" action="/admin/settings/mtls" class="space-y-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200 cursor-pointer">
        <input type="checkbox" name="mtls_fail_open" value="1" {{if .MTLSFailOpen}}checked{{end}}>
        Fail open - allow traffic even when no client certificate is presented
      </label>
      <p class="text-xs text-slate-500 dark:text-slate-400">When unchecked (default): Caddy uses <code>require_and_verify</code> - the TLS handshake is rejected if no valid client cert is presented. When checked: Caddy uses <code>request</code> - the cert is optional and traffic proceeds regardless.</p>
      <div class="flex justify-end">
        <button class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 cursor-pointer transition-colors">Save</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="analytics" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Analytics retention</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Controls automatic pruning of aggregated traffic rollup data.</p>
    <form method="POST" action="/admin/settings/analytics" id="form-analytics">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Rollup retention (days)</label>
          <input type="number" name="rollup_retention_days" value="{{.RollupRetentionDays}}"
                 min="0" max="3650"
                 placeholder="0 (keep forever)"
                 class="w-full max-w-xs px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 text-sm">
          <p class="mt-1 text-xs text-slate-500">log_rollups rows older than N days are deleted hourly. 0 = keep forever.</p>
        </div>
      </div>
      <div class="flex justify-end pt-4">
        <button type="submit" form="form-analytics"
                class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer">Save</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="failover" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Auto failover</h2>
    <form method="POST" action="/admin/settings/failover" id="form-failover">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" name="auto_failover_enabled" value="1"
               {{if .AutoFailoverEnabled}}checked{{end}}
               class="w-4 h-4 rounded text-indigo-600">
        <span class="text-sm font-medium">Enable automatic route failover</span>
      </label>
      <p class="text-xs text-slate-500 mt-2">When enabled, routes on a dead node move to a healthy sibling in the same failover node group. Requires node groups with mode=failover.</p>
      <div class="flex justify-end pt-4">
        <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer">Save</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="alerts" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Alert thresholds</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Override the default alert thresholds at runtime without restart. Leave a field as-is to keep its current value.</p>
    <form method="POST" action="/admin/settings/alert" id="form-alerts" class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Node offline threshold (minutes)</label>
        <input name="node_offline_min" type="number" min="1" value="{{.AlertNodeOfflineMin}}"
               class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="mt-1 text-[11px] text-slate-400">Node must be unhealthy for at least this many minutes before alerting.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Cert stuck threshold (minutes)</label>
        <input name="cert_stuck_min" type="number" min="1" value="{{.AlertCertStuckMin}}"
               class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="mt-1 text-[11px] text-slate-400">Minutes a cert may stay in pending_ssl before firing a "cert failing" alert.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Alert cooldown (seconds)</label>
        <input name="cooldown_sec" type="number" min="60" value="{{.AlertCooldownSec}}"
               class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="mt-1 text-[11px] text-slate-400">Minimum seconds between repeated fires of the same rule and label combination.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Manual cert expiry warn (days)</label>
        <input name="manual_cert_days_warn" type="number" min="1" value="{{.AlertManualCertDaysWarn}}"
               class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="mt-1 text-[11px] text-slate-400">Days before expiry to alert for manually imported certificates.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Error rate threshold (0.01 - 1)</label>
        <input name="error_rate_pct" type="number" step="0.01" min="0.01" max="1" value="{{.AlertErrorRatePct}}"
               class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="mt-1 text-[11px] text-slate-400">5xx ratio (fraction of 1) within the window that triggers a high-error-rate alert.</p>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Error rate window (minutes)</label>
        <input name="error_rate_window_min" type="number" min="1" value="{{.AlertErrorRateWindowMin}}"
               class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
        <p class="mt-1 text-[11px] text-slate-400">Rolling window size used by the high-error-rate calculation.</p>
      </div>
      <div class="sm:col-span-2 flex justify-end pt-2">
        <button type="submit" form="form-alerts"
                class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer">Save thresholds</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="geoip" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">GeoIP database (MaxMind GeoLite2)</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Enter your free MaxMind account ID + license key. The panel downloads GeoLite2-Country daily and distributes it to every Caddy node over the tunnel, so per-route country blocking works without manual file placement.</p>

    <form method="POST" action="/admin/settings/geoip" class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">MaxMind account ID</label>
        <input name="account_id" type="text" value="{{.GeoIP.AccountID}}" autocomplete="off" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">License key {{if .GeoIP.Configured}}<span class="text-emerald-600">(configured)</span>{{end}}</label>
        <input name="license_key" type="password" placeholder="{{if .GeoIP.Configured}}leave blank to keep current{{else}}paste license key{{end}}" autocomplete="new-password" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="sm:col-span-2 flex justify-end pt-2">
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save GeoIP credentials</button>
      </div>
    </form>

    <div class="mt-4 pt-4 border-t border-slate-200 dark:border-zinc-700 text-xs text-slate-600 dark:text-slate-300">
      <div class="flex items-center gap-2 mb-3">
        <p class="font-medium text-slate-700 dark:text-slate-200">Current database</p>
        {{if .GeoIP.Available}}
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Active
          </span>
        {{else}}
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-100 text-amber-700 dark:bg-amber-500/15 dark:text-amber-300">
            Not loaded
          </span>
        {{end}}
      </div>
      {{if .GeoIP.FetchedAt}}
        <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
          <dt class="text-slate-500 dark:text-slate-400">Fetched</dt>
          <dd>{{.GeoIP.FetchedAt}}</dd>
          <dt class="text-slate-500 dark:text-slate-400">Size</dt>
          <dd>{{.GeoIP.SizeHuman}}</dd>
          <dt class="text-slate-500 dark:text-slate-400">SHA-256</dt>
          <dd class="font-mono break-all">{{.GeoIP.SHA256Short}}…</dd>
        </dl>
        {{if not .GeoIP.Available}}
          <p class="mt-2 text-amber-600 dark:text-amber-400">File downloaded but not yet loaded - restart the panel or trigger a refresh.</p>
        {{end}}
      {{else}}
        <p class="text-slate-500 dark:text-slate-400">No database downloaded yet. Save credentials and click "Refresh database now".</p>
      {{end}}
      {{if .GeoIP.LastError}}
      <div class="mt-2 rounded-lg bg-rose-50 dark:bg-rose-900/20 px-3 py-2">
        <p class="text-[10px] uppercase tracking-wide text-rose-600 dark:text-rose-400 mb-1">Last refresh failed{{if .GeoIP.LastAttempt}} ({{.GeoIP.LastAttempt}}){{end}}</p>
        <p class="font-mono text-rose-700 dark:text-rose-300 break-all">{{.GeoIP.LastError}}</p>
      </div>
      {{end}}
      <form method="POST" action="/admin/settings/geoip/refresh" class="mt-3">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button {{if not .GeoIP.Configured}}disabled{{end}} class="px-3 py-2 rounded-lg ring-1 ring-slate-300 dark:ring-zinc-600 text-sm hover:bg-slate-100 dark:hover:bg-zinc-800 disabled:opacity-50 disabled:cursor-not-allowed">Refresh database now</button>
      </form>
    </div>
  </section>

  <section data-settings-pane="sms" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">SMS provider</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Used for security alerts and (optionally) 2FA SMS fallback. Pick a gateway below - only its fields will be shown.</p>

    <form method="POST" action="/admin/settings/sms" class="text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <!-- sms_provider value is kept in sync by the card-picker JS below -->
      <input type="hidden" id="sms_provider_input" name="sms_provider" value="{{if .SMS.Provider}}{{.SMS.Provider}}{{else}}bulkgate{{end}}">

      <!-- Enable toggle -->
      <div class="mb-4">
        <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200">
          <input type="checkbox" name="enabled" value="1" {{if .SMS.Enabled}}checked{{end}}>
