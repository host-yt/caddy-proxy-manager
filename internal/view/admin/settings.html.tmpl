  <!-- ── SMTP ──────────────────────────────────────────────── -->
  <section data-settings-pane="email" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Delivery</p>
    <h2 class="t-h3 mb-3">SMTP</h2>

    <!-- Preset cards - JS-only convenience, no hidden field needed -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2 mb-4" id="smtp-preset-cards">
      <button type="button" class="smtp-preset-card text-left rounded-xl border p-3 cursor-pointer transition" data-smtp-preset="custom" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
        <span class="block text-sm font-medium" style="color:rgb(var(--text))">Custom</span>
        <span class="block t-caption" style="color:rgb(var(--muted))">Enter manually</span>
      </button>
      <button type="button" class="smtp-preset-card text-left rounded-xl border p-3 cursor-pointer transition" data-smtp-preset="gmail" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
        <span class="block text-sm font-medium" style="color:rgb(var(--text))">Gmail</span>
        <span class="block t-caption" style="color:rgb(var(--muted))">smtp.gmail.com:587</span>
      </button>
      <button type="button" class="smtp-preset-card text-left rounded-xl border p-3 cursor-pointer transition" data-smtp-preset="microsoft365" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
        <span class="block text-sm font-medium" style="color:rgb(var(--text))">Microsoft 365</span>
        <span class="block t-caption" style="color:rgb(var(--muted))">smtp.office365.com:587</span>
      </button>
      <button type="button" class="smtp-preset-card text-left rounded-xl border p-3 cursor-pointer transition" data-smtp-preset="sendgrid" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
        <span class="block text-sm font-medium" style="color:rgb(var(--text))">SendGrid</span>
        <span class="block t-caption" style="color:rgb(var(--muted))">smtp.sendgrid.net:587</span>
      </button>
      <button type="button" class="smtp-preset-card text-left rounded-xl border p-3 cursor-pointer transition" data-smtp-preset="brevo" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
        <span class="block text-sm font-medium" style="color:rgb(var(--text))">Brevo</span>
        <span class="block t-caption" style="color:rgb(var(--muted))">smtp-relay.brevo.com:587</span>
      </button>
      <button type="button" class="smtp-preset-card text-left rounded-xl border p-3 cursor-pointer transition" data-smtp-preset="mailgun" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
        <span class="block text-sm font-medium" style="color:rgb(var(--text))">Mailgun</span>
        <span class="block t-caption" style="color:rgb(var(--muted))">smtp.mailgun.org:587</span>
      </button>
    </div>

    <form method="POST" action="/admin/settings/smtp" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Host</label>
        <input name="host" id="smtp-host" value="{{.SMTP.Host}}" class="r-input">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Port</label>
        <input name="port" id="smtp-port" type="number" min="1" max="65535" value="{{.SMTP.Port}}" class="r-input tabular-nums">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Encryption</label>
        <select name="encryption" id="smtp-encryption" class="r-select">
          <option value="tls" {{if eq .SMTP.Encryption "tls"}}selected{{end}}>STARTTLS</option>
          <option value="ssl" {{if eq .SMTP.Encryption "ssl"}}selected{{end}}>SSL/TLS</option>
          <option value="none" {{if eq .SMTP.Encryption "none"}}selected{{end}}>None</option>
        </select>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Username</label>
        <input name="username" value="{{.SMTP.Username}}" class="r-input">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Password {{if .SMTP.HasPassword}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
        <input name="password" type="password" placeholder="{{if .SMTP.HasPassword}}leave blank to keep{{end}}" class="r-input">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">From email</label>
        <input name="from_email" type="email" value="{{.SMTP.FromEmail}}" class="r-input">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">From name</label>
        <input name="from_name" value="{{.SMTP.FromName}}" class="r-input">
      </div>
      <div class="sm:col-span-2 flex flex-wrap justify-end gap-2">
        <button name="action" value="test" class="r-btn-secondary">Send test email</button>
        <button name="action" value="save" class="r-btn-primary">Save SMTP</button>
      </div>
    </form>
  </section>

  <!-- ── OIDC / SSO ─────────────────────────────────────────── -->
  <section data-settings-pane="auth" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Auth &amp; access</p>
    <h2 class="t-h3 mb-2">OIDC / Single sign-on</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Works with Authentik, Microsoft Entra ID, and any standards-compliant OIDC provider.</p>
    <form id="oidc-form" method="POST" action="/admin/settings/oidc" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="enabled" value="1" {{if .OIDC.Enabled}}checked{{end}}>
          <span></span>
          Enable OIDC sign-in button on the login page
        </label>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Provider display name</label>
        <input name="provider_name" value="{{.OIDC.ProviderName}}" placeholder="Authentik" class="r-input">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Label for the login button, e.g. "Sign in with Authentik".</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Default role for new users</label>
        <select name="default_role" class="r-select">
          <option value="support" {{if eq .OIDC.DefaultRole "support"}}selected{{end}}>support</option>
          <option value="admin" {{if eq .OIDC.DefaultRole "admin"}}selected{{end}}>admin</option>
          <option value="client" {{if eq .OIDC.DefaultRole "client"}}selected{{end}}>client</option>
        </select>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">"admin" + auto-provision is refused for safety.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Issuer URL</label>
        <input id="oidc-issuer" name="issuer" value="{{.OIDC.Issuer}}" placeholder="https://authentik.example.com/application/o/hostyt/" class="r-input font-mono">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">In Authentik: Application → Provider → "OpenID Configuration Issuer". Paste the base URL, not <code class="text-xs">/.well-known/openid-configuration</code>.</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Client ID</label>
        <input name="client_id" value="{{.OIDC.ClientID}}" class="r-input font-mono">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Client secret {{if .OIDC.HasSecret}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved, encrypted</span>{{end}}</label>
        <input name="client_secret" type="password" autocomplete="new-password" placeholder="{{if .OIDC.HasSecret}}leave blank to keep{{end}}" class="r-input">
        {{if .OIDC.HasSecret}}<label class="r-toggle mt-1" style="font-size:.75rem;color:rgb(var(--danger))"><input type="checkbox" name="clear_secret" value="1"><span></span>Clear stored secret on save</label>{{end}}
      </div>
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Redirect URL <span style="color:rgb(var(--muted))">(configure this exact URL on the IdP side)</span></label>
        <div class="flex gap-2">
          <input id="oidc-redirect" name="redirect_url" value="{{.OIDC.RedirectURL}}" placeholder="{{.OIDC.DefaultRedirect}}" class="r-input font-mono flex-1">
          <button type="button" data-oidc-fill-redirect data-redirect="{{.OIDC.DefaultRedirect}}" class="r-btn-secondary shrink-0">Use default</button>
        </div>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Leave blank to auto-fill from APP_URL on save.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Scopes (space-separated; <code class="text-xs">openid</code> always included)</label>
        <input name="scopes" value="{{.OIDC.Scopes}}" placeholder="openid email profile" class="r-input font-mono">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Add <code class="text-xs">groups</code> only when your IdP exposes a groups claim you actually map.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="auto_provision" value="1" {{if .OIDC.AutoProvision}}checked{{end}}>
          <span></span>
          Auto-create local account on first OIDC login
        </label>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Off = admin must pre-create matching email accounts. Existing local users with the same email are linked automatically on first SSO sign-in either way.</p>
      </div>
      <div class="sm:col-span-2" style="border-top:1px solid rgb(var(--border));padding-top:1rem">
        <label class="r-toggle">
          <input type="checkbox" name="password_login_disabled" value="1" {{if .OIDC.PasswordLoginDisabled}}checked{{end}}>
          <span></span>
          <strong>SSO-only mode</strong> - disable password login for all non-admin users (superadmins can always sign in with password as failsafe)
        </label>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">When enabled, the login form is hidden and only the SSO button is shown. Enable only after verifying OIDC works.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="allow_unverified_email" value="1" {{if .OIDC.AllowUnverifiedEmail}}checked{{end}}>
          <span></span>
          Allow unverified email from IdP
        </label>
        <p class="t-caption mt-1" style="color:rgb(var(--warning))">By default panel refuses login when the ID token says <code>email_verified: false</code>. Enable ONLY when your IdP (e.g. Authentik tied to corporate AD/LDAP) guarantees email ownership in some other way. Public-signup IdPs without this gate let anyone register <code>victim@yourdomain</code> and take over the matching local account.</p>
      </div>
      <div class="sm:col-span-2 flex flex-wrap items-center justify-between gap-2">
        <button type="button" id="oidc-test-btn" class="r-btn-secondary">Test discovery</button>
        <button class="r-btn-primary">Save OIDC</button>
      </div>
      <div id="oidc-test-result" class="sm:col-span-2 hidden t-caption"></div>
    </form>
  </section>

  <!-- ── Social login ──────────────────────────────────────── -->
  <section data-settings-pane="auth" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Auth &amp; access</p>
    <h2 class="t-h3 mb-2">Social login (GitHub, Google)</h2>
