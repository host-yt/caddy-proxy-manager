        <div class="r-card" style="background:rgb(var(--surface-2));padding:.5rem .75rem">
          <code class="block text-xs break-all font-mono tabular-nums" style="color:rgb(var(--text))">{{.WireGuard.PublicKey}}</code>
        </div>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Private key {{if .WireGuard.HasPrivate}}<span style="color:rgb(var(--success))">stored AES-256-GCM encrypted</span>{{else}}<span style="color:rgb(var(--danger))">not generated yet</span>{{end}}.</p>
      </div>
      {{end}}
