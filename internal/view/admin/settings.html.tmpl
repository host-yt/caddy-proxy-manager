{{define "settings"}}
<div class="space-y-4">

  <!-- Page header -->
  <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="t-eyebrow">System configuration</p>
      <h2 class="t-h2">Settings</h2>
    </div>
    <span class="t-caption" style="color:rgb(var(--muted))">Changes save per section.</span>
  </div>

  <!-- Nav sidebar grid -->
  <div class="grid gap-3 lg:grid-cols-5">

    <!-- Identity group -->
    <div class="r-card" style="padding:.75rem">
      <p class="t-eyebrow mb-2">Identity</p>
      <div class="grid gap-0.5">
        <button type="button" data-settings-tab="general" class="hpg-settings-tab hpg-settings-tab-active r-segment-item is-active text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">General</button>
        <button type="button" data-settings-tab="branding" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Branding</button>
        <button type="button" data-settings-tab="customfields" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Custom fields</button>
      </div>
    </div>

    <!-- Auth group -->
    <div class="r-card" style="padding:.75rem">
      <p class="t-eyebrow mb-2">Auth &amp; access</p>
      <div class="grid gap-0.5">
        <button type="button" data-settings-tab="auth" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">SSO / OIDC</button>
        <button type="button" data-settings-tab="security" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Admin 2FA</button>
        <button type="button" data-settings-tab="self-registration" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Self-registration</button>
        <button type="button" data-settings-tab="captcha" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">CAPTCHA</button>
      </div>
    </div>

    <!-- Delivery group -->
    <div class="r-card" style="padding:.75rem">
      <p class="t-eyebrow mb-2">Delivery</p>
      <div class="grid gap-0.5">
        <button type="button" data-settings-tab="email" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Email (SMTP)</button>
        <button type="button" data-settings-tab="sms" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">SMS</button>
        <button type="button" data-settings-tab="sso-jump" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">SSO Jump</button>
      </div>
    </div>

    <!-- Infrastructure group -->
    <div class="r-card" style="padding:.75rem">
      <p class="t-eyebrow mb-2">Infrastructure</p>
      <div class="grid gap-0.5">
        <button type="button" data-settings-tab="wireguard" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">WireGuard</button>
        <button type="button" data-settings-tab="cloudflare" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Cloudflare</button>
        <button type="button" data-settings-tab="acme" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">ACME / TLS</button>
        <button type="button" data-settings-tab="mtls" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">mTLS</button>
        <button type="button" data-settings-tab="analytics" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Analytics</button>
        <button type="button" data-settings-tab="failover" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Failover</button>
        <button type="button" data-settings-tab="alerts" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Alerts</button>
        <button type="button" data-settings-tab="geoip" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">GeoIP database</button>
      </div>
    </div>

    <!-- Developer group -->
    <div class="r-card" style="padding:.75rem">
      <p class="t-eyebrow mb-2">Developer</p>
      <div class="grid gap-0.5">
        <button type="button" data-settings-tab="apidocs" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">API docs</button>
        <button type="button" data-settings-tab="ai" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">AI assistant</button>
        <button type="button" data-settings-tab="banner" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Announcement</button>
        <button type="button" data-settings-tab="instances" class="hpg-settings-tab r-segment-item text-left px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors">Instances</button>
      </div>
    </div>
  </div>

  <!-- ── Admin 2FA ───────────────────────────────────────────── -->
  <section data-settings-pane="security" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Admin 2FA enforcement</p>
    <h2 class="t-h3 mb-2">Require two-factor authentication</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">When on, every <strong>admin</strong> / <strong>super_admin</strong> without an enrolled 2FA method is redirected to setup before reaching the panel. Existing admins get a short grace window so flipping it on never instantly locks anyone out.{{if .Require2FAEnvForced}} <strong style="color:rgb(var(--warning))">Locked on by the REQUIRE_ADMIN_2FA env var.</strong>{{end}}</p>
    <form method="POST" action="/admin/settings/require-2fa" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="require_admin_2fa" value="1" {{if .Require2FA}}checked{{end}}{{if .Require2FAEnvForced}} disabled{{end}}>
        <span></span>
        Require 2FA for all admin accounts
      </label>
      {{if not .Require2FAEnvForced}}
      <div class="flex justify-end">
        <button class="r-btn-primary">Save</button>
      </div>
      {{end}}
    </form>
  </section>

  <!-- ── Self-registration ─────────────────────────────────── -->
  <section data-settings-pane="self-registration" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Client self-registration</p>
    <h2 class="t-h3 mb-2">Allow public registration</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">When on, <code class="text-xs">/auth/register</code> is publicly accessible and anyone can create a client account. New accounts are active immediately - no email verification step.</p>
    <form method="POST" action="/admin/settings/self-registration" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="allow_self_registration" value="1" {{if .AllowSelfRegistration}}checked{{end}}>
        <span></span>
        Allow client self-registration
      </label>
      <div>
        <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Default plan for new registrations</label>
        <input name="default_plan_id" value="{{.DefaultPlanID}}" placeholder="Plan ID (optional)" class="r-input w-full font-mono">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">When set, a service on this plan is assigned to the new client automatically. Leave empty to assign no plan.</p>
      </div>
      <div class="flex justify-end">
        <button class="r-btn-primary">Save</button>
      </div>
    </form>
  </section>

  <!-- ── API docs ───────────────────────────────────────────── -->
  <section data-settings-pane="apidocs" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">API documentation</p>
    <h2 class="t-h3 mb-2">API documentation visibility</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))"><code class="text-xs">/api-docs</code> renders the Scalar API Reference. SSO jump and other internal endpoints are NOT in the spec. Off = anonymous visitors get 404, admins still see it when logged in.</p>
    <form method="POST" action="/admin/settings/apidocs" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="public_enabled" value="1" {{if .APIDocsPublic}}checked{{end}}>
        <span></span>
        Publicly reachable (no login required)
      </label>
      <div class="flex justify-end">
        <button class="r-btn-primary">Save</button>
      </div>
    </form>
  </section>

  <!-- ── Customer fields ───────────────────────────────────── -->
  <section data-settings-pane="customer" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Customer profile fields</p>
    <h2 class="t-h3 mb-2">Customer profile fields</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Configures which optional profile fields customers can fill at <code class="text-xs">/app/account</code>. Disabled = field hidden from the customer portal and refused server-side even if posted directly.</p>
    <form method="POST" action="/admin/settings/customer-fields" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="phone_enabled" value="1" {{if .CustomerFields.PhoneEnabled}}checked{{end}}>
        <span></span>
        Show <strong>phone</strong> field to customers (E.164) - required for SMS outage alerts and 2FA SMS fallback
      </label>
      <div class="flex justify-end">
        <button class="r-btn-primary">Save</button>
      </div>
    </form>
  </section>

  <!-- ── Custom fields ────────────────────────────────────── -->
  <section data-settings-pane="customfields" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Entity custom fields</p>
    <h2 class="t-h3 mb-2">Custom fields</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Define extra fields per entity type. Values are stored as JSON on each entity row and rendered on the client/host edit and detail pages.</p>

    <!-- Entity switcher -->
    <div class="flex gap-2 mb-4" id="cf-entity-switcher">
      <button type="button" data-cf-entity="client" class="r-btn-primary" id="cf-btn-client">Clients</button>
      <button type="button" data-cf-entity="host"   class="r-btn-secondary" id="cf-btn-host">Hosts</button>
    </div>

    <!-- Defs list -->
    <div id="cf-defs-list" class="space-y-2 mb-4"></div>

    <!-- Add field form -->
    <div class="r-card" style="background:rgb(var(--surface-2)/.5)">
      <p class="t-body font-medium mb-3" style="color:rgb(var(--text))">Add field</p>
      <form id="cf-add-form" method="POST" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <input type="hidden" name="entity_type" id="cf-entity-type-input" value="client">
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Label</label>
          <input name="label" id="cf-label-input" maxlength="120" placeholder="e.g. Company name" class="r-input" required>
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Key (slug)</label>
          <input name="field_key" id="cf-key-input" maxlength="40" placeholder="e.g. company_name" pattern="[a-z0-9_]{1,40}" class="r-input font-mono" required>
          <p class="t-caption mt-1" style="color:rgb(var(--muted))">Lowercase letters, digits, underscores only.</p>
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Type</label>
          <select name="field_type" id="cf-type-select" class="r-select">
            <option value="text">Text</option>
            <option value="number">Number</option>
            <option value="select">Select</option>
            <option value="bool">Boolean</option>
          </select>
        </div>
        <div id="cf-options-row" class="hidden">
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Options (one per line or comma-separated)</label>
          <textarea name="options" rows="3" class="r-input" placeholder="Option A&#10;Option B"></textarea>
        </div>
        <div class="sm:col-span-2">
          <label class="r-toggle">
            <input type="checkbox" name="required" value="1">
            <span></span>
            Required field
          </label>
        </div>
        <div class="sm:col-span-2 flex justify-end">
          <button type="submit" class="r-btn-primary cursor-pointer">Add field</button>
        </div>
      </form>
    </div>
  </section>
  <script nonce="{{.CSPNonce}}">
  (function(){
    var currentEntity = 'client';
    var csrfToken = document.querySelector('[data-settings-pane="customfields"] input[name="csrf_token"]');
    var csrfVal = csrfToken ? csrfToken.value : '';

    var btnClient = document.getElementById('cf-btn-client');
    var btnHost   = document.getElementById('cf-btn-host');
    var listEl    = document.getElementById('cf-defs-list');
    var addForm   = document.getElementById('cf-add-form');
    var entityIn  = document.getElementById('cf-entity-type-input');
    var labelIn   = document.getElementById('cf-label-input');
    var keyIn     = document.getElementById('cf-key-input');
    var typeEl    = document.getElementById('cf-type-select');
    var optsRow   = document.getElementById('cf-options-row');

    if (!listEl || !addForm) return;

    function setEntity(e) {
      currentEntity = e;
      if (entityIn) entityIn.value = e;
      if (btnClient) { btnClient.className = e === 'client' ? 'r-btn-primary' : 'r-btn-secondary'; }
      if (btnHost)   { btnHost.className   = e === 'host'   ? 'r-btn-primary' : 'r-btn-secondary'; }
      loadDefs();
    }

    function loadDefs() {
      listEl.innerHTML = '<p class="t-caption" style="color:rgb(var(--muted))">Loading…</p>';
      fetch('/admin/settings/custom-fields?entity=' + currentEntity, {
        credentials: 'same-origin', headers: {'Accept': 'application/json'}
      }).then(function(r){ return r.json(); })
        .then(function(j){
          renderDefs(j.defs || []);
        })
        .catch(function(){ listEl.innerHTML = '<p class="t-caption" style="color:rgb(var(--danger))">Failed to load fields.</p>'; });
    }

    // Build the list with DOM nodes + textContent only. Field labels are
    // admin-supplied; never interpolate them into HTML or inline handlers
    // (entity decoding in attributes would re-open an XSS hole).
    function renderDefs(defs) {
      listEl.textContent = '';
      if (!defs.length) {
        var empty = document.createElement('p');
        empty.className = 't-caption';
        empty.style.color = 'rgb(var(--muted))';
        empty.textContent = 'No custom fields defined yet.';
        listEl.appendChild(empty);
        return;
      }
      defs.forEach(function(d) {
        var card = document.createElement('div');
        card.className = 'r-card flex items-center justify-between gap-3';
        card.style.background = 'rgb(var(--surface-2)/.4)';

        var info = document.createElement('div');
        info.className = 'flex-1 min-w-0';

        var label = document.createElement('span');
        label.className = 't-body font-medium';
        label.style.color = 'rgb(var(--text))';
        label.textContent = d.label;
        info.appendChild(label);

        info.appendChild(document.createTextNode(' '));
        var key = document.createElement('code');
        key.className = 'text-xs font-mono';
        key.style.color = 'rgb(var(--muted))';
        key.textContent = d.key;
        info.appendChild(key);

        info.appendChild(document.createTextNode(' '));
        var type = document.createElement('span');
        type.className = 'r-pill r-pill-neutral';
        type.style.fontSize = '.6rem';
        type.textContent = d.type;
        info.appendChild(type);

        if (d.required) {
          info.appendChild(document.createTextNode(' '));
          var req = document.createElement('span');
          req.className = 'r-pill r-pill-warning';
          req.style.fontSize = '.6rem';
          req.textContent = 'required';
          info.appendChild(req);
        }
        if (d.options && d.options.length) {
          var optsP = document.createElement('p');
          optsP.className = 't-caption mt-0.5';
          optsP.style.color = 'rgb(var(--muted))';
          optsP.textContent = 'Options: ' + d.options.join(', ');
          info.appendChild(optsP);
        }

        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/settings/custom-fields/' + encodeURIComponent(d.id) + '/delete';
        form.addEventListener('submit', function(e) {
          if (!confirm('Delete field "' + d.label + '"?')) e.preventDefault();
        });
        var csrf = document.createElement('input');
        csrf.type = 'hidden'; csrf.name = 'csrf_token'; csrf.value = csrfVal;
        form.appendChild(csrf);
        var btn = document.createElement('button');
        btn.type = 'submit'; btn.className = 'r-btn-danger';
        btn.style.fontSize = '.75rem'; btn.style.padding = '.25rem .6rem';
        btn.textContent = 'Delete';
        form.appendChild(btn);

        card.appendChild(info);
        card.appendChild(form);
        listEl.appendChild(card);
      });
    }

    if (btnClient) btnClient.addEventListener('click', function(){ setEntity('client'); });
    if (btnHost)   btnHost.addEventListener('click',   function(){ setEntity('host'); });

    if (typeEl) {
      typeEl.addEventListener('change', function(){
        if (optsRow) optsRow.classList.toggle('hidden', typeEl.value !== 'select');
      });
    }

    // Auto-slug label -> key
    if (labelIn && keyIn) {
      labelIn.addEventListener('input', function(){
        if (keyIn.dataset.userEdited) return;
        keyIn.value = labelIn.value.toLowerCase().replace(/[^a-z0-9]+/g,'_').replace(/^_|_$/g,'').slice(0,40);
      });
      keyIn.addEventListener('input', function(){
        keyIn.dataset.userEdited = '1';
      });
    }

    if (addForm) {
      addForm.action = '/admin/settings/custom-fields';
      addForm.addEventListener('submit', function(){
        if (keyIn) delete keyIn.dataset.userEdited;
      });
    }

    // Load on first tab activate
    document.querySelectorAll('[data-settings-tab="customfields"]').forEach(function(btn){
      btn.addEventListener('click', function(){ if (!listEl.children.length) loadDefs(); });
    });

    // Also load if pane is already active (page reload via hash)
    if (!document.querySelector('[data-settings-pane="customfields"]').classList.contains('hidden')) {
      loadDefs();
    }
  })();
  </script>

  <!-- ── General ───────────────────────────────────────────── -->
  <section data-settings-pane="general" class="hpg-settings-pane r-card">
    <p class="t-eyebrow mb-1">Panel</p>
    <h2 class="t-h3 mb-3">General information</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <div>
        <dt class="t-eyebrow">Public URL</dt>
        <dd class="font-mono break-all mt-0.5" style="color:rgb(var(--text))">{{.AppURL}}</dd>
      </div>
      <div>
        <dt class="t-eyebrow">Installed</dt>
        <dd class="mt-0.5"><span class="r-pill r-pill-success">yes</span></dd>
      </div>
    </dl>
    <p class="t-caption mt-3" style="color:rgb(var(--muted))">To change the panel URL, edit APP_URL in .env and restart.</p>
  </section>

  <!-- ── Branding ──────────────────────────────────────────── -->
  <section data-settings-pane="branding" class="hpg-settings-pane hidden space-y-4">

    <div class="r-card space-y-4">
      <div>
        <p class="t-eyebrow mb-1">Branding</p>
        <p class="t-small" style="color:rgb(var(--muted))">Customise the panel + login page brand. URLs must be <code class="text-xs">http://</code> or <code class="text-xs">https://</code> (they render as <code class="text-xs">&lt;img src&gt;</code>/<code class="text-xs">&lt;link href&gt;</code> so other schemes are refused).</p>
      </div>

      <form method="POST" action="/admin/branding" class="space-y-4">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">

        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Brand name</label>
          <input name="brand_name" value="{{.Branding.BrandName}}" maxlength="64" placeholder="Hostyt Proxy" class="r-input">
          <p class="t-caption mt-1" style="color:rgb(var(--muted))">Shown in the sidebar + login header. Empty = default "Hostyt Proxy".</p>
        </div>

        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Tagline (optional)</label>
          <input name="tagline" value="{{.Branding.Tagline}}" maxlength="128" placeholder="Self-hosted reverse-proxy panel" class="r-input">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block t-caption mb-1" style="color:rgb(var(--text))">Logo URL (light mode)</label>
            <input name="logo_url_light" value="{{.Branding.LogoURLLight}}" placeholder="https://cdn.example.com/logo-dark.svg" class="r-input">
            {{if .Branding.LogoURLLight}}<div class="mt-2 inline-block p-2 rounded-lg r-card"><img src="{{.Branding.LogoURLLight}}" alt="light preview" class="h-8"></div>{{end}}
            <p class="t-caption mt-1" style="color:rgb(var(--muted))">Used on white backgrounds. Pick a logo with dark ink.</p>
          </div>
          <div>
            <label class="block t-caption mb-1" style="color:rgb(var(--text))">Logo URL (dark mode)</label>
            <input name="logo_url_dark" value="{{.Branding.LogoURLDark}}" placeholder="https://cdn.example.com/logo-light.svg" class="r-input">
            {{if .Branding.LogoURLDark}}<div class="mt-2 inline-block p-2 rounded-lg r-card"><img src="{{.Branding.LogoURLDark}}" alt="dark preview" class="h-8"></div>{{end}}
            <p class="t-caption mt-1" style="color:rgb(var(--muted))">Falls back to the light logo if empty. Pick a logo with light ink for dark backgrounds.</p>
          </div>
        </div>

        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Favicon URL</label>
          <input name="favicon_url" value="{{.Branding.FaviconURL}}" placeholder="https://cdn.example.com/favicon.ico" class="r-input">
          <p class="t-caption mt-1" style="color:rgb(var(--muted))">16x16 ICO or PNG. Browsers cache aggressively - change the URL or path to bust.</p>
        </div>

        <!-- Error page skin sub-card -->
        <div class="r-card" style="background:rgb(var(--surface-2)/.5)">
          <p class="t-eyebrow mb-2">Error / maintenance page skin</p>
          <p class="t-caption mb-3" style="color:rgb(var(--muted))">Branding for the pages Caddy serves directly (404, 403, 502, 503, 504, maintenance). Empty fields fall back to a neutral deep-gray skin.</p>
          <div class="space-y-3">
            <div>
              <label class="block t-caption mb-1" style="color:rgb(var(--text))">Error page logo URL</label>
              <input name="error_logo_url" value="{{.Branding.ErrorLogoURL}}" placeholder="https://cdn.example.com/logo-error.svg" class="r-input">
              {{if .Branding.ErrorLogoURL}}<div class="mt-2 inline-block p-2 rounded-lg" style="background: {{if .Branding.ErrorBgColor}}{{.Branding.ErrorBgColor}}{{else}}#1f2937{{end}};"><img src="{{.Branding.ErrorLogoURL}}" alt="error logo preview" class="h-8"></div>{{end}}
            </div>
            <div>
              <label class="block t-caption mb-1" style="color:rgb(var(--text))">Error page logo link</label>
