{{define "settings"}}
<div class="space-y-4">

  <section class="space-y-3">
    <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="hpg-eyebrow">System configuration</p>
        <h2 class="text-lg font-semibold text-slate-950 dark:text-white">Operational settings</h2>
      </div>
      <span class="text-xs text-slate-500 dark:text-slate-400">Changes save per section.</span>
    </div>

    <div class="grid gap-3 lg:grid-cols-5">
      <div class="rounded-lg bg-white p-3 ring-1 ring-slate-200 dark:bg-zinc-900 dark:ring-zinc-800">
        <p class="hpg-eyebrow mb-2">Identity</p>
        <div class="grid gap-1">
          <button type="button" data-settings-tab="general" class="hpg-settings-tab hpg-settings-tab-active text-left px-3 py-2 rounded-lg text-sm bg-slate-200 dark:bg-zinc-800 text-slate-900 dark:text-slate-100 font-medium">General</button>
          <button type="button" data-settings-tab="branding" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800 cursor-pointer transition-colors">Branding</button>
          <button type="button" data-settings-tab="customer" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">Customer fields</button>
        </div>
      </div>

      <div class="rounded-lg bg-white p-3 ring-1 ring-slate-200 dark:bg-zinc-900 dark:ring-zinc-800">
        <p class="hpg-eyebrow mb-2">Auth &amp; access</p>
        <div class="grid gap-1">
          <button type="button" data-settings-tab="auth" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">SSO / OIDC</button>
          <button type="button" data-settings-tab="security" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">Admin 2FA</button>
          <button type="button" data-settings-tab="captcha" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">CAPTCHA</button>
        </div>
      </div>

      <div class="rounded-lg bg-white p-3 ring-1 ring-slate-200 dark:bg-zinc-900 dark:ring-zinc-800">
        <p class="hpg-eyebrow mb-2">Delivery</p>
        <div class="grid gap-1">
          <button type="button" data-settings-tab="email" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">Email (SMTP)</button>
          <button type="button" data-settings-tab="sms" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">SMS</button>
          <button type="button" data-settings-tab="sso-jump" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">SSO Jump</button>
        </div>
      </div>

      <div class="rounded-lg bg-white p-3 ring-1 ring-slate-200 dark:bg-zinc-900 dark:ring-zinc-800">
        <p class="hpg-eyebrow mb-2">Infrastructure</p>
        <div class="grid gap-1">
          <button type="button" data-settings-tab="wireguard" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">WireGuard</button>
          <button type="button" data-settings-tab="cloudflare" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">Cloudflare</button>
          <button type="button" data-settings-tab="acme" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">ACME / TLS</button>
        </div>
      </div>

      <div class="rounded-lg bg-white p-3 ring-1 ring-slate-200 dark:bg-zinc-900 dark:ring-zinc-800">
        <p class="hpg-eyebrow mb-2">Developer</p>
        <div class="grid gap-1">
          <button type="button" data-settings-tab="apidocs" class="hpg-settings-tab text-left px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-zinc-800">API docs</button>
        </div>
      </div>
    </div>
  </section>

  <section data-settings-pane="security" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-2">Admin 2FA enforcement</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">When on, every <strong>admin</strong> / <strong>super_admin</strong> without an enrolled 2FA method is redirected to setup before reaching the panel. Existing admins get a short grace window so flipping it on never instantly locks anyone out.{{if .Require2FAEnvForced}} <strong class="text-amber-600 dark:text-amber-400">Locked on by the REQUIRE_ADMIN_2FA env var.</strong>{{end}}</p>
    <form method="POST" action="/admin/settings/require-2fa" class="space-y-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200">
        <input type="checkbox" name="require_admin_2fa" value="1" {{if .Require2FA}}checked{{end}}{{if .Require2FAEnvForced}} disabled{{end}}>
        Require 2FA for all admin accounts
      </label>
      {{if not .Require2FAEnvForced}}
      <div class="flex justify-end">
        <button class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Save</button>
      </div>
      {{end}}
    </form>
  </section>

  <section data-settings-pane="apidocs" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-2">API documentation visibility</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4"><code class="text-xs">/api-docs</code> renders the Scalar API Reference. SSO jump and other internal endpoints are NOT in the spec. Off = anonymous visitors get 404, admins still see it when logged in.</p>
    <form method="POST" action="/admin/settings/apidocs" class="space-y-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200">
        <input type="checkbox" name="public_enabled" value="1" {{if .APIDocsPublic}}checked{{end}}>
        Publicly reachable (no login required)
      </label>
      <div class="flex justify-end">
        <button class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">Save</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="customer" class="hpg-settings-pane hidden hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Customer fields</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">Controls which optional profile fields the customer can fill in <code class="text-xs">/app/account</code>. Disabled = field hidden from the customer UI and refused at the server layer even if posted directly.</p>
    <form method="POST" action="/admin/settings/customer-fields" class="space-y-3 text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="flex items-center gap-2 text-slate-700 dark:text-slate-200">
        <input type="checkbox" name="phone_enabled" value="1" {{if .CustomerFields.PhoneEnabled}}checked{{end}}>
        Show <strong>phone</strong> field to customers (E.164) - required for SMS outage alerts and 2FA SMS fallback
      </label>
      <div class="flex justify-end pt-2">
        <button class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-sm">Save</button>
      </div>
    </form>
  </section>

  <section data-settings-pane="general" class="hpg-settings-pane hpg-card">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-3">Panel</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <div><dt class="hpg-eyebrow">Public URL</dt><dd class="font-mono text-slate-800 dark:text-slate-100 break-all mt-0.5">{{.AppURL}}</dd></div>
      <div><dt class="hpg-eyebrow">Installed</dt><dd class="mt-0.5"><span class="hpg-pill hpg-pill-ok">yes</span></dd></div>
    </dl>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-2">To change the panel URL, edit APP_URL in .env and restart.</p>
  </section>

  <section data-settings-pane="branding" class="hpg-settings-pane hidden space-y-4">

    <!-- Branding form (posts to /admin/branding); fields are nested under .Branding on the Settings page. -->
    <div class="hpg-card space-y-4 text-sm">
      <div>
        <div class="hpg-eyebrow">Branding</div>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Customise the panel + login page brand. URLs must be <code class="text-xs">http://</code> or <code class="text-xs">https://</code> (they render as <code class="text-xs">&lt;img src&gt;</code>/<code class="text-xs">&lt;link href&gt;</code> so other schemes are refused).</p>
      </div>

      <form method="POST" action="/admin/branding" class="space-y-4">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">

        <div>
          <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Brand name</label>
          <input name="brand_name" value="{{.Branding.BrandName}}" maxlength="64" placeholder="Hostyt Proxy" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
          <p class="text-[11px] text-slate-500 mt-1">Shown in the sidebar + login header. Empty = default "Hostyt Proxy".</p>
        </div>

        <div>
          <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Tagline (optional)</label>
          <input name="tagline" value="{{.Branding.Tagline}}" maxlength="128" placeholder="Self-hosted reverse-proxy panel" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Logo URL (light mode)</label>
            <input name="logo_url_light" value="{{.Branding.LogoURLLight}}" placeholder="https://cdn.example.com/logo-dark.svg" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
            {{if .Branding.LogoURLLight}}<div class="mt-2 inline-block p-2 rounded-lg bg-white ring-1 ring-slate-200 dark:ring-zinc-700"><img src="{{.Branding.LogoURLLight}}" alt="light preview" class="h-8"></div>{{end}}
            <p class="text-[11px] text-slate-500 mt-1">Used on white backgrounds. Pick a logo with dark ink.</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Logo URL (dark mode)</label>
            <input name="logo_url_dark" value="{{.Branding.LogoURLDark}}" placeholder="https://cdn.example.com/logo-light.svg" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
            {{if .Branding.LogoURLDark}}<div class="mt-2 inline-block p-2 rounded-lg bg-zinc-900 ring-1 ring-zinc-700"><img src="{{.Branding.LogoURLDark}}" alt="dark preview" class="h-8"></div>{{end}}
            <p class="text-[11px] text-slate-500 mt-1">Falls back to the light logo if empty. Pick a logo with light ink for dark backgrounds.</p>
          </div>
        </div>

        <div>
          <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Favicon URL</label>
          <input name="favicon_url" value="{{.Branding.FaviconURL}}" placeholder="https://cdn.example.com/favicon.ico" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
          <p class="text-[11px] text-slate-500 mt-1">16x16 ICO or PNG. Browsers cache aggressively - change the URL or path to bust.</p>
        </div>

        <div class="rounded-xl ring-1 ring-slate-200 dark:ring-zinc-800 bg-slate-50 dark:bg-zinc-900/50 p-4 space-y-3">
          <div class="hpg-eyebrow">Error / maintenance page skin</div>
          <p class="text-[11px] text-slate-500">Branding for the pages Caddy serves directly (404, 403, 502, 503, 504, maintenance). Empty fields fall back to a neutral deep-gray skin.</p>
          <div>
            <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Error page logo URL</label>
            <input name="error_logo_url" value="{{.Branding.ErrorLogoURL}}" placeholder="https://cdn.example.com/logo-error.svg" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
            {{if .Branding.ErrorLogoURL}}<div class="mt-2 inline-block p-2 rounded-lg" style="background: {{if .Branding.ErrorBgColor}}{{.Branding.ErrorBgColor}}{{else}}#1f2937{{end}};"><img src="{{.Branding.ErrorLogoURL}}" alt="error logo preview" class="h-8"></div>{{end}}
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Error page logo link</label>
            <input name="error_logo_link" value="{{.Branding.ErrorLogoLink}}" placeholder="https://www.your-brand.com/" class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none">
            <p class="text-[11px] text-slate-500 mt-1">Where the logo links on error pages. Leave empty for a non-clickable logo.</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Background color</label>
            <div class="flex gap-2 items-center">
              <input name="error_bg_color" value="{{.Branding.ErrorBgColor}}" placeholder="#1f2937" class="flex-1 px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 outline-none font-mono">
              <span class="inline-block w-8 h-8 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700" style="background: {{if .Branding.ErrorBgColor}}{{.Branding.ErrorBgColor}}{{else}}#1f2937{{end}};"></span>
            </div>
            <p class="text-[11px] text-slate-500 mt-1">Hex (#RGB / #RRGGBB / #RRGGBBAA) or rgb()/rgba(). Default is deep slate (#1f2937).</p>
          </div>
        </div>

        <div class="flex justify-end pt-2">
          <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 cursor-pointer transition-colors">Save branding</button>
        </div>
      </form>
    </div>

    <!-- Appearance sub-section: per-browser palette picker (server cookie set via /theme/{slug} link). -->
    <div class="hpg-card">
      <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Appearance</h2>
      <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Pick a color palette. Themes are per-browser and switch instantly - they do not change settings for other users. This is separate from the light/dark toggle in the top bar.</p>
    {{$cur := .Theme}}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <a href="/theme/default" data-palette-pick="default" data-palette-card="default" class="group block rounded-2xl border p-3 transition-all hover:-translate-y-0.5 hover:shadow-md {{if eq "default" $cur}}border-indigo-500 ring-2 ring-indigo-500{{else}}ring-1 ring-slate-200/70 dark:ring-zinc-800{{end}}">
        <!-- Live preview: [data-theme] scopes the real palette vars, so these utility-class dots always match themes.css. -->
        <div data-theme="default" class="flex gap-1.5 mb-2">
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-slate-50"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-zinc-900"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-indigo-600"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-emerald-500"></span>
        </div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-100">Slate (default)</span>
          {{if eq "default" $cur}}<span data-palette-active-pill class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">Active</span>{{end}}
        </div>
      </a>
      <a href="/theme/midnight" data-palette-pick="midnight" data-palette-card="midnight" class="group block rounded-2xl border p-3 transition-all hover:-translate-y-0.5 hover:shadow-md {{if eq "midnight" $cur}}border-indigo-500 ring-2 ring-indigo-500{{else}}ring-1 ring-slate-200/70 dark:ring-zinc-800{{end}}">
        <div data-theme="midnight" class="flex gap-1.5 mb-2">
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-slate-50"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-zinc-900"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-indigo-600"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-emerald-500"></span>
        </div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-100">Midnight</span>
          {{if eq "midnight" $cur}}<span data-palette-active-pill class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">Active</span>{{end}}
        </div>
      </a>
      <a href="/theme/ocean" data-palette-pick="ocean" data-palette-card="ocean" class="group block rounded-2xl border p-3 transition-all hover:-translate-y-0.5 hover:shadow-md {{if eq "ocean" $cur}}border-indigo-500 ring-2 ring-indigo-500{{else}}ring-1 ring-slate-200/70 dark:ring-zinc-800{{end}}">
        <div data-theme="ocean" class="flex gap-1.5 mb-2">
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-slate-50"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-zinc-900"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-indigo-600"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-emerald-500"></span>
        </div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-100">Ocean</span>
          {{if eq "ocean" $cur}}<span data-palette-active-pill class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">Active</span>{{end}}
        </div>
      </a>
      <a href="/theme/forest" data-palette-pick="forest" data-palette-card="forest" class="group block rounded-2xl border p-3 transition-all hover:-translate-y-0.5 hover:shadow-md {{if eq "forest" $cur}}border-indigo-500 ring-2 ring-indigo-500{{else}}ring-1 ring-slate-200/70 dark:ring-zinc-800{{end}}">
        <div data-theme="forest" class="flex gap-1.5 mb-2">
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-slate-50"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-zinc-900"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-indigo-600"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-emerald-500"></span>
        </div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-100">Forest</span>
          {{if eq "forest" $cur}}<span data-palette-active-pill class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">Active</span>{{end}}
        </div>
      </a>
      <a href="/theme/violet" data-palette-pick="violet" data-palette-card="violet" class="group block rounded-2xl border p-3 transition-all hover:-translate-y-0.5 hover:shadow-md {{if eq "violet" $cur}}border-indigo-500 ring-2 ring-indigo-500{{else}}ring-1 ring-slate-200/70 dark:ring-zinc-800{{end}}">
        <div data-theme="violet" class="flex gap-1.5 mb-2">
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-slate-50"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-zinc-900"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-indigo-600"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-emerald-500"></span>
        </div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-100">Violet</span>
          {{if eq "violet" $cur}}<span data-palette-active-pill class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">Active</span>{{end}}
        </div>
      </a>
      <a href="/theme/sunset" data-palette-pick="sunset" data-palette-card="sunset" class="group block rounded-2xl border p-3 transition-all hover:-translate-y-0.5 hover:shadow-md {{if eq "sunset" $cur}}border-indigo-500 ring-2 ring-indigo-500{{else}}ring-1 ring-slate-200/70 dark:ring-zinc-800{{end}}">
        <div data-theme="sunset" class="flex gap-1.5 mb-2">
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-slate-50"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-zinc-900"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-indigo-600"></span>
          <span class="w-5 h-5 rounded-full ring-1 ring-black/10 bg-emerald-500"></span>
        </div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-100">Sunset</span>
