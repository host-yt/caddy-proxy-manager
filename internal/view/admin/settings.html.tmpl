    <h2 class="t-h3 mb-2">WireGuard (multi-node mesh)</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Required for one-command node join. Auto-generates a keypair on first save.</p>
    <form method="POST" action="/admin/settings/wireguard" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="enabled" value="1" {{if .WireGuard.Enabled}}checked{{end}}>
          <span></span>
          Multi-node mode enabled
        </label>
      </div>
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Public endpoint (host:port - what new nodes will dial)</label>
        <input name="endpoint" value="{{.WireGuard.Endpoint}}" placeholder="manager.example.com:51820" class="r-input font-mono">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Listen port (UDP)</label>
        <input name="listen_port" type="number" value="{{.WireGuard.ListenPort}}" class="r-input tabular-nums">
      </div>
