  <!-- ── ACME / TLS ─────────────────────────────────────────── -->
  <section data-settings-pane="acme" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-4">ACME / TLS</h2>
    <form method="POST" action="/admin/settings/acme" class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="acme-form">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">ACME contact email</label>
        <input name="email" type="email" required value="{{.ACME.Email}}" class="r-input">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Registration contact for the ACME CA.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Certificate Authority</label>
        <select name="acme_ca_url" id="acme-ca-select" class="r-input cursor-pointer" onchange="acmeCAChange(this.value)">
          <option value="" {{if or (eq .ACME.CaURL "") (eq .ACME.CaURL "letsencrypt")}}selected{{end}}>Let's Encrypt (default)</option>
          <option value="zerossl" {{if eq .ACME.CaURL "zerossl"}}selected{{end}}>ZeroSSL</option>
          <option value="custom" {{if and (ne .ACME.CaURL "") (ne .ACME.CaURL "letsencrypt") (ne .ACME.CaURL "zerossl")}}selected{{end}}>Custom URL</option>
        </select>
      </div>
      <div class="sm:col-span-2" id="acme-custom-url-row" style="display:none">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Custom ACME directory URL</label>
        <input name="acme_ca_url_custom" id="acme-ca-url-custom" type="url" class="r-input" placeholder="https://acme.example.com/directory" value="{{if and (ne .ACME.CaURL "") (ne .ACME.CaURL "letsencrypt") (ne .ACME.CaURL "zerossl")}}{{.ACME.CaURL}}{{end}}">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Full ACME directory URL for a private or alternate CA.</p>
      </div>
      <div class="sm:col-span-2" id="acme-eab-row" style="display:none">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">EAB Key ID</label>
        <input name="acme_eab_kid" type="text" class="r-input" placeholder="ZeroSSL EAB key ID" value="{{.ACME.EabKID}}">
      </div>
      <div class="sm:col-span-2" id="acme-eab-hmac-row" style="display:none">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">EAB HMAC Key</label>
        <input name="acme_eab_hmac" type="password" class="r-input" placeholder="{{if .ACME.HasEABKey}}(unchanged){{else}}ZeroSSL EAB HMAC key{{end}}" autocomplete="new-password">
        {{if .ACME.HasEABKey}}<p class="t-caption mt-1" style="color:rgb(var(--muted))">A key is stored. Leave blank to keep the existing value.</p>{{end}}
      </div>
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="staging" value="1" {{if .ACME.Staging}}checked{{end}}>
          <span></span>
          Use Let's Encrypt staging directory (overrides CA selection above)
        </label>
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Enable while testing to avoid burning production rate limits. Issued certs will not be trusted by browsers.</p>
      </div>
      <div class="sm:col-span-2 flex justify-end">
        <button class="r-btn-primary">Save ACME</button>
      </div>
    </form>
    <p class="t-caption mt-3" style="color:rgb(var(--muted))">Changes take effect on the next Caddy push (next route create/delete or node resync).</p>
    <script>
    (function(){
      function acmeCAChange(val){
        document.getElementById('acme-custom-url-row').style.display = val === 'custom' ? '' : 'none';
        document.getElementById('acme-eab-row').style.display = val === 'zerossl' ? '' : 'none';
        document.getElementById('acme-eab-hmac-row').style.display = val === 'zerossl' ? '' : 'none';
      }
      window.acmeCAChange = acmeCAChange;
      // On submit, write custom URL into the select value so the server sees it.
      var form = document.getElementById('acme-form');
      if(form){
        form.addEventListener('submit', function(){
          var sel = document.getElementById('acme-ca-select');
          if(sel && sel.value === 'custom'){
            var inp = document.getElementById('acme-ca-url-custom');
            if(inp) sel.value = inp.value;
          }
        });
      }
      var sel = document.getElementById('acme-ca-select');
      if(sel) acmeCAChange(sel.value);
    })();
    </script>
  </section>

  <!-- ── mTLS ──────────────────────────────────────────────── -->
  <section data-settings-pane="mtls" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-2">Mutual TLS (mTLS) enforcement</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Controls how Caddy behaves when a client-cert is required on a route but no valid certificate is presented. Changes take effect on the next Caddy push.</p>
    <form method="POST" action="/admin/settings/mtls" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="mtls_fail_open" value="1" {{if .MTLSFailOpen}}checked{{end}}>
        <span></span>
        Fail open - allow traffic even when no client certificate is presented
      </label>
      <p class="t-caption" style="color:rgb(var(--muted))">When unchecked (default): Caddy uses <code>require_and_verify</code> - the TLS handshake is rejected if no valid client cert is presented. When checked: Caddy uses <code>request</code> - the cert is optional and traffic proceeds regardless.</p>
      <div class="flex justify-end">
        <button class="r-btn-primary cursor-pointer">Save</button>
      </div>
    </form>
  </section>

  <!-- ── Analytics ─────────────────────────────────────────── -->
  <section data-settings-pane="analytics" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-2">Analytics retention</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Controls automatic pruning of aggregated traffic rollup data.</p>
    <form method="POST" action="/admin/settings/analytics" id="form-analytics" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block t-body font-medium mb-1" style="color:rgb(var(--text))">Rollup retention (days)</label>
        <input type="number" name="rollup_retention_days" value="{{.RollupRetentionDays}}"
               min="0" max="3650"
               placeholder="0 (keep forever)"
               class="r-input tabular-nums" style="max-width:16rem">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">log_rollups rows older than N days are deleted hourly. 0 = keep forever.</p>
      </div>
      <div class="flex justify-end">
        <button type="submit" form="form-analytics" class="r-btn-primary cursor-pointer">Save</button>
      </div>
    </form>
  </section>

  <!-- ── Failover ───────────────────────────────────────────── -->
  <section data-settings-pane="failover" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-4">Auto failover</h2>
    <form method="POST" action="/admin/settings/failover" id="form-failover" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="auto_failover_enabled" value="1"
               {{if .AutoFailoverEnabled}}checked{{end}}>
        <span></span>
        Enable automatic route failover
      </label>
      <p class="t-small" style="color:rgb(var(--muted))">When enabled, routes on a dead node move to a healthy sibling in the same failover node group. Requires node groups with mode=failover.</p>
      <div class="flex justify-end">
        <button type="submit" class="r-btn-primary cursor-pointer">Save</button>
      </div>
    </form>
  </section>

  <!-- ── Alert thresholds ───────────────────────────────────── -->
  <section data-settings-pane="alerts" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-2">Alert thresholds</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Override the default alert thresholds at runtime without restart. Leave a field as-is to keep its current value.</p>
    <form method="POST" action="/admin/settings/alert" id="form-alerts" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Node offline threshold (minutes)</label>
        <input name="node_offline_min" type="number" min="1" value="{{.AlertNodeOfflineMin}}" class="r-input tabular-nums">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Node must be unhealthy for at least this many minutes before alerting.</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Cert stuck threshold (minutes)</label>
        <input name="cert_stuck_min" type="number" min="1" value="{{.AlertCertStuckMin}}" class="r-input tabular-nums">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Minutes a cert may stay in pending_ssl before firing a "cert failing" alert.</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Alert cooldown (seconds)</label>
        <input name="cooldown_sec" type="number" min="60" value="{{.AlertCooldownSec}}" class="r-input tabular-nums">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Minimum seconds between repeated fires of the same rule and label combination.</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Manual cert expiry warn (days)</label>
        <input name="manual_cert_days_warn" type="number" min="1" value="{{.AlertManualCertDaysWarn}}" class="r-input tabular-nums">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Days before expiry to alert for manually imported certificates.</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Error rate threshold (0.01 - 1)</label>
        <input name="error_rate_pct" type="number" step="0.01" min="0.01" max="1" value="{{.AlertErrorRatePct}}" class="r-input tabular-nums">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">5xx ratio (fraction of 1) within the window that triggers a high-error-rate alert.</p>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Error rate window (minutes)</label>
        <input name="error_rate_window_min" type="number" min="1" value="{{.AlertErrorRateWindowMin}}" class="r-input tabular-nums">
        <p class="t-caption mt-1" style="color:rgb(var(--muted))">Rolling window size used by the high-error-rate calculation.</p>
      </div>
      <div class="sm:col-span-2 flex justify-end">
        <button type="submit" form="form-alerts" class="r-btn-primary cursor-pointer">Save thresholds</button>
      </div>
    </form>
  </section>

  <!-- ── GeoIP ─────────────────────────────────────────────── -->
  <section data-settings-pane="geoip" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-2">GeoIP database (MaxMind GeoLite2)</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Enter your free MaxMind account ID + license key. The panel downloads GeoLite2-Country daily and distributes it to every Caddy node over the tunnel, so per-route country blocking works without manual file placement.</p>

    <form method="POST" action="/admin/settings/geoip" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">MaxMind account ID</label>
        <input name="account_id" type="text" value="{{.GeoIP.AccountID}}" autocomplete="off" class="r-input tabular-nums">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">License key {{if .GeoIP.Configured}}<span class="r-pill r-pill-success" style="font-size:.6rem">configured</span>{{end}}</label>
        <input name="license_key" type="password" placeholder="{{if .GeoIP.Configured}}leave blank to keep current{{else}}paste license key{{end}}" autocomplete="new-password" class="r-input">
      </div>
      <div class="sm:col-span-2 flex justify-end">
        <button class="r-btn-primary">Save GeoIP credentials</button>
      </div>
    </form>

    <div class="mt-4 pt-4 space-y-3" style="border-top:1px solid rgb(var(--border))">
      <div class="flex items-center gap-2">
        <p class="t-body font-medium" style="color:rgb(var(--text))">Current database</p>
        {{if .GeoIP.Available}}
          <span class="r-pill r-pill-success">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 inline" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Active
          </span>
        {{else}}
          <span class="r-pill r-pill-warning">Not loaded</span>
        {{end}}
      </div>
      {{if .GeoIP.FetchedAt}}
        <dl class="grid gap-x-4 gap-y-1 t-small" style="grid-template-columns:auto 1fr;color:rgb(var(--text))">
          <dt style="color:rgb(var(--muted))">Fetched</dt>
          <dd>{{.GeoIP.FetchedAt}}</dd>
          <dt style="color:rgb(var(--muted))">Size</dt>
          <dd class="tabular-nums">{{.GeoIP.SizeHuman}}</dd>
          <dt style="color:rgb(var(--muted))">SHA-256</dt>
          <dd class="font-mono break-all tabular-nums">{{.GeoIP.SHA256Short}}…</dd>
        </dl>
        {{if not .GeoIP.Available}}
          <p class="t-caption" style="color:rgb(var(--warning))">File downloaded but not yet loaded - restart the panel or trigger a refresh.</p>
        {{end}}
      {{else}}
        <p class="t-caption" style="color:rgb(var(--muted))">No database downloaded yet. Save credentials and click "Refresh database now".</p>
      {{end}}
      {{if .GeoIP.LastError}}
      <div class="r-card" style="background:rgb(var(--danger)/.08);border:1px solid rgb(var(--danger)/.2)">
        <p class="t-caption font-semibold mb-1" style="color:rgb(var(--danger))">Last refresh failed{{if .GeoIP.LastAttempt}} ({{.GeoIP.LastAttempt}}){{end}}</p>
        <p class="font-mono t-small break-all" style="color:rgb(var(--danger))">{{.GeoIP.LastError}}</p>
      </div>
      {{end}}
      <form method="POST" action="/admin/settings/geoip/refresh">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <button {{if not .GeoIP.Configured}}disabled{{end}} class="r-btn-secondary disabled:opacity-50 disabled:cursor-not-allowed">Refresh database now</button>
      </form>
    </div>
  </section>

  <!-- ── SMS ───────────────────────────────────────────────── -->
  <section data-settings-pane="sms" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Delivery</p>
    <h2 class="t-h3 mb-2">SMS provider</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Used for security alerts and (optionally) 2FA SMS fallback. Pick a gateway below - only its fields will be shown.</p>

    <form method="POST" action="/admin/settings/sms">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <!-- sms_provider value is kept in sync by the card-picker JS below -->
      <input type="hidden" id="sms_provider_input" name="sms_provider" value="{{if .SMS.Provider}}{{.SMS.Provider}}{{else}}bulkgate{{end}}">

      <div class="mb-4">
        <label class="r-toggle">
          <input type="checkbox" name="enabled" value="1" {{if .SMS.Enabled}}checked{{end}}>
          <span></span>
          Enable SMS sending
        </label>
      </div>

      <!-- Provider cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-5" id="sms-provider-cards">
        <button type="button" data-sms-card="bulkgate"
          class="sms-provider-card r-card text-left transition-colors cursor-pointer focus:outline-none" style="padding:.75rem">
          <div class="t-body font-semibold mb-0.5" style="color:rgb(var(--text))">BulkGate</div>
          <div class="t-caption" style="color:rgb(var(--muted))">Simple Transactional API. App ID + token, no server setup.</div>
        </button>
        <button type="button" data-sms-card="twilio"
          class="sms-provider-card r-card text-left transition-colors cursor-pointer focus:outline-none" style="padding:.75rem">
          <div class="t-body font-semibold mb-0.5" style="color:rgb(var(--text))">Twilio</div>
          <div class="t-caption" style="color:rgb(var(--muted))">Account SID + Auth Token. Verified sender phone or alphanumeric ID.</div>
        </button>
        <button type="button" data-sms-card="smsapi"
          class="sms-provider-card r-card text-left transition-colors cursor-pointer focus:outline-none" style="padding:.75rem">
          <div class="t-body font-semibold mb-0.5" style="color:rgb(var(--text))">SMSAPI.pl</div>
          <div class="t-caption" style="color:rgb(var(--muted))">OAuth Bearer token. EU-based gateway, Polish-market oriented.</div>
        </button>
        <button type="button" data-sms-card="webhook"
          class="sms-provider-card r-card text-left transition-colors cursor-pointer focus:outline-none" style="padding:.75rem">
          <div class="t-body font-semibold mb-0.5" style="color:rgb(var(--text))">Generic webhook</div>
          <div class="t-caption" style="color:rgb(var(--muted))">HTTP POST to any gateway. Payload: to, from, message fields.</div>
        </button>
      </div>

      <!-- Shared: sender -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Sender (phone or alphanumeric)</label>
          <input name="from" value="{{.SMS.From}}" placeholder="+48555111222 or HostytPxy" class="r-input font-mono">
        </div>
      </div>

      <!-- BulkGate fields -->
      <div id="sms-fields-bulkgate" class="sms-provider-fields grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3 hidden">
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">BulkGate Application ID</label>
          <input name="bulkgate_app_id" value="{{.SMS.BulkGateAppID}}" placeholder="123" class="r-input font-mono" data-sms-required="bulkgate">
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">BulkGate Application Token {{if .SMS.HasBulkGateToken}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
          <input name="bulkgate_app_token" type="password" placeholder="{{if .SMS.HasBulkGateToken}}leave blank to keep{{end}}" class="r-input">
        </div>
      </div>

      <!-- Twilio fields -->
      <div id="sms-fields-twilio" class="sms-provider-fields grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3 hidden">
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Twilio Account SID</label>
          <input name="twilio_account_sid" value="{{.SMS.TwilioAccountSID}}" placeholder="AC..." class="r-input font-mono" data-sms-required="twilio">
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Twilio Auth Token {{if .SMS.HasTwilioToken}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
          <input name="twilio_auth_token" type="password" placeholder="{{if .SMS.HasTwilioToken}}leave blank to keep{{end}}" class="r-input">
        </div>
      </div>

      <!-- SMSAPI fields -->
      <div id="sms-fields-smsapi" class="sms-provider-fields grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3 hidden">
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">SMSAPI base URL</label>
          <input name="smsapi_base_url" value="{{.SMS.SMSAPIBaseURL}}" placeholder="https://api.smsapi.pl" class="r-input font-mono">
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">SMSAPI OAuth token {{if .SMS.HasSMSAPIToken}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
          <input name="smsapi_token" type="password" placeholder="{{if .SMS.HasSMSAPIToken}}leave blank to keep{{end}}" class="r-input" data-sms-required="smsapi">
        </div>
      </div>

      <!-- Webhook fields -->
      <div id="sms-fields-webhook" class="sms-provider-fields grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3 hidden">
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Webhook URL (any HTTP gateway)</label>
          <input name="webhook_url" value="{{.SMS.WebhookURL}}" placeholder="https://sms-gw.example.com/send" class="r-input font-mono" data-sms-required="webhook">
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Webhook Bearer token {{if .SMS.HasWebhookToken}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
          <input name="webhook_token" type="password" placeholder="{{if .SMS.HasWebhookToken}}leave blank to keep{{end}}" class="r-input">
        </div>
      </div>

      <div class="flex justify-end">
        <button class="r-btn-primary">Save SMS</button>
      </div>
    </form>

    <!-- Test SMS -->
    <form method="POST" action="/admin/settings/sms/test" class="mt-4 flex flex-wrap items-end gap-2" style="border-top:1px solid rgb(var(--border));padding-top:1rem">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="flex-1" style="min-width:14rem">
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Send a test SMS to (E.164)</label>
        <input name="test_phone" placeholder="+48555111222" class="r-input font-mono">
      </div>
      <button class="r-btn-secondary">Send test SMS</button>
    </form>

    <!-- SMS 2FA -->
    <form method="POST" action="/admin/settings/sms-otp" class="mt-4 space-y-3" style="border-top:1px solid rgb(var(--border));padding-top:1rem">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="sms_otp_available" value="1" {{if .SMSOTPAvailable}}checked{{end}}>
        <span></span>
        Allow customers to use SMS as a second factor (2FA). Requires SMS configured above and phone set on the account.
      </label>
      <div class="flex justify-end">
        <button class="r-btn-primary">Save SMS 2FA setting</button>
      </div>
    </form>

    <div style="border-top:1px solid rgb(var(--border));margin-top:1.25rem;padding-top:1.25rem;">
      <p class="t-eyebrow mb-2" style="color:rgb(var(--muted))">Customer portal</p>
      <form method="POST" action="/admin/settings/customer-fields" class="space-y-3">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <label class="r-toggle">
          <input type="checkbox" name="phone_enabled" value="1" {{if .CustomerFields.PhoneEnabled}}checked{{end}}>
          <span></span>
          Show <strong>phone</strong> field to customers (E.164) - required for SMS outage alerts and 2FA SMS fallback
        </label>
        <div class="flex justify-end">
          <button class="r-btn-secondary text-sm">Save</button>
        </div>
      </form>
    </div>
  </section>

  <!-- ── SSO Jump ───────────────────────────────────────────── -->
  <section data-settings-pane="sso-jump" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Delivery</p>
    <h2 class="t-h3 mb-2">External SSO jump (signed URL)</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Lets an <strong>external system</strong> (FOSSBilling or any other trusted back-end) sign a URL with a shared HMAC secret to log a customer directly into the panel without a password. Signature: <code class="text-xs">HMAC-SHA256(secret, "email=&lt;email&gt;&amp;exp=&lt;unix&gt;")</code>. <a href="/docs/sso-jump" style="color:rgb(var(--accent))" class="hover:underline">View integration docs →</a></p>
    <p class="t-caption mb-4" style="color:rgb(var(--muted))">To log into a customer account from inside the panel, use <strong>Impersonate</strong> on the Users page.</p>

    {{if .SSOJump.NewSecret}}
    <div id="hpg-sso-secret-modal" class="fixed inset-0 z-[60] flex items-center justify-center p-4" style="background:rgba(0,0,0,.5);backdrop-filter:blur(4px)">
      <div class="r-card shadow-2xl max-w-xl w-full space-y-4" style="border:1px solid rgb(var(--success)/.4)">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="t-h3" style="color:rgb(var(--success))">SSO Jump secret - shown once</h3>
            <p class="t-caption mt-1" style="color:rgb(var(--muted))">Copy this secret into your FOSSBilling <code class="text-xs">HOSTYT_SSO_SECRET</code> env variable. This value will <strong>not</strong> be shown again.</p>
          </div>
          <button type="button" data-sso-secret-close class="cursor-pointer" style="color:rgb(var(--muted));font-size:1.25rem;line-height:1">×</button>
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--muted))">HOSTYT_SSO_SECRET</label>
          <div class="flex gap-2">
            <input id="hpg-sso-secret-val" readonly value="{{.SSOJump.NewSecret}}" class="r-input font-mono flex-1 text-xs">
            <button type="button" data-copy-target="hpg-sso-secret-val" class="r-btn-primary text-xs">Copy</button>
          </div>
        </div>
        <div class="flex justify-end pt-2" style="border-top:1px solid rgb(var(--border))">
          <button type="button" data-sso-secret-close class="r-btn-primary">I've copied - close</button>
        </div>
      </div>
    </div>
    {{end}}

    {{if not .SSOJump.HasSecret}}
    <div class="r-card mb-4 t-small" style="background:rgb(var(--warning)/.1);border:1px solid rgb(var(--warning)/.3);color:rgb(var(--warning))">
      No secret set - generate one below to enable this feature.
    </div>
    {{else}}
    <div class="r-card mb-4 flex items-center gap-2 t-small" style="background:rgb(var(--success)/.08);border:1px solid rgb(var(--success)/.25);color:rgb(var(--success))">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      Secret configured (encrypted at rest). Use the Rotate button to issue a new one.
    </div>
    {{end}}

    <form method="POST" action="/admin/settings/sso-jump" class="space-y-4 mb-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <label class="r-toggle">
        <input type="checkbox" name="sso_jump_enabled" value="1" {{if .SSOJump.Enabled}}checked{{end}}>
        <span></span>
        Enable SSO jump-login
      </label>
      <div>
        <label class="r-toggle">
          <input type="checkbox" name="sso_jump_allow_admin" value="1" {{if .SSOJump.AllowAdmin}}checked{{end}}>
          <span></span>
          Allow admin role login via jump
        </label>
        <p class="t-caption mt-1 ml-9" style="color:rgb(var(--warning))">Disables failsafe - admin accounts will be loggable without password if their email is signed.</p>
      </div>
      <div class="flex justify-end">
        <button class="r-btn-primary">Save settings</button>
      </div>
    </form>

    <div class="space-y-3 pt-4" style="border-top:1px solid rgb(var(--border))">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <span class="t-body font-medium" style="color:rgb(var(--text))">Shared secret</span>
        <form method="POST" action="/admin/settings/sso-jump/rotate" class="inline" data-confirm="{{if .SSOJump.HasSecret}}Rotate secret? This invalidates your current FOSSBilling configuration - you must update HOSTYT_SSO_SECRET there.{{end}}">
          <input type="hidden" name="csrf_token" value="{{.CSRF}}">
          <button class="{{if .SSOJump.HasSecret}}r-btn-danger{{else}}r-btn-primary{{end}} text-xs">
            {{if .SSOJump.HasSecret}}Rotate secret{{else}}Generate secret{{end}}
          </button>
        </form>
      </div>
      <div>
        <p class="t-caption mb-1" style="color:rgb(var(--muted))">Example callback URL (computed from APP_URL)</p>
        <div class="r-card" style="background:rgb(var(--surface-2));padding:.5rem .75rem">
          <code class="block text-xs break-all font-mono tabular-nums" style="color:rgb(var(--text))">{{.SSOJump.CallbackURLEx}}</code>
        </div>
      </div>
    </div>
  </section>

</div>
<script nonce="{{.CSPNonce}}">
(function(){
  var tabs = document.querySelectorAll('[data-settings-tab]');
  var panes = document.querySelectorAll('[data-settings-pane]');
  function activate(name){
    tabs.forEach(function(b){
      var on = b.dataset.settingsTab === name;
      b.classList.toggle('is-active', on);
    });
    panes.forEach(function(p){ p.classList.toggle('hidden', p.dataset.settingsPane !== name); });
    try { history.replaceState(null, '', '#'+name); } catch(e){}
    try { localStorage.setItem('settings_tab', name); } catch(e){}
  }
  function knownTab(name){ for (var i=0;i<tabs.length;i++){ if (tabs[i].dataset.settingsTab === name) return true; } return false; }
  tabs.forEach(function(b){ b.addEventListener('click', function(){ activate(b.dataset.settingsTab); }); });
  var hash = (location.hash || '').replace('#','');
  var qtab = new URLSearchParams(location.search).get('tab') || '';
  var saved = '';
  try { saved = localStorage.getItem('settings_tab') || ''; } catch(e){}
  if (hash && knownTab(hash)) activate(hash);
  else if (qtab && knownTab(qtab)) activate(qtab);
  else if (saved && knownTab(saved)) activate(saved);

  // Appearance picker
  var paletteCards = document.querySelectorAll('[data-palette-card]');
  function activePill(){
    var s = document.createElement('span');
    s.className = 'r-pill r-pill-info';
    s.style.cssText = 'font-size:.6rem;padding:.15rem .4rem';
    s.textContent = 'Active';
    return s;
  }
  function markPaletteActive(slug){
    paletteCards.forEach(function(card){
      var on = card.dataset.paletteCard === slug;
      card.style.border = on ? '1px solid rgb(var(--accent))' : '1px solid rgb(var(--border))';
      var row = card.querySelector('.items-center.justify-between');
      if (!row) return;
      var pill = row.querySelector('[data-palette-active-pill]');
      if (on && !pill){ var p = activePill(); p.setAttribute('data-palette-active-pill',''); row.appendChild(p); }
      else if (!on && pill){ pill.remove(); }
    });
  }
  paletteCards.forEach(function(a){
    a.addEventListener('click', function(){
      var slug = a.dataset.palettePick;
      try { localStorage.setItem('ui_theme', slug); } catch(e){}
      try { localStorage.setItem('settings_tab', 'branding'); } catch(e){}
      document.documentElement.dataset.theme = slug;
      markPaletteActive(slug);
    });
  });

  // SMS provider card picker
  var providerInput = document.getElementById('sms_provider_input');
  var cards = document.querySelectorAll('[data-sms-card]');

  function applyCardStyles(card, active) {
    card.style.outline = active ? '2px solid rgb(var(--accent))' : '';
    card.style.background = active ? 'rgb(var(--accent-weak))' : '';
  }

  function selectProvider(id) {
    if (providerInput) providerInput.value = id;
    document.querySelectorAll('.sms-provider-fields').forEach(function(div) {
      var match = div.id === 'sms-fields-' + id;
      div.classList.toggle('hidden', !match);
      div.querySelectorAll('[data-sms-required]').forEach(function(inp) {
        if (inp.type !== 'password') inp.required = match;
      });
    });
    cards.forEach(function(c) { applyCardStyles(c, c.dataset.smsCard === id); });
  }

  if (cards.length && providerInput) {
    cards.forEach(function(c) {
      c.addEventListener('click', function() { selectProvider(c.dataset.smsCard); });
    });
    selectProvider(providerInput.value || 'bulkgate');
  }

  // AI provider card picker
  (function(){
    var aiInput = document.getElementById('ai-provider-input');
    var aiCards = document.querySelectorAll('[data-ai-card]');
    function paintAICard(card, active) {
      card.style.borderColor = active ? 'rgb(var(--accent))' : 'rgb(var(--border))';
      card.style.background  = active ? 'rgb(var(--accent)/.12)' : 'rgb(var(--surface-2)/.4)';
      card.style.boxShadow   = active ? '0 0 0 1px rgb(var(--accent))' : 'none';
    }
    function selectAIProvider(id) {
      if (aiInput) aiInput.value = id;
      document.querySelectorAll('.ai-provider-fields').forEach(function(div) {
        div.classList.toggle('hidden', div.id !== 'ai-fields-' + id);
      });
      aiCards.forEach(function(c) { paintAICard(c, c.dataset.aiCard === id); });
    }
    if (aiCards.length) {
      aiCards.forEach(function(c) {
        c.addEventListener('click', function() { selectAIProvider(c.dataset.aiCard); });
      });
      selectAIProvider(aiInput ? (aiInput.value || '') : '');
    }
  })();

  // SMTP preset card picker
  (function(){
    var SMTP_PRESETS = {
      gmail:        { host: 'smtp.gmail.com',         port: '587', enc: 'tls' },
      microsoft365: { host: 'smtp.office365.com',     port: '587', enc: 'tls' },
      sendgrid:     { host: 'smtp.sendgrid.net',      port: '587', enc: 'tls' },
      brevo:        { host: 'smtp-relay.brevo.com',   port: '587', enc: 'tls' },
      mailgun:      { host: 'smtp.mailgun.org',       port: '587', enc: 'tls' }
    };
    var smtpCards = document.querySelectorAll('[data-smtp-preset]');
    var hostEl = document.getElementById('smtp-host');
    var portEl = document.getElementById('smtp-port');
    var encEl  = document.getElementById('smtp-encryption');
    var activePreset = '';
    function paintSMTPCard(card, active) {
      card.style.borderColor = active ? 'rgb(var(--accent))' : 'rgb(var(--border))';
      card.style.background  = active ? 'rgb(var(--accent)/.12)' : 'rgb(var(--surface-2)/.4)';
      card.style.boxShadow   = active ? '0 0 0 1px rgb(var(--accent))' : 'none';
    }
    smtpCards.forEach(function(c) {
      c.addEventListener('click', function() {
        var key = c.dataset.smtpPreset;
        activePreset = key;
        smtpCards.forEach(function(x) { paintSMTPCard(x, x.dataset.smtpPreset === key); });
        var p = SMTP_PRESETS[key];
        if (p) {
          if (hostEl) hostEl.value = p.host;
          if (portEl) portEl.value = p.port;
          if (encEl)  encEl.value  = p.enc;
        }
        // Custom: leave fields as-is, just highlight
      });
    });
  })();

  // OIDC: "Use default" redirect fill button.
  var fillBtn = document.querySelector('[data-oidc-fill-redirect]');
  if (fillBtn) fillBtn.addEventListener('click', function() {
    var el = document.getElementById('oidc-redirect');
    if (el) el.value = fillBtn.dataset.redirect || '';
  });

  // OIDC: "Test discovery" button
  var testBtn = document.getElementById('oidc-test-btn');
  var testResult = document.getElementById('oidc-test-result');
  var oidcForm = document.getElementById('oidc-form');
  if (testBtn && testResult && oidcForm) {
    testBtn.addEventListener('click', function() {
      var issuer = (document.getElementById('oidc-issuer') || {}).value || '';
      var csrf = oidcForm.querySelector('[name=csrf_token]');
      testBtn.disabled = true;
      testBtn.textContent = 'Probing…';
      testResult.classList.remove('hidden');
      testResult.removeAttribute('style');
      testResult.textContent = 'Contacting issuer…';
      var body = new URLSearchParams();
      body.set('issuer', issuer.trim());
      if (csrf) body.set('csrf_token', csrf.value);
      fetch('/admin/settings/oidc/test', {
        method: 'POST',
        credentials: 'same-origin',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json'},
        body: body.toString()
      }).then(function(r){ return r.json().catch(function(){ return {ok:false,error:'invalid JSON response'}; }); })
        .then(function(j){
          testBtn.disabled = false;
          testBtn.textContent = 'Test discovery';
          if (j && j.ok && j.probe) {
            testResult.style.cssText = 'padding:.5rem .75rem;border-radius:.5rem;background:rgb(var(--success)/.1);border:1px solid rgb(var(--success)/.3);color:rgb(var(--success))';
            var p = j.probe;
            testResult.textContent = 'OK. issuer=' + (p.issuer||'') + '  auth=' + (p.authorization_endpoint||'') + '  token=' + (p.token_endpoint||'') + '  jwks=' + (p.jwks_uri||'');
          } else {
            testResult.style.cssText = 'padding:.5rem .75rem;border-radius:.5rem;background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))';
            testResult.textContent = 'Failed: ' + ((j && j.error) || 'unknown error');
          }
        })
        .catch(function(err){
          testBtn.disabled = false;
          testBtn.textContent = 'Test discovery';
          testResult.style.cssText = 'padding:.5rem .75rem;border-radius:.5rem;background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))';
          testResult.textContent = 'Network error: ' + (err && err.message || err);
        });
    });
  }

  // AI assistant: per-provider "Test key" buttons
  (function(){
    var aiForm = document.querySelector('form[action="/admin/settings/ai"]');
    document.querySelectorAll('[data-ai-test]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var provider = btn.dataset.aiTest;
        var result = document.querySelector('[data-ai-test-result="'+provider+'"]');
        var csrf = aiForm ? aiForm.querySelector('[name=csrf_token]') : null;
        btn.disabled = true;
        var prev = btn.textContent;
        btn.textContent = 'Testing…';
        if (result){ result.classList.remove('hidden'); result.removeAttribute('style'); result.textContent = 'Contacting provider…'; }
        var body = new URLSearchParams();
        body.set('provider', provider);
        if (csrf) body.set('csrf_token', csrf.value);
        fetch('/admin/settings/ai/test', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json'},
          body: body.toString()
        }).then(function(r){ return r.json().catch(function(){ return {ok:false,error:'invalid JSON response'}; }); })
          .then(function(j){
            btn.disabled = false; btn.textContent = prev;
            if (!result) return;
            if (j && j.ok){
              result.style.cssText = 'padding:.35rem .6rem;border-radius:.5rem;background:rgb(var(--success)/.1);border:1px solid rgb(var(--success)/.3);color:rgb(var(--success))';
              result.textContent = 'OK - key works' + (j.model ? ' (model: ' + j.model + ').' : '.');
            } else {
              result.style.cssText = 'padding:.35rem .6rem;border-radius:.5rem;background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))';
              result.textContent = 'Failed: ' + ((j && j.error) || 'unknown error');
            }
          })
          .catch(function(err){
            btn.disabled = false; btn.textContent = prev;
            if (!result) return;
            result.style.cssText = 'padding:.35rem .6rem;border-radius:.5rem;background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))';
            result.textContent = 'Network error: ' + (err && err.message || err);
          });
      });
    });
  })();

  // AI assistant: per-provider "Refresh models" buttons
  (function(){
    document.querySelectorAll('[data-ai-models-refresh]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var provider = btn.dataset.aiModelsRefresh;
        var sel = document.querySelector('[data-ai-model="'+provider+'"]');
        var status = document.querySelector('[data-ai-models-status="'+provider+'"]');
        var saved = sel ? (sel.dataset.aiModelSaved || '') : '';
        btn.disabled = true;
        var prev = btn.textContent;
        btn.textContent = 'Loading…';
        if (status){ status.classList.remove('hidden'); status.removeAttribute('style'); status.textContent = 'Fetching available models…'; }
        fetch('/admin/settings/ai/models?provider=' + encodeURIComponent(provider), {
          method: 'GET', credentials: 'same-origin', headers: {'Accept': 'application/json'}
        }).then(function(r){ return r.json().catch(function(){ return {error:'invalid JSON response'}; }); })
          .then(function(j){
            btn.disabled = false; btn.textContent = prev;
            if (j && j.error){
              if (status){ status.style.cssText = 'padding:.35rem .6rem;border-radius:.5rem;background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))'; status.textContent = 'Failed: ' + j.error; }
              return;
            }
            var models = (j && j.models) || [];
            var dl = document.getElementById('ai-mdl-' + provider);
            if (dl) {
              dl.innerHTML = '<option value=""></option>';
              var hasSaved = false;
              models.forEach(function(m){
                var o = document.createElement('option');
                o.value = m;
                if (m === saved) hasSaved = true;
                dl.appendChild(o);
              });
              if (saved && !hasSaved) {
                var o2 = document.createElement('option');
                o2.value = saved;
                dl.appendChild(o2);
              }
            }
            if (status){ status.style.color = 'rgb(var(--success))'; status.textContent = models.length + ' models loaded.'; }
          })
          .catch(function(err){
            btn.disabled = false; btn.textContent = prev;
            if (status){ status.style.cssText = 'padding:.35rem .6rem;border-radius:.5rem;background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))'; status.textContent = 'Network error: ' + (err && err.message || err); }
          });
      });
    });
  })();

  // SSO Jump: copy button + close modal
  (function(){
    function copy(id){
      var el = document.getElementById(id);
      if (!el) return;
      el.select(); el.setSelectionRange(0, 99999);
      try { navigator.clipboard.writeText(el.value); }
      catch(e){ document.execCommand && document.execCommand('copy'); }
      window.hpgToast && window.hpgToast('Copied', 'ok');
    }
    document.querySelectorAll('[data-copy-target]').forEach(function(b){
      b.addEventListener('click', function(){ copy(b.dataset.copyTarget); });
    });
    document.querySelectorAll('[data-sso-secret-close]').forEach(function(b){
      b.addEventListener('click', function(){
        var m = document.getElementById('hpg-sso-secret-modal');
        if (m) m.remove();
        var u = new URL(window.location.href);
        u.searchParams.delete('show_sso_secret');
        window.history.replaceState({}, '', u.toString());
      });
    });
  })();
})();
</script>

<section data-settings-pane="banner" class="hpg-settings-pane hidden r-card">
  <p class="t-eyebrow mb-1">Developer</p>
  <h2 class="t-h3 mb-2">System announcement</h2>
  <p class="t-small mb-4" style="color:rgb(var(--muted))">Displays a banner on every page for all users (admin and client portal). Leave blank to clear the announcement.</p>
  <form method="POST" action="/admin/settings/banner" class="space-y-4">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <div>
      <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Message</label>
      <textarea name="banner_text" rows="3" placeholder="Leave blank to clear the announcement" class="r-input">{{.SystemBannerText}}</textarea>
    </div>
    <div>
      <label class="block t-caption font-medium mb-2" style="color:rgb(var(--text))">Type</label>
      <div class="flex gap-4">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="banner_type" value="info" {{if or (eq .SystemBannerType "info") (eq .SystemBannerType "")}}checked{{end}}>
          <span class="r-pill r-pill-info">Info</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="banner_type" value="warning" {{if eq .SystemBannerType "warning"}}checked{{end}}>
          <span class="r-pill r-pill-warning">Warning</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="banner_type" value="error" {{if eq .SystemBannerType "error"}}checked{{end}}>
          <span class="r-pill r-pill-danger">Error</span>
        </label>
      </div>
    </div>
    <div>
      <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Link URL (optional)</label>
      <input name="banner_link" type="url" value="{{.SystemBannerLink}}" placeholder="https://example.com/status" class="r-input">
    </div>
    <div>
      <label class="block t-caption font-medium mb-1" style="color:rgb(var(--text))">Link label (optional)</label>
      <input name="banner_link_label" value="{{.SystemBannerLinkLabel}}" placeholder="View details" class="r-input">
    </div>
    <div class="flex justify-end">
      <button class="r-btn-primary">Save</button>
    </div>
  </form>
</section>

<section data-settings-pane="instances" class="hpg-settings-pane hidden r-card">
  <p class="t-eyebrow mb-1">Multi-instance</p>
  <h2 class="t-h3 mb-2">Instance sync</h2>
  {{if .IsSlaveMode}}
  <div class="r-alert r-alert-info mb-4">This instance runs in <strong>slave mode</strong>. Config writes are disabled; it receives sync pushes from the master.</div>
  {{end}}
  <p class="t-muted mb-4">Register slave HPG instances. After every route, WAF, or cert save the master sends a push trigger so slaves re-apply config to their Caddy nodes.</p>
  {{if not .IsSlaveMode}}
  {{if .Slaves}}
  <table class="r-table mb-6 w-full">
    <thead><tr><th>Name</th><th>URL</th><th>Last sync</th><th>Status</th><th></th></tr></thead>
    <tbody>
    {{range .Slaves}}
    <tr>
      <td class="font-medium">{{.Name}}</td>
      <td class="t-muted text-xs">{{.URL}}</td>
      <td class="t-muted text-xs">{{if .LastSyncAt}}{{.LastSyncAt}}{{else}}-{{end}}</td>
      <td>
        {{if eq .LastSyncStatus "ok"}}<span class="r-pill r-pill-success">ok</span>
        {{else if eq .LastSyncStatus "error"}}<span class="r-pill r-pill-danger" title="{{.LastSyncError}}">error</span>
        {{else}}<span class="r-pill r-pill-neutral">-</span>{{end}}
      </td>
      <td class="text-right space-x-2">
        <form method="POST" action="/admin/settings/instances/{{.ID}}/sync" class="inline">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button class="r-btn r-btn-sm r-btn-secondary cursor-pointer" type="submit">Sync</button>
        </form>
        <form method="POST" action="/admin/settings/instances/{{.ID}}/delete" class="inline">
          <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
          <button class="r-btn r-btn-sm r-btn-danger cursor-pointer" type="submit">Remove</button>
        </form>
      </td>
    </tr>
    {{end}}
    </tbody>
  </table>
  {{else}}
  <p class="t-muted mb-4">No slave instances registered.</p>
  {{end}}
  <p class="t-eyebrow mb-2">Add slave instance</p>
  <p class="t-muted text-xs mb-3">Generate a random token, configure <code>HPG_SLAVE=1</code> and <code>HPG_SLAVE_TOKEN=&lt;token&gt;</code> on the slave, then register it here.</p>
  <form method="POST" action="/admin/settings/instances" class="space-y-3 max-w-lg">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <div>
      <label class="r-label">Name</label>
      <input class="r-input" name="name" placeholder="eu-slave-1" required>
    </div>
    <div>
      <label class="r-label">Slave panel URL</label>
      <input class="r-input" name="url" type="url" placeholder="https://panel.eu.example.com" required>
    </div>
    <div>
      <label class="r-label">Pre-shared token</label>
      <input class="r-input" name="token" placeholder="paste HPG_SLAVE_TOKEN value" required>
