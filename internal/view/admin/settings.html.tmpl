  <!-- ── CAPTCHA ───────────────────────────────────────────── -->
  <section data-settings-pane="captcha" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Auth &amp; access</p>
    <h2 class="t-h3 mb-2">CAPTCHA on login</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Protect the login form from bots. Pick a provider, paste its keys, save. Pick <b>None</b> to disable.</p>
    <form method="POST" action="/admin/settings/turnstile" id="captcha-form">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <input type="hidden" name="provider" id="captcha-provider" value="{{.Turnstile.Provider}}">

      <!-- Provider picker: clickable cards; selected one fills with the accent. -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 mb-5">
        <button type="button" class="captcha-card text-left rounded-xl border p-3 cursor-pointer transition" data-provider="" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
          <span class="block text-sm font-medium" style="color:rgb(var(--text))">None</span>
          <span class="block t-caption" style="color:rgb(var(--muted))">CAPTCHA off</span>
        </button>
        <button type="button" class="captcha-card text-left rounded-xl border p-3 cursor-pointer transition" data-provider="turnstile" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
          <span class="block text-sm font-medium" style="color:rgb(var(--text))">Cloudflare Turnstile</span>
          <span class="block t-caption" style="color:rgb(var(--muted))">Free, privacy-first</span>
        </button>
        <button type="button" class="captcha-card text-left rounded-xl border p-3 cursor-pointer transition" data-provider="hcaptcha" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
          <span class="block text-sm font-medium" style="color:rgb(var(--text))">hCaptcha</span>
          <span class="block t-caption" style="color:rgb(var(--muted))">Privacy-focused</span>
        </button>
        <button type="button" class="captcha-card text-left rounded-xl border p-3 cursor-pointer transition" data-provider="recaptcha" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
          <span class="block text-sm font-medium" style="color:rgb(var(--text))">Google reCAPTCHA</span>
          <span class="block t-caption" style="color:rgb(var(--muted))">v2 checkbox</span>
        </button>
      </div>

      <!-- Keys: hidden when None is selected. -->
      <div id="captcha-keys" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <p id="captcha-help" class="sm:col-span-2 t-caption" style="color:rgb(var(--muted))"></p>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Site key (public)</label>
          <input name="site_key" value="{{.Turnstile.SiteKey}}" class="r-input font-mono">
        </div>
        <div>
          <label class="block t-caption mb-1" style="color:rgb(var(--text))">Secret key {{if .Turnstile.HasSecret}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
          <input name="secret" type="password" placeholder="{{if .Turnstile.HasSecret}}leave blank to keep{{end}}" class="r-input">
        </div>
      </div>

      <div class="flex justify-end mt-5">
        <button class="r-btn-primary">Save CAPTCHA</button>
      </div>
    </form>
  </section>
  <script nonce="{{.CSPNonce}}">
  (function(){
    var form = document.getElementById('captcha-form');
    if (!form) return;
    var hidden = document.getElementById('captcha-provider');
    var keys   = document.getElementById('captcha-keys');
    var help   = document.getElementById('captcha-help');
    var cards  = form.querySelectorAll('.captcha-card');
    var secret = form.querySelector('input[name="secret"]');
    var saved  = hidden.value || '';        // provider stored on the server
    var secretPH = secret ? secret.getAttribute('placeholder') : '';
    var HELP = {
      turnstile: 'Get keys from the Cloudflare dashboard → Turnstile.',
      hcaptcha:  'Get keys from the hCaptcha dashboard → Sites.',
      recaptcha: 'Get keys from Google reCAPTCHA admin (use reCAPTCHA v2 “I’m not a robot”).'
    };
    function paint(prov){
      cards.forEach(function(c){
        var on = c.getAttribute('data-provider') === prov;
        c.style.borderColor = on ? 'rgb(var(--accent))' : 'rgb(var(--border))';
        c.style.background  = on ? 'rgb(var(--accent)/.12)' : 'rgb(var(--surface-2)/.4)';
        c.style.boxShadow   = on ? '0 0 0 1px rgb(var(--accent))' : 'none';
      });
      hidden.value = prov;
      var none = (prov === '');
      keys.style.display = none ? 'none' : '';
      if (!none && help) help.textContent = HELP[prov] || '';
      // Secrets are provider-specific: switching providers needs a fresh secret.
      if (secret) secret.setAttribute('placeholder', (!none && prov !== saved) ? 'Required - enter this provider’s secret' : secretPH);
    }
    cards.forEach(function(c){
      c.addEventListener('click', function(){ paint(c.getAttribute('data-provider')); });
    });
    paint(hidden.value || '');
  })();
  </script>

  <!-- ── Cloudflare ─────────────────────────────────────────── -->
  <section data-settings-pane="cloudflare" class="hpg-settings-pane hidden r-card">
    <p class="t-eyebrow mb-1">Infrastructure</p>
    <h2 class="t-h3 mb-2">Cloudflare account integration</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Account-level Cloudflare integration: an API token (verified on save) lets the panel call Cloudflare APIs, and the IP-trust toggle instructs Caddy to read real client IPs from the <code class="text-xs">CF-Connecting-IP</code> header when proxied through Cloudflare. This is <strong>not</strong> the same as the per-zone DNS credentials used for ACME DNS-01 wildcard certificates - those are configured per-domain in the DNS providers section.</p>
    <form method="POST" action="/admin/settings/cloudflare" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="enabled" value="1" {{if .Cloudflare.Enabled}}checked{{end}}>
          <span></span>
          Cloudflare integration enabled
        </label>
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">Account ID</label>
        <input name="account_id" value="{{.Cloudflare.AccountID}}" class="r-input font-mono">
      </div>
      <div>
        <label class="block t-caption mb-1" style="color:rgb(var(--text))">API token {{if .Cloudflare.HasToken}}<span class="r-pill r-pill-success" style="font-size:.6rem">saved</span>{{end}}</label>
        <input name="api_token" type="password" placeholder="{{if .Cloudflare.HasToken}}leave blank to keep{{end}}" class="r-input">
      </div>
      <div class="sm:col-span-2">
        <label class="r-toggle">
          <input type="checkbox" name="trust_connecting_ip" value="1" {{if .Cloudflare.TrustConnectingIP}}checked{{end}}>
          <span></span>
          Trust <code class="text-xs" style="background:rgb(var(--surface-2));padding:.1rem .3rem;border-radius:.25rem">CF-Connecting-IP</code> header (only when this app sits behind Cloudflare)
        </label>
      </div>
      <div class="sm:col-span-2 flex justify-end">
        <button class="r-btn-primary">Verify token &amp; save</button>
      </div>
    </form>
  </section>

  <!-- ── AI assistant ───────────────────────────────────────── -->
  <section data-settings-pane="ai" class="hpg-settings-pane hidden r-card">
    <div class="flex items-center gap-2 mb-1">
      <span class="icon-chip" style="background:rgb(var(--accent-weak))">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" style="color:rgb(var(--accent))"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
      </span>
      <p class="t-eyebrow">Developer</p>
    </div>
    <h2 class="t-h3 mb-2">AI assistant</h2>
    <p class="t-small mb-4" style="color:rgb(var(--muted))">Configure an LLM provider for the in-app assistant. API keys are stored AES-256-GCM encrypted at rest and never shown again - leave a field blank to keep the existing key. Use <strong>Test</strong> to verify a saved key with a minimal request.</p>
    <form method="POST" action="/admin/settings/ai" class="space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <!-- hidden input kept in sync by the card-picker JS below; Go handler reads "default_provider" -->
      <input type="hidden" id="ai-provider-input" name="default_provider" value="{{.AI.DefaultProvider}}">

      <!-- Provider cards -->
      <div>
        <p class="t-caption mb-2" style="color:rgb(var(--text))">Default provider</p>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-2" id="ai-provider-cards">
          <button type="button" class="ai-provider-card text-left rounded-xl border p-3 cursor-pointer transition" data-ai-card="anthropic" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
            <span class="block text-sm font-medium" style="color:rgb(var(--text))">Anthropic</span>
            <span class="block t-caption" style="color:rgb(var(--muted))">Claude models</span>
          </button>
          <button type="button" class="ai-provider-card text-left rounded-xl border p-3 cursor-pointer transition" data-ai-card="openai" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
            <span class="block text-sm font-medium" style="color:rgb(var(--text))">OpenAI</span>
            <span class="block t-caption" style="color:rgb(var(--muted))">GPT models</span>
          </button>
          <button type="button" class="ai-provider-card text-left rounded-xl border p-3 cursor-pointer transition" data-ai-card="gemini" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
            <span class="block text-sm font-medium" style="color:rgb(var(--text))">Google Gemini</span>
            <span class="block t-caption" style="color:rgb(var(--muted))">Gemini models</span>
          </button>
          <button type="button" class="ai-provider-card text-left rounded-xl border p-3 cursor-pointer transition" data-ai-card="openrouter" style="border-color:rgb(var(--border));background:rgb(var(--surface-2)/.4)">
            <span class="block text-sm font-medium" style="color:rgb(var(--text))">OpenRouter</span>
            <span class="block t-caption" style="color:rgb(var(--muted))">Multi-model gateway</span>
          </button>
        </div>
        <p class="t-caption mt-2" style="color:rgb(var(--muted))">The assistant uses this provider's key unless overridden.</p>
      </div>

      <!-- Per-provider field blocks; only the selected one is shown -->
      {{range .AI.Providers}}
      <div id="ai-fields-{{.ID}}" class="ai-provider-fields r-card hidden" style="background:rgb(var(--surface-2)/.5)">
        <div class="flex items-center justify-between mb-3">
          <span class="t-body font-medium" style="color:rgb(var(--text))">{{.Label}}</span>
          {{if .Configured}}
          <span class="r-pill r-pill-success">Key configured</span>
          {{else}}
          <span class="r-pill r-pill-neutral">Not set</span>
          {{end}}
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center gap-2">
          <input name="key_{{.ID}}" type="password" autocomplete="new-password" placeholder="{{if .Configured}}leave blank to keep{{else}}paste API key{{end}}" class="r-input font-mono flex-1">
          <button type="button" data-ai-test="{{.ID}}" class="r-btn-secondary cursor-pointer whitespace-nowrap">Test key</button>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 mt-2">
          <label class="t-caption shrink-0" style="min-width:4rem;color:rgb(var(--muted))">Model</label>
          <input type="text" name="model_{{.ID}}" data-ai-model="{{.ID}}" data-ai-model-saved="{{.Model}}"
            value="{{.Model}}" list="ai-mdl-{{.ID}}"
            placeholder="Default ({{if eq .ID "anthropic"}}claude-3-5-haiku-latest{{else if eq .ID "openai"}}gpt-4o-mini{{else if eq .ID "gemini"}}gemini-1.5-flash{{else}}openai/gpt-4o-mini{{end}})"
            class="r-input flex-1" style="font-size:.75rem" autocomplete="off">
          <datalist id="ai-mdl-{{.ID}}">
            <option value=""></option>
            {{if .Model}}<option value="{{.Model}}"></option>{{end}}
          </datalist>
          <button type="button" data-ai-models-refresh="{{.ID}}" class="r-btn-secondary cursor-pointer whitespace-nowrap">Refresh models</button>
        </div>
        {{if .Configured}}<label class="r-toggle mt-2" style="font-size:.75rem;color:rgb(var(--danger))"><input type="checkbox" name="clear_{{.ID}}" value="1"><span></span>Remove stored key on save</label>{{end}}
        <p data-ai-models-status="{{.ID}}" class="hidden mt-2 t-caption"></p>
        <p data-ai-test-result="{{.ID}}" class="hidden mt-2 t-caption"></p>
      </div>
      {{end}}

      <div class="flex justify-end">
        <button class="r-btn-primary cursor-pointer">Save AI settings</button>
      </div>
    </form>
  </section>

  <!-- ── WireGuard ─────────────────────────────────────────── -->
