          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Sender (phone or alphanumeric)</label>
          <input name="from" value="{{.SMS.From}}" placeholder="+48555111222 or HostytPxy"
            class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 font-mono">
