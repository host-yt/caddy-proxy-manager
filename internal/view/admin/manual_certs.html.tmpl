{{define "manual_certs"}}
<div class="space-y-6">

  {{if .Flash}}
  <div class="rounded-xl bg-emerald-50 dark:bg-emerald-950/40 ring-1 ring-emerald-200 dark:ring-emerald-800/60 p-3 text-sm text-emerald-800 dark:text-emerald-200">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="rounded-xl bg-rose-50 dark:bg-rose-950/40 ring-1 ring-rose-200 dark:ring-rose-800/60 p-3 text-sm text-rose-800 dark:text-rose-200">{{.Error}}</div>
  {{end}}

  <!-- Imported cert list -->
  <section class="hpg-card overflow-x-auto p-0">
    <div class="p-4 border-b border-slate-100 dark:border-zinc-800 flex items-center justify-between">
      <div>
        <h2 class="font-semibold text-slate-800 dark:text-slate-100">Manually imported certificates <span class="font-normal text-slate-400">({{.Total}})</span></h2>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Private keys are encrypted at rest. Certs expiring within 30 days are flagged.</p>
      </div>
    </div>
    <table class="w-full text-sm">
      <thead class="text-left hpg-eyebrow">
        <tr>
          <th class="px-4 py-3">Name / CN</th>
          <th class="px-4 py-3">SANs</th>
          <th class="px-4 py-3">Valid from</th>
          <th class="px-4 py-3">Expires</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-zinc-800">
      {{range .Certs}}
        <tr>
          <td class="px-4 py-3">
            <p class="font-medium text-slate-800 dark:text-slate-100 text-xs">{{if .Name}}{{.Name}}{{else}}<span class="text-slate-400">—</span>{{end}}</p>
            <p class="font-mono text-[11px] text-slate-500 dark:text-slate-400">{{.CommonName}}</p>
          </td>
          <td class="px-4 py-3 text-[11px] font-mono text-slate-500 dark:text-slate-400 max-w-xs">
            {{range .SANs}}<span class="mr-1">{{.}}</span>{{end}}
          </td>
          <td class="px-4 py-3 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">{{.NotBefore}}</td>
          <td class="px-4 py-3 text-xs whitespace-nowrap {{if eq .Status "expired"}}text-rose-600 dark:text-rose-400 font-medium{{else if eq .Status "warn"}}text-amber-600 dark:text-amber-400 font-medium{{else}}text-slate-600 dark:text-slate-300{{end}}">
            {{.NotAfter}}
            {{if ge .DaysLeft 0}}<span class="text-slate-400">({{.DaysLeft}}d)</span>{{end}}
          </td>
          <td class="px-4 py-3 text-xs">
            {{if eq .Status "expired"}}<span class="hpg-pill hpg-pill-err">expired</span>
            {{else if eq .Status "warn"}}<span class="hpg-pill hpg-pill-warn">expiring soon</span>
            {{else}}<span class="hpg-pill hpg-pill-ok">valid</span>{{end}}
          </td>
          <td class="px-4 py-3 text-right text-xs whitespace-nowrap">
            <form method="POST" action="/admin/manual-certs/{{.ID}}/delete" class="inline" data-confirm="Delete this certificate?">
              <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
              <button class="text-rose-600 dark:text-rose-400 hover:underline cursor-pointer">delete</button>
            </form>
          </td>
        </tr>
      {{else}}
        <tr><td colspan="6" class="px-4 py-10 text-center text-slate-500 dark:text-slate-400">No manually imported certificates yet.</td></tr>
      {{end}}
      </tbody>
    </table>
  </section>

  <!-- Import form -->
  <section class="hpg-card p-5">
    <h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1">Import certificate</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">Paste PEM-encoded blocks. The private key is validated against the certificate and stored encrypted at rest.</p>
    <form method="POST" action="/admin/manual-certs/import" class="space-y-4 max-w-3xl text-sm">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Label (optional)</label>
          <input name="name" placeholder="e.g. wildcard *.example.com"
            class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
        </div>
        <div>
          <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Linked proxy route ID (optional)</label>
          <input name="route_id" placeholder="e.g. 42" type="number" min="1"
            class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 text-sm">
        </div>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Certificate PEM <span class="text-rose-500">*</span></label>
        <textarea name="cert_pem" required rows="8" placeholder="-----BEGIN CERTIFICATE-----&#10;...&#10;-----END CERTIFICATE-----"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 font-mono text-xs resize-y"></textarea>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Private key PEM <span class="text-rose-500">*</span></label>
        <textarea name="key_pem" required rows="8" placeholder="-----BEGIN EC PRIVATE KEY-----&#10;...&#10;-----END EC PRIVATE KEY-----"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 font-mono text-xs resize-y"></textarea>
      </div>
      <div>
        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Certificate chain PEM (optional — intermediate CAs)</label>
        <textarea name="chain_pem" rows="5" placeholder="-----BEGIN CERTIFICATE-----&#10;... intermediate CA ...&#10;-----END CERTIFICATE-----"
          class="w-full px-3 py-2 rounded-lg ring-1 ring-slate-200 dark:ring-zinc-700 border-0 bg-slate-50 dark:bg-zinc-800/50 focus:ring-2 focus:ring-indigo-500 dark:text-slate-100 font-mono text-xs resize-y"></textarea>
      </div>
      <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors cursor-pointer">Import certificate</button>
    </form>
  </section>

</div>
<script nonce="{{.CSPNonce}}">
// Warn before navigating away with text in key textarea (prevent accidental key loss).
(function() {
  var keyTA = document.querySelector('textarea[name="key_pem"]');
  if (!keyTA) return;
  window.addEventListener('beforeunload', function(e) {
    if (keyTA.value.trim()) {
      e.preventDefault();
      e.returnValue = '';
    }
  });
  // Clear the key field after successful form submission so it is not cached.
  keyTA.closest('form').addEventListener('submit', function() {
    window.removeEventListener('beforeunload', arguments.callee);
  });
})();
</script>
{{end}}
