{{define "manual_certs"}}
<div class="space-y-6">

  {{if .Flash}}
  <div class="rounded-xl p-3 t-small" style="background:rgb(var(--success)/.1);border:1px solid rgb(var(--success)/.3);color:rgb(var(--success))">{{.Flash}}</div>
  {{end}}
  {{if .Error}}
  <div class="rounded-xl p-3 t-small" style="background:rgb(var(--danger)/.1);border:1px solid rgb(var(--danger)/.3);color:rgb(var(--danger))">{{.Error}}</div>
  {{end}}

  <!-- Imported cert list -->
  <div class="r-card overflow-x-auto !p-0">
    <div class="px-5 py-4 flex items-center justify-between" style="border-bottom:1px solid rgb(var(--border))">
      <div>
        <h2 class="t-h3">Manually imported certificates <span class="t-small font-normal" style="color:rgb(var(--muted))">({{.Total}})</span></h2>
        <p class="t-caption mt-0.5" style="color:rgb(var(--muted))">Private keys are encrypted at rest. Certs expiring within 30 days are flagged. A cert linked to a route is served by that route's edge node(s); unlinked certs are stored only.</p>
      </div>
    </div>
    <!-- Filter bar -->
    <div class="px-5 py-3 flex flex-wrap items-center gap-2" style="border-bottom:1px solid rgb(var(--border))">
      <input type="search" id="cert-search" placeholder="Name or common name..."
             class="r-input" style="width:13rem">
      <select id="cert-status" class="r-select">
        <option value="">All</option>
        <option value="valid">Valid</option>
        <option value="expiring">Expiring Soon</option>
        <option value="expired">Expired</option>
      </select>
      <span id="cert-filter-count" class="t-caption" style="color:rgb(var(--muted))"></span>
    </div>
    <table class="r-table">
      <thead>
        <tr>
          <th>Name / CN</th>
          <th>SANs</th>
          <th>Valid from</th>
          <th>Expires</th>
          <th>Status</th>
          <th class="text-right"></th>
        </tr>
      </thead>
      <tbody id="certs-tbody">
      {{range .Certs}}
        <tr data-name="{{.Name}}" data-cn="{{.CommonName}}" data-status="{{if eq .Status "expired"}}expired{{else if eq .Status "warn"}}expiring{{else}}valid{{end}}">
          <td>
            <p class="t-small font-medium">{{if .Name}}{{.Name}}{{else}}<span style="color:rgb(var(--muted))">&mdash;</span>{{end}}</p>
            <p class="font-mono t-caption" style="color:rgb(var(--muted))">{{.CommonName}}</p>
          </td>
          <td class="font-mono t-caption max-w-xs" style="color:rgb(var(--muted))">
            {{range .SANs}}<span class="mr-1">{{.}}</span>{{end}}
          </td>
          <td class="t-small whitespace-nowrap" style="color:rgb(var(--muted))">{{.NotBefore}}</td>
          <td class="t-small whitespace-nowrap {{if eq .Status "expired"}}font-medium{{else if eq .Status "warn"}}font-medium{{end}}"
              style="color:{{if eq .Status "expired"}}rgb(var(--danger)){{else if eq .Status "warn"}}rgb(var(--warning)){{else}}rgb(var(--muted)){{end}}">
            {{.NotAfter}}
            {{if ge .DaysLeft 0}}<span style="color:rgb(var(--muted))">({{.DaysLeft}}d)</span>{{end}}
          </td>
          <td>
            {{if eq .Status "expired"}}<span class="r-pill r-pill-danger">expired</span>
            {{else if eq .Status "warn"}}<span class="r-pill r-pill-warning">expiring soon</span>
            {{else}}<span class="r-pill r-pill-success">valid</span>{{end}}
          </td>
          <td class="text-right whitespace-nowrap">
            <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="mcert-act-{{.ID}}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
            </button>
            <div id="mcert-act-{{.ID}}" class="hpg-act-menu" role="menu">
              {{if ne .Status "ok"}}
              <button type="button"
                data-action="open-replace-modal"
                data-cert-id="{{.ID}}"
                data-cert-name="{{.Name}}"
                data-route-id="{{if .RouteID.Valid}}{{.RouteID.Int64}}{{else}}{{end}}"
                class="hpg-act-item" role="menuitem">Replace</button>
              {{end}}
              <form method="POST" action="/admin/manual-certs/{{.ID}}/delete" class="contents" data-confirm="Delete this certificate?">
                <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                <button type="submit" class="hpg-act-item is-danger" role="menuitem">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      {{else}}
        <tr>
          <td colspan="6" class="px-4 py-12 text-center">
            <div class="r-empty">
              <span class="r-empty-icon">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
              </span>
              <p class="t-body font-medium mt-2">No manually imported certificates yet</p>
            </div>
          </td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </div>

  <!-- Replace modal - shown only when operator clicks "replace" on an expiring/expired cert -->
  <div id="replace-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,.45);backdrop-filter:blur(4px)" aria-modal="true" role="dialog">
    <div class="r-card w-full max-w-2xl shadow-2xl overflow-y-auto max-h-[90vh]">
      <div class="flex items-center justify-between pb-4 mb-4" style="border-bottom:1px solid rgb(var(--border))">
        <h2 class="t-h3">Replace certificate</h2>
        <button type="button" data-action="close-replace-modal" class="r-btn-ghost cursor-pointer" style="color:rgb(var(--muted))" aria-label="Close">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="replace-form" method="POST" class="space-y-4">
        <input type="hidden" name="csrf_token" value="{{.CSRF}}">
        <p class="t-small" style="color:rgb(var(--muted))">The existing certificate will be deleted and the new PEM imported in its place. Paste the replacement certificate and private key below.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="t-eyebrow block mb-1">Label</label>
            <input id="replace-name" name="name" placeholder="e.g. wildcard *.example.com" class="r-input w-full">
          </div>
          <div>
            <label class="t-eyebrow block mb-1">Linked route ID (optional)</label>
            <input id="replace-route-id" name="route_id" placeholder="e.g. 42" type="number" min="1" class="r-input w-full">
          </div>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Certificate PEM <span style="color:rgb(var(--danger))">*</span></label>
          <textarea name="cert_pem" required rows="6" placeholder="-----BEGIN CERTIFICATE-----&#10;...&#10;-----END CERTIFICATE-----"
            class="r-input w-full font-mono text-xs resize-y"></textarea>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Private key PEM <span style="color:rgb(var(--danger))">*</span></label>
          <textarea id="replace-key" name="key_pem" required rows="6" placeholder="-----BEGIN EC PRIVATE KEY-----&#10;...&#10;-----END EC PRIVATE KEY-----"
            class="r-input w-full font-mono text-xs resize-y"></textarea>
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Chain PEM (optional)</label>
          <textarea name="chain_pem" rows="4" placeholder="-----BEGIN CERTIFICATE-----&#10;... intermediate CA ...&#10;-----END CERTIFICATE-----"
            class="r-input w-full font-mono text-xs resize-y"></textarea>
        </div>
        <div class="flex items-center justify-end gap-3 pt-1">
          <button type="button" data-action="close-replace-modal" class="r-btn-secondary cursor-pointer">Cancel</button>
          <button type="submit" class="r-btn-primary cursor-pointer">Replace certificate</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Import form -->
  <div class="r-card">
    <h2 class="t-h3 mb-1">Import certificate</h2>
    <p class="t-small mb-5" style="color:rgb(var(--muted))">Paste PEM-encoded blocks. The private key is validated against the certificate and stored encrypted at rest.</p>
    <form method="POST" action="/admin/manual-certs/import" class="space-y-4 max-w-3xl">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="t-eyebrow block mb-1">Label (optional)</label>
          <input name="name" placeholder="e.g. wildcard *.example.com" class="r-input w-full">
        </div>
        <div>
          <label class="t-eyebrow block mb-1">Linked proxy route ID (optional)</label>
          <input name="route_id" placeholder="e.g. 42" type="number" min="1" class="r-input w-full">
          <p class="t-caption mt-1" style="color:rgb(var(--muted))">Link a route to have its edge node serve this cert for that domain (no ACME). Leave blank to store only.</p>
        </div>
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Certificate PEM <span style="color:rgb(var(--danger))">*</span></label>
        <textarea name="cert_pem" required rows="8" placeholder="-----BEGIN CERTIFICATE-----&#10;...&#10;-----END CERTIFICATE-----"
          class="r-input w-full font-mono text-xs resize-y"></textarea>
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Private key PEM <span style="color:rgb(var(--danger))">*</span></label>
        <textarea name="key_pem" required rows="8" placeholder="-----BEGIN EC PRIVATE KEY-----&#10;...&#10;-----END EC PRIVATE KEY-----"
          class="r-input w-full font-mono text-xs resize-y"></textarea>
      </div>
      <div>
        <label class="t-eyebrow block mb-1">Certificate chain PEM (optional - intermediate CAs)</label>
        <textarea name="chain_pem" rows="5" placeholder="-----BEGIN CERTIFICATE-----&#10;... intermediate CA ...&#10;-----END CERTIFICATE-----"
          class="r-input w-full font-mono text-xs resize-y"></textarea>
      </div>
      <button type="submit" class="r-btn-primary cursor-pointer">Import certificate</button>
    </form>
  </div>

</div>
<script nonce="{{$.CSPNonce}}">
// Client-side filter for certs table.
(function() {
  var searchEl = document.getElementById('cert-search');
  var statusEl = document.getElementById('cert-status');
  var counter  = document.getElementById('cert-filter-count');
  var tbody    = document.querySelector('#certs-tbody');
  if (!searchEl || !statusEl || !tbody) return;

  function applyFilter() {
    var q      = searchEl.value.trim().toLowerCase();
    var status = statusEl.value;
    var rows   = tbody.querySelectorAll('tr[data-name]');
    var shown  = 0;
    rows.forEach(function(row) {
      var name = (row.getAttribute('data-name') || '').toLowerCase();
      var cn   = (row.getAttribute('data-cn')   || '').toLowerCase();
      var st   = row.getAttribute('data-status') || '';
      var nameOk   = !q || name.indexOf(q) !== -1 || cn.indexOf(q) !== -1;
      var statusOk = !status || st === status;
      var visible  = nameOk && statusOk;
      row.style.display = visible ? '' : 'none';
      if (visible) shown++;
    });
    if (counter) {
      counter.textContent = (q || status) ? ('Showing ' + shown + ' of ' + rows.length) : '';
    }
  }

  searchEl.addEventListener('input', applyFilter);
  statusEl.addEventListener('change', applyFilter);
})();

// Warn before navigating away with text in key textarea (prevent accidental key loss).
(function() {
  var keyTA = document.querySelector('textarea[name="key_pem"]');
  if (!keyTA) return;
  window.addEventListener('beforeunload', function(e) {
    if (keyTA.value.trim()) {
      e.preventDefault();
      e.returnValue = '';
    }
  });
  // Clear the key field after successful form submission so it is not cached.
  keyTA.closest('form').addEventListener('submit', function() {
    window.removeEventListener('beforeunload', arguments.callee);
  });
})();

function openReplaceModal(id, name, routeId) {
  var modal = document.getElementById('replace-modal');
  var form  = document.getElementById('replace-form');
  form.action = '/admin/manual-certs/' + id + '/replace';
  document.getElementById('replace-name').value = name || '';
  var rid = document.getElementById('replace-route-id');
  rid.value = routeId || '';
  modal.classList.remove('hidden');
  modal.focus();
}

function closeReplaceModal() {
  var modal = document.getElementById('replace-modal');
  modal.classList.add('hidden');
  // Clear sensitive key field when dismissing.
  document.getElementById('replace-key').value = '';
}

// Delegated handler - CSP blocks inline on* attributes, nonce only covers <script>.
document.addEventListener('click', function(e) {
  var el = e.target.closest('[data-action]');
  if (!el) return;
  switch (el.getAttribute('data-action')) {
    case 'open-replace-modal':
      openReplaceModal(el.getAttribute('data-cert-id'), el.getAttribute('data-cert-name'), el.getAttribute('data-route-id'));
      break;
    case 'close-replace-modal':
      closeReplaceModal();
      break;
  }
});

// Close modal on backdrop click.
document.getElementById('replace-modal').addEventListener('click', function(e) {
  if (e.target === this) closeReplaceModal();
});
</script>
{{end}}
