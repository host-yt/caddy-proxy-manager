{{define "nodes"}}
{{if .TunnelCreds}}
<div id="hpg-creds-modal" class="fixed inset-0 z-[60] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
  <div class="r-card ring-2 ring-[rgb(var(--accent)/0.4)] shadow-2xl max-w-xl w-full space-y-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="t-h3" style="color:rgb(var(--accent))">Tunnel credentials - shown once</h3>
        <p class="t-caption mt-1">Copy into <code class="text-xs">hpg-node-agent</code> env. After you close this modal the values are gone (TTL 10 min, single-fetch). If lost, click <strong>Rotate</strong> in the tunnel modal - invalidates all existing customer installs.</p>
      </div>
      <button type="button" data-creds-close class="cursor-pointer text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] text-xl leading-none transition-colors">&times;</button>
    </div>

    <div class="space-y-3">
      <div>
        <label class="t-caption font-medium block mb-1">HPG_NODE_TOKEN</label>
        <div class="flex gap-2">
          <input id="hpg-cred-token" readonly value="{{.TunnelCreds.Token}}" class="r-input flex-1 font-mono text-xs">
          <button type="button" data-copy-target="hpg-cred-token" class="r-btn-secondary text-xs cursor-pointer">Copy</button>
        </div>
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">HPG_WG_PRIVATE_KEY</label>
        <div class="flex gap-2">
          <input id="hpg-cred-priv" readonly value="{{.TunnelCreds.PrivateKey}}" class="r-input flex-1 font-mono text-xs">
          <button type="button" data-copy-target="hpg-cred-priv" class="r-btn-secondary text-xs cursor-pointer">Copy</button>
        </div>
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">HPG_WG_LISTEN_PORT</label>
        <div class="flex gap-2">
          <input id="hpg-cred-port" readonly value="{{.TunnelCreds.ListenPort}}" class="r-input flex-1 font-mono text-xs">
          <button type="button" data-copy-target="hpg-cred-port" class="r-btn-secondary text-xs cursor-pointer">Copy</button>
        </div>
      </div>
    </div>

    <div>
      <label class="t-caption font-medium block mb-1">.env block</label>
      <div class="flex gap-2">
        <textarea id="hpg-cred-all" readonly rows="{{if ne .TunnelCreds.Transport "udp"}}5{{else}}3{{end}}" class="r-input flex-1 font-mono text-xs">HPG_NODE_TOKEN={{.TunnelCreds.Token}}
HPG_WG_PRIVATE_KEY={{.TunnelCreds.PrivateKey}}
HPG_WG_LISTEN_PORT={{.TunnelCreds.ListenPort}}{{if ne .TunnelCreds.Transport "udp"}}
HPG_TUNNEL_TRANSPORT={{.TunnelCreds.Transport}}
HPG_WSTUNNEL_PORT={{.TunnelCreds.WstunnelPort}}{{end}}</textarea>
        <button type="button" data-copy-target="hpg-cred-all" class="r-btn-primary text-xs cursor-pointer self-start">Copy all</button>
      </div>
      {{if ne .TunnelCreds.Transport "udp"}}<p class="t-caption mt-1" style="color:rgb(var(--warning))">WSS node: the two extra vars are required or the agent stays UDP-only.</p>{{end}}
    </div>

    <div class="flex justify-end pt-2 border-t border-[rgb(var(--border))]">
      <button type="button" data-creds-close class="r-btn-primary cursor-pointer">I've copied - close</button>
    </div>
  </div>
</div>
<script nonce="{{.CSPNonce}}">
(function(){
  function copy(id){
    var el = document.getElementById(id);
    if (!el) return;
    el.select(); el.setSelectionRange(0, 99999);
    try { navigator.clipboard.writeText(el.value); }
    catch(e){ document.execCommand && document.execCommand('copy'); }
    window.hpgToast && window.hpgToast('Copied', 'ok');
  }
  document.querySelectorAll('[data-copy-target]').forEach(function(b){
    b.addEventListener('click', function(){ copy(b.dataset.copyTarget); });
  });
  document.querySelectorAll('[data-creds-close]').forEach(function(b){
    b.addEventListener('click', function(){
      var m = document.getElementById('hpg-creds-modal');
      if (m) m.remove();
      // Strip query so refresh doesn't try to re-fetch a stale nonce.
      var u = new URL(window.location.href);
      u.searchParams.delete('show_creds');
      window.history.replaceState({}, '', u.toString());
    });
  });
})();
</script>
{{end}}
{{if .NewJoinToken}}
<div class="mb-6 r-card" style="background:rgb(var(--warning)/0.08);border-color:rgb(var(--warning)/0.3)">
  <h3 class="t-h3 mb-1" style="color:rgb(var(--warning))">Join command - copy now</h3>
  <p class="t-caption mb-3">Valid for 30 minutes. The plaintext token won't be shown again. Run on the new VPS as root:</p>
  <pre class="r-card text-xs font-mono whitespace-pre-wrap break-all p-3" style="background:rgb(var(--bg));border-color:rgb(var(--warning)/0.3)">curl -fsSL {{.AppURL}}/install/node.sh | sudo bash -s -- --manager {{.AppURL}} --token {{.NewJoinToken}}</pre>
  <p class="t-caption mt-2" style="color:rgb(var(--warning))">Token expires at {{.NewJoinTTL}}.</p>
</div>
{{end}}

<div class="mb-4 flex justify-end gap-2">
  <button type="button" id="hpg-add-node-btn" class="r-btn-primary text-xs cursor-pointer">
    <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v10M3 8h10"/></svg>
    Add node manually
  </button>
  <form method="POST" action="/admin/nodes/apply-wg" class="inline">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <button class="r-btn-secondary text-xs cursor-pointer">
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8a6 6 0 1 0 12 0A6 6 0 0 0 2 8z"/><path d="M8 5v3l2 2"/></svg>
      Apply WG config
    </button>
  </form>
</div>

<div class="mb-6 r-card">
  <h2 class="t-h3 mb-1">Auto-join - one-command node</h2>
  <p class="t-caption mb-3">Generates a one-time token + curl command. New node installs WireGuard + Docker + Caddy, joins the mesh, and registers itself. The manager-side WG sidecar picks up the new peer within ~10 s - no manual <code>wg syncconf</code> needed.</p>
  <form method="POST" action="/admin/nodes/join-token" class="grid grid-cols-1 sm:grid-cols-4 gap-3">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <div>
      <label class="t-caption font-medium block mb-1">Node group</label>
      <select name="node_group_id" required class="r-select w-full">
        {{range .Groups}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
      </select>
    </div>
    <div>
      <label class="t-caption font-medium block mb-1">Max routes</label>
      <input name="max_routes" type="number" min="1" value="1000" class="r-input w-full">
    </div>
    <div>
      <label class="t-caption font-medium block mb-1">Priority</label>
      <input name="priority" type="number" min="0" value="100" class="r-input w-full">
    </div>
    <div>
      <label class="t-caption font-medium block mb-1">Name hint (optional)</label>
      <input name="name_hint" placeholder="node-fra-01" class="r-input w-full">
    </div>
    <div class="sm:col-span-4 flex justify-end">
      <button class="r-btn-primary cursor-pointer">
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8h12M10 4l4 4-4 4"/></svg>
        Generate join command
      </button>
    </div>
  </form>
</div>

<!-- Bulk form is hidden; submitted via JS to avoid nested <form> issues. -->
<form method="POST" action="/admin/nodes/bulk" id="nodes-bulk-form" class="hidden">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <input type="hidden" name="action" id="nodes-bulk-action">
  <div id="nodes-bulk-ids"></div>
</form>

<div class="space-y-6">
  <section class="r-card p-0 overflow-hidden">
    <!-- Bulk toolbar: shown only when checkboxes are checked. -->
    <div id="nodes-bulk-bar" class="hidden px-5 py-3 border-b border-[rgb(var(--border))] flex items-center gap-2">
      <span class="t-eyebrow">Bulk action</span>
      <select id="nodes-bulk-select" class="r-select text-xs">
        <option value="">- action -</option>
        <option value="approve">Approve</option>
        <option value="resync">Resync</option>
        <option value="disable">Disable</option>
      </select>
      <button type="button" id="nodes-bulk-apply" class="r-btn-secondary text-xs cursor-pointer">Apply</button>
    </div>
    <div class="overflow-x-auto">
      <table class="r-table">
        <thead>
          <tr>
            <th class="pl-4 pr-2 py-2 w-8"><input type="checkbox" id="nodes-check-all" class="rounded cursor-pointer"></th>
            <th>Name</th>
            <th>Admin URL</th>
            <th>Public</th>
            <th>Group</th>
            <th>Routes</th>
            <th>BW 24h</th>
            <th>Health</th>
            <th>Fingerprint</th>
            <th>Capabilities</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{range .Nodes}}
          <tr>
            <td class="pl-4 pr-2 py-2"><input type="checkbox" name="ids" value="{{.ID}}" class="nodes-row-check rounded cursor-pointer"></td>
            <td class="font-medium">{{.Name}}</td>
            <td><code class="text-xs">{{.APIURL}}</code></td>
            <td>
              {{.PublicHostname}}{{if .PublicIP}} <span class="t-caption">({{.PublicIP}})</span>{{end}}
            </td>
            <td>{{.GroupName}}</td>
            <td class="tabular-nums">{{.CurrentRoutes}} / {{.MaxRoutes}}</td>
            <td class="tabular-nums font-mono text-xs">{{if .Bandwidth24h}}{{formatBytes .Bandwidth24h}}{{else}}-{{end}}</td>
            <td>
              <span class="r-pill {{if eq .Health "healthy"}}r-pill-success{{else if eq .Health "down"}}r-pill-danger{{else}}r-pill-neutral{{end}}">
                <span class="w-1.5 h-1.5 rounded-full {{if eq .Health "healthy"}}bg-[rgb(var(--success))]{{else if eq .Health "down"}}bg-[rgb(var(--danger))]{{else}}bg-[rgb(var(--muted))]{{end}}"></span>
                {{.Health}}
              </span>
              {{if not .Enabled}}<span class="r-pill r-pill-warning ml-1">disabled</span>{{end}}
            </td>
            <td class="font-mono text-xs">
              {{if .Fingerprint}}<code>{{.Fingerprint}}</code>{{else}}-{{end}}
            </td>
            <td>
              <div class="flex flex-wrap gap-1">
                {{if .HasWAF}}<span class="r-pill r-pill-danger">WAF</span>{{end}}
                {{if .HasGeoIP}}<span class="r-pill r-pill-info">GeoIP</span>{{end}}
                {{if .HasRateLimit}}<span class="r-pill r-pill-warning">RL</span>{{end}}
                {{if .HasL4}}<span class="r-pill" style="background:rgb(var(--accent)/0.1);color:rgb(var(--accent))">L4</span>{{end}}
                {{if .CaddyVersion}}<span class="t-caption">{{.CaddyVersion}}</span>{{end}}
                {{if and (not .HasWAF) (not .HasGeoIP) (not .HasRateLimit) (not .HasL4) (not .CaddyVersion)}}-{{end}}
              </div>
            </td>
            <td class="text-right whitespace-nowrap">
              <button type="button" class="hpg-act-toggle cursor-pointer" aria-label="Row actions" aria-haspopup="true" aria-expanded="false" data-hpg-act-btn="node-act-{{.ID}}">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
              </button>
              <div id="node-act-{{.ID}}" class="hpg-act-menu" role="menu">
                {{if not .Approved}}
                <form class="contents" method="POST" action="/admin/nodes/{{.ID}}/approve" data-confirm="Approve {{.Name}}? Verify the fingerprint above matches the bootstrap script output.">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item" role="menuitem">Approve</button>
                </form>
                {{end}}
                <a href="/admin/nodes/{{.ID}}" class="hpg-act-item" role="menuitem">Detail</a>
                <a href="/admin/nodes/{{.ID}}/edit" class="hpg-act-item" role="menuitem">Edit IPs</a>
                <a href="/admin/nodes/{{.ID}}/preflight.json" target="_blank" rel="noopener" class="hpg-act-item" role="menuitem" title="Capability mismatch check">Preflight ↗</a>
                <button type="button" data-tunnel-open="{{.ID}}" data-tunnel-name="{{.Name}}" data-tunnel-host="{{.PublicHostname}}" data-tunnel-transport="{{.Transport}}" data-tunnel-wstport="{{.WstunnelPort}}" class="hpg-act-item" role="menuitem">Tunnel</button>
                <form class="contents" method="POST" action="/admin/nodes/{{.ID}}/resync">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item" role="menuitem">Resync</button>
                </form>
                <form class="contents" method="POST" action="/admin/nodes/{{.ID}}/toggle">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item" role="menuitem">{{if .Enabled}}Disable{{else}}Enable{{end}}</button>
                </form>
                <form class="contents" method="POST" action="/admin/nodes/{{.ID}}/rekey" data-confirm="Rotate WG key for {{.Name}}? New private key will be stashed in settings encrypted; copy it to the node.">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item" role="menuitem">Rekey</button>
                </form>
                <form class="contents" method="POST" action="/admin/nodes/{{.ID}}/drain" data-confirm="Drain {{.Name}}? Routes will be moved to a healthy peer in the same group + node is disabled (maintenance mode). Re-enable later without re-approval.">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item is-danger" role="menuitem">Drain</button>
                </form>
                <form class="contents" method="POST" action="/admin/nodes/{{.ID}}/decommission" data-confirm="Decommission {{.Name}}? Routes will be migrated to a peer in the same group; then the node is removed." data-confirm-type="{{.Name}}">
                  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
                  <button type="submit" class="hpg-act-item is-danger" role="menuitem">Decommission</button>
                </form>
              </div>
            </td>
          </tr>
          {{if .TunnelEnabled}}
          <tr style="background:rgb(var(--surface-2)/0.4)">
            <td colspan="10" class="px-4 pb-2 pt-1">
              <div class="flex flex-wrap items-center gap-2 text-xs">
                <span class="font-medium t-caption">WG tunnel:</span>
                {{if .TunnelMTU.Valid}}
                <span class="r-pill r-pill-info">
                  <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="14" height="8" rx="1.5"/><path d="M5 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1"/></svg>
                  MTU {{.TunnelMTU.Int32}}
                </span>
                {{end}}
                <span class="r-pill r-pill-neutral">
                  <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/></svg>
                  keepalive {{.WGKeepalive}}s
                </span>
                {{if .FwdIPForward.Valid}}
                <span class="r-pill {{if .FwdIPForward.Bool}}r-pill-success{{else}}r-pill-danger{{end}}">
                  <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8h12M10 4l4 4-4 4"/></svg>
                  ip_forward {{if .FwdIPForward.Bool}}on{{else}}OFF{{end}}
                </span>
                {{end}}
                {{if .FwdPolicyDrop.Valid}}{{if .FwdPolicyDrop.Bool}}
                <span class="r-pill r-pill-warning" title="Host firewall has a DROP forward policy - check nft/iptables">
                  <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2l6 11H2L8 2z"/><path d="M8 7v3M8 12h.01"/></svg>
                  fwd policy DROP
                </span>
                {{end}}{{end}}
                {{if .FwdFirewallBackend.Valid}}
                <span class="r-pill r-pill-neutral">
                  <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="2" width="14" height="12" rx="1.5"/><path d="M1 6h14"/></svg>
                  {{.FwdFirewallBackend.String}}
                </span>
                {{end}}
                {{if .WstunnelHealthy.Valid}}
                <span class="r-pill {{if .WstunnelHealthy.Bool}}r-pill-success{{else}}r-pill-danger{{end}}">
                  <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10 6 6l3 3 5-5"/></svg>
                  wstunnel {{if .WstunnelHealthy.Bool}}ok{{else}}down{{end}}
                </span>
                {{end}}
                {{if .FwdLastSetupError.Valid}}{{if .FwdLastSetupError.String}}
                <span class="r-pill r-pill-danger max-w-xs truncate" title="{{.FwdLastSetupError.String}}">
                  <svg class="w-3 h-3 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><path d="M8 5v4M8 11h.01"/></svg>
                  err: {{.FwdLastSetupError.String}}
                </span>
                {{end}}{{end}}
                {{if .FwdReportedAt.Valid}}{{if .FwdReportedAt.String}}
                <span class="t-caption ml-auto">reported {{.FwdReportedAt.String}}</span>
                {{end}}{{end}}
              </div>
            </td>
          </tr>
          {{end}}
          {{else}}
          <tr><td colspan="10" class="px-4 py-8 text-center t-caption">No nodes yet.</td></tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Customer-tunnel modal. Lets the operator enable/disable wg-tun0
       on a node and pick the UDP listen port + public endpoint. -->
  <div id="hpg-node-tunnel-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <form id="hpg-node-tunnel-form" method="POST" action="" class="r-card shadow-2xl max-w-lg w-full space-y-4">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <h3 class="t-h3">Customer tunnel - <span id="hpg-nt-name"></span></h3>
      <p class="t-caption">First save generates server-side keypair + agent token (popup with copy buttons). Subsequent saves only update metadata - use <strong>Rotate keys</strong> below to issue fresh credentials (invalidates existing customer installs).</p>
      <div>
        <label class="t-caption font-medium block mb-1">Listen port (UDP)</label>
        <input name="listen_port" type="number" min="1" max="65535" value="51821" class="r-input w-full font-mono">
        <p class="t-caption mt-1">Pick whatever's free on this node's firewall. Customer's .conf will dial this port.</p>
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">Public endpoint (host:port)</label>
        <input id="hpg-nt-endpoint" name="endpoint" placeholder="leave blank to use node hostname + listen_port" class="r-input w-full font-mono">
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">Tenant /16 subnet</label>
        <input name="subnet" value="100.96.0.0/16" class="r-input w-full font-mono">
        <p class="t-caption mt-1">Default CGNAT range. ~65k tenant IPs per node. Don't overlap with operator mesh or customer LANs.</p>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="t-caption font-medium block mb-1">Transport</label>
          <select id="hpg-nt-transport" name="transport" class="r-select w-full">
            <option value="udp">UDP (default)</option>
            <option value="auto">Auto (UDP, fall back to WSS)</option>
            <option value="wss">WSS (force WebSocket-over-TLS)</option>
          </select>
        </div>
        <div>
          <label class="t-caption font-medium block mb-1">wstunnel port</label>
          <input id="hpg-nt-wstport" name="wstunnel_port" type="number" min="1" max="65535" placeholder="e.g. 51823" class="r-input w-full font-mono">
        </div>
      </div>
      <p class="t-caption -mt-2">Non-UDP requires a free loopback port for the wstunnel server. Set <code>HPG_TUNNEL_TRANSPORT</code> + <code>HPG_WSTUNNEL_PORT</code> on this node's agent to match, then redeploy.</p>
      <div class="flex flex-wrap justify-between gap-2 pt-2 border-t border-[rgb(var(--border))]">
        <div class="flex gap-2">
          <button type="button" id="hpg-nt-disable" class="r-btn-ghost cursor-pointer" style="color:rgb(var(--danger))">Disable tunnel</button>
          <button type="button" id="hpg-nt-rotate" class="r-btn-ghost cursor-pointer" style="color:rgb(var(--warning))">Rotate keys</button>
        </div>
        <div class="flex gap-2">
          <button type="button" data-tunnel-close class="r-btn-ghost cursor-pointer">Cancel</button>
          <button class="r-btn-primary cursor-pointer">Save &amp; enable</button>
        </div>
      </div>
    </form>
  </div>
  <script nonce="{{.CSPNonce}}">
  (function(){
    var m = document.getElementById('hpg-node-tunnel-modal');
    var f = document.getElementById('hpg-node-tunnel-form');
    var name = document.getElementById('hpg-nt-name');
    var ep = document.getElementById('hpg-nt-endpoint');
    var trSel = document.getElementById('hpg-nt-transport');
    var wstIn = document.getElementById('hpg-nt-wstport');
    var disBtn = document.getElementById('hpg-nt-disable');
    var rotBtn = document.getElementById('hpg-nt-rotate');
    function open(id, n, host, transport, wstport){
      f.action = '/admin/nodes/' + id + '/tunnel/enable';
      name.textContent = n;
      ep.placeholder = host ? (host + ':51821 (default)') : 'host:port';
      // Prefill current transport/port so a re-save doesn't flip WSS back to UDP.
      if (trSel) trSel.value = transport || 'udp';
      if (wstIn) wstIn.value = (wstport && wstport !== '0') ? wstport : '';
      disBtn.dataset.nodeId = id;
      if (rotBtn) rotBtn.dataset.nodeId = id;
      m.classList.remove('hidden'); m.classList.add('flex');
    }
    function close(){ m.classList.add('hidden'); m.classList.remove('flex'); }
    document.querySelectorAll('[data-tunnel-open]').forEach(function(b){
      b.addEventListener('click', function(){ open(b.dataset.tunnelOpen, b.dataset.tunnelName, b.dataset.tunnelHost, b.dataset.tunnelTransport, b.dataset.tunnelWstport); });
    });
    document.querySelectorAll('[data-tunnel-close]').forEach(function(b){ b.addEventListener('click', close); });
    m && m.addEventListener('click', function(e){ if (e.target === m) close(); });
    function submitAction(nodeID, path, csrf){
      var df = document.createElement('form');
      df.method = 'POST';
      df.action = '/admin/nodes/' + nodeID + path;
      var t = document.createElement('input'); t.type='hidden'; t.name='csrf_token'; t.value = csrf;
      df.appendChild(t);
      document.body.appendChild(df); df.submit();
    }
    disBtn && disBtn.addEventListener('click', function(){
      if (!disBtn.dataset.nodeId) return;
      var csrf = f.querySelector('input[name=csrf_token]').value;
      window.hpgConfirm && window.hpgConfirm('Disable tunnel on this node? Peers stay in DB; re-enabling later restores everything.').then(function(ok){
        if (ok) submitAction(disBtn.dataset.nodeId, '/tunnel/disable', csrf);
      });
    });
    rotBtn && rotBtn.addEventListener('click', function(){
      if (!rotBtn.dataset.nodeId) return;
      var csrf = f.querySelector('input[name=csrf_token]').value;
      window.hpgConfirm && window.hpgConfirm('Rotate tunnel keys? This invalidates ALL existing customer install URLs on this node - every peer must re-install with the new install.sh. Use only when the original credentials are lost.').then(function(ok){
        if (ok) submitAction(rotBtn.dataset.nodeId, '/tunnel/rotate', csrf);
      });
    });
  })();
  </script>

  <div id="hpg-add-node-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <form method="POST" action="/admin/nodes" class="r-card shadow-2xl max-w-lg w-full space-y-3">
      <input type="hidden" name="csrf_token" value="{{.CSRF}}">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 class="t-h3">Add Caddy node manually</h3>
          <p class="t-caption mt-1">Use Auto-join above instead unless you already provisioned the node by hand. Admin API URL must be reachable from this app (typically over WireGuard).</p>
        </div>
        <button type="button" data-add-node-close class="cursor-pointer text-[rgb(var(--muted))] hover:text-[rgb(var(--text))] text-xl leading-none transition-colors">&times;</button>
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">Name</label>
        <input name="name" required placeholder="node-fra-01" class="r-input w-full">
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">Admin API URL</label>
        <input name="api_url" required placeholder="http://10.66.0.2:2019" class="r-input w-full font-mono">
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="t-caption font-medium block mb-1">Public hostname</label>
          <input name="public_hostname" required placeholder="fra.proxy.example.com" class="r-input w-full">
        </div>
        <div>
          <label class="t-caption font-medium block mb-1">Public IP (optional)</label>
          <input name="public_ip" placeholder="203.0.113.10" class="r-input w-full font-mono">
        </div>
      </div>
      <div>
        <label class="t-caption font-medium block mb-1">Node group</label>
        <select name="node_group_id" required class="r-select w-full">
          {{range .Groups}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
        </select>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="t-caption font-medium block mb-1">Max routes</label>
          <input name="max_routes" type="number" min="1" value="1000" required class="r-input w-full">
        </div>
        <div>
          <label class="t-caption font-medium block mb-1">Priority</label>
          <input name="priority" type="number" min="0" value="100" required class="r-input w-full">
        </div>
      </div>
      <div class="flex justify-end gap-2 pt-2 border-t border-[rgb(var(--border))]">
        <button type="button" data-add-node-close class="r-btn-ghost cursor-pointer">Cancel</button>
        <button class="r-btn-primary cursor-pointer">Add node</button>
      </div>
    </form>
  </div>
  <script nonce="{{.CSPNonce}}">
  (function(){
    /* Bulk action */
    var bar = document.getElementById('nodes-bulk-bar');
    var allChk = document.getElementById('nodes-check-all');
    function rowChecks(){ return Array.from(document.querySelectorAll('.nodes-row-check')); }
    function updateBar(){
      var n = rowChecks().filter(function(c){ return c.checked; }).length;
      if (bar) bar.classList.toggle('hidden', n === 0);
    }
    if (allChk) {
      allChk.addEventListener('change', function(){
        rowChecks().forEach(function(c){ c.checked = allChk.checked; });
        updateBar();
      });
    }
    rowChecks().forEach(function(c){
      c.addEventListener('change', function(){
        if (!c.checked && allChk) allChk.checked = false;
        updateBar();
      });
    });
    var applyBtn = document.getElementById('nodes-bulk-apply');
    if (applyBtn) {
      applyBtn.addEventListener('click', function(){
        var sel = document.getElementById('nodes-bulk-select');
        var action = sel ? sel.value : '';
        if (!action) { window.hpgToast && window.hpgToast('Pick an action.', 'warn'); return; }
        var ids = rowChecks().filter(function(c){ return c.checked; }).map(function(c){ return c.value; });
        if (ids.length === 0) { window.hpgToast && window.hpgToast('Select at least one node.', 'warn'); return; }
        var msg = action + ' ' + ids.length + ' node(s)?';
        var go = function(){
          document.getElementById('nodes-bulk-action').value = action;
          var box = document.getElementById('nodes-bulk-ids');
          box.innerHTML = '';
          ids.forEach(function(v){
            var i = document.createElement('input');
            i.type = 'hidden'; i.name = 'ids'; i.value = v;
            box.appendChild(i);
          });
          document.getElementById('nodes-bulk-form').submit();
        };
        if (window.hpgConfirm) {
          window.hpgConfirm(msg).then(function(ok){ if (ok) go(); });
        } else if (confirm(msg)) {
          go();
        }
      });
    }
  })();
  </script>
  <script nonce="{{.CSPNonce}}">
  (function(){
    var m = document.getElementById('hpg-add-node-modal');
    var open = document.getElementById('hpg-add-node-btn');
    if (!m || !open) return;
    open.addEventListener('click', function(){ m.classList.remove('hidden'); m.classList.add('flex'); });
    document.querySelectorAll('[data-add-node-close]').forEach(function(b){
      b.addEventListener('click', function(){ m.classList.add('hidden'); m.classList.remove('flex'); });
    });
    m.addEventListener('click', function(e){ if (e.target === m) { m.classList.add('hidden'); m.classList.remove('flex'); } });
  })();
  </script>
</div>
{{end}}
