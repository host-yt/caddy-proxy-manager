{{define "2fa_required"}}
<div class="max-w-lg mx-auto mt-16 hpg-card text-center space-y-5">
  <div class="hpg-chip bg-indigo-50 text-indigo-600 mx-auto text-xl">🔐</div>
  <p class="text-base font-medium text-slate-600 dark:text-slate-300">Protect this admin account with a second factor.</p>
  <p class="text-sm text-slate-600 dark:text-slate-400">
    This panel requires all admin accounts to protect sign-in with a second
    factor. Set one up now to continue.
  </p>
  <div class="flex flex-col gap-3">
    <a href="/admin/2fa{{if .Next}}?next={{.Next}}{{end}}"
       class="inline-flex justify-center items-center gap-2 px-4 py-2.5 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
      Set up 2FA now
    </a>
    {{if .Next}}<p class="text-xs text-slate-400">You will be taken back to your original page after setup.</p>{{end}}
  </div>
  <form method="POST" action="/auth/logout" class="mt-2">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <button type="submit" class="text-xs text-slate-400 hover:text-slate-600 underline">Sign out</button>
  </form>
</div>
{{end}}
