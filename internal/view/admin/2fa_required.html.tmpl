{{define "2fa_required"}}
<div class="max-w-lg mx-auto mt-16 r-card text-center space-y-5">
  <div class="icon-chip mx-auto" style="width:3rem;height:3rem;background:rgb(var(--accent-weak));color:rgb(var(--accent))">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
  </div>
  <p class="t-body font-medium" style="color:rgb(var(--text))">Protect this admin account with a second factor.</p>
  <p class="t-small" style="color:rgb(var(--muted))">
    This panel requires all admin accounts to protect sign-in with a second
    factor. Set one up now to continue.
  </p>
  <div class="flex flex-col gap-3">
    <a href="/admin/2fa{{if .Next}}?next={{.Next}}{{end}}"
       class="r-btn-primary inline-flex justify-center items-center gap-2">
      Set up 2FA now
    </a>
    {{if .Next}}<p class="t-caption" style="color:rgb(var(--muted))">You will be taken back to your original page after setup.</p>{{end}}
  </div>
  <form method="POST" action="/auth/logout" class="mt-2">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <button type="submit" class="t-caption cursor-pointer hover:underline" style="color:rgb(var(--muted))">Sign out</button>
  </form>
</div>
{{end}}
