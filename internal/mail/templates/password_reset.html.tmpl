<!doctype html>
<html><body style="font-family:-apple-system,Segoe UI,Roboto,sans-serif;color:#1f2937;padding:24px;max-width:560px;margin:auto">
<h2 style="margin:0 0 16px 0">Reset your password</h2>
<p>Hi {{.Name}},</p>
<p>Someone (hopefully you) requested a password reset for {{.AppName}}.</p>
<p style="margin:24px 0">
  <a href="{{.ResetURL}}" style="background:#4f46e5;color:#fff;padding:10px 16px;border-radius:6px;text-decoration:none;display:inline-block">Reset password</a>
</p>
<p style="color:#6b7280;font-size:13px">Or copy this link:<br><code>{{.ResetURL}}</code></p>
<p style="color:#6b7280;font-size:13px">This link expires in {{.ExpiresMin}} minutes. If you didn't request a reset, ignore this email.</p>
</body></html>
