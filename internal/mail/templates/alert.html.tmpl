<!doctype html>
<html><body style="font-family:-apple-system,Segoe UI,Roboto,sans-serif;color:#1f2937;padding:24px;max-width:560px;margin:auto">
<h2 style="margin:0 0 16px 0;color:#b45309">{{.Alert.Title}}</h2>
<p style="margin:0 0 8px 0"><strong>Severity:</strong> {{.Alert.Severity}}</p>
<p style="background:#fffbeb;border:1px solid #fde68a;padding:12px;border-radius:6px;color:#78350f;font-size:13px">{{.Alert.Detail}}</p>
<p style="color:#6b7280;font-size:13px;margin-top:16px">Rule: <code>{{.Alert.RuleID}}</code></p>
</body></html>
