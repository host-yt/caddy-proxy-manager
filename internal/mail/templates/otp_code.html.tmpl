<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="color-scheme" content="light dark">
<meta name="supported-color-schemes" content="light dark">
<title>{{.AppName}} verification code</title>
<style>
  :root { color-scheme: light dark; supported-color-schemes: light dark; }
  body { margin:0; padding:0; background:#f5f5f7; }
  .wrap { width:100%; background:#f5f5f7; padding:32px 16px; }
  .card { max-width:560px; margin:0 auto; background:#ffffff; border:1px solid #e5e7eb; border-radius:14px; overflow:hidden; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif; color:#0f172a; }
  .header { padding:28px 32px 8px 32px; text-align:left; }
  .logo { height:32px; width:auto; display:inline-block; }
  .body { padding:8px 32px 24px 32px; }
  h1 { font-size:20px; font-weight:600; margin:16px 0 8px 0; color:#0f172a; letter-spacing:-0.01em; }
  p { font-size:14px; line-height:1.55; margin:8px 0; color:#334155; }
  .code-box { background:#0f172a; color:#ffffff; font-family:ui-monospace,"SF Mono",Menlo,Consolas,monospace; font-size:30px; letter-spacing:0.4em; text-align:center; padding:22px 0; border-radius:10px; margin:20px 0; font-weight:600; }
  .meta { font-size:12px; color:#64748b; margin-top:18px; }
  .divider { height:1px; background:#e5e7eb; margin:24px 0 0 0; }
  .footer { padding:18px 32px 24px 32px; font-size:12px; color:#94a3b8; text-align:center; }
  .footer a { color:#94a3b8; text-decoration:none; }

  @media (prefers-color-scheme: dark) {
    body, .wrap { background:#0b0b0d !important; }
    .card { background:#141418 !important; border-color:#27272a !important; color:#f4f4f5 !important; }
    h1 { color:#fafafa !important; }
    p { color:#d4d4d8 !important; }
    .code-box { background:#fafafa !important; color:#0b0b0d !important; }
    .meta, .footer, .footer a { color:#71717a !important; }
    .divider { background:#27272a !important; }
    .logo { filter: invert(1) brightness(1.2); }
  }
  [data-ogsc] body, [data-ogsc] .wrap { background:#0b0b0d !important; }
  [data-ogsc] .card { background:#141418 !important; border-color:#27272a !important; color:#f4f4f5 !important; }
  [data-ogsc] h1 { color:#fafafa !important; }
  [data-ogsc] p { color:#d4d4d8 !important; }
  [data-ogsc] .code-box { background:#fafafa !important; color:#0b0b0d !important; }
  [data-ogsc] .meta, [data-ogsc] .footer, [data-ogsc] .footer a { color:#71717a !important; }
  [data-ogsc] .logo { filter: invert(1) brightness(1.2); }
</style>
</head>
<body>
  <div class="wrap">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
      <tr><td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="card" width="560" style="max-width:560px">
          <tr><td class="header">
            <img src="{{.LogoURL}}" alt="{{.AppName}}" class="logo" height="32">
          </td></tr>
          <tr><td class="body">
            <h1>{{.Purpose}}</h1>
            <p>{{if .Name}}Hi {{.Name}},{{else}}Hi,{{end}}</p>
            <p>{{.Intro}} Enter the code below to continue. It expires in <strong>{{.ExpiresMin}} minutes</strong>.</p>

            <div class="code-box">{{.Code}}</div>

            <p class="meta">If you didn't request this, you can ignore this email - your account is safe.</p>

            <div class="divider"></div>
            <p class="meta">Request from <strong>{{.IP}}</strong> · {{.UserAgent}}</p>
          </td></tr>
          <tr><td class="footer">
            Sent by {{.AppName}}{{if .PanelURL}} · <a href="{{.PanelURL}}">{{.PanelURL}}</a>{{end}}
          </td></tr>
        </table>
      </td></tr>
    </table>
  </div>
</body>
</html>
