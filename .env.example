# =========================================================================
# Hostyt Proxy Gateway - environment template
# Copy to .env and fill values. Never commit .env.
# =========================================================================

# --- App ----------------------------------------------------------------
APP_ENV=production              # production | development
APP_URL=https://panel.example.com
APP_BIND=0.0.0.0:8080
APP_SECRET=                     # generate: openssl rand -hex 32 (REQUIRED)
APP_TRUSTED_PROXIES=            # comma-separated CIDR list, optional
LOG_LEVEL=info                  # debug | info | warn | error

# --- Install ------------------------------------------------------------
# When INSTALLED=0 the /install wizard is reachable. Wizard flips this to 1.
INSTALLED=0

# --- Database -----------------------------------------------------------
# DB_DRIVER=mysql  -> use MariaDB/MySQL (default, requires mariadb service)
# DB_DRIVER=sqlite3 -> use SQLite (embedded, no separate service needed)
DB_DRIVER=mysql

# --- Database (MariaDB / MySQL) -----------------------------------------
# Used when DB_DRIVER=mysql. Can be local container or external managed DB.
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=hostyt_proxy
DB_USER=hostyt
DB_PASSWORD=change_me_strong
DB_TLS=false                    # set true for managed DBs requiring TLS
# DSN override (optional, takes precedence over fields above):
# DB_DSN=user:pass@tcp(host:3306)/dbname?parseTime=true&loc=UTC

# Local-only - root password for the bundled MariaDB container.
# Ignore when using external DB.
MARIADB_ROOT_PASSWORD=change_me_root_strong

# --- Database (SQLite) --------------------------------------------------
# Used when DB_DRIVER=sqlite3. File path must be writable by the app container.
DB_SQLITE_PATH=./data/hpg.db

# --- Redis --------------------------------------------------------------
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Caddy (first node, also editable from admin UI) --------------------
CADDY_ADMIN_URL=http://caddy:2019
CADDY_PUBLIC_HOSTNAME=proxy.example.com
CADDY_PUBLIC_IP=
CADDY_ACME_EMAIL=ops@example.com
CADDY_ACME_STAGING=false        # true for Let's Encrypt staging

# --- SMTP (defaults; admin UI can override) -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls             # tls | ssl | none
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Hostyt Proxy

# --- Security -----------------------------------------------------------
SESSION_COOKIE_NAME=hpg_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=hpg_csrf
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_ASK_PER_MIN=120

# --- CAPTCHA (optional) -------------------------------------------------
CAPTCHA_PROVIDER=               # turnstile | recaptcha | (empty = off)
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET=

# --- OIDC / SSO (configurable in admin UI; env is bootstrap default) ----
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=

# --- Future Hostyt/FOSSBilling jump-login -------------------------------
SSO_JUMP_SHARED_SECRET=

# --- External HTTPS upstream routes (open-relay allowlist) --------------
# CSV of public FQDNs an "External HTTPS upstream" host may proxy to.
# Empty = the feature is disabled (no external route can be created).
EXTERNAL_UPSTREAM_ALLOWLIST=    # e.g. adm.tools

# --- Caddy module gates (flip ON only after ALL nodes run the custom -----
# --- image; turning on while any node is stock rejects /load = outage) ---
# weighted_round_robin LB policy (round_robin/least_conn/ip_hash are stock).
WEIGHTED_LB_AVAILABLE=0
# Per-route rate_limit handler (xcaddy --with github.com/mholt/caddy-ratelimit).
RATE_LIMIT_AVAILABLE=0
# Per-route coraza WAF (xcaddy --with github.com/corazawaf/coraza-caddy/v2).
WAF_MODULE_AVAILABLE=0
# Wildcard DNS-01 automation (xcaddy --with github.com/caddy-dns/<provider>).
DNS01_AVAILABLE=0

# --- Admin 2FA enforcement ----------------------------------------------
# Block admin/super_admin without any 2FA from /admin/* until they enroll.
# Hot-toggle at runtime via settings row security.require_admin_2fa.
REQUIRE_ADMIN_2FA=0
# Break-glass: hours an existing admin keeps access after enforcement first
# applies, so flipping it on never instantly locks anyone out. 0 = immediate.
REQUIRE_ADMIN_2FA_GRACE_HOURS=0

# --- Audit SIEM forwarder (optional) ------------------------------------
# POST each audit event as JSON to this URL. Empty = disabled. The forwarder
# blocks RFC1918/loopback (SSRF guard). Best-effort, fire-and-forget.
AUDIT_SIEM_WEBHOOK=
