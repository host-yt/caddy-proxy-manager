# =========================================================================
# Caddy base config - bootstrap only.
# After install, the app drives configuration via the Admin API (:2019).
# This file exists so the container starts cleanly on first boot.
# =========================================================================

{
	# Admin API listens INSIDE the compose network only.
	# Never expose :2019 to the public internet.
	admin 0.0.0.0:2019

	# ACME contact. Fallback when env unset so Caddy starts cleanly on
	# bootstrap (app pushes the real email later via Admin API).
	email {$ACME_EMAIL:bootstrap@invalid.local}

	# On-Demand TLS: ask app whether a domain is allowed before issuing.
	# Reference: https://caddyserver.com/docs/automatic-https#on-demand-tls
	on_demand_tls {
		ask {$ASK_ENDPOINT_URL:http://app:8080/internal/ask}
		# Optional global rate guard - adjust under load:
		# interval 2m
		# burst 5
	}

	# Storage: filesystem by default. Switch to Redis module for HA later.
	# storage redis { host redis:6379  password "{$REDIS_PASSWORD}" }

	# Use staging while testing to avoid burning Let's Encrypt rate limit.
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Default catch-all. Real routes get pushed in by the app via Admin API.
# Until then we serve a maintenance page.
:80 {
	respond "Hostyt Proxy Gateway - no routes configured yet" 503
}
